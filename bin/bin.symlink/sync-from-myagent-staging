  echo -e "${White}Doing a ${BGreen}DRY RUN${White} of ${Cyan}production → ${Yellow}local${NC}"
  echo -e ""
  rsync --dry-run --checksum --exclude="backup*" --exclude="tmp/*" --exclude=".git" --exclude="uploads*" --progress --human-readable --compress --update --archive --update --stats eboney@hedgewig:/var/www/staging.myagent.site/ /var/www/myagent.site
