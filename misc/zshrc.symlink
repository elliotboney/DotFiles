fi

if [ "$DEBUG" = true ]; then
  if [[ "${USE_EPOCHREALTIME}" = true ]]; then
    TOTAL=$EPOCHREALTIME
    TOTAL_MS=$(printf "%.0f" $(( (TOTAL - N_ORIG) * 1000 )))
  else
    TOTAL=$($DATECOMMAND +%N)
    TOTAL_MS=$(((${TOTAL}-${N_ORIG})/1000000))
  fi
  echo -e "------------------------------------------------------------------------------------"
  echo -e "\x1b[1;34m Total Time: \x1b[1;32m[${TOTAL_MS}ms]\x1b[m                       "
  echo -e "------------------------------------------------------------------------------------"
fi
