3" lineend="309" name="(anonymous 13)" signature="(anonymous 13)(i, frame)"><variable ilk="argument" line="303" name="i" /><variable ilk="argument" line="303" name="frame" /></scope></scope><scope attributes="__local__ private" ilk="function" line="314" lineend="325" name="userIsActive" signature="userIsActive()"><scope attributes="__local__ private" ilk="function" line="317" lineend="322" name="(anonymous 14)" signature="(anonymous 14)(i, frame)"><variable ilk="argument" line="317" name="i" /><variable ilk="argument" line="317" name="frame" /></scope></scope><variable attributes="__local__ private" citdl="isUserActive" line="333" name="lastActive" /><scope attributes="__local__ private" ilk="function" line="337" lineend="337" name="(anonymous 15)" signature="(anonymous 15)()" /><scope attributes="__local__ private" ilk="function" line="339" lineend="344" name="(anonymous 16)" signature="(anonymous 16)(i, frame)"><variable ilk="argument" line="339" name="i" /><variable ilk="argument" line="339" name="frame" /><scope attributes="__local__ private" ilk="function" line="343" lineend="343" name="(anonymous 17)" signature="(anonymous 17)()" /></scope><scope attributes="__local__ private" ilk="function" line="351" lineend="351" name="(anonymous 18)" signature="(anonymous 18)()" /><scope attributes="__local__ private" ilk="function" line="352" lineend="357" name="(anonymous 19)" signature="(anonymous 19)()" /></scope><scope doc="Returns a boolean that's indicative of whether or not there is a connection error" ilk="function" line="59" lineend="83" name="hasConnectionError" returns="Boolean" signature="hasConnectionError()"><variable citdl="(anonymous 1)" name="this" /></scope><variable citdl="Boolean" line="140" name="hasConnectionError" /><scope ilk="function" line="359" lineend="361" name="hasFocus" returns="hasFocus" signature="hasFocus()"><variable citdl="(anonymous 1)" name="this" /></scope><scope doc="Get/Set the interval&#10;&#10;When setting to 'fast', the interval is 5 sec. for the next 30 ticks (for 2 min and 30 sec).&#10;If the window doesn't have focus, the interval slows down to 2 min." ilk="function" line="373" lineend="416" name="interval" returns="Number" signature="interval(speed, ticks)"><variable citdl="(anonymous 1)" name="this" /><variable ilk="argument" line="373" name="speed" /><variable citdl="ticks" ilk="argument" line="373" name="ticks" /><variable attributes="__local__ private" citdl="seconds" line="374" name="reset" /><variable attributes="__local__ private" citdl="Number" line="374" name="seconds" /><variable citdl="Number" line="386" name="countdown" /><variable citdl="Number" line="405" name="tempInterval" /></scope><variable citdl="Number" line="390" name="interval" /><scope doc="Enqueue data to send with the next XHR&#10;&#10;As the data is sent later, this function doesn't return the XHR response.&#10;To see the response, use the custom jQuery event 'heartbeat-tick' on the document, example:&#10;$(document).on( 'heartbeat-tick.myname', function( event, data, textStatus, jqXHR ) {&#10;// code&#10;});&#10;If the same 'handle' is used more than once, the data is not overwritten when the third argument is 'true'.&#10;Use wp.heartbeat.isQueued('handle') to see if any data is already queued for that handle.&#10;&#10;$param string handle Unique handle for the data. The handle is used in PHP to receive the data.&#10;$param mixed data The data to send.&#10;$param bool dont_overwrite Whether to overwrite existing data in the queue.&#10;$return bool Whether the data was queued or not." ilk="function" line="434" lineend="443" name="enqueue" returns="Boolean" signature="enqueue(handle, data, dont_overwrite)"><variable citdl="(anonymous 1)" name="this" /><variable ilk="argument" line="434" name="handle" /><variable ilk="argument" line="434" name="data" /><variable ilk="argument" line="434" name="dont_overwrite" /></scope><scope doc="Check if data with a particular handle is queued&#10;&#10;$param string handle The handle for the data&#10;$return bool Whether some data is queued with this handle" ilk="function" line="451" lineend="454" name="isQueued" signature="isQueued(handle)"><variable citdl="(anonymous 1)" name="this" /><variable ilk="argument" line="451" name="handle" /></scope><scope doc="Remove data with a particular handle from the queue&#10;&#10;$param string handle The handle for the data&#10;$return void" ilk="function" line="462" lineend="465" name="dequeue" signature="dequeue(handle)"><variable citdl="(anonymous 1)" name="this" /><variable ilk="argument" line="462" name="handle" /></scope><scope doc="Get data that was enqueued with a particular handle&#10;&#10;$param string handle The handle for the data&#10;$return mixed The data or undefined" ilk="function" line="473" lineend="476" name="getQueuedItem" signature="getQueuedItem(handle)"><variable citdl="(anonymous 1)" name="this" /><variable ilk="argument" line="473" name="handle" /></scope></scope><variable citdl="settings.ajaxurl" line="63" name="url" /><variable citdl="settings.interval" line="67" name="interval" /><variable citdl="$.extend()" line="72" name="settings" /><variable citdl="screenId" line="78" name="screenId" /><variable line="111" name="error" /><variable citdl="Number" line="144" name="errorcount" /><variable citdl="$.extend()" line="153" name="data" /><variable citdl="Boolean" line="153" name="empty" /><variable line="153" name="i" /><variable line="154" name="nonce" /><variable citdl="Boolean" line="173" name="connecting" /><variable citdl="interval" line="228" name="t" /><variable citdl="Number" line="258" name="frameBlurTimeout" /><variable citdl="Number" line="258" name="winBlurTimeout" /><variable citdl="Boolean" line="260" name="hasFocus" /><variable citdl="time()" line="270" name="isUserActive" /><variable citdl="Boolean" line="315" name="userActiveEvents" /><variable citdl="ticks" line="382" name="countdown" /><variable citdl="seconds" line="402" name="tempInterval" /><variable citdl