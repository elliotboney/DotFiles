<scope ilk="blob" lang="JavaScript" name="issue-143.js" src="/private/var/www/kw/content/themes/goodlife/node_modules/grunt-contrib-uglify/node_modules/uglify-js/test/compress/issue-143.js"><variable citdl="Object" doc="There was an incorrect sort behaviour documented in issue #143:&#10;(x = f(&#8230;)) &lt;= x &#8594; x &gt;= (x = f(&#8230;))&#10;&#10;For example, let the equation be:&#10;(a = parseInt('100')) &lt;= a&#10;&#10;If a was an integer and has the value of 99,&#10;(a = parseInt('100')) &lt;= a &#8594; 100 &lt;= 100 &#8594; true&#10;&#10;When transformed incorrectly:&#10;a &gt;= (a = parseInt('100')) &#8594; 99 &gt;= 100 &#8594; false" line="15" lineend="22" name="tranformation_sort_order_equal"><variable citdl="Object" line="16" lineend="18" name="options"><variable citdl="Boolean" line="17" name="comparisons" /></variable><variable citdl="Object" line="20" lineend="20" name="input" /></variable><variable citdl="parseInt()" line="21" name="a" /><variable line="21" name="parseInt()" /><variable citdl="Object" line="24" lineend="31" name="tranformation_sort_order_unequal"><variable citdl="Object" line="25" lineend="27" name="options"><variable citdl="Boolean" line="26" name="comparisons" /></variable><variable citdl="Object" line="29" lineend="29" name="input" /></variable><variable citdl="Object" line="33" lineend="40" name="tranformation_sort_order_lesser_or_equal"><variable citdl="Object" line="34" lineend="36" name="options"><variable citdl="Boolean" line="35" name="comparisons" /></variable><variable citdl="Object" line="38" lineend="38" name="input" /></variable><variable citdl="Object" line="41" lineend="48" name="tranformation_sort_order_greater_or_equal"><variable citdl="Object" line="42" lineend="44" name="options"><variable citdl="Boolean" line="43" name="comparisons" /></variable><variable citdl="Object" line="46" lineend="46" name="input" /></variable></scope>