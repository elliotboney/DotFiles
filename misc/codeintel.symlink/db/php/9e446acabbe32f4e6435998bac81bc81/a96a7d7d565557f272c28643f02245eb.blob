osed in an &amp;lt;a&gt; tag" ilk="function" line="784" lineend="812" name="returnSee" returns="string" signature="returnSee(&amp; $element, $eltext = false, $with_a = true)"><variable ilk="argument" line="784" name="element" /><variable default="false" ilk="argument" line="784" name="eltext" /><variable default="true" ilk="argument" line="784" name="with_a" /></scope><scope ilk="function" line="814" lineend="865" name="getId" returns="string" signature="getId($element, $fullpath = true)"><variable ilk="argument" line="814" name="element" /><variable default="true" ilk="argument" line="814" name="fullpath" /><variable citdl="string" line="830" name="b" /><variable citdl="element" line="819" name="elp" /><variable citdl="string" line="858" name="d" /><variable citdl="string" line="825" name="c" /></scope><scope doc="Convert README/INSTALL/CHANGELOG file contents to output format&#10;@param README|INSTALL|CHANGELOG&#10;@param string contents of the file" ilk="function" line="872" lineend="876" name="Convert_RIC" signature="Convert_RIC($name, $contents)"><variable ilk="argument" line="872" name="name" /><variable ilk="argument" line="872" name="contents" /></scope><scope ilk="function" line="878" lineend="891" name="writeRIC" signature="writeRIC()"><variable attributes="__not_yet_defined__" line="882" name="contents" /><variable citdl="this.newSmarty()" line="884" name="template" /><variable line="882" name="name" /></scope><scope ilk="function" line="893" lineend="920" name="ConvertTodoList" signature="ConvertTodoList()"><variable line="896" name="package" /><variable citdl="this.newSmarty()" line="915" name="templ" /><variable attributes="__not_yet_defined__" line="896" name="alltodos" /><variable attributes="__not_yet_defined__" line="898" name="todos" /><variable attributes="__not_yet_defined__" line="907" name="todo" /><variable citdl="array()" line="900" name="converted" /><variable citdl="array()" line="895" name="todolist" /></scope><scope doc="Create errors.ht