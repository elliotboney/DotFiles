r&#10;&#10;Each graph node can contain multiple 'metadata' entries, each stored under a different key, as in an &#10;associative array or in a dictionary. This method stores data under the given key. If the key already exists,&#10;previously stored data is discarded.&#10;&#10;@param    string  Key&#10;@param    mixed   Data &#10;@access	public" ilk="function" line="216" lineend="218" name="setMetadata" signature="setMetadata($key, $data)"><variable ilk="argument" line="216" name="key" /><variable ilk="argument" line="216" name="data" /></scope><scope doc="@access private" ilk="function" line="223" lineend="225" name="_connectTo" signature="_connectTo(&amp; $destinationNode)"><variable ilk="argument" line="223" name="destinationNode" /></scope><scope doc="Connect this node to another one.&#10;&#10;If the graph is not directed, the reverse arc, connecting $destinationNode to $this is also created.&#10;&#10;@param    Structures_Graph_Node Node to connect to&#10;@access	public" ilk="function" line="238" lineend="250" name="connectTo" signature="connectTo(&amp; $destinationNode)"><variable ilk="argument" line="238" name="destinationNode" /></scope><scope doc="Return nodes connected to this one.&#10;&#10;@return   array   Array of nodes&#10;@access	public" ilk="function" line="261" lineend="263" name="getNeighbours" returns="array" signature="array getNeighbours()" /><scope doc="Test wether this node has an arc to the target node&#10;&#10;@return	boolean   True if the two nodes are connected&#10;@access	public" ilk="function" line="274" lineend="298" name="connectsTo" returns="boolean" signature="boolean connectsTo(&amp; $target)"><variable ilk="argument" line="274" name="target" /><variable attributes="__not_yet_defined__" line="281" name="key" /><variable citdl="array_keys()" line="280" name="arcKeys" /><variable citdl="target" line="279" name="copy" /><variable citdl="this._arcs" line="286" name="arc" /></scope><scope doc="Calculate the in degree of the node.&#10;&#10;