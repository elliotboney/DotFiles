<scope ilk="blob" lang="PHP" name="wpv-filter-date-embedded.php" src="/private/var/www/wordpress.staging/plugins/types/embedded/common/wpv-filter-date-embedded.php"><scope doc="Helper function for parsing dates.&#10;&#10;Possible inputs:&#10;&#10;NOW()&#10;FUTURE(1000)  (1000 seconds)&#10;PAST(1000)&#10;TODAY()    (time at 00:00 today)&#10;FUTURE_DAY(1)&#10;PAST_DAY(1)&#10;THIS_MONTH()   (time at 00:00 on first day of this month)&#10;FUTURE_MONTH(1)&#10;PAST_MONTH(1)&#10;THIS_YEAR()   (time at 00:00 on first day of this year)&#10;FUTURE_YEAR(1)&#10;PAST_YEAR(1)&#10;DATE(dd,mm,yyyy)    eg. DATE(03,04,2012)&#10;&#10;@param int timestamp $date_format" ilk="function" line="24" lineend="56" name="wpv_filter_parse_date" returns="date_format" signature="wpv_filter_parse_date($date_format)"><variable ilk="argument" line="24" name="date_format" /><variable citdl="matches" line="31" name="date_value" /><variable citdl="matches" line="30" name="date_func" /><variable citdl="mktime()" line="32" name="resulting_date" /><variable line="29" name="i" /><variable citdl="preg_match_all()" line="25" name="occurences" /><variable citdl="explode()" line="47" name="date_parts" /></scope></scope>