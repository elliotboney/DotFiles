nodeKeys" /><variable citdl="array()" line="97" name="leafNodes" /><variable citdl="array()" line="87" name="refGenerator" /><variable citdl="leafNodes" line="106" name="visited" /></scope><scope doc="sort returns the graph's nodes, sorted by topological order. &#10;&#10;The result is an array with &#10;as many entries as topological levels. Each entry in this array is an array of nodes within&#10;the given topological level.&#10;&#10;@return	array	 The graph's nodes, sorted by topological order.&#10;@access	public" ilk="function" line="131" lineend="149" name="sort" returns="array" signature="array sort(&amp; $graph)"><variable ilk="argument" line="131" name="graph" /><variable citdl="array()" line="137" name="result" /><variable attributes="__not_yet_defined__" line="142" name="key" /><variable citdl="array_keys()" line="141" name="nodeKeys" /><variable citdl="graph.getNodes()" line="140" name="nodes" /></scope></scope></scope>