<scope ilk="blob" lang="PHP" name="StreamOutput.php" src="/usr/local/pear/share/pear/PhpDocumentor/vendor/symfony/console/Symfony/Component/Console/Output/StreamOutput.php"><scope doc="This file is part of the Symfony package.&#10;&#10;(c) Fabien Potencier &lt;fabien@symfony.com&gt;&#10;&#10;For the full copyright and license information, please view the LICENSE&#10;file that was distributed with this source code." ilk="namespace" line="12" name="Symfony\Component\Console\Output"><import line="14" module="Symfony\Component\Console\Formatter" symbol="OutputFormatterInterface" /><scope classrefs="Output" doc="StreamOutput writes the output to a given stream.&#10;&#10;Usage:&#10;&#10;$output = new StreamOutput(fopen('php://stdout', 'w'));&#10;&#10;As `StreamOutput` can use any stream, you can also use a file:&#10;&#10;$output = new StreamOutput(fopen('/path/to/output.log', 'a', false));&#10;&#10;@author Fabien Potencier &lt;fabien@symfony.com&gt;&#10;&#10;@api" ilk="class" line="31" lineend="107" name="StreamOutput"><variable attributes="private" citdl="stream" line="33" name="stream" /><scope attributes="public __ctor__" doc="Constructor.&#10;&#10;@param mixed                         $stream    A stream resource&#10;@param integer                       $verbosity The verbosity level (one of the VERBOSITY constants in OutputInterface)&#10;@param Boolean|null                  $decorated Whether to decorate messages (null for auto-guessing)&#10;@param OutputFormatterInterface|null $formatter Output formatter instance (null to use default OutputFormatter)&#10;&#10;@throws \InvalidArgumentException When first argument is not a real stream&#10;&#10;@api" ilk="function" line="47" lineend="60" name="__construct" signature="__construct(mixed $stream, integer $verbosity = self::VERBOSITY_NORMAL, $decorated = null, OutputFormatterInterface $formatter=null)"><variable citdl="mixed" ilk="argument" line="47" name="stream" /><variable citdl="integer" default="self::VERBOSITY_NORMAL" ilk="argument" line="47" name="verbosity" /><variable default="null" ilk="argument" line="47" name="decorated" /><variable citdl="OutputFormatterInterface" ilk="argument" line="47" name="formatter" /></scope><scope attributes="public" doc="Gets the stream attached to this StreamOutput instance.&#10;&#10;@return resource A stream resource" ilk="function" line="67" lineend="70" name="getStream" returns="resource" signature="resource getStream()" /><scope attributes="protected" doc="{@inheritdoc}" ilk="function" line="75" lineend="85" name="doWrite" signature="doWrite($message, $newline)"><variable ilk="argument" line="75" name="message" /><variable ilk="argument" line="75" name="newline" /></scope><scope attributes="protected" doc="Returns true if the stream supports colorization.&#10;&#10;Colorization is disabled if not supported by the stream:&#10;&#10; -  windows without ansicon and ConEmu&#10; -  non tty consoles&#10;&#10;@return Boolean true if the stream supports colorization, false otherwise" ilk="function" line="97" lineend="106" name="hasColorSupport" returns="Boolean" signature="Boolean hasColorSupport()" /></scope></scope></scope>