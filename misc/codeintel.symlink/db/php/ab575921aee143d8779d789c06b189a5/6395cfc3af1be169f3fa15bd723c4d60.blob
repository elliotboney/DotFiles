e attributes="public" doc="Get all restrictions&#10;&#10;@return array|null Array of {@see SimplePie_Restriction} objects" ilk="function" line="777" lineend="787" name="get_restrictions" returns="array" signature="array get_restrictions()" /><scope attributes="public" doc="Get the sampling rate (in kHz)&#10;&#10;@return string|null" ilk="function" line="794" lineend="804" name="get_sampling_rate" returns="string" signature="string get_sampling_rate()" /><scope attributes="public" doc="Get the file size (in MiB)&#10;&#10;@return float|null File size in mebibytes (1048 bytes)" ilk="function" line="811" lineend="822" name="get_size" returns="float" signature="float get_size()"><variable citdl="this.get_length()" line="813" name="length" /></scope><scope attributes="public" doc="Get a single thumbnail&#10;&#10;@param int $key&#10;@return string|null Thumbnail URL" ilk="function" line="830" lineend="841" name="get_thumbnail" returns="string" signature="string get_thumbnail(int $key = 0)"><variable citdl="int" default="0" ilk="argument" line="830" name="key" /><variable citdl="this.get_thumbnails()" line="832" name="thumbnails" /></scope><scope attributes="public" doc="Get all thumbnails&#10;&#10;@return array|null Array of thumbnail URLs" ilk="function" line="848" lineend="858" name="get_thumbnails" returns="array" signature="array get_thumbnails()" /><scope attributes="public" doc="Get the title&#10;&#10;@return string|null" ilk="function" line="865" lineend="875" name="get_title" returns="string" signature="string get_title()" /><scope attributes="public" doc="Get mimetype of the enclosure&#10;&#10;@see get_real_type()&#10;@return string|null MIME type" ilk="function" line="883" lineend="893" name="get_type" returns="string" signature="string get_type()" /><scope attributes="public" doc="Get the width&#10;&#10;@return string|null" ilk="function" line="900" lineend="910" name="get_width" returns="string" signature="string get_width()" /><scope attributes="public" doc="Embed the enclosure using `&lt;embed&gt;`&#10;&#10;@deprecated Use the second parameter to {@see embed} instead&#10;&#10;@param array|string $options See first paramter to {@see embed}&#10;@return string HTML string to output" ilk="function" line="920" lineend="923" name="native_embed" returns="string" signature="string native_embed($options = '')"><variable default="''" ilk="argument" line="920" name="options" /></scope><scope attributes="public" doc="Embed the enclosure using Javascript&#10;&#10;`$options` is an array or comma-separated key:value string, with the&#10;following properties:&#10;&#10;- `alt` (string): Alternate content for when an end-user does not have&#10;   the appropriate handler installed or when a file type is&#10;   unsupported. Can be any text or HTML. Defaults to blank.&#10;- `altclass` (string): If a file type is unsupported, the end-user will&#10;   see the alt text (above) linked directly to the content. That link&#10;   will have this value as its class name. Defaults to blank.&#10;- `audio` (string): This is an image that should be used as a&#10;   placeholder for audio files before they're loaded (QuickTime-only).&#10;   Can be any relative or absolute URL. Defaults to blank.&#10;- `bgcolor` (string): The background color for the media, if not&#10;   already transparent. Defaults to `#ffffff`.&#10;- `height` (integer): The height of the embedded media. Accepts any&#10;   numeric pixel value (such as `360`) or `auto`. Defaults to `auto`,&#10;   and it is recommended that you use this default.&#10;- `loop` (boolean): Do you want the media to loop when its done?&#10;   Defaults to `false`.&#10;- `mediaplayer` (string): The location of the included&#10;   `mediaplayer.swf` file. This allows for the playback of Flash Video&#10;   (`.flv`) files, and is the default handler for non-Odeo MP3's.&#10;   Defaults to blank.&#10;- `video` (string): This is an image that should be used as a&#10;   placeholder for video files before they're loaded (QuickTime-only).&#10;   Can be any relative or absolute URL. Defaults to blank.&#10;- `width` (integer): The width of the embedded media. Accepts any&#10;   numeric pixel value (such as `480`) or `auto`. Defaults to `auto`,&#10;   and it is recommended that you use this default.&#10;- `widescreen` (boolean): Is the enclosure widescreen or standard?&#10;   This applies only to video enclosures, and will automatically resize&#10;   the content appropriately.  Defaults to `false`, implying 4:3 mode.&#10;&#10;Note: Non-widescreen (4:3) mode with `width` and `height` set to `auto`&#10;will default to 480x360 video resolution.  Widescreen (16:9) mode with&#10;`width` and `height` set to `auto` will default to 480x270 video resolution.&#10;&#10;@todo If the dimensions for media:content are defined, use them when width/height are set to 'auto'.&#10;@param array|string $options Comma-separated key:value list, or array&#10;@param bool $native Use `&lt;embed&gt;`&#10;@return string HTML string to output" ilk="function" line="970" lineend="1192" name="embed" returns="string" signature="string embed($options = '', bool $native = false)"><variable default="''" ilk="argument" line="970" name="options" /><variable citdl="bool" default="false" ilk="argument" line="970" name="native" /><variable citdl="string" line="975" name="alt" /><variable citdl="this.get_handler()" line="983" name="handler" /><variable citdl="int" line="979" name="height" /><variable citdl="string" line="976" name="altclass" /><variable citdl="this.get_real_type()" line="984" name="type" /><variable citdl="explode()" line="1047" name="mime" /><variable citdl="string" line="974" name="video" /><variable citdl="round()" line="978" name="width" /><variable citdl="string" line="1122" name="embed" /><variable citdl="boolean" line="982" name="widescreen" /><variable citdl="string" line="981" name="mediaplayer" /><variable attributes="__not_yet_defined__" line="994" name="option" /><variable citdl="audio" line="1115" name="placeholder" /><variable citdl="string" line="980" name="bgcolor" /><variable citdl="string" line="973" name="audio" /><variable citdl="explode()" line="996" name="opt" /><variable citdl="string" line="977" name="loop" /></scope><scope attributes="public" doc="Get the real media type&#10;&#10;Often, feeds lie to us, necessitating a bit of deeper inspection. This&#10;converts types to their canonical representations based on the file&#10;extension&#10;&#10;@see get_type()&#10;@param bool $find_handler Internal use only, use {@see get_handler()} instead&#10;@return string MIME type" ilk="function" line="1205" lineend="1378" name="get_real_type" returns="string" signature="string get_real_type(bool $find_handler = false)"><variable citdl="bool" default="false" ilk="argument" line="1205" name="find_handler" /><variable citdl="array()" line="1211" name="types_wmedia" /><variable citdl="array()" line="1212" name="types_mp3" /><variable citdl="array()" line="1209" name="types_fmedia" /><variable citdl="array()" line="1210" name="types_quicktime" /><variable citdl="array()" line="1208" name="types_flash" /><variable citdl="string" line="1216" name="type" /></scope></scope></scope>