<scope ilk="blob" lang="PHP" name="Logger.php" src="/private/var/www/wordpress.staging/min/lib/Minify/Logger.php"><scope doc="Message logging class&#10;&#10;@package Minify&#10;@author Stephen Clay &lt;steve@mrclay.org&gt;&#10;&#10;@todo lose this singleton! pass log object in Minify::serve and distribute to others" ilk="class" line="15" lineend="47" name="Minify_Logger"><scope attributes="public static" doc="Set logger object. &#10;&#10;The object should have a method &quot;log&quot; that accepts a value as 1st argument and&#10;an optional string label as the 2nd.&#10;&#10;@param mixed $obj or a &quot;falsey&quot; value to disable&#10;@return null" ilk="function" line="26" lineend="30" name="setLogger" returns="null" signature="null setLogger(mixed $obj = null)"><variable citdl="mixed" default="null" ilk="argument" line="26" name="obj" /></scope><variable citdl="obj" line="29" name="_logger" /><scope attributes="public static" doc="Pass a message to the logger (if set)&#10;&#10;@param string $msg message to log&#10;@return null" ilk="function" line="38" lineend="41" name="log" returns="null" signature="null log(string $msg, $label = 'Minify')"><variable citdl="string" ilk="argument" line="38" name="msg" /><variable default="'Minify'" ilk="argument" line="38" name="label" /></scope></scope></scope>