<scope ilk="blob" lang="PHP" name="CommentPreserver.php" src="/private/var/www/wordpress.staging/min/lib/Minify/CommentPreserver.php"><scope doc="Process a string in pieces preserving C-style comments that begin with &quot;/*!&quot;&#10;&#10;@package Minify&#10;@author Stephen Clay &lt;steve@mrclay.org&gt;" ilk="class" line="13" lineend="89" name="Minify_CommentPreserver"><variable attributes="public static" citdl="string" doc="String to be prepended to each preserved comment&#10;&#10;@var string" line="20" name="prepend" /><variable attributes="public static" citdl="string" doc="String to be appended to each preserved comment&#10;&#10;@var string" line="27" name="append" /><scope attributes="public static" doc="Process a string outside of C-style comments that begin with &quot;/*!&quot;&#10;&#10;On each non-empty string outside these comments, the given processor &#10;function will be called. The comments will be surrounded by &#10;Minify_CommentPreserver::$preprend and Minify_CommentPreserver::$append.&#10;&#10;@param string $content&#10;@param callback $processor function&#10;@param array $args array of extra arguments to pass to the processor &#10;function (default = array())&#10;@return string" ilk="function" line="42" lineend="59" name="process" returns="string" signature="string process(string $content, callback $processor, array $args = array())"><variable citdl="string" ilk="argument" line="42" name="content" /><variable citdl="callback" ilk="argument" line="42" name="processor" /><variable citdl="array" default="array()" ilk="argument" line="42" name="args" /><variable citdl="string" line="44" name="ret" /><variable citdl="args" line="48" name="callArgs" /><variable attributes="__not_yet_defined__" line="46" name="comment" /><variable attributes="__not_yet_defined__" line="46" name="beforeComment" /><variable attributes="__not_yet_defined__" line="46" name="afterComment" /></scope><scope attributes="private static" doc="Extract comments that YUI Compressor preserves.&#10;&#10;@param string $in input&#10;&#10;@return array 3 elements are returned. If a YUI comment is found, the&#10;2nd element is the comment and the 1st and 3rd are the surrounding&#10;strings. If no comment is found, the entire string is returned as the &#10;1st element and the other two are false." ilk="function" line="71" lineend="88" name="_nextComment" returns="array" signature="array _nextComment(string $in)"><variable citdl="string" ilk="argument" line="71" name="in" /><variable line="73" name="end" /><variable citdl="array()" line="82" name="ret" /><variable line="83" name="endChars" /><variable line="73" name="start" /></scope></scope></scope>