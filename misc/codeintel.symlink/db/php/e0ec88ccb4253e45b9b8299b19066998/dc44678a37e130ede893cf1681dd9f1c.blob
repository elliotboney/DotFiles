ine for supported toplevel tops&#10;&#10;@return mixed" ilk="function" line="144" lineend="162" name="_decodeValue" returns="mixed" signature="mixed _decodeValue()" /><scope attributes="protected" doc="Decodes an object of the form:&#10; { &quot;attribute: value, &quot;attribute2&quot; : value,...}&#10;&#10;If Zend\Json\Encoder was used to encode the original object then&#10;a special attribute called __className which specifies a class&#10;name that should wrap the data contained within the encoded source.&#10;&#10;Decodes to either an array or stdClass object, based on the value of&#10;{@link $decodeType}. If invalid $decodeType present, returns as an&#10;array.&#10;&#10;@return array|stdClass&#10;@throws RuntimeException" ilk="function" line="179" lineend="230" name="_decodeObject" returns="array" signature="array _decodeObject()"><variable citdl="array()" line="181" name="members" /><variable citdl="members" line="224" name="result" /><variable attributes="__not_yet_defined__" line="215" name="value" /><variable citdl="this._getNextToken()" line="182" name="tok" /><variable citdl="this.tokenValue" line="189" name="key" /></scope><scope attributes="protected" doc="Decodes a JSON array format:&#10;   [element, element2,...,elementN]&#10;&#10;@return array&#10;@throws RuntimeException" ilk="function" line="239" lineend="263" name="_decodeArray" returns="array" signature="array _decodeArray()"><variable citdl="int" line="243" name="index" /><variable citdl="this._getNextToken()" line="242" name="tok" /><variable citdl="array()" line="241" name="result" /></scope><scope attributes="protected" doc="Removes whitespace characters from the source input" ilk="function" line="269" lineend="281" name="_eatWhitespace" signature="_eatWhitespace()"><variable attributes="__not_yet_defined__" line="271" name="matches" /></scope><scope attributes="protected" doc="Retrieves the next token from the source stream&#10;&#10;@return int Token constant value specified in class definitio