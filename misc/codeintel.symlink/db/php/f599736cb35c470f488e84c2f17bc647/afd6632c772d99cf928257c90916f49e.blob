<scope ilk="blob" lang="PHP" name="Log.php" src="/usr/local/Cellar/php55/5.5.7/lib/php/Log.php"><variable citdl="int" ilk="constant" line="10" name="PEAR_LOG_EMERG" /><variable citdl="int" ilk="constant" line="11" name="PEAR_LOG_ALERT" /><variable citdl="int" ilk="constant" line="12" name="PEAR_LOG_CRIT" /><variable citdl="int" ilk="constant" line="13" name="PEAR_LOG_ERR" /><variable citdl="int" ilk="constant" line="14" name="PEAR_LOG_WARNING" /><variable citdl="int" ilk="constant" line="15" name="PEAR_LOG_NOTICE" /><variable citdl="int" ilk="constant" line="16" name="PEAR_LOG_INFO" /><variable citdl="int" ilk="constant" line="17" name="PEAR_LOG_DEBUG" /><variable citdl="int" ilk="constant" line="19" name="PEAR_LOG_ALL" /><variable citdl="int" ilk="constant" line="20" name="PEAR_LOG_NONE" /><variable citdl="int" ilk="constant" line="23" name="PEAR_LOG_TYPE_SYSTEM" /><variable citdl="int" ilk="constant" line="24" name="PEAR_LOG_TYPE_MAIL" /><variable citdl="int" ilk="constant" line="25" name="PEAR_LOG_TYPE_DEBUG" /><variable citdl="int" ilk="constant" line="26" name="PEAR_LOG_TYPE_FILE" /><variable citdl="int" ilk="constant" line="27" name="PEAR_LOG_TYPE_SAPI" /><scope doc="The Log:: class implements both an abstraction for various logging&#10;mechanisms and the Subject end of a Subject-Observer pattern.&#10;&#10;@author  Chuck Hagenbuch &lt;chuck@horde.org&gt;&#10;@author  Jon Parise &lt;jon@php.net&gt;&#10;@since   Horde 1.3&#10;@package Log" ilk="class" line="38" lineend="868" name="Log"><variable citdl="boolean" doc="Indicates whether or not the log can been opened / connected.&#10;&#10;@var boolean&#10;@access protected" line="46" name="_opened" /><variable citdl="integer" doc="Instance-specific unique identification number.&#10;&#10;@var integer&#10;@access protected" line="54" name="_id" /><variable citdl="string" doc="The label that uniquely identifies this set of log messages.&#10;&#10;@var string&#10;@access protected" line="62" name="_ident" /><variable citdl="integer" doc="The default priority to use when logging an event.&#10;&#10;@var integer&#10;@access protected" line="70" name="_priority" /><variable citdl="integer" doc="The bitmask of allowed log levels.&#10;&#10;@var integer&#10;@access protected" line="78" name="_mask" /><variable citdl="array" doc="Holds all Log_observer objects that wish to be notified of new messages.&#10;&#10;@var array&#10;@access protected" line="86" name="_listeners" /><variable citdl="integer" doc="Starting depth to use when walking a backtrace in search of the &#10;function that invoked the log system.&#10;&#10;@var integer&#10;@access protected" line="95" name="_backtrace_depth" /><variable citdl="array" doc="Maps canonical format keys to position arguments for use in building&#10;&quot;line format&quot; strings.&#10;&#10;@var array&#10;@access protected" line="112" name="_formatMap" /><scope attributes="public static" doc="Attempts to return a concrete Log instance of type $handler.&#10;&#10;@param string $handler   The type of concrete Log subclass to return.&#10;                         Attempt to dynamically include the code for&#10;                         this subclass. Currently, valid values are&#10;                         'console', 'syslog', 'sql', 'file', and 'mcal'.&#10;&#10;@param string $name      The name of the actually log file, table, or&#10;                         other specific store to use. Defaults to an&#10;                         empty string, with which the subclass will&#10;                         attempt to do something intelligent.&#10;&#10;@param string $ident     The identity reported to the log system.&#10;&#10;@param array  $conf      A hash containing any additional configuration&#10;                         information that a subclass might need.&#10;&#10;@param int $level        Log messages up to and including this level.&#10;&#10;@return object Log       The newly created concrete Log instance, or&#10;                         null on an error.&#10;@access public&#10;@since Log 1.0" ilk="function" line="139" lineend="163" name="factory" returns="object" signature="object factory(string $handler, string $name = '', string $ident = '', array $conf = array(), int $level = PEAR_LOG_DEBUG)"><variable citdl="string" ilk="argument" line="139" name="handler" /><variable citdl="string" default="''" ilk="argument" line="139" name="name" /><variable citdl="string" default="''" ilk="argument" line="139" name="ident" /><variable citdl="array" default="array()" ilk="argument" line="139" name="conf" /><variable citdl="int" default="PEAR_LOG_DEBUG" ilk="argument" line="139" name="level" /><variable line="157" name="obj" /><variable citdl="string" line="143" name="class" /><variable line="161" name="null" /><variable citdl="string" line="144" name="classfile" /></scope><scope attributes="public static" doc="Attempts to return a reference to a concrete Log instance of type&#10;$handler, only creating a new instance if no log instance with the same&#10;parameters currently exists.&#10;&#10;You should use this if there are multiple places you might create a&#10;logger, you don't want to create multiple loggers, and you don't want to&#10;check for the existance of one each time. The singleton pattern does all&#10;the checking work for you.&#10;&#10;&lt;b&gt;You MUST call this method with the $var = &amp;Log::singleton() syntax.&#10;Without the ampersand (&amp;) in front of the method name, you will not get&#10;a reference, you will get a copy.&lt;/b&gt;&#10;&#10;@param string $handler   The type of concrete Log subclass to return.&#10;                         Attempt to dynamically include the code for&#10;                         this subclass. Currently, valid values are&#10;                         'console', 'syslog', 'sql', 'file', and 'mcal'.&#10;&#10;@param string $name      The name of the actually log file, table, or&#10;                         other specific store to use.  Defaults to an&#10;                         empty string, with which the subclass will&#10;                         attempt to do something intelligent.&#10;&#10;@param string $ident     The identity reported to the log system.&#10;&#10;@param array $conf       A hash containing any additional configuration&#10;                         information that a subclass might need.&#10;&#10;@param int $level        Log messages up to and including this level.&#10;&#10;@return object Log       The newly created concrete Log instance, or&#10;                         null on an error.&#10;@access public&#10;@since Log 1.0" ilk="function" line="201" lineend="214" name="singleton" returns="object" signature="object singleton(string $handler, string $name = '', string $ident = '', array $conf = array(), int $level = PEAR_LOG_DEBUG)"><variable citdl="string" ilk="argument" line="201" name="handler" /><variable citdl="string" default="''" ilk="argument" line="201" name="name" /><variable citdl="string" default="''" ilk="argument" line="201" name="ident" /><variable citdl="array" default="array()" ilk="argument" line="201" name="conf" /><variable citdl="int" default="PEAR_LOG_DEBUG" ilk="argument" line="201" name="level" /><variable citdl="serialize()" line="207" name="signature" /><variable attributes="__not_yet_defined__" line="205" name="instances" /></scope><variable attributes="static" line="204" name="instances" /><scope doc="Abstract implementation of the open() method.&#10;@since Log 1.0" ilk="function" line="220" lineend="223" name="open" returns="boolean" signature="open()" /><scope doc="Abstract implementation of the close() method.&#10;@since Log 1.0" ilk="function" line="229" lineend="232" name="close" returns="boolean" signature="close()" /><scope doc="Abstract implementation of the flush() method.&#10;@since Log 1.8.2" ilk="function" line="238" lineend="241" name="flush" returns="boolean" signature="flush()" /><scope attributes="__ctor__" doc="Abstract implementation of the log() method.&#10;@since Log 1.0" ilk="function" line="247" lineend="250" name="log" returns="boolean" signature="log($message, $priority = null)"><variable ilk="argument" line="247" name="message" /><variable default="null" ilk="argument" line="247" name="priority" /></scope><scope doc="A convenience function for logging a emergency event.  It will log a&#10;message at the PEAR_LOG_EMERG log level.&#10;&#10;@param   mixed   $message    String or object containing the message&#10;                             to log.&#10;&#10;@return  boolean True if the message was successfully logged.&#10;&#10;@access  public&#10;@since   Log 1.7.0" ilk="function" line="264" lineend="267" name="emerg" returns="boolean" signature="boolean emerg(mixed $message)"><variable citdl="mixed" ilk="argument" line="264" name="message" /></scope><scope doc="A convenience function for logging an alert event.  It will log a&#10;message at the PEAR_LOG_ALERT log level.&#10;&#10;@param   mixed   $message    String or object containing the message&#10;                             to log.&#10;&#10;@return  boolean True if the message was successfully logged.&#10;&#10;@access  public&#10;@since   Log 1.7.0" ilk="function" line="281" lineend="284" name="alert" returns="boolean" signature="boolean alert(mixed $message)"><variable citdl="mixed" ilk="argument" line="281" name="message" /></scope><scope doc="A convenience function for logging a critical event.  It will log a&#10;message at the PEAR_LOG_CRIT log level.&#10;&#10;@param   mixed   $message    String or object containing the message&#10;                             to log.&#10;&#10;@return  boolean True if the message was successfully logged.&#10;&#10;@access  public&#10;@since   Log 1.7.0" ilk="function" line="298" lineend="301" name="crit" returns="boolean" signature="boolean crit(mixed $message)"><variable citdl="mixed" ilk="argument" line="298" name="message" /></scope><scope doc="A convenience function for logging a error event.  It will log a&#10;message at the PEAR_LOG_ERR log level.&#10;&#10;@param   mixed   $message    String or object containing the message&#10;                             to log.&#10;&#10;@return  boolean True if the message was successfully logged.&#10;&#10;@access  public&#10;@since   Log 1.7.0" ilk="function" line="315" lineend="318" name="err" returns="boolean" signature="boolean err(mixed $message)"><variable citdl="mixed" ilk="argument" line="315" name="message" /></scope><scope doc="A convenience function for logging a warning event.  It will log a&#10;message at the PEAR_LOG_WARNING log level.&#10;&#10;@param   mixed   $message    String or object containing the message&#10;                             to log.&#10;&#10;@return  boolean True if the message was successfully logged.&#10;&#10;@access  public&#10;@since   Log 1.7.0" ilk="function" line="332" lineend="335" name="warning" returns="boolean" signature="boolean warning(mixed $message)"><variable citdl="mixed" ilk="argument" line="332" name="message" /></scope><scope doc="A convenience function for logging a notice event.  It will log a&#10;message at the PEAR_LOG_NOTICE log level.&#10;&#10;@param   mixed   $message    String or object containing the message&#10;                             to log.&#10;&#10;@return  boolean True if the message was successfully logged.&#10;&#10;@access  public&#10;@since   Log 1.7.0" ilk="function" line="349" lineend="352" name="notice" returns="boolean" signature="boolean notice(mixed $message)"><variable citdl="mixed" ilk="argument" line="349" name="message" /></scope><scope doc="A convenience function for logging a information event.  It will log a&#10;message at the PEAR_LOG_INFO log level.&#10;&#10;@param   mixed   $message    String or object containing the message&#10;                             to log.&#10;&#10;@return  boolean True if the message was successfully logged.&#10;&#10;@access  public&#10;@since   Log 1.7.0" ilk="function" line="366" lineend="369" name="info" returns="boolean" signature="boolean info(mixed $message)"><variable citdl="mixed" ilk="argument" line="366" name="message" /></scope><scope doc="A convenience function for logging a debug event.  It will log a&#10;message at the PEAR_LOG_DEBUG log level.&#10;&#10;@param   mixed   $message    String or object containing the message&#10;                             to log.&#10;&#10;@return  boolean True if the message was successfully logged.&#10;&#10;@access  public&#10;@since   Log 1.7.0" ilk="function" line="383" lineend="386" name="debug" returns="boolean" signature="boolean debug(mixed $message)"><variable citdl="mixed" ilk="argument" line="383" name="message" /></scope><scope doc="Returns the string representation of the message data.&#10;&#10;If $message is an object, _extractMessage() will attempt to extract&#10;the message text using a known method (such as a PEAR_Error object's&#10;getMessage() method).  If a known method, cannot be found, the&#10;serialized representation of the object will be returned.&#10;&#10;If the message data is already a string, it will be returned unchanged.&#10;&#10;@param  mixed $message   The original message data.  This may be a&#10;                         string or any object.&#10;&#10;@return string           The string representation of the message.&#10;&#10;@access protected" ilk="function" line="405" lineend="440" name="_extractMessage" returns="string" signature="string _extractMessage(mixed $message)"><variable citdl="mixed" ilk="argument" line="405" name="message" /></scope><scope doc="Using debug_backtrace(), returns the file, line, and enclosing function&#10;name of the source code context from which log() was invoked.&#10;&#10;@param   int     $depth  The initial number of frames we should step&#10;                         back into the trace.&#10;&#10;@return  array   Array containing four strings: the filename, the line,&#10;                 the function name, and the class name from which log()&#10;                 was called.&#10;&#10;@access  private&#10;@since   Log 1.9.4" ilk="function" line="456" lineend="512" name="_getBacktraceVars" returns="array" signature="array _getBacktraceVars(int $depth)"><variable citdl="int" ilk="argument" line="456" name="depth" /><variable citdl="is_array()" line="485" name="line" /><variable citdl="is_array()" line="484" name="file" /><variable citdl="is_array()" line="486" name="func" /><variable line="494" name="bt2" /><variable line="463" name="bt1" /><variable line="462" name="bt0" /><variable citdl="debug_backtrace()" line="459" name="bt" /><variable line="469" name="class" /></scope><scope attributes="public" doc="Sets the starting depth to use when walking a backtrace in search of &#10;the function that invoked the log system.  This is used on conjunction &#10;with the 'file', 'line', 'function', and 'class' formatters.&#10;&#10;@param int $depth    The new backtrace depth.&#10;&#10;@access  public&#10;@since   Log 1.12.7" ilk="function" line="524" lineend="527" name="setBacktraceDepth" signature="setBacktraceDepth(int $depth)"><variable citdl="int" ilk="argument" line="524" name="depth" /></scope><scope doc="Produces a formatted log line based on a format string and a set of&#10;variables representing the current log record and state.&#10;&#10;@return  string  Formatted log string.&#10;&#10;@access  protected&#10;@since   Log 1.9.4" ilk="function" line="538" lineend="564" name="_format" returns="string" signature="string _format($format, $timestamp, $priority, $message)"><variable ilk="argument" line="538" name="format" /><variable ilk="argument" line="538" name="timestamp" /><variable ilk="argument" line="538" name="priority" /><variable ilk="argument" line="538" name="message" /><variable attributes="__not_yet_defined__" line="547" name="file" /><variable attributes="__not_yet_defined__" line="547" name="func" /><variable attributes="__not_yet_defined__" line="547" name="line" /><variable citdl="this._backtrace_depth" line="546" name="d" /><variable attributes="__not_yet_defined__" line="547" name="class" /></scope><scope doc="Returns the string representation of a PEAR_LOG_* integer constant.&#10;&#10;@param int $priority     A PEAR_LOG_* integer constant.&#10;&#10;@return string           The string representation of $level.&#10;&#10;@access  public&#10;@since   Log 1.0" ilk="function" line="576" lineend="590" name="priorityToString" returns="string" signature="string priorityToString(int $priority)"><variable citdl="int" ilk="argument" line="576" name="priority" /><variable citdl="array()" line="587" name="levels" /></scope><scope doc="Returns the the PEAR_LOG_* integer constant for the given string&#10;representation of a priority name.  This function performs a&#10;case-insensitive search.&#10;&#10;@param string $name      String containing a priority name.&#10;&#10;@return string           The PEAR_LOG_* integer contstant corresponding&#10;                         the the specified priority name.&#10;&#10;@access  public&#10;@since   Log 1.9.0" ilk="function" line="605" lineend="619" name="stringToPriority" returns="string" signature="string stringToPriority(string $name)"><variable citdl="string" ilk="argument" line="605" name="name" /><variable citdl="array()" line="616" name="levels" /></scope><scope attributes="public static" doc="Calculate the log mask for the given priority.&#10;&#10;This method may be called statically.&#10;&#10;@param integer   $priority   The priority whose mask will be calculated.&#10;&#10;@return integer  The calculated log mask.&#10;&#10;@access  public&#10;@since   Log 1.7.0" ilk="function" line="633" lineend="636" name="MASK" returns="integer" signature="integer MASK(integer $priority)"><variable citdl="integer" ilk="argument" line="633" name="priority" /></scope><scope attributes="public static" doc="Calculate the log mask for all priorities up to the given priority.&#10;&#10;This method may be called statically.&#10;&#10;@param integer   $priority   The maximum priority covered by this mask.&#10;&#10;@return integer  The resulting log mask.&#10;&#10;@access  public&#10;@since   Log 1.7.0&#10;&#10;@deprecated deprecated since Log 1.9.4; use Log::MAX() instead" ilk="function" line="652" lineend="655" name="UPTO" returns="integer" signature="integer UPTO(integer $priority)"><variable citdl="integer" ilk="argument" line="652" name="priority" /></scope><scope attributes="public static" doc="Calculate the log mask for all priorities greater than or equal to the&#10;given priority.  In other words, $priority will be the lowest priority&#10;matched by the resulting mask.&#10;&#10;This method may be called statically.&#10;&#10;@param integer   $priority   The minimum priority covered by this mask.&#10;&#10;@return integer  The resulting log mask.&#10;&#10;@access  public&#10;@since   Log 1.9.4" ilk="function" line="671" lineend="674" name="MIN" returns="integer" signature="integer MIN(integer $priority)"><variable citdl="integer" ilk="argument" line="671" name="priority" /></scope><scope attributes="public static" doc="Calculate the log mask for all priorities less than or equal to the&#10;given priority.  In other words, $priority will be the highests priority&#10;matched by the resulting mask.&#10;&#10;This method may be called statically.&#10;&#10;@param integer   $priority   The maximum priority covered by this mask.&#10;&#10;@return integer  The resulting log mask.&#10;&#10;@access  public&#10;@since   Log 1.9.4" ilk="function" line="690" lineend="693" name="MAX" returns="integer" signature="integer MAX(integer $priority)"><variable citdl="integer" ilk="argument" line="690" name="priority" /></scope><scope doc="Set and return the level mask for the current Log instance.&#10;&#10;@param integer $mask     A bitwise mask of log levels.&#10;&#10;@return integer          The current level mask.&#10;&#10;@access  public&#10;@since   Log 1.7.0" ilk="function" line="705" lineend="710" name="setMask" returns="integer" signature="integer setMask(integer $mask)"><variable citdl="integer" ilk="argument" line="705" name="mask" /></scope><scope doc="Returns the current level mask.&#10;&#10;@return interger         The current level mask.&#10;&#10;@access  public&#10;@since   Log 1.7.0" ilk="function" line="720" lineend="723" name="getMask" returns="interger" signature="interger getMask()" /><scope doc="Check if the given priority is included in the current level mask.&#10;&#10;@param integer   $priority   The priority to check.&#10;&#10;@return boolean  True if the given priority is included in the current&#10;                 log mask.&#10;&#10;@access  protected&#10;@since   Log 1.7.0" ilk="function" line="736" lineend="739" name="_isMasked" returns="boolean" signature="boolean _isMasked(integer $priority)"><variable citdl="integer" ilk="argument" line="736" name="priority" /></scope><scope doc="Returns the current default priority.&#10;&#10;@return integer  The current default priority.&#10;&#10;@access  public&#10;@since   Log 1.8.4" ilk="function" line="749" lineend="752" name="getPriority" returns="integer" signature="integer getPriority()" /><scope doc="Sets the default priority to the specified value.&#10;&#10;@param   integer $priority   The new default priority.&#10;&#10;@access  public&#10;@since   Log 1.8.4" ilk="function" line="762" lineend="765" name="setPriority" signature="setPriority(integer $priority)"><variable citdl="integer" ilk="argument" line="762" name="priority" /></scope><scope doc="Adds a Log_observer instance to the list of observers that are listening&#10;for messages emitted by this Log instance.&#10;&#10;@param object    $observer   The Log_observer instance to attach as a&#10;                             listener.&#10;&#10;@param boolean   True if the observer is successfully attached.&#10;&#10;@access  public&#10;@since   Log 1.0" ilk="function" line="779" lineend="788" name="attach" returns="boolean" signature="attach(object &amp; $observer)"><variable citdl="object" ilk="argument" line="779" name="observer" /></scope><scope doc="Removes a Log_observer instance from the list of observers.&#10;&#10;@param object    $observer   The Log_observer instance to detach from&#10;                             the list of listeners.&#10;&#10;@param boolean   True if the observer is successfully detached.&#10;&#10;@access  public&#10;@since   Log 1.0" ilk="function" line="801" lineend="811" name="detach" returns="boolean" signature="detach(object $observer)"><variable citdl="object" ilk="argument" line="801" name="observer" /></scope><scope doc="Informs each registered observer instance that a new message has been&#10;logged.&#10;&#10;@param array     $event      A hash describing the log event.&#10;&#10;@access protected" ilk="function" line="821" lineend="828" name="_announce" signature="_announce(array $event)"><variable citdl="array" ilk="argument" line="821" name="event" /><variable attributes="__not_yet_defined__" line="823" name="listener" /><variable line="823" name="id" /></scope><scope doc="Indicates whether this is a composite class.&#10;&#10;@return boolean          True if this is a composite class.&#10;&#10;@access  public&#10;@since   Log 1.0" ilk="function" line="838" lineend="841" name="isComposite" returns="boolean" signature="boolean isComposite()" /><scope doc="Sets this Log instance's identification string.&#10;&#10;@param string    $ident      The new identification string.&#10;&#10;@access  public&#10;@since   Log 1.6.3" ilk="function" line="851" lineend="854" name="setIdent" signature="setIdent(string $ident)"><variable citdl="string" ilk="argument" line="851" name="ident" /></scope><scope doc="Returns the current identification string.&#10;&#10;@return string   The current Log instance's identification string.&#10;&#10;@access  public&#10;@since   Log 1.6.3" ilk="function" line="864" lineend="867" name="getIdent" returns="string" signature="string getIdent()" /></scope></scope>