<scope ilk="blob" lang="PHP" name="PEAR5.php" src="/usr/local/Cellar/php55/5.5.7/lib/php/PEAR5.php"><scope doc="This is only meant for PHP 5 to get rid of certain strict warning&#10;that doesn't get hidden since it's in the shutdown function" ilk="class" line="6" lineend="33" name="PEAR5"><scope attributes="static" doc="If you have a class that's mostly/entirely static, and you need static&#10;properties, you can use this method to simulate them. Eg. in your method(s)&#10;do this: $myVar = &amp;PEAR5::getStaticProperty('myclass', 'myVar');&#10;You MUST use a reference, or they will not persist!&#10;&#10;@access public&#10;@param  string $class  The calling classname, to prevent clashes&#10;@param  string $var    The variable to retrieve.&#10;@return mixed   A reference to the variable. If not set it will be&#10;                auto initialised to NULL." ilk="function" line="20" lineend="32" name="getStaticProperty" returns="mixed" signature="mixed &amp;getStaticProperty(string $class, string $var)"><variable citdl="string" ilk="argument" line="20" name="class" /><variable citdl="string" ilk="argument" line="20" name="var" /><variable attributes="__not_yet_defined__" line="23" name="properties" /></scope><variable attributes="static" line="22" name="properties" /></scope></scope>