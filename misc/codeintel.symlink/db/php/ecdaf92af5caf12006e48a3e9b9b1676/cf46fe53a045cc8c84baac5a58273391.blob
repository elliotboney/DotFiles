<scope ilk="blob" lang="PHP" name="Dir.php" src="/private/var/www/kw/plugins/w3-total-cache/lib/Minify/Solar/Dir.php"><scope doc="Utility class for static directory methods.&#10;&#10;@category Solar&#10;&#10;@package Solar&#10;&#10;@author Paul M. Jones &lt;pmjones@solarphp.com&gt;&#10;&#10;@license http://opensource.org/licenses/bsd-license.php BSD&#10;&#10;@version $Id: Dir.php 2926 2007-11-09 16:25:44Z pmjones $" ilk="class" line="17" lineend="199" name="Solar_Dir"><variable attributes="protected static" citdl="string" doc="The OS-specific temporary directory location.&#10;&#10;@var string" line="26" name="_tmp" /><scope attributes="public static" doc="Hack for [[php::is_dir() | ]] that checks the include_path.&#10;&#10;Use this to see if a directory exists anywhere in the include_path.&#10;&#10;{{code: php&#10;    $dir = Solar_Dir::exists('path/to/dir')&#10;    if ($dir) {&#10;        $files = scandir($dir);&#10;    } else {&#10;        echo &quot;Not found in the include-path.&quot;;&#10;    }&#10;}}&#10;&#10;@param string $dir Check for this directory in the include_path.&#10;&#10;@return mixed If the directory exists in the include_path, returns the&#10;absolute path; if not, returns boolean false." ilk="function" line="49" lineend="77" name="exists" returns="mixed" signature="mixed exists(string $dir)"><variable citdl="string" ilk="argument" line="49" name="dir" /><variable line="60" name="abs" /><variable attributes="__not_yet_defined__" line="67" name="base" /><variable citdl="rtrim()" line="69" name="target" /><variable citdl="explode()" line="66" name="path" /></scope><scope attributes="public static" doc="&quot;Fixes&quot; a directory string for the operating system.&#10;&#10;Use slashes anywhere you need a directory separator. Then run the&#10;string through fixdir() and the slashes will be converted to the&#10;proper separator (for example '\' on Windows).&#10;&#10;Always adds a final trailing separator.&#10;&#10;@param string $dir The directory string to 'fix'.&#10;&#10;@return string The &quot;fixed&quot; directory string." ilk="function" line="94" lineend="98" name="fix" returns="string" signature="string fix(string $dir)"><variable citdl="string" ilk="argument" line="94" name="dir" /></scope><scope attributes="public static" doc="Convenience method for dirname() and higher-level directories.&#10;&#10;@param string $file Get the dirname() of this file.&#10;&#10;@param int $up Move up in the directory structure this many &#10;times, default 0.&#10;&#10;@return string The dirname() of the file." ilk="function" line="112" lineend="119" name="name" returns="string" signature="string name(string $file, int $up = 0)"><variable citdl="string" ilk="argument" line="112" name="file" /><variable citdl="int" default="0" ilk="argument" line="112" name="up" /><variable citdl="dirname()" line="114" name="dir" /></scope><scope attributes="public static" doc="Returns the OS-specific directory for temporary files.&#10;&#10;@param string $sub Add this subdirectory to the returned temporary&#10;directory name.&#10;&#10;@return string The temporary directory path." ilk="function" line="131" lineend="157" name="tmp" returns="string" signature="string tmp(string $sub = '')"><variable citdl="string" default="''" ilk="argument" line="131" name="sub" /><variable citdl="sys_get_temp_dir()" line="138" name="tmp" /></scope><scope attributes="protected static" doc="Returns the OS-specific temporary directory location.&#10;&#10;@return string The temp directory path." ilk="function" line="166" lineend="198" name="_tmp" returns="string" signature="string _tmp()"><variable line="170" name="tmp" /></scope></scope></scope>