<scope ilk="blob" lang="PHP" name="Cache.php" src="/private/var/www/wordpress.staging/wp-includes/SimplePie/Cache.php"><scope doc="Used to create cache objects&#10;&#10;This class can be overloaded with {@see SimplePie::set_cache_class()},&#10;although the preferred way is to create your own handler&#10;via {@see register()}&#10;&#10;@package SimplePie&#10;@subpackage Caching" ilk="class" line="55" lineend="133" name="SimplePie_Cache"><variable attributes="protected static" citdl="array" doc="Cache handler classes&#10;&#10;These receive 3 parameters to their constructor, as documented in&#10;{@see register()}&#10;@var array" line="67" name="handlers" /><scope attributes="private __ctor__" doc="Don't call the constructor. Please." ilk="function" line="72" lineend="72" name="__construct" signature="__construct()" /><scope attributes="public static" doc="Create a new SimplePie_Cache object&#10;&#10;@param string $location URL location (scheme is used to determine handler)&#10;@param string $filename Unique identifier for cache object&#10;@param string $extension 'spi' or 'spc'&#10;@return SimplePie_Cache_Base Type of object depends on scheme of `$location`" ilk="function" line="82" lineend="93" name="get_handler" returns="SimplePie_Cache_Base" signature="SimplePie_Cache_Base get_handler(string $location, string $filename, string $extension)"><variable citdl="string" ilk="argument" line="82" name="location" /><variable citdl="string" ilk="argument" line="82" name="filename" /><variable citdl="string" ilk="argument" line="82" name="extension" /><variable citdl="explode()" line="84" name="type" /><variable citdl="self.$handlers" line="88" name="class" /></scope><scope attributes="public" doc="Create a new SimplePie_Cache object&#10;&#10;@deprecated Use {@see get_handler} instead" ilk="function" line="100" lineend="104" name="create" returns="self.get_handler()" signature="create($location, $filename, $extension)"><variable ilk="argument" line="100" name="location" /><vari