<scope ilk="blob" lang="PHP" name="W3tcOAuth.php" src="/private/var/www/kw/plugins/w3-total-cache/lib/OAuth/W3tcOAuth.php"><scope classrefs="Exception" doc="Generic exception class" ilk="class" line="6" lineend="8" name="W3tcOAuthException" /><scope ilk="class" line="11" lineend="24" name="W3tcOAuthConsumer"><variable attributes="public" citdl="key" line="12" name="key" /><variable attributes="public" citdl="secret" line="13" name="secret" /><scope attributes="__ctor__" ilk="function" line="15" lineend="19" name="__construct" signature="__construct($key, $secret, $callback_url = NULL)"><variable ilk="argument" line="15" name="key" /><variable ilk="argument" line="15" name="secret" /><variable default="NULL" ilk="argument" line="15" name="callback_url" /></scope><variable citdl="callback_url" line="18" name="callback_url" /><scope ilk="function" line="21" lineend="23" name="__toString" returns="string" signature="__toString()" /></scope><scope ilk="class" line="26" lineend="54" name="W3tcOAuthToken"><variable attributes="public" citdl="key" line="28" name="key" /><variable attributes="public" citdl="secret" line="29" name="secret" /><scope attributes="__ctor__" doc="key = the token&#10;secret = the token secret" ilk="function" line="35" lineend="38" name="__construct" signature="__construct($key, $secret)"><variable ilk="argument" line="35" name="key" /><variable ilk="argument" line="35" name="secret" /></scope><scope doc="generates the basic string serialization of a token that a server&#10;would respond to request_token and access_token calls with" ilk="function" line="44" lineend="49" name="to_string" returns="string" signature="to_string()" /><scope ilk="function" line="51" lineend="53" name="__toString" returns="this.to_string()" signature="__toString()" /></scope><scope attributes="abstract" doc="A class for implementing a Signature Method&#10;See section 9 (&quot;Signing Requests&quot;) in the spec" ilk="class" line="60" lineend="107" name="W3tcOAuthSignatureMethod"><scope attributes="abstract public" doc="Needs to return the name of the Signature Method (ie HMAC-SHA1)&#10;@return string" ilk="function" line="65" lineend="65" name="get_name" returns="string" signature="string get_name()" /><scope attributes="abstract public" doc="Build up the signature&#10;NOTE: The output of this function MUST NOT be urlencoded.&#10;the encoding is handled in OAuthRequest when the final&#10;request is serialized&#10;@param W3tcOAuthRequest $request&#10;@param W3tcOAuthConsumer $consumer&#10;@param W3tcOAuthToken $token&#10;@return string" ilk="function" line="77" lineend="77" name="build_signature" returns="string" signature="string build_signature(W3tcOAuthRequest $request, W3tcOAuthConsumer $consumer, W3tcOAuthToken $token)"><variable citdl="W3tcOAuthRequest" ilk="argument" line="77" name="request" /><variable citdl="W3tcOAuthConsumer" ilk="argument" line="77" name="consumer" /><variable citdl="W3tcOAuthToken" ilk="argument" line="77" name="token" /></scope><scope attributes="public" doc="Verifies that a given signature is correct&#10;@param W3tcOAuthRequest $request&#10;@param W3tcOAuthConsumer $consumer&#10;@param W3tcOAuthToken $token&#10;@param string $signature&#10;@return bool" ilk="function" line="87" lineend="106" name="check_signature" returns="bool" signature="bool check_signature(W3tcOAuthRequest $request, W3tcOAuthConsumer $consumer, W3tcOAuthToken $token, string $signature)"><variable citdl="W3tcOAuthRequest" ilk="argument" line="87" name="request" /><variable citdl="W3tcOAuthConsumer" ilk="argument" line="87" name="consumer" /><variable citdl="W3tcOAuthToken" ilk="argument" line="87" name="token" /><variable citdl="string" ilk="argument" line="87" name="signature" /><variable citdl="this.build_signature()" line="88" name="built" /><variable line="101" name="i" /><variable citdl="int" line="100" name="result" /></scope></scope><scope classrefs="W3tcOAuthSignatureMethod" doc="The HMAC-SHA1 signature method uses the HMAC-SHA1 signature algorithm as defined in [RFC2104] &#10;where the Signature Base String is the text and the key is the concatenated values (each first &#10;encoded per Parameter Encoding) of the Consumer Secret and Token Secret, separated by an '&amp;' &#10;character (ASCII code 38) even if empty.&#10;  - Chapter 9.2 (&quot;HMAC-SHA1&quot;)" ilk="class" line="116" lineend="135" name="W3tcOAuthSignatureMethod_HMAC_SHA1"><scope ilk="function" line="117" lineend="119" name="get_name" returns="string" signature="get_name()" /><scope attributes="public" ilk="function" line="121" lineend="134" name="build_signature" returns="base64_encode()" signature="build_signature($request, $consumer, $token)"><variable ilk="argument" line="121" name="request" /><variable ilk="argument" line="121" name="consumer" /><variable ilk="argument" line="121" name="token" /><variable citdl="array()" line="128" name="key_parts" /><variable citdl="request.get_signature_base_string()" line="122" name="base_string" /><variable citdl="implode()" line="131" name="key" /></scope></scope><scope classrefs="W3tcOAuthSignatureMethod" doc="The PLAINTEXT method does not provide any security protection and SHOULD only be used &#10;over a secure channel such as HTTPS. It does not use the Signature Base String.&#10;  - Chapter 9.4 (&quot;PLAINTEXT&quot;)" ilk="class" line="142" lineend="168" name="W3tcOAuthSignatureMethod_PLAINTEXT"><scope attributes="public" ilk="function" line="143" lineend="145" name="get_name" returns="string" signature="get_name()" /><scope attributes="public" doc="oauth_signature is set to the concatenated encoded values of the Consumer Secret and &#10;Token Secret, separated by a '&amp;' character (ASCII code 38), even if either secret is &#10;empty. The result MUST be encoded again.&#10;  - Chapter 9.4.1 (&quot;Generating Signatures&quot;)&#10;&#10;Please note that the second encoding MUST NOT happen in the SignatureMethod, as&#10;OAuthRequest handles this!" ilk="function" line="156" lineend="167" name="build_signature" returns="key" signature="build_signature($request, $consumer, $token)"><variable ilk="argument" line="156" name="request" /><variable ilk="argument" line="156" name="consumer" /><variable ilk="argument" line="156" name="token" /><variable citdl="array()" line="160" name="key_parts" /><variable citdl="implode()" line="163" name="key" /></scope></scope><scope attributes="abstract" classrefs="W3tcOAuthSignatureMethod" doc="The RSA-SHA1 signature method uses the RSASSA-PKCS1-v1_5 signature algorithm as defined in &#10;[RFC3447] section 8.2 (more simply known as PKCS#1), using SHA-1 as the hash function for &#10;EMSA-PKCS1-v1_5. It is assumed that the Consumer has provided its RSA public key in a &#10;verified way to the Service Provider, in a manner which is beyond the scope of this &#10;specification.&#10;  - Chapter 9.3 (&quot;RSA-SHA1&quot;)" ilk="class" line="178" lineend="235" name="W3tcOAuthSignatureMethod_RSA_SHA1"><scope attributes="public" ilk="function" line="179" lineend="181" name="get_name" returns="string" signature="get_name()" /><scope attributes="protected abstract" doc="Up to the SP to implement this lookup of keys. Possible ideas are:&#10;(1) do a lookup in a table of trusted certs keyed off of consumer&#10;(2) fetch via http using a url provided by the requester&#10;(3) some sort of specific discovery code based on request&#10;&#10;Either way should return a string representation of the certificate" ilk="function" line="189" lineend="189" name="fetch_public_cert" signature="fetch_public_cert(&amp; $request)"><variable ilk="argument" line="189" name="request" /></scope><scope attributes="protected abstract" doc="Up to the SP to implement this lookup of keys. Possible ideas are:&#10;(1) do a lookup in a table of trusted certs keyed off of consumer&#10;&#10;Either way should return a string representation of the certificate" ilk="function" line="195" lineend="195" name="fetch_private_cert" signature="fetch_private_cert(&amp; $request)"><variable ilk="argument" line="195" name="request" /></scope><scope attributes="public" ilk="function" line="197" lineend="214" name="build_signature" returns="base64_encode()" signature="build_signature($request, $consumer, $token)"><variable ilk="argument" line="197" name="request" /><variable ilk="argument" line="197" name="consumer" /><variable ilk="argument" line="197" name="token" /><variable citdl="request.get_signature_base_string()" line="198" name="base_string" /><variable citdl="openssl_get_privatekey()" line="205" name="privatekeyid" /><variable citdl="openssl_sign()" line="208" name="ok" /><variable citdl="this.fetch_private_cert()" line="202" name="cert" /></scope><scope attributes="public" ilk="function" line="216" lineend="234" name="check_signature" returns="ok" signature="check_signature($request, $consumer, $token, $signature)"><variable ilk="argument" line="216" name="request" /><variable ilk="argument" line="216" name="consumer" /><variable ilk="argument" line="216" name="token" /><variable ilk="argument" line="216" name="signature" /><variable citdl="request.get_signature_base_string()" line="219" name="base_string" /><variable citdl="openssl_get_publickey()" line="225" name="publickeyid" /><variable citdl="base64_decode()" line="217" name="decoded_sig" /><variable citdl="openssl_verify()" line="228" name="ok" /><variable citdl="this.fetch_public_cert()" line="222" name="cert" /></scope></scope><scope ilk="class" line="237" lineend="495" name="W3tcOAuthRequest"><variable attributes="protected" citdl="parameters" line="238" name="parameters" /><variable attributes="protected" citdl="http_method" line="239" name="http_method" /><variable attributes="protected" citdl="http_url" line="240" name="http_url" /><variable attributes="public" line="242" name="base_string" /><variable attributes="public static" citdl="string" line="243" name="version" /><variable attributes="public static" citdl="string" line="244" name="POST_INPUT" /><sco