<scope ilk="blob" lang="PHP" name="XMLDocBookpeardoc2Converter.inc" src="/usr/local/pear/share/pear/PhpDocumentor/phpDocumentor/Converters/XML/DocBook/peardoc2/XMLDocBookpeardoc2Converter.inc"><import line="227" module="phpDocumentor/Converters/XML/DocBook/peardoc2/Beautifier.php" /><scope classrefs="Converter" doc="XML DocBook converter.&#10;This Converter takes output from the {@link Parser} and converts it to DocBook&#10;output for PEAR documentation.&#10;&#10;This Converter differs from the parent DocBook Converter in that it does not&#10;recognize the possibility of procedural pages or of functions!  All functions&#10;must be defined as static methods for namespace purposes.  In addition, all&#10;constants and global variables for a package are grouped together as per&#10;peardoc2 requirements.  Include statements are not documented.  If you want&#10;to document a normal project, don't use the peardoc2 converter, use the&#10;DocBook converter.&#10;@package Converters&#10;@subpackage XMLDocBook&#10;@author Greg Beaver &lt;cellog@php.net&gt;&#10;@since 1.2&#10;@version $Id: XMLDocBookpeardoc2Converter.inc 234423 2007-04-24 21:32:15Z ashnazg $" ilk="class" line="58" lineend="1700" name="XMLDocBookpeardoc2Converter"><variable citdl="boolean" doc="This converter knows about the new root tree processing&#10;In order to fix PEAR Bug #6389&#10;@var boolean" line="65" name="processSpecialRoots" /><variable citdl="boolean" doc="XMLDocBookConverter wants elements sorted by type as well as alphabetically&#10;@see Converter::$sort_page_contents_by_type&#10;@var boolean" line="71" name="sort_page_contents_by_type" /><variable citdl="string" doc="@var string" line="73" name="outputformat" /><variable citdl="string" doc="@var string" line="75" name="name" /><variable citdl="array" doc="indexes of elements by package that need to be generated&#10;@var array" line="80" name="leftindex" /><variable citdl="boolean" doc="whether a @see is going to be in the {@link $base_dir}, or in a package/subpackage subdirectory of $base_dir&#10;@var boolean" line="85" name="local" /><variable citdl="string" doc="name of current page being converted&#10;@var string" line="91" name="page" /><variable citdl="string" doc="path of current page being converted&#10;@var string" line="97" name="path" /><variable citdl="string" doc="name of current class being converted&#10;@var string" line="103" name="class" /><variable citdl="Template" doc="template for the procedural page currently being processed&#10;@var Template" line="109" name="page_data" /><variable citdl="string" doc="output directory for the current procedural page being processed&#10;@var string" line="115" name="page_dir" /><variable citdl="array" doc="Constants, used for constants.tpl&#10;@var array" line="121" name="_peardoc2_constants" /><variable citdl="array" doc="Global Variables, used for globals.tpl&#10;@var array" line="127" name="_peardoc2_globals" /><variable citdl="string" doc="target directory passed on the command-line.&#10;{@link $targetDir} is malleable, always adding package/ and package/subpackage/ subdirectories onto it.&#10;@var string" line="134" name="base_dir" /><variable citdl="string" doc="output directory for the current class being processed&#10;@var string" line="140" name="class_dir" /><variable citdl="Template" doc="template for the class currently being processed&#10;@var Template" line="146" name="class_data" /><variable citdl="array" doc="array of converted package page names.&#10;Used to link to the package page in the left index&#10;@var array Format: array(package =&gt; 1)" line="153" name="package_pages" /><variable citdl="Smarty" doc="Contents of the packagename.xml file are stored in this template variable&#10;@var Smarty" line="159" name="packagexml" /><variable citdl="boolean" doc="controls formatting of parser informative output&#10;&#10;Converter prints:&#10;&quot;Converting /path/to/file.php... Procedural Page Elements... Classes...&quot;&#10;Since HTMLdefaultConverter outputs files while converting, it needs to send a \n to start a new line.  However, if there&#10;is more than one class, output is messy, with multiple \n's just between class file output.  This variable prevents that&#10;and is purely cosmetic&#10;@var boolean" line="170" name="juststarted" /><variable citdl="array" doc="contains all of the template procedural page element loop data needed for the current template&#10;@var array" line="176" name="current" /><variable citdl="array" doc="contains all of the template class element loop data needed for the current template&#10;@var array" line="182" name="currentclass" /><variable citdl="boolean" line="187" name="sort_absolutely_everything" /><variable citdl="array" doc="template options.  Currently only 1 recognized option usepear&#10;&#10;usepear tells the getLink() function to return a package link to PEAR and PEAR_ERROR if possible, and to link directly&#10;to the fully-delimited link package#class.method or package#file.method in PEAR style, if possible, even if the&#10;package is not parsed.  This will allow parsing of separate PEAR packages without parsing the entire thing at once!&#10;@var array" line="196" name="template_options" /><variable citdl="array()" line="198" name="function_data" /><variable citdl="array()" line="199" name="method_data" /><variable citdl="array()" line="200" name="_write_constants_xml" /><variable citdl="array()" line="201" name="_write_globals_xml" /><variable citdl="string" line="202" name="sourceloc" /><variable citdl="string" doc="peardoc2 Category&#10;@var string" line="207" name="category" /><variable citdl="XML_Beautifier" doc="Used to re-format output so that it's easy for translators to handle&#10;&#10;@var XML_Beautifier|false&#10;@access private" line="214" name="_beautifier" /><scope attributes="__ctor__" doc="sets {@link $base_dir} to $targetDir&#10;@see Converter()" ilk="function" line="220" lineend="232" name="XMLDocBookpeardoc2Converter" signature="XMLDocBookpeardoc2Converter(&amp; $allp, &amp; $packp, &amp; $classes, &amp; $procpages, $po, $pp, $qm, $targetDir, $templateDir, $title)"><variable ilk="argument" line="220" name="allp" /><variable ilk="argument" line="220" name="packp" /><variable ilk="argument" line="220" name="classes" /><variable ilk="argument" line="220" name="procpages" /><variable ilk="argument" line="220" name="po" /><variable ilk="argument" line="220" name="pp" /><variable ilk="argument" line="220" name="qm" /><variable ilk="argument" line="220" name="targetDir" /><variable ilk="argument" line="220" name="templateDir" /><variable ilk="argument" line="220" name="title" /></scope><scope doc="do that stuff in $template_options" ilk="function" line="237" lineend="240" name="getLink" returns="Converter.getLink()" signature="&amp;getLink($expr, $package = false, $packages = false)"><variable ilk="argument" line="237" name="expr" /><variable default="false" ilk="argument" line="237" name="package" /><variable default="false" ilk="argument" line="237" name="packages" /></scope><scope ilk="function" line="242" lineend="246" name="unmangle" returns="string" signature="unmangle($s, $sourcecode)"><variable ilk="argument" line="242" name="s" /><variable ilk="argument" line="242" name="sourcecode" /></scope><scope doc="Writes a file to target dir, beautify any .xml files first&#10;@param string filename&#10;@param string file contents&#10;@param boolean true if the data is binary and not text" ilk="function" line="254" lineend="265" name="writeFile" signature="writeFile($file, $data, $binary = false)"><variable ilk="argument" line="254" name="file" /><variable ilk="argument" line="254" name="data" /><variable default="false" ilk="argument" line="254" name="binary" /><variable citdl="this._beautifier.formatString()" line="257" name="ret" /></scope><scope doc="Used to convert the {@}example} inline tag in a docblock.&#10;&#10;By default, this just wraps ProgramExample&#10;@see XMLDocBookpeardoc2Converter::examp