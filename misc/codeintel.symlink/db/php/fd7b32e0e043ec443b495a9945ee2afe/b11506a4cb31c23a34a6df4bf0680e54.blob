<scope ilk="blob" lang="PHP" name="cache.php" src="/private/var/www/paperless/wp-content/plugins/bbpress/includes/core/cache.php"><scope doc="Skip invalidation of child post content when editing a parent.&#10;&#10;This prevents invalidating caches for topics and replies when editing a forum&#10;or a topic. Without this in place, WordPress will attempt to invalidate all&#10;child posts whenever a parent post is modified. This can cause thousands of&#10;cache invalidations to occur on a single edit, which is no good for anyone.&#10;&#10;@since bbPress (r4011)&#10;&#10;@package bbPress&#10;@subpackage Cache" ilk="class" line="33" lineend="119" name="BBP_Skip_Children"><variable attributes="private" citdl="int" doc="@var int Post ID being updated" line="38" name="updating_post" /><variable attributes="private" citdl="bool" doc="@var bool The original value of $_wp_suspend_cache_invalidation global" line="43" name="original_cache_invalidation" /><scope attributes="public __ctor__" doc="Hook into the 'pre_post_update' action.&#10;&#10;@since bbPress (r4011)" ilk="function" line="52" lineend="54" name="__construct" signature="__construct()" /><scope attributes="public" doc="Only clean post caches for main bbPress posts.&#10;&#10;Check that the post being updated is a bbPress post type, saves the&#10;post ID to be used later, and adds an action to 'clean_post_cache' that&#10;prevents child post caches from being cleared.&#10;&#10;@since bbPress (r4011)&#10;&#10;@param int $post_id The post ID being updated&#10;@return If invalid post data" ilk="function" line="68" lineend="80" name="pre_post_update" returns="If" signature="If pre_post_update(int $post_id = 0)"><variable citdl="int" default="0" ilk="argument" line="68" name="post_id" /></scope><scope attributes="public" doc="Skip cache invalidation of related posts if the post ID being invalidated&#10;is not the one that was just updated.&#10;&#10;@since bbPress (r4011)&#10;&#10;@param int $post_id The post ID of the cache being invalidated&#10;@return If invalid post data" ilk="function" line="91" lineend="108" name="skip_related_posts" returns="If" signature="If skip_related_posts(int $post_id = 0)"><variable citdl="int" default="0" ilk="argument" line="91" name="post_id" /><variable attributes="__not_yet_defined__" line="99" name="_wp_suspend_cache_invalidation" /></scope><scope attributes="public" doc="Restore the cache invalidation to its previous value.&#10;&#10;@since bbPress (r4011)&#10;@uses wp_suspend_cache_invalidation()" ilk="function" line="116" lineend="118" name="restore_cache_invalidation" signature="restore_cache_invalidation()" /></scope><scope doc="Will clean a post in the cache.&#10;&#10;Will call to clean the term object cache associated with the post ID.&#10;&#10;@since bbPress (r4040)&#10;&#10;@uses do_action() Calls 'bbp_clean_post_cache' on $id&#10;@param object|int $_post The post object or ID to remove from the cache" ilk="function" line="134" lineend="168" name="bbp_clean_post_cache" signature="bbp_clean_post_cache($_post = '')"><variable default="''" ilk="argument" line="134" name="_post" /><variable citdl="array()" line="153" name="post_types" /><variable attributes="__not_yet_defined__" line="156" name="post_type" /></scope></scope>