<scope ilk="blob" lang="PHP" name="capabilities.php" src="/private/var/www/paperless/wp-content/plugins/bbpress/includes/core/capabilities.php"><scope doc="Returns an array of capabilities based on the role that is being requested.&#10;&#10;@since bbPress (r2994)&#10;&#10;@todo Map all of these and deprecate&#10;&#10;@param string $role Optional. Defaults to The role to load caps for&#10;@uses apply_filters() Allow return value to be filtered&#10;&#10;@return array Capabilities for $role" ilk="function" line="31" lineend="209" name="bbp_get_caps_for_role" returns="array" signature="array bbp_get_caps_for_role(string $role = '')"><variable citdl="string" default="''" ilk="argument" line="31" name="role" /><variable citdl="array()" line="80" name="caps" /></scope><scope doc="Adds capabilities to WordPress user roles.&#10;&#10;@since bbPress (r2608)" ilk="function" line="216" lineend="226" name="bbp_add_caps" signature="bbp_add_caps()"><variable attributes="__not_yet_defined__" line="219" name="role" /><variable attributes="__not_yet_defined__" line="220" name="value" /><variable line="220" name="cap" /></scope><scope doc="Removes capabilities from WordPress user roles.&#10;&#10;@since bbPress (r2608)" ilk="function" line="233" lineend="243" name="bbp_remove_caps" signature="bbp_remove_caps()"><variable attributes="__not_yet_defined__" line="236" name="role" /><variable attributes="__not_yet_defined__" line="237" name="cap" /></scope><scope doc="Get the $wp_roles global without needing to declare it everywhere&#10;&#10;@since bbPress (r4293)&#10;&#10;@global WP_Roles $wp_roles&#10;@return WP_Roles" ilk="function" line="253" lineend="261" name="bbp_get_wp_roles" returns="WP_Roles" signature="WP_Roles bbp_get_wp_roles()"><variable attributes="__not_yet_defined__" line="254" name="wp_roles" /></scope><scope doc="Get the available roles minus bbPress's dynamic roles&#10;&#10;@since bbPress (r5064)&#10;&#10;@uses bbp_get_wp_roles() To load and get the $wp_roles global&#10;@return array" ilk="function" line="271" lineend="284" name="bbp_get_blog_roles" returns="array" signature="array bbp_get_blog_roles()"><variable line="280" name="the_roles" /><variable citdl="apply_filters()" line="281" name="all_roles" /><variable citdl="bbp_get_wp_roles()" line="274" name="wp_roles" /></scope><scope doc="Add the bbPress roles to the $wp_roles global.&#10;&#10;We do this to avoid adding these values to the database.&#10;&#10;@since bbPress (r4290)&#10;&#10;@uses bbp_get_wp_roles() To load and get the $wp_roles global&#10;@uses bbp_get_dynamic_roles() To get and add bbPress's roles to $wp_roles&#10;@return WP_Roles The main $wp_roles global" ilk="function" line="299" lineend="309" name="bbp_add_forums_roles" returns="WP_Roles" signature="WP_Roles bbp_add_forums_roles()"><variable line="302" name="role_id" /><variable citdl="bbp_get_wp_roles()" line="300" name="wp_roles" /><variable attributes="__not_yet_defined__" line="302" name="details" /></scope><scope doc="Helper function to add filter to option_wp_user_roles&#10;&#10;@since bbPress (r4363)&#10;&#10;@see _bbp_reinit_dynamic_roles()&#10;&#10;@global WPDB $wpdb Used to get the database prefix" ilk="function" line="320" lineend="326" name="bbp_filter_user_roles_option" signature="bbp_filter_user_roles_option()"><variable citdl="wpdb.prefix" line="323" name="role_key" /><variable attributes="__not_yet_defined__" line="321" name="wpdb" /></scope><scope doc="This is necessary because in a few places (noted below) WordPress initializes&#10;a blog's roles directly from the database option. When this happens, the&#10;$wp_roles global gets flushed, causing a user to magically lose any&#10;dynamically assigned roles or capabilities when $current_user in refreshed.&#10;&#10;Because dynamic multiple roles is a new concept in WordPress, we work around&#10;it here for now, knowing that improvements will come to WordPress core later.&#10;&#10;Also note that if using the $wp_user_roles global non-database approach,&#10;bbPress does not have an intercept point to add its dynamic roles.&#10;&#10;@see switch_to_blog()&#10;@see restore_current_blog()&#10;@see WP_Roles::_init()&#10;&#10;@since bbPress (r4363)&#10;&#10;@internal Used by bbPress to reinitialize dynamic roles on blog switch&#10;&#10;@param array $roles&#10;@return array Combined array of database roles and dynamic bbPress roles" ilk="function" line="351" lineend="356" name="_bbp_reinit_dynamic_roles" returns="array" signature="array _bbp_reinit_dynamic_roles(array $roles = array())"><variable citdl="array" default="array()" ilk="argument" line="351" name="roles" /><variable line="352" name="role_id" /><variable attributes="__not_yet_defined__" line="352" name="details" /></scope><scope doc="Fetch a filtered list of forum roles that the current user is&#10;allowed to have.&#10;&#10;Simple function who's main purpose is to allow filtering of the&#10;list of forum roles so that plugins can remove inappropriate ones depending&#10;on the situation or user making edits.&#10;&#10;Specifically because without filtering, anyone with the edit_users&#10;capability can edit others to be administrators, even if they are&#10;only editors or authors. This filter allows admins to delegate&#10;user management.&#10;&#10;@since bbPress (r4284)&#10;&#10;@return array" ilk="function" line="375" lineend="408" name="bbp_get_dynamic_roles" returns="array" signature="array bbp_get_dynamic_roles()" /><scope doc="Gets a translated role name from a role ID&#10;&#10;@since bbPress (r4792)&#10;&#10;@param string $role_id&#10;@return string Translated role name" ilk="function" line="418" lineend="423" name="bbp_get_dynamic_role_name" returns="string" signature="string bbp_get_dynamic_role_name(string $role_id = '')"><variable citdl="string" default="''" ilk="argument" line="418" name="role_id" /><variable line="420" name="role" /><variable citdl="bbp_get_dynamic_roles()" line="419" name="roles" /></scope><scope doc="Removes the bbPress roles from the editable roles array&#10;&#10;This used to use array_diff_assoc() but it randomly broke before 2.2 release.&#10;Need to research what happened, and if there's a way to speed this up.&#10;&#10;@since bbPress (r4303)&#10;&#10;@param array $all_roles All registered roles&#10;@return array" ilk="function" line="436" lineend="452" name="bbp_filter_blog_editable_roles" returns="array" signature="array bbp_filter_blog_editable_roles(array $all_roles = array())"><variable citdl="array" default="array()" ilk="argument" line="436" name="all_roles" /><variable attributes="__not_yet_defined__" line="439" name="bbp_role" /><variable attributes="__not_yet_defined__" line="442" name="wp_role" /></scope><scope doc="The keymaster role for bbPress users&#10;&#10;@since bbPress (r4284)&#10;&#10;@uses apply_filters() Allow override of hardcoded keymaster role&#10;@return string" ilk="function" line="462" lineend="464" name="bbp_get_keymaster_role" returns="string" signature="string bbp_get_keymaster_role()" /><scope doc="The moderator role for bbPress users&#10;&#10;@since bbPress (r3410)&#10;&#10;@uses apply_filters() Allow override of hardcoded moderator role&#10;@return string" ilk="function" line="474" lineend="476" name="bbp_get_moderator_role" returns="string" signature="string bbp_get_moderator_role()" /><scope doc="The participant role for registered user that can participate in forums&#10;&#10;@since bbPress (r3410)&#10;&#10;@uses apply_filters() Allow override of hardcoded participant role&#10;@return string" ilk="function" line="486" lineend="488" name="bbp_get_participant_role" returns="string" signature="string bbp_get_participant_role()" /><scope doc="The spectator role is for registered users without any capabilities&#10;&#10;@since bbPress (r3860)&#10;&#10;@uses apply_filters() Allow override of hardcoded spectator role&#10;@return string" ilk="function" line="498" lineend="500" name="bbp_get_spectator_role" returns="string" signature="string bbp_get_spectator_role()" /><scope doc="The blocked role is for registered users that cannot spectate or participate&#10;&#10;@since bbPress (r4284)&#10;&#10;@uses apply_filters() Allow override of hardcoded blocked role&#10;@return string" ilk="function" line="510" lineend="512" name="bbp_get_blocked_role" returns="string" signature="string bbp_get_blocked_role()" /><scope doc="Adds bbPress-specific user roles.&#10;&#10;@since bbPress (r2741)&#10;@deprecated since version 2.2" ilk="function" line="522" lineend="524" name="bbp_add_roles" signature="bbp_add_roles()" /><scope doc="Removes bbPress-specific user roles.&#10;&#10;@since bbPress (r2741)&#10;@deprecated since version 2.2" ilk="function" line="532" lineend="542" name="bbp_remove_roles" signature="bbp_remove_roles()"><variable attributes="__not_yet_defined__" line="535" name="bbp_role" /></scope></scope>