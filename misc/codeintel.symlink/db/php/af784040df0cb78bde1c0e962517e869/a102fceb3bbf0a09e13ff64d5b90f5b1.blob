re" returns="integer" signature="integer lastIndexWhere(callable $callable)"><variable citdl="callable" ilk="argument" line="101" name="callable" /></scope><scope attributes="public" doc="Returns all indices of this collection.&#10;&#10;@return array&lt;integer&gt;" ilk="function" line="108" lineend="108" name="indices" returns="array" signature="array indices()" /><scope attributes="public" doc="Returns the element at the given index.&#10;&#10;@param integer $index (0-based)&#10;&#10;@return T" ilk="function" line="117" lineend="117" name="get" returns="T" signature="T get(integer $index)"><variable citdl="integer" ilk="argument" line="117" name="index" /></scope><scope attributes="public" doc="Adds an element to the sequence.&#10;&#10;@param T $elem&#10;&#10;@return void" ilk="function" line="126" lineend="126" name="add" signature="void add(T $elem)"><variable citdl="T" ilk="argument" line="126" name="elem" /></scope><scope attributes="public" doc="Removes the element at the given index, and returns it.&#10;&#10;@param integer $index&#10;&#10;@return T" ilk="function" line="135" lineend="135" name="remove" returns="T" signature="T remove(integer $index)"><variable citdl="integer" ilk="argument" line="135" name="index" /></scope><scope attributes="public" doc="Adds all elements to the sequence.&#10;&#10;@param array&lt;T&gt; $elements&#10;&#10;@return void" ilk="function" line="144" lineend="144" name="addAll" signature="void addAll(array $elements)"><variable citdl="array" ilk="argument" line="144" name="elements" /></scope><scope attributes="public" doc="Updates the value at the given index.&#10;&#10;@param integer $index&#10;@param T $value&#10;&#10;@return void" ilk="function" line="154" lineend="154" name="update" signature="void update(integer $index, T $value)"><variable citdl="integer" ilk="argument" line="154" name="index" /><variable citdl="T" ilk="argument" line="154" name="value" /></scope><scope attributes="public" doc="Returns a new sequence by omitting the given number of elements from the beginning.&#10;&#10;If the passed number is greater than the available number of elements, all will be removed.&#10;&#10;@param integer $number&#10;&#10;@return SequenceInterface" ilk="function" line="165" lineend="165" name="drop" returns="SequenceInterface" signature="SequenceInterface drop(integer $number)"><variable citdl="integer" ilk="argument" line="165" name="number" /></scope><scope attributes="public" doc="Returns a new sequence by omitting the given number of elements from the end.&#10;&#10;If the passed number is greater than the available number of elements, all will be removed.&#10;&#10;@param integer $number&#10;&#10;@return SequenceInterface" ilk="function" line="176" lineend="176" name="dropRight" returns="SequenceInterface" signature="SequenceInterface dropRight(integer $number)"><variable citdl="integer" ilk="argument" line="176" name="number" /></scope><scope attributes="public" doc="Returns a new sequence by omitting elements from the beginning for as long as the callable returns true.&#10;&#10;@param callable $callable Receives the element to drop as first argument, and returns true (drop), or false (stop).&#10;&#10;@return SequenceInterface" ilk="function" line="185" lineend="185" name="dropWhile" returns="SequenceInterface" signature="SequenceInterface dropWhile(callable $callable)"><variable citdl="callable" ilk="argument" line="185" name="callable" /></scope><scope attributes="public" doc="Creates a new collection by taking the given number of elements from the beginning&#10;of the current collection.&#10;&#10;If the passed number is greater than the available number of elements, then all elements&#10;will be returned as a new collection.&#10;&#10;@param integer $number&#10;&#10;@return CollectionInterface&lt;T&gt;" ilk="function" line="198" lineend="198" name="take" returns="CollectionInterface" signature="CollectionInterface take(integer $number)"><variable citdl="integer" ilk="argument" line="198" name="number" /></scope><scope attributes="public" doc="Creates a new collection by taking elements from the current collection&#10;for as long as the callable returns true.&#10;&#10;@param callable $callable&#10;&#10;@return CollectionInterface&lt;T&gt;" ilk="function" line="208" lineend="208" name="takeWhile" returns="CollectionInterface" signature="CollectionInterface takeWhile(callable $callable)"><variable citdl="callable" ilk="argument" line="208" name="callable" /></scope></scope></scope></scope>