afNodes" /><variable attributes="__not_yet_defined__" line="85" name="key" /></scope><scope doc="isAcyclic returns true if a graph contains no cycles, false otherwise.&#10;&#10;@return	boolean	 true iff graph is acyclic&#10;@access	public" ilk="function" line="126" lineend="132" name="isAcyclic" returns="boolean" signature="boolean isAcyclic(&amp; $graph)"><variable ilk="argument" line="126" name="graph" /></scope></scope></scope>