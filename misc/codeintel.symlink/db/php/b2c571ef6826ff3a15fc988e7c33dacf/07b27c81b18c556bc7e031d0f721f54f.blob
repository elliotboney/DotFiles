 attributes="public" doc="Returns the node definition as is requested by GraphViz.&#10;&#10;@return string" ilk="function" line="123" lineend="138" name="__toString" returns="string" signature="string __toString()"><variable citdl="addslashes()" line="131" name="name" /><variable attributes="__not_yet_defined__" line="126" name="value" /><variable citdl="array()" line="125" name="attributes" /></scope></scope></scope></scope>