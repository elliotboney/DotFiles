<scope ilk="blob" lang="PHP" name="functions.wp-scripts.php" src="/private/var/www/paperless/wp-includes/functions.wp-scripts.php"><scope doc="Prints script tags in document head.&#10;&#10;Called by admin-header.php and by wp_head hook. Since it is called by wp_head&#10;on every page load, the function does not instantiate the WP_Scripts object&#10;unless script names are explicitly passed. Does make use of already&#10;instantiated $wp_scripts if present. Use provided wp_print_scripts hook to&#10;register/enqueue new scripts.&#10;&#10;@since r16&#10;@see WP_Dependencies::print_scripts()" ilk="function" line="21" lineend="39" name="wp_print_scripts" returns="wp_scripts.do_items()" signature="wp_print_scripts($handles = false)"><variable default="false" ilk="argument" line="21" name="handles" /><variable attributes="__not_yet_defined__" line="26" name="wp_scripts" /></scope><scope doc="Register new Javascript file.&#10;&#10;@since r16&#10;@param string $handle Script name&#10;@param string $src Script url&#10;@param array $deps (optional) Array of script names on which this script depends&#10;@param string|bool $ver (optional) Script version (used for cache busting), set to null to disable&#10;@param bool $in_footer (optional) Whether to enqueue the script before &lt;/head&gt; or before &lt;/body&gt;&#10;@return null" ilk="function" line="52" lineend="64" name="wp_register_script" returns="null" signature="null wp_register_script(string $handle, string $src, array $deps = array(), $ver = false, bool $in_footer = false)"><variable citdl="string" ilk="argument" line="52" name="handle" /><variable citdl="string" ilk="argument" line="52" name="src" /><variable citdl="array" default="array()" ilk="argument" line="52" name="deps" /><variable default="false" ilk="argument" line="52" name="ver" /><variable citdl="bool" default="false" ilk="argument" line="52" name="in_footer" /><variable attributes="__not_yet_defined__" citdl="WP_Scripts" line="53" name="wp_scripts" /></scope><scope doc="Wrapper for $wp_scripts-&gt;localize().&#10;&#10;Used to localize a script.&#10;Works only if the script has already been added.&#10;Accepts an associative array $l10n and creates JS object:&#10;&quot;$object_name&quot; = {&#10;  key: value,&#10;  key: value,&#10;  ...&#10;}&#10;See http://core.trac.wordpress.org/ticket/11520 for more information.&#10;&#10;@since r16&#10;&#10;@param string $handle The script handle that was registered or used in script-loader&#10;@param string $object_name Name for the created JS object. This is passed directly so it should be qualified JS variable /[a-zA-Z0-9_]+/&#10;@param array $l10n Associative PHP array containing the translated strings. HTML entities will be converted and the array will be JSON encoded.&#10;@return bool Whether the localization was added successfully." ilk="function" line="86" lineend="97" name="wp_localize_script" returns="bool" signature="bool wp_localize_script(string $handle, string $object_name, array $l10n)"><variable citdl="string" ilk="argument" line="86" name="handle" /><variable citdl="string" ilk="argument" line="86" name="object_name" /><variable citdl="array" ilk="argument" line="86" name="l10n" /><variable attributes="__not_yet_defined__" line="87" name="wp_scripts" /></scope><scope doc="Remove a registered script.&#10;&#10;@since r16&#10;@see WP_Scripts::remove() For parameter information." ilk="function" line="105" lineend="135" name="wp_deregister_script" signature="wp_deregister_script($handle)"><variable ilk="argument" line="105" name="handle" /><variable citdl="sprintf()" line="128" name="message" /><variable citdl="array()" line="124" name="no" /><variable attributes="__not_yet_defined__" citdl="WP_Scripts" line="106" name="wp_scripts" /></scope><scope doc="Enqueues script.&#10;&#10;Registers the script if src provided (does NOT overwrite) and enqueues.&#10;&#10;@since r16&#10;@see wp_register_script() For parameter information." ilk="function" line="145" lineend="161" name="wp_enqueue_script" signature="wp_enqueue_script($handle, $src = false, $deps = array(), $ver = false, $in_footer = false)"><variable ilk="argument" line="145" name="handle" /><variable default="false" ilk="argument" line="145" name="src" /><variable default="array()" ilk="argument" line="145" name="deps" /><variable default="false" ilk="argument" line="145" name="ver" /><variable default="false" ilk="argument" line="145" name="in_footer" /><variable citdl="explode()" line="155" name="_handle" /><variable attributes="__not_yet_defined__" citdl="WP_Scripts" line="146" name="wp_scripts" /></scope><scope doc="Remove an enqueued script.&#10;&#10;@since WP 3.1&#10;@see WP_Scripts::dequeue() For parameter information." ilk="function" line="169" lineend="179" name="wp_dequeue_script" signature="wp_dequeue_script($handle)"><variable ilk="argument" line="169" name="handle" /><variable attributes="__not_yet_defined__" citdl="WP_Scripts" line="170" name="wp_scripts" /></scope><scope doc="Check whether script has been added to WordPress Scripts.&#10;&#10;By default, checks if the script has been enqueued. You can also&#10;pass 'registered' to $list, to see if the script is registered,&#10;and you can check processing statuses with 'to_do' and 'done'.&#10;&#10;@since WP unknown; BP unknown&#10;&#10;@param string $handle Name of the script.&#10;@param string $list Optional. Defaults to 'enqueued'. Values are&#10;	'registered', 'enqueued' (or 'queue'), 'to_do', and 'done'.&#10;@return bool Whether script is in the list." ilk="function" line="195" lineend="205" name="wp_script_is" returns="bool" signature="bool wp_script_is(string $handle, string $list = 'enqueued')"><variable citdl="string" ilk="argument" line="195" name="handle" /><variable citdl="string" default="'enqueued'" ilk="argument" line="195" name="list" /><variable attributes="__not_yet_defined__" citdl="WP_Scripts" line="196" name="wp_scripts" /></scope></scope>