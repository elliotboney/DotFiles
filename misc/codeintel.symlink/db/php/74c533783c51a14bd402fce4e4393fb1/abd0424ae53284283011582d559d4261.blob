ross multiple columns&#10;&#10;@access protected&#10;@since 3.1.0&#10;&#10;@param string $string&#10;@param array $cols&#10;@param bool $wild Whether to allow wildcard searches. Default is false for Network Admin, true for&#10; single site. Single site allows leading and trailing wildcards, Network Admin only trailing.&#10;@return string" ilk="function" line="610" lineend="624" name="get_search_sql" returns="string" signature="string get_search_sql(string $string, array $cols, bool $wild = false)"><variable citdl="string" ilk="argument" line="610" name="string" /><variable citdl="array" ilk="argument" line="610" name="cols" /><variable citdl="bool" default="false" ilk="argument" line="610" name="wild" /><variable line="614" name="leading_wild" /><variable line="615" name="trailing_wild" /><variable citdl="array()" line="613" name="searches" /><variable attributes="__not_yet_defined__" line="616" name="col" /></scope><scope doc="Return the list of users&#10;&#10;@since 3.1.0&#10;@access public&#10;&#10;@return array" ilk="function" line="634" lineend="636" name="get_results" returns="array" signature="array get_results()" /><scope doc="Return the total number of users for the current query&#10;&#10;@since 3.1.0&#10;@access public&#10;&#10;@return array" ilk="function" line="646" lineend="648" name="get_total" returns="array" signature="array get_total()" /></scope><scope doc="Retrieve list of users matching criteria.&#10;&#10;@since 3.1.0&#10;@uses $wpdb&#10;@uses WP_User_Query See for default arguments and information.&#10;&#10;@param array $args Optional.&#10;@return array List of users." ilk="function" line="661" lineend="669" name="get_users" returns="array" signature="array get_users(array $args = array())"><variable citdl="array" default="array()" ilk="argument" line="661" name="args" /><variable citdl="WP_User_Query" line="666" name="user_search" /></scope><scope doc="Get the blogs a user belongs to.&#10;&#10;@since 3.0.0&#10;&#10;@param int $user_id User ID&#