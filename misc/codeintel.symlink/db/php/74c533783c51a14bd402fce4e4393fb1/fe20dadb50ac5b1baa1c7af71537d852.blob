<scope ilk="blob" lang="PHP" name="script-loader.php" src="/private/var/www/paperless/wp-includes/script-loader.php"><import line="25" module="/class.wp-dependencies.php" /><import line="28" module="/class.wp-scripts.php" /><import line="31" module="/functions.wp-scripts.php" /><import line="34" module="/class.wp-styles.php" /><import line="37" module="/functions.wp-styles.php" /><scope doc="Register all WordPress scripts.&#10;&#10;Localizes some of them.&#10;args order: $scripts-&gt;add( 'handle', 'url', 'dependencies', 'query-string', 1 );&#10;when last arg === 1 queues the script for the footer&#10;&#10;@since 2.6.0&#10;&#10;@param object $scripts WP_Scripts object." ilk="function" line="50" lineend="512" name="wp_default_scripts" signature="wp_default_scripts(object &amp; $scripts)"><variable citdl="object" ilk="argument" line="50" name="scripts" /><variable line="52" name="guessurl" /><variable line="209" name="max_upload_size" /><variable citdl="defined()" line="60" name="suffix" /><variable citdl="array()" line="238" name="uploader_l10n" /></scope><scope doc="Assign default styles to $styles object.&#10;&#10;Nothing is returned, because the $styles parameter is passed by reference.&#10;Meaning that whatever object is passed will be updated without having to&#10;reassign the variable that was passed back to the same value. This saves&#10;memory.&#10;&#10;Adding default styles is not the only task, it also assigns the base_url&#10;property, the default version, and text direction for the object.&#10;&#10;@since 2.6.0&#10;&#10;@param object $styles" ilk="function" line="529" lineend="582" name="wp_default_styles" signature="wp_default_styles(object &amp; $styles)"><variable citdl="object" ilk="argument" line="529" name="styles" /><variable line="531" name="guessurl" /><variable attributes="__not_yet_defined__" line="577" name="rtl_style" /><variable citdl="defined()" line="540" name="suffix" /><variable citdl="array()" line="544" name="no_suffix" /><variable citdl="array()" line="542" name="rtl_styles" /></scope><scope doc="Reorder JavaScript scripts array to place prototype before jQuery.&#10;&#10;@since 2.3.1&#10;&#10;@param array $js_array JavaScript scripts array&#10;@return array Reordered array, if needed." ilk="function" line="592" lineend="607" name="wp_prototype_before_jquery" returns="array" signature="array wp_prototype_before_jquery(array $js_array)"><variable citdl="array" ilk="argument" line="592" name="js_array" /><variable line="593" name="prototype" /><variable line="596" name="jquery" /></scope><scope doc="Load localized data on print rather than initialization.&#10;&#10;These localizations require information that may not be loaded even by init.&#10;&#10;@since 2.5.0" ilk="function" line="616" lineend="625" name="wp_just_in_time_script_localization" signature="wp_just_in_time_script_localization()" /><scope doc="Administration Screen CSS for changing the styles.&#10;&#10;If installing the 'wp-admin/' directory will be replaced with './'.&#10;&#10;The $_wp_admin_css_colors global manages the Administration Screens CSS&#10;stylesheet that is loaded. The option that is set is 'admin_color' and is the&#10;color and key for the array. The value for the color key is an object with&#10;a 'url' parameter that has the URL path to the CSS file.&#10;&#10;The query from $src parameter will be appended to the URL that is given from&#10;the $_wp_admin_css_colors array value URL.&#10;&#10;@since 2.6.0&#10;@uses $_wp_admin_css_colors&#10;&#10;@param string $src Source URL.&#10;@param string $handle Either 'colors' or 'colors-rtl'.&#10;@return string URL path to CSS stylesheet for Administration Screens." ilk="function" line="647" lineend="674" name="wp_style_loader_src" returns="string" signature="string wp_style_loader_src(string $src, string $handle)"><variable citdl="string" ilk="argument" line="647" name="src" /><variable citdl="string" ilk="argument" line="647" name="handle" /><variable citdl="get_user_option()" line="653" name="color" /><variable attributes="__not_yet_defined__" line="652" name="_wp_admin_css_colors" /><variable citdl="color.url" line="660" name="url" /><variable citdl="parse_url()" line="659" name="parsed" /></scope><scope doc="Prints the script queue in the HTML head on admin pages.&#10;&#10;Postpones the scripts that were queued for the footer.&#10;print_footer_scripts() is called in the footer to print these scripts.&#10;&#10;@since 2.8&#10;@see wp_print_scripts()" ilk="function" line="685" lineend="703" name="print_head_scripts" returns="wp_scripts.done" signature="print_head_scripts()"><variable attributes="__not_yet_defined__" line="686" name="wp_scripts" /><variable attributes="__not_yet_defined__" line="686" name="concatenate_scripts" /></scope><scope doc="Prints the scripts that were queued for the footer or too late for the HTML head.&#10;&#10;@since 2.8" ilk="function" line="710" lineend="725" name="print_footer_scripts" returns="wp_scripts.done" signature="print_footer_scripts()"><variable attributes="__not_yet_defined__" line="711" name="wp_scripts" /><variable attributes="__not_yet_defined__" line="711" name="concatenate_scripts" /></scope><scope doc="@internal use" ilk="function" line="730" lineend="756" name="_print_scripts" signature="_print_scripts()"><variable citdl="compress_scripts" line="733" name="zip" /><variable citdl="str_split()" line="737" name="concat" /><variable attributes="__not_yet_defined__" line="731" name="compress_scripts" /><variable attributes="__not_yet_defined__" line="731" name="wp_scripts" /><variable citdl="wp_scripts.base_url" line="750" name="src" /></scope><scope doc="Prints the script queue in the HTML head on the front end.&#10;&#10;Postpones the scripts that were queued for the footer.&#10;wp_print_footer_scripts() is called in the footer to print these scripts.&#10;&#10;@since 2.8" ilk="function" line="766" lineend="776" name="wp_print_head_scripts" returns="print_head_scripts()" signature="wp_print_head_scripts()"><variable attributes="__not_yet_defined__" line="770" name="wp_scripts" /></scope><scope doc="Private, for use in *_footer_scripts hooks&#10;&#10;@since 3.3.0" ilk="function" line="783" lineend="786" name="_wp_footer_scripts" signature="_wp_footer_scripts()" /><scope doc="Hooks to print the scripts and styles in the footer.&#10;&#10;@since 2.8" ilk="function" line="793" lineend="795" name="wp_print_footer_scripts" signature="wp_print_footer_scripts()" /><scope doc="Wrapper for do_action('wp_enqueue_scripts')&#10;&#10;Allows plugins to queue scripts for the front end using wp_enqueue_script().&#10;Runs first in wp_head() where all is_home(), is_page(), etc. functions are available.&#10;&#10;@since 2.8" ilk="function" line="805" lineend="807" name="wp_enqueue_scripts" signature="wp_enqueue_scripts()" /><scope doc="Prints the styles queue in the HTML head on admin pages.&#10;&#10;@since 2.8" ilk="function" line="814" lineend="833" name="print_admin_styles" returns="wp_styles.done" signature="print_admin_styles()"><variable citdl="compress_css" line="822" name="zip" /><variable attributes="__not_yet_defined__" line="815" name="wp_styles" /><variable attributes="__not_yet_defined__" line="815" name="compress_css" /><variable attributes="__not_yet_defined__" line="815" name="concatenate_scripts" /></scope><scope doc="Prints the styles that were queued too late for the HTML head.&#10;&#10;@since 3.3.0" ilk="function" line="840" lineend="854" name="print_late_styles" returns="wp_styles.done" signature="print_late_styles()"><variable attributes="__not_yet_defined__" line="841" name="wp_styles" /><variable attributes="__not_yet_defined__" line="841" name="concatenate_scripts" /></scope><scope doc="@internal use" ilk="function" line="859" lineend="881" name="_print_styles" signature="_print_styles()"><variable citdl="wp_styles.text_direction" line="867" name="dir" /><variable attributes="__not_yet_defined__" line="860" name="wp_styles" /><variable citdl="wp_styles.def