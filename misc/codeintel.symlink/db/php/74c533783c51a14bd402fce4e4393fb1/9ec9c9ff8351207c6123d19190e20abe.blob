<scope ilk="blob" lang="PHP" name="class-wp-error.php" src="/private/var/www/paperless/wp-includes/class-wp-error.php"><scope doc="WordPress Error class.&#10;&#10;Container for checking for WordPress errors and error messages. Return&#10;WP_Error and use {@link is_wp_error()} to check if this class is returned.&#10;Many core WordPress functions pass this class in the event of an error and&#10;if not handled properly will result in code errors.&#10;&#10;@package WordPress&#10;@since 2.1.0" ilk="class" line="21" lineend="192" name="WP_Error"><variable citdl="array" doc="Stores the list of errors.&#10;&#10;@since 2.1.0&#10;@var array&#10;@access private" line="29" name="errors" /><variable citdl="array" doc="Stores the list of data for error codes.&#10;&#10;@since 2.1.0&#10;@var array&#10;@access private" line="38" name="error_data" /><scope attributes="__ctor__" doc="Constructor - Sets up error message.&#10;&#10;If code parameter is empty then nothing will be done. It is possible to&#10;add multiple messages to the same code, but with other methods in the&#10;class.&#10;&#10;All parameters are optional, but if the code parameter is set, then the&#10;data parameter is optional.&#10;&#10;@since 2.1.0&#10;&#10;@param string|int $code Error code&#10;@param string $message Error message&#10;@param mixed $data Optional. Error data.&#10;@return WP_Error" ilk="function" line="57" lineend="65" name="__construct" returns="WP_Error" signature="WP_Error __construct($code = '', string $message = '', mixed $data = '')"><variable default="''" ilk="argument" line="57" name="code" /><variable citdl="string" default="''" ilk="argument" line="57" name="message" /><variable citdl="mixed" default="''" ilk="argument" line="57" name="data" /></scope><scope doc="Retrieve all error codes.&#10;&#10;@since 2.1.0&#10;@access public&#10;&#10;@return array List of error codes, if available." ilk="function" line="75" lineend="80" name="get_error_codes" returns="array" signature="array get_error_codes()" /><scope doc="Retrieve first error code available.&#10;&#10;@since 2.1.0&#10;@access public&#10;&#10;@return string|int Empty string, if no error codes." ilk="function" line="90" lineend="97" name="get_error_code" returns="string" signature="string get_error_code()"><variable citdl="this.get_error_codes()" line="91" name="codes" /></scope><scope doc="Retrieve all error messages or error messages matching code.&#10;&#10;@since 2.1.0&#10;&#10;@param string|int $code Optional. Retrieve messages matching code, if exists.&#10;@return array Error strings on success, or empty array on failure (if using code parameter)." ilk="function" line="107" lineend="121" name="get_error_messages" returns="array" signature="array get_error_messages($code = '')"><variable default="''" ilk="argument" line="107" name="code" /><variable attributes="__not_yet_defined__" line="111" name="messages" /><variable citdl="array()" line="110" name="all_messages" /></scope><scope doc="Get single error message.&#10;&#10;This will get the first message available for the code. If no code is&#10;given then the first code available will be used.&#10;&#10;@since 2.1.0&#10;&#10;@param string|int $code Optional. Error code to retrieve message.&#10;@return string" ilk="function" line="134" lineend="141" name="get_error_message" returns="string" signature="string get_error_message($code = '')"><variable default="''" ilk="argument" line="134" name="code" /><variable citdl="this.get_error_messages()" line="137" name="messages" /></scope><scope doc="Retrieve error data for error code.&#10;&#10;@since 2.1.0&#10;&#10;@param string|int $code Optional. Error code.&#10;@return mixed Null, if no errors." ilk="function" line="151" lineend="158" name="get_error_data" returns="mixed" signature="mixed get_error_data($code = '')"><variable default="''" ilk="argument" line="151" name="code" /></scope><scope doc="Append more error messages to list of error messages.&#10;&#10;@since 2.1.0&#10;@access public&#10;&#10;@param string|int $code Error code.&#10;@param string $message Error message.&#10;@param mixed $data Optional. Error data." ilk="function" line="170" lineend="174" name="add" signature="add($code, string $message, mixed $data = '')"><variable ilk="argument" line="170" name="code" /><variable citdl="string" ilk="argument" line="170" name="message" /><variable citdl="mixed" default="''" ilk="argument" line="170" name="data" /></scope><scope doc="Add data for error code.&#10;&#10;The error code can only contain one error data.&#10;&#10;@since 2.1.0&#10;&#10;@param mixed $data Error data.&#10;@param string|int $code Error code." ilk="function" line="186" lineend="191" name="add_data" signature="add_data(mixed $data, $code = '')"><variable citdl="mixed" ilk="argument" line="186" name="data" /><variable default="''" ilk="argument" line="186" name="code" /></scope></scope><scope doc="Check whether variable is a WordPress Error.&#10;&#10;Returns true if $thing is an object of the WP_Error class.&#10;&#10;@since 2.1.0&#10;&#10;@param mixed $thing Check if unknown variable is a WP_Error object.&#10;@return bool True, if WP_Error. False, if not WP_Error." ilk="function" line="204" lineend="208" name="is_wp_error" returns="bool" signature="bool is_wp_error(mixed $thing)"><variable citdl="mixed" ilk="argument" line="204" name="thing" /></scope></scope>