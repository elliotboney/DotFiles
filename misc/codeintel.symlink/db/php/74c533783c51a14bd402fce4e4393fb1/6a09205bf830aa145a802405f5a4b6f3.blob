l="_get_random_header_data()" line="949" name="random_image" /></scope><scope doc="Check if random header image is in use.&#10;&#10;Always true if user expressly chooses the option in Appearance &gt; Header.&#10;Also true if theme has multiple header images registered, no specific header image&#10;is chosen, and theme turns on random headers with add_theme_support().&#10;&#10;@since 3.2.0&#10;&#10;@param string $type The random pool to use. any|default|uploaded&#10;@return boolean" ilk="function" line="967" lineend="981" name="is_random_header_image" returns="boolean" signature="boolean is_random_header_image(string $type = 'any')"><variable citdl="string" default="'any'" ilk="argument" line="967" name="type" /><variable citdl="get_theme_mod()" line="968" name="header_image_mod" /></scope><scope doc="Display header image URL.&#10;&#10;@since 2.1.0" ilk="function" line="988" lineend="990" name="header_image" signature="header_image()" /><scope doc="Get the header images uploaded for the current theme.&#10;&#10;@since 3.2.0&#10;&#10;@return array" ilk="function" line="999" lineend="1023" name="get_uploaded_header_images" returns="array" signature="array get_uploaded_header_images()"><variable citdl="esc_url_raw()" line="1009" name="url" /><variable citdl="array()" line="1000" name="header_images" /><variable attributes="__not_yet_defined__" line="1008" name="header" /><variable citdl="wp_get_attachment_metadata()" line="1010" name="header_data" /><variable citdl="basename()" line="1011" name="header_index" /><variable citdl="get_posts()" line="1003" name="headers" /></scope><scope doc="Get the header image data.&#10;&#10;@since 3.4.0&#10;&#10;@return object" ilk="function" line="1032" lineend="1064" name="get_custom_header" returns="object" signature="object get_custom_header()"><variable attributes="__not_yet_defined__" line="1044" name="default_header" /><variable citdl="vsprintf()" line="1045" name="url" /><variable citdl="array()" line="1040" name="directory_args"