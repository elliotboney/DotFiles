<scope ilk="blob" lang="PHP" name="author-template.php" src="/private/var/www/paperless/wp-includes/author-template.php"><scope doc="Retrieve the author of the current post.&#10;&#10;@since 1.5&#10;@uses $authordata The current author's DB object.&#10;@uses apply_filters() Calls 'the_author' hook on the author display name.&#10;&#10;@param string $deprecated Deprecated.&#10;@return string The author's display name." ilk="function" line="23" lineend="30" name="get_the_author" returns="string" signature="string get_the_author(string $deprecated = '')"><variable citdl="string" default="''" ilk="argument" line="23" name="deprecated" /><variable attributes="__not_yet_defined__" line="24" name="authordata" /></scope><scope doc="Display the name of the author of the current post.&#10;&#10;The behavior of this function is based off of old functionality predating&#10;get_the_author(). This function is not deprecated, but is designed to echo&#10;the value from get_the_author() and as an result of any old theme that might&#10;still use the old behavior will also pass the value from get_the_author().&#10;&#10;The normal, expected behavior of this function is to echo the author and not&#10;return it. However, backwards compatibility has to be maintained.&#10;&#10;@since 0.71&#10;@see get_the_author()&#10;@link http://codex.wordpress.org/Template_Tags/the_author&#10;&#10;@param string $deprecated Deprecated.&#10;@param string $deprecated_echo Deprecated. Use get_the_author(). Echo the string or return it.&#10;@return string The author's display name, from get_the_author()." ilk="function" line="51" lineend="59" name="the_author" returns="string" signature="string the_author(string $deprecated = '', string $deprecated_echo = true)"><variable citdl="string" default="''" ilk="argument" line="51" name="deprecated" /><variable citdl="string" default="true" ilk="argument" line="51" name="deprecated_echo" /></scope><scope doc="Retrieve the author who last edited the current post.&#10;&#10;@since 2.8&#10;@uses $post The current post's DB object.&#10;@uses get_post_meta() Retrieves the ID of the author who last edited the current post.&#10;@uses get_userdata() Retrieves the author's DB object.&#10;@uses apply_filters() Calls 'the_modified_author' hook on the author display name.&#10;@return string The author's display name." ilk="function" line="71" lineend="76" name="get_the_modified_author" returns="string" signature="string get_the_modified_author()"><variable citdl="get_userdata()" line="73" name="last_user" /><variable line="72" name="last_id" /></scope><scope doc="Display the name of the author who last edited the current post.&#10;&#10;@since 2.8&#10;@see get_the_author()&#10;@return string The author's display name, from get_the_modified_author()." ilk="function" line="85" lineend="87" name="the_modified_author" returns="string" signature="string the_modified_author()" /><scope doc="Retrieve the requested data of the author of the current post.&#10;@link http://codex.wordpress.org/Template_Tags/the_author_meta&#10;@since 2.8.0&#10;@uses $authordata The current author's DB object (if $user_id not specified).&#10;@param string $field selects the field of the users record.&#10;@param int $user_id Optional. User ID.&#10;@return string The author's field from the current author's DB object." ilk="function" line="98" lineend="112" name="get_the_author_meta" returns="string" signature="string get_the_author_meta(string $field = '', int $user_id = false)"><variable citdl="string" default="''" ilk="argument" line="98" name="field" /><variable citdl="int" default="false" ilk="argument" line="98" name="user_id" /><variable line="109" name="value" /><variable attributes="__not_yet_defined__" citdl="get_userdata()" line="100" name="authordata" /></scope><scope doc="Retrieve the requested data of the author of the current post.&#10;@link http://codex.wordpress.org/Template_Tags/the_author_meta&#10;@since 2.8.0&#10;@param string $field selects the field of the users record.&#10;@param int $user_id Optional. User ID.&#10;@echo string The author's field from the current author's DB object." ilk="function" line="122" lineend="124" name="the_author_meta" signature="the_author_meta(string $field = '', int $user_id = false)"><variable citdl="string" default="''" ilk="argument" line="122" name="field" /><variable citdl="int" default="false" ilk="argument" line="122" name="user_id" /></scope><scope doc="Retrieve either author's link or author's name.&#10;&#10;If the author has a home page set, return an HTML link, otherwise just return the&#10;author's name.&#10;&#10;@uses get_the_author_meta()&#10;@uses get_the_author()" ilk="function" line="135" lineend="141" name="get_the_author_link" returns="string" signature="get_the_author_link()" /><scope doc="Display either author's link or author's name.&#10;&#10;If the author has a home page set, echo an HTML link, otherwise just echo the&#10;author's name.&#10;&#10;@link http://codex.wordpress.org/Template_Tags/the_author_link&#10;@since 2.1&#10;@uses get_the_author_link()" ilk="function" line="153" lineend="155" name="the_author_link" signature="the_author_link()" /><scope doc="Retrieve the number of posts by the author of the current post.&#10;&#10;@since 1.5&#10;@uses $post The current post in the Loop's DB object.&#10;@uses count_user_posts()&#10;@return int The number of posts by the author." ilk="function" line="165" lineend="167" name="get_the_author_posts" returns="int" signature="int get_the_author_posts()" /><scope doc="Display the number of posts by the author of the current post.&#10;&#10;@link http://codex.wordpress.org/Template_Tags/the_author_posts&#10;@since 0.71&#10;@uses get_the_author_posts() Echoes returned value from function." ilk="function" line="176" lineend="178" name="the_author_posts" signature="the_author_posts()" /><scope doc="Display an HTML link to the author page of the author of the current post.&#10;&#10;Does just echo get_author_posts_url() function, like the others do. The&#10;reason for this, is that another function is used to help in printing the&#10;link to the author's posts.&#10;&#10;@link http://codex.wordpress.org/Template_Tags/the_author_posts_link&#10;@since 1.2.0&#10;@uses $authordata The current author's DB object.&#10;@uses get_author_posts_url()&#10;@uses get_the_author()&#10;@param string $deprecated Deprecated." ilk="function" line="194" lineend="208" name="the_author_posts_link" signature="the_author_posts_link(string $deprecated = '')"><variable citdl="string" default="''" ilk="argument" line="194" name="deprecated" /><variable citdl="sprintf()" line="206" name="link" /><variable attributes="__not_yet_defined__" line="198" name="authordata" /></scope><scope doc="Retrieve the URL to the author page for the user with the ID provided.&#10;&#10;@since 2.1.0&#10;@uses $wp_rewrite WP_Rewrite&#10;@return string The URL to the author's page." ilk="function" line="217" lineend="238" name="get_author_posts_url" returns="string" signature="string get_author_posts_url($author_id, $author_nicename = '')"><variable ilk="argument" line="217" name="author_id" /><variable default="''" ilk="argument" line="217" name="author_nicename" /><variable attributes="__not_yet_defined__" line="218" name="wp_rewrite" /><variable citdl="home_url()" line="223" name="file" /><variable citdl="wp_rewrite.get_author_permastruct()" line="220" name="link" /><variable citdl="get_userdata()" line="227" name="user" /><variable citdl="int" line="219" name="auth_ID" /></scope><scope doc="List all the authors of the blog, with several options available.&#10;&#10;&lt;ul&gt;&#10;&lt;li&gt;optioncount (boolean) (false): Show the count in parenthesis next to the&#10;author's name.&lt;/li&gt;&#10;&lt;li&gt;exclude_admin (boolean) (true): Exclude the 'admin' user that is&#10;installed by default.&lt;/li&gt;&#10;&lt;li&gt;show_fullname (boolean) (false): Show their full names.&lt;/li&gt;&#10;&lt;li&gt;hide_empty (boolean) (true): Don't show authors without any posts.&lt;/li&gt;&#10;&lt;li&gt;feed (string) (''): If isn't empty, show links to author's feeds.&lt;/li&gt;&#10;&lt;li&gt;feed_image (string) (''): If isn't empty, use this image to link to&#10;feeds.&lt;/li&gt;&#10;&lt;li&gt;echo (boolean) (true): Set to false to return the output, instead of&#10;echoing.&lt;/li&gt;&#10;&lt;li&gt;style (string) ('list'): Whether to display list of authors in list form&#10;or as a string.&lt;/li&gt;&#10;&lt;li&gt;html (bool) (true): Whether to list the items in html form or plaintext.&#10;&lt;/li&gt;&#10;&lt;/ul&gt;&#10;&#10;@link http://codex.wordpress.org/Template_Tags/wp_list_authors&#10;@since 1.2.0&#10;@param array $args The argument array.&#10;@return null|string The output, if echo is set to false." ilk="function" line="266" lineend="362" name="wp_list_authors" returns="null" signature="null wp_list_authors(array $args = '')"><variable citdl="array" default="''" ilk="argument" line="266" name="args" /><variable attributes="__not_yet_defined__" line="308" name="html" /><variable attributes="__not_yet_defined__" line="320" name="feed" /><variable citdl="title" line="328" name="alt" /><variable citdl="wp_array_slice_assoc()" line="282" name="query_args" /><variable citdl="get_users()" line="284" name="authors" /><variable citdl="array()" line="275" name="defaults" /><variable attributes="__not_yet_defined__" line="267" name="wpdb" /><variable attributes="__not_yet_defined__" line="303" name="show_fullname" /><variable citdl="get_userdata()" line="291" name="author" /><variable attributes="__not_yet_defined__" line="358" name="echo" /><variable attributes="__not_yet_defined__" line="349" name="optioncount" /><variable citdl="array()" line="286" name="author_count" /><variable attributes="__not_yet_defined__" line="320" name="feed_image" /><variable attributes="__not_yet_defined__" line="314" name="style" /><variable attributes="__not_yet_defined__" line="287" name="row" /><variable citdl="string" line="280" name="return" /><variable line="296" name="posts" /><variable attributes="__not_yet_defined__" line="298" name="hide_empty" /><variable citdl="string" line="301" name="link" /><variable attributes="__not_yet_defined__" line="293" name="exclude_admin" /><variable attributes="__not_yet_defined__" line="290" name="author_id" /><variable citdl="string" line="330" name="title" /><variable citdl="feed" line="303" name="name" /></scope><scope doc="Does this site have more than one author&#10;&#10;Checks to see if more than one author has published posts.&#10;&#10;@since 3.2.0&#10;@return bool Whether or not we have more than one author" ilk="function" line="372" lineend="382" name="is_multi_author" returns="bool" signature="bool is_multi_author()"><variable citdl="int" line="375" name="is_multi_author" /><variable attributes="__not_yet_defined__" line="373" name="wpdb" /><variable citdl="array()" line="376" name="rows" /></scope><scope doc="Helper function to clear the cache for number of authors.&#10;&#10;@private" ilk="function" line="389" lineend="391" name="__clear_multi_author_cache" signature="__clear_multi_author_cache()" /></scope>