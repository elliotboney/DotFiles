 of the admin bar.&#10;&#10;This can be called immediately upon plugin load. It does not need to be called from a function hooked to the init action.&#10;&#10;@since 3.1.0&#10;&#10;@param bool $show Whether to allow the admin bar to show.&#10;@return void" ilk="function" line="717" lineend="720" name="show_admin_bar" signature="void show_admin_bar(bool $show)"><variable citdl="bool" ilk="argument" line="717" name="show" /><variable attributes="__not_yet_defined__" citdl="boolean" line="718" name="show_admin_bar" /></scope><scope doc="Determine whether the admin bar should be showing.&#10;&#10;@since 3.1.0&#10;&#10;@return bool Whether the admin bar should be showing." ilk="function" line="729" lineend="751" name="is_admin_bar_showing" returns="bool" signature="bool is_admin_bar_showing()"><variable attributes="__not_yet_defined__" citdl="boolean" line="730" name="show_admin_bar" /><variable attributes="__not_yet_defined__" line="730" name="pagenow" /></scope><scope doc="Retrieve the admin bar display preference of a user.&#10;&#10;@since 3.1.0&#10;@access private&#10;&#10;@param string $context Context of this preference check. Defaults to 'front'. The 'admin'&#10;	preference is no longer used.&#10;@param int $user Optional. ID of the user to check, defaults to 0 for current user.&#10;@return bool Whether the admin bar should be showing for this user." ilk="function" line="764" lineend="770" name="_get_admin_bar_pref" returns="bool" signature="bool _get_admin_bar_pref(string $context = 'front', int $user = 0)"><variable citdl="string" default="'front'" ilk="argument" line="764" name="context" /><variable citdl="int" default="0" ilk="argument" line="764" name="user" /><variable citdl="get_user_option()" line="765" name="pref" /></scope></scope>