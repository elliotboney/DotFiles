ment" line="2228" name="scheme" /><variable citdl="scheme" line="2229" name="orig_scheme" /></scope><scope doc="Get the URL to the user's dashboard.&#10;&#10;If a user does not belong to any site, the global user dashboard is used. If the user belongs to the current site,&#10;the dashboard for the current site is returned. If the user cannot edit the current site, the dashboard to the user's&#10;primary blog is returned.&#10;&#10;@since 3.1.0&#10;&#10;@param int $user_id User ID&#10;@param string $path Optional path relative to the dashboard. Use only paths known to both blog and user admins.&#10;@param string $scheme The scheme to use. Default is 'admin', which obeys force_ssl_admin() and is_ssl(). 'http' or 'https' can be passed to force those schemes.&#10;@return string Dashboard url link with optional path appended." ilk="function" line="2270" lineend="2292" name="get_dashboard_url" returns="string" signature="string get_dashboard_url(int $user_id, string $path = '', string $scheme = 'admin')"><variable citdl="int" ilk="argument" line="2270" name="user_id" /><variable citdl="string" default="''" ilk="argument" line="2270" name="path" /><variable citdl="string" default="'admin'" ilk="argument" line="2270" name="scheme" /><variable citdl="get_current_blog_id()" line="2279" name="current_blog" /><variable citdl="admin_url()" line="2275" name="url" /><variable citdl="get_blogs_of_user()" line="2273" name="blogs" /><variable citdl="get_active_blog_for_user()" line="2283" name="active" /></scope><scope doc="Get the URL to the user's profile editor.&#10;&#10;@since 3.1.0&#10;&#10;@param int $user User ID&#10;@param string $scheme The scheme to use. Default is 'admin', which obeys force_ssl_admin() and is_ssl(). 'http' or 'https' can be passed to force those schemes.&#10;@return string Dashboard url link with optional path appended." ilk="function" line="2303" lineend="2314" name="get_edit_profile_url" returns="string" signature="string get_edit_profile_url(int $user, s