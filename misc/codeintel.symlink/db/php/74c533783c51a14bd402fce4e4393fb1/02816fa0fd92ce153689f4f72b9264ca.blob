 mapping&#10;&#10;@access private&#10;@return string" ilk="function" line="628" lineend="631" name="_map" returns="string" signature="string _map()"><variable citdl="array()" line="629" name="callback" /></scope><scope doc="preg_replace_callback hook&#10;&#10;@access public&#10;@param  array $matches preg_replace regexp matches&#10;@return string" ilk="function" line="640" lineend="643" name="callback" returns="string" signature="string callback(array $matches)"><variable citdl="array" ilk="argument" line="640" name="matches" /><variable citdl="intval()" line="641" name="index" /></scope></scope></scope>