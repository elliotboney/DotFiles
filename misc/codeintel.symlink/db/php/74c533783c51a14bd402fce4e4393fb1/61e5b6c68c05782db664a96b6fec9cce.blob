 the feed URL along with cache&#10;options directly into the constructor. This has been removed as of 1.3 as&#10;it caused a lot of confusion.&#10;&#10;@since 1.0 Preview Release" ilk="function" line="685" lineend="713" name="__construct" signature="__construct()"><variable citdl="defined()" line="699" name="level" /><variable citdl="func_get_args()" line="702" name="args" /></scope><scope attributes="public" doc="Used for converting object to a string" ilk="function" line="718" lineend="721" name="__toString" returns="md5()" signature="__toString()" /><scope attributes="public" doc="Remove items that link back to this before destroying this object" ilk="function" line="726" lineend="747" name="__destruct" signature="__destruct()"><variable attributes="__not_yet_defined__" line="732" name="item" /></scope><scope attributes="public" doc="Force the given data/URL to be treated as a feed&#10;&#10;This tells SimplePie to ignore the content-type provided by the server.&#10;Be careful when using this option, as it will also disable autodiscovery.&#10;&#10;@since 1.1&#10;@param bool $enable Force the given data/URL to be treated as a feed" ilk="function" line="758" lineend="761" name="force_feed" signature="force_feed(bool $enable = false)"><variable citdl="bool" default="false" ilk="argument" line="758" name="enable" /></scope><scope attributes="public" doc="Set the URL of the feed you want to parse&#10;&#10;This allows you to enter the URL of the feed you want to parse, or the&#10;website you want to try to use auto-discovery on. This takes priority&#10;over any set raw data.&#10;&#10;You can set multiple feeds to mash together by passing an array instead&#10;of a string for the $url. Remember that with each additional feed comes&#10;additional processing and resources.&#10;&#10;@since 1.0 Preview Release&#10;@see set_raw_data()&#10;@param string|array $url This is the URL (or array of URLs) that you want to parse." ilk="function" line="778" lineend="792" name="set_feed_url" signature="set_feed_url($url)"><variable ilk="argument" line="778" name="url" /><variable attributes="__not_yet_defined__" line="783" name="value" /></scope><scope attributes="public" doc="Set an instance of {@see SimplePie_File} to use as a feed&#10;&#10;@param SimplePie_File &amp;$file&#10;@return bool True on success, false on failure" ilk="function" line="800" lineend="809" name="set_file" returns="bool" signature="bool set_file(&amp; $file)"><variable ilk="argument" line="800" name="file" /></scope><scope attributes="public" doc="Set the raw XML data to parse&#10;&#10;Allows you to use a string of RSS/Atom data instead of a remote feed.&#10;&#10;If you have a feed available as a string in PHP, you can tell SimplePie&#10;to parse that data string instead of a remote feed. Any set feed URL&#10;takes precedence.&#10;&#10;@since 1.0 Beta 3&#10;@param string $data RSS or Atom data as a string.&#10;@see set_feed_url()" ilk="function" line="824" lineend="827" name="set_raw_data" signature="set_raw_data(string $data)"><variable citdl="string" ilk="argument" line="824" name="data" /></scope><scope attributes="public" doc="Set the the default timeout for fetching remote feeds&#10;&#10;This allows you to change the maximum time the feed's server to respond&#10;and send the feed back.&#10;&#10;@since 1.0 Beta 3&#10;@param int $timeout The maximum number of seconds to spend waiting to retrieve a feed." ilk="function" line="838" lineend="841" name="set_timeout" signature="set_timeout(int $timeout = 10)"><variable citdl="int" default="10" ilk="argument" line="838" name="timeout" /></scope><scope attributes="public" doc="Force SimplePie to use fsockopen() instead of cURL&#10;&#10;@since 1.0 Beta 3&#10;@param bool $enable Force fsockopen() to be used" ilk="function" line="849" lineend="852" name="force_fsockopen" signature="force_fsockopen(bool $enable = false)"><variable citdl="bool" default="false" ilk="argument" line="849" name="enable" /></scope><scope attributes="public" doc="Enable/disable caching in SimplePie.&#10;&#10;This option allows you to disable caching all-together in SimplePie.&#10;However, disabling the cache can lead to longer load times.&#10;&#10;@since 1.0 Preview Release&#10;@param bool $enable Enable caching" ilk="function" line="863" lineend="866" name="enable_cache" signature="enable_cache(bool $enable = true)"><variable citdl="bool" default="true" ilk="argument" line="863" name="enable" /></scope><scope attributes="public" doc="Set the length of time (in seconds) that the contents of a feed will be&#10;cached&#10;&#10;@param int $seconds The feed content cache duration" ilk="function" line="874" lineend="877" name="set_cache_duration" signature="set_cache_duration(int $seconds = 3600)"><variable citdl="int" default="3600" ilk="argument" line="874" name="seconds" /></scope><scope attributes="public" doc="Set the length of time (in seconds) that the autodiscovered feed URL will&#10;be cached&#10;&#10;@param int $seconds The autodiscovered feed URL cache duration." ilk="function" line="885" lineend="888" name="set_autodiscovery_cache_duration" signature="set_autodiscovery_cache_duration(int $seconds = 604800)"><variable citdl="int" default="604800" ilk="argument" line="885" name="seconds" /></scope><scope attributes="public" doc="Set the file system location where the cached files should be stored&#10;&#10;@param string $location The file system location." ilk="function" line="895" lineend="898" name="set_cache_location" signature="set_cache_location(string $location = './cache')"><variable citdl="string" default="'./cache'" ilk="argument" line="895" name="location" /></scope><scope attributes="public" doc="Set whether feed items should be sorted into reverse chronological order&#10;&#10;@param bool $enable Sort as reverse chronological order." ilk="function" line="905" lineend="908" name="enable_order_by_date" signature="enable_order_by_date(bool $enable = true)"><variable citdl="bool" default="true" ilk="argument" line="905" name="enable" /></scope><scope attributes="public" doc="Set the character encoding used to parse the feed&#10;&#10;This overrides the encoding reported by the feed, however it will fall&#10;back to the normal encoding detection if the override fails&#10;&#10;@param string $encoding Character encoding" ilk="function" line="918" lineend="928" name="set_input_encoding" signature="set_input_encoding(string $encoding = false)"><variable citdl="string" default="false" ilk="argument" line="918" name="encoding" /></scope><scope attributes="public" doc="Set how much feed autodiscovery to do&#10;&#10;@see SIMPLEPIE_LOCATOR_NONE&#10;@see SIMPLEPIE_LOCATOR_AUTODISCOVERY&#10;@see SIMPLEPIE_LOCATOR_LOCAL_EXTENSION&#10;@see SIMPLEPIE_LOCATOR_LOCAL_BODY&#10;@see SIMPLEPIE_LOCATOR_REMOTE_EXTENSION&#10;@see SIMPLEPIE_LOCATOR_REMOTE_BODY&#10;@see SIMPLEPIE_LOCATOR_ALL&#10;@param int $level Feed Autodiscovery Level (level can be a combination of the above constants, see bitwise OR operator)" ilk="function" line="942" lineend="945" name="set_autodiscovery_level" signature="set_autodiscovery_level(int $level = SIMPLEPIE_LOCATOR_ALL)"><variable citdl="int" default="SIMPLEPIE_LOCATOR_ALL" ilk="argument" line="942" name="level" /></scope><scope attributes="public" doc="Get the class registry&#10;&#10;Use this to override SimplePie's default classes&#10;@see SimplePie_Registry&#10;@return SimplePie_Registry" ilk="function" line="954" lineend="957" name="get_registry" returns="SimplePie_Registry" signature="SimplePie_Registry &amp;get_registry()" /><scope attributes="public" doc="Set which class SimplePie uses for caching" ilk="function" line="970" lineend="973" name="set_cache_class" returns="this.registry.register()" signature="set_cache_class($class = 'SimplePie_Cache')"><variable default="'SimplePie_Cache'" ilk="argument" line="970" name="class" /></scope><scope attributes="public" doc="Set which class SimplePie uses for auto-discovery" ilk="function" line="978" lineend="9