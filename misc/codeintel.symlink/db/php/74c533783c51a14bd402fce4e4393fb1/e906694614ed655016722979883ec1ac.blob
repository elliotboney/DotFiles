_diff" returns="string" signature="string wp_text_diff(string $left_string, string $right_string, $args = null)"><variable citdl="string" ilk="argument" line="1703" name="left_string" /><variable citdl="string" ilk="argument" line="1703" name="right_string" /><variable default="null" ilk="argument" line="1703" name="args" /><variable citdl="explode()" line="1713" name="left_lines" /><variable citdl="explode()" line="1714" name="right_lines" /><variable citdl="string" line="1722" name="r" /><variable citdl="Text_Diff" line="1715" name="text_diff" /><variable citdl="WP_Text_Diff_Renderer_Table" line="1716" name="renderer" /><variable citdl="array()" line="1704" name="defaults" /><variable citdl="renderer.render()" line="1717" name="diff" /></scope></scope>