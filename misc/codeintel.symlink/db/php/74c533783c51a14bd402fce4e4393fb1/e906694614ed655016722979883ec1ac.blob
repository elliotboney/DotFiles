gged in user.&#10;&#10;@since 2.0.0&#10;&#10;@return bool True if user is logged in, false if not logged in." ilk="function" line="724" lineend="731" name="is_user_logged_in" returns="bool" signature="bool is_user_logged_in()"><variable citdl="wp_get_current_user()" line="725" name="user" /></scope><scope doc="Checks if a user is logged in, if not it redirects them to the login page.&#10;&#10;@since 1.5" ilk="function" line="740" lineend="789" name="auth_redirect" signature="auth_redirect()"><variable citdl="apply_filters()" line="743" name="secure" /><variable line="758" name="scheme" /><variable line="783" name="redirect" /><variable citdl="wp_login_url()" line="785" name="login_url" /><variable line="763" name="user_id" /><variable attributes="__not_yet_defined__" line="748" name="_SERVER" /></scope><scope doc="Makes sure that a user was referred from another admin page.&#10;&#10;To avoid security exploits.&#10;&#10;@since 1.2.0&#10;@uses do_action() Calls 'check_admin_referer' on $action.&#10;&#10;@param string $action Action nonce&#10;@param string $query_arg where to look for nonce in $_REQUEST (since 2.5)" ilk="function" line="804" lineend="817" name="check_admin_referer" returns="result" signature="check_admin_referer(string $action = -1, string $query_arg = '_wpnonce')"><variable citdl="string" default="-1" ilk="argument" line="804" name="action" /><variable citdl="string" default="'_wpnonce'" ilk="argument" line="804" name="query_arg" /><variable citdl="strtolower()" line="809" name="referer" /><variable citdl="strtolower()" line="808" name="adminurl" /><variable line="810" name="result" /></scope><scope doc="Verifies the AJAX request to prevent processing requests external of the blog.&#10;&#10;@since 2.0.3&#10;&#10;@param string $action Action nonce&#10;@param string $query_arg where to look for nonce in $_REQUEST (since 2.5)" ilk="function" line="829" lineend="847" name="check_ajax_referer" returns="result" signature="check_ajax_referer(string $action =