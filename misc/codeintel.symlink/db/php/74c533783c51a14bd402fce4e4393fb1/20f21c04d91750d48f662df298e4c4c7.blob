 options.&#10;@param int|object $post Optional. Post that the comment is going to be displayed on.&#10;@return string|bool|null Link to show comment form, if successful. False, if comments are closed." ilk="function" line="1126" lineend="1128" name="post_reply_link" returns="string" signature="string post_reply_link(array $args = array(), $post = null)"><variable citdl="array" default="array()" ilk="argument" line="1126" name="args" /><variable default="null" ilk="argument" line="1126" name="post" /></scope><scope doc="Retrieve HTML content for cancel comment reply link.&#10;&#10;@since 2.7.0&#10;&#10;@param string $text Optional. Text to display for cancel reply link." ilk="function" line="1137" lineend="1144" name="get_cancel_comment_reply_link" returns="apply_filters()" signature="get_cancel_comment_reply_link(string $text = '')"><variable citdl="string" default="''" ilk="argument" line="1137" name="text" /><variable line="1141" name="style" /><variable citdl="esc_html()" line="1142" name="link" /></scope><scope doc="Display HTML content for cancel comment reply link.&#10;&#10;@since 2.7.0&#10;&#10;@param string $text Optional. Text to display for cancel reply link." ilk="function" line="1153" lineend="1155" name="cancel_comment_reply_link" signature="cancel_comment_reply_link(string $text = '')"><variable citdl="string" default="''" ilk="argument" line="1153" name="text" /></scope><scope doc="Retrieve hidden input HTML for replying to comments.&#10;&#10;@since 3.0.0&#10;&#10;@return string Hidden input HTML for replying to comments" ilk="function" line="1164" lineend="1172" name="get_comment_id_fields" returns="string" signature="string get_comment_id_fields($id = 0)"><variable default="0" ilk="argument" line="1164" name="id" /><variable line="1168" name="replytoid" /><variable citdl="string" line="1169" name="result" /></scope><scope doc="Output hidden input HTML for replying to comments.&#10;&#10;@since 2.7.0&#10;@see get_comment_id_fields() Echoes result" ilk