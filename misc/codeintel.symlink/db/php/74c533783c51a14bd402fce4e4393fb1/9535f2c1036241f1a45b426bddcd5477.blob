<scope ilk="blob" lang="PHP" name="class-wp-image-editor.php" src="/private/var/www/paperless/wp-includes/class-wp-image-editor.php"><scope attributes="abstract" doc="Base image editor class from which implementations extend&#10;&#10;@since 3.5.0" ilk="class" line="14" lineend="402" name="WP_Image_Editor"><variable attributes="protected" citdl="file" line="15" name="file" /><variable attributes="protected" citdl="array()" line="16" name="size" /><variable attributes="protected" line="17" name="mime_type" /><variable attributes="protected" citdl="string" line="18" name="default_mime_type" /><variable attributes="protected" citdl="int" line="19" name="quality" /><scope attributes="public __ctor__" doc="Each instance handles a single file." ilk="function" line="24" lineend="26" name="__construct" signature="__construct($file)"><variable ilk="argument" line="24" name="file" /></scope><scope attributes="public static" doc="Checks to see if current environment supports the editor chosen.&#10;Must be overridden in a sub-class.&#10;&#10;@since 3.5.0&#10;@access public&#10;@abstract&#10;&#10;@param array $args&#10;@return boolean" ilk="function" line="39" lineend="41" name="test" returns="boolean" signature="boolean test(array $args = array())"><variable citdl="array" default="array()" ilk="argument" line="39" name="args" /></scope><scope attributes="public static" doc="Checks to see if editor supports the mime-type specified.&#10;Must be overridden in a sub-class.&#10;&#10;@since 3.5.0&#10;@access public&#10;@abstract&#10;&#10;@param string $mime_type&#10;@return boolean" ilk="function" line="54" lineend="56" name="supports_mime_type" returns="boolean" signature="boolean supports_mime_type(string $mime_type)"><variable citdl="string" ilk="argument" line="54" name="mime_type" /></scope><scope attributes="abstract public" doc="Loads image from $this-&gt;file into editor.&#10;&#10;@since 3.5.0&#10;@access protected&#10;@abstract&#10;&#10;@return boolean|WP_Error True if loaded