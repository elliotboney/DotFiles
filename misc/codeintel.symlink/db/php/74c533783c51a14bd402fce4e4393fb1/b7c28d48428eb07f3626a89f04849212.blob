 citdl="array()" line="369" name="keys" /><scope attributes="public" doc="Method to implement ArrayAccess for keys formerly returned by get_themes().&#10;&#10;Author, Author Name, Author URI, and Description did not previously return&#10;translated data. We are doing so now as it is safe to do. However, as&#10;Name and Title could have been used as the key for get_themes(), both remain&#10;untranslated for back compatibility. This means that ['Name'] is not ideal,&#10;and care should be taken to use $theme-&gt;display('Name') to get a properly&#10;translated header." ilk="function" line="384" lineend="427" name="offsetGet" returns="this.get()" signature="offsetGet($offset)"><variable ilk="argument" line="384" name="offset" /></scope><scope attributes="public" doc="Returns errors property.&#10;&#10;@since 3.4.0&#10;@access public&#10;&#10;@return WP_Error|bool WP_Error if there are errors, or false." ilk="function" line="437" lineend="439" name="errors" returns="WP_Error" signature="WP_Error errors()" /><scope attributes="public" doc="Whether the theme exists.&#10;&#10;A theme with errors exists. A theme with the error of 'theme_not_found',&#10;meaning that the theme's directory was not found, does not exist.&#10;&#10;@since 3.4.0&#10;@access public&#10;&#10;@return bool Whether the theme exists." ilk="function" line="452" lineend="454" name="exists" returns="bool" signature="bool exists()" /><scope attributes="private" doc="Adds theme data to cache.&#10;&#10;Cache entries keyed by the theme and the type of data.&#10;&#10;@access private&#10;@since 3.4.0&#10;&#10;@param string $key Type of data to store (theme, screenshot, headers, page_templates)&#10;@param string $data Data to store&#10;@return bool Return value from wp_cache_add()" ilk="function" line="480" lineend="482" name="cache_add" returns="bool" signature="bool cache_add(string $key, string $data)"><variable citdl="string" ilk="argument" line="480" name="key" /><variable citdl="string" ilk="argument" line="480" name="data" /></scope><scope attributes="private" doc="Gets theme data from cache.&#10;&#10;Cache entries are keyed by the theme and the type of data.&#10;&#10;@access private&#10;@since 3.4.0&#10;&#10;@param string $key Type of data to retrieve (theme, screenshot, headers, page_templates)&#10;@return mixed Retrieved data" ilk="function" line="495" lineend="497" name="cache_get" returns="mixed" signature="mixed cache_get(string $key)"><variable citdl="string" ilk="argument" line="495" name="key" /></scope><scope attributes="public" doc="Clears the cache for the theme.&#10;&#10;@access public&#10;@since 3.4.0" ilk="function" line="505" lineend="511" name="cache_delete" signature="cache_delete()"><variable attributes="__not_yet_defined__" line="506" name="key" /></scope><scope attributes="public" doc="Get a raw, unformatted theme header.&#10;&#10;The header is sanitized, but is not translated, and is not marked up for display.&#10;To get a theme header for display, use the display() method.&#10;&#10;Use the get_template() method, not the 'Template' header, for finding the template.&#10;The 'Template' header is only good for what was written in the style.css, while&#10;get_template() takes into account where WordPress actually located the theme and&#10;whether it is actually valid.&#10;&#10;@access public&#10;@since 3.4.0&#10;&#10;@param string $header Theme header. Name, Description, Author, Version, ThemeURI, AuthorURI, Status, Tags.&#10;@return string String on success, false on failure." ilk="function" line="530" lineend="553" name="get" returns="string" signature="string get(string $header)"><variable citdl="string" ilk="argument" line="530" name="header" /><variable attributes="__not_yet_defined__" line="545" name="_header" /></scope><scope attributes="public" doc="Gets a theme header, formatted and translated for display.&#10;&#10;@access public&#10;@since 3.4.0&#10;&#10;@param string $header Theme header. Name, Description, Author, Version, ThemeURI, AuthorURI, Status, Tags.&#10;@param bool $markup Optional. Whether to mark up the header. Defaults to true.&#10;@param bool $translate Optional. Whether to translate the header. Defaults to true.&#10;@return string Processed header, false on failure." ilk="function" line="566" lineend="579" name="display" returns="string" signature="string display(string $header, bool $markup = true, bool $translate = true)"><variable citdl="string" ilk="argument" line="566" name="header" /><variable citdl="bool" default="true" ilk="argument" line="566" name="markup" /><variable citdl="bool" default="true" ilk="argument" line="566" name="translate" /><variable citdl="this.get()" line="567" name="value" /></scope><scope attributes="private" doc="Sanitize a theme header.&#10;&#10;@param string $header Theme header. Name, Description, Author, Version, ThemeURI, AuthorURI, Status, Tags.&#10;@param string $value Value to sanitize." ilk="function" line="587" lineend="628" name="sanitize_header" returns="value" signature="sanitize_header(string $header, string $value)"><variable citdl="string" ilk="argument" line="587" name="header" /><variable citdl="string" ilk="argument" line="587" name="value" /></scope><variable attributes="static" citdl="array()" line="602" name="header_tags" /><variable attributes="static" citdl="array()" line="615" name="header_tags_with_a" /><scope attributes="private" doc="Mark up a theme header.&#10;&#10;@access private&#10;@since 3.4.0&#10;&#10;@param string $header Theme header. Name, Description, Author, Version, ThemeURI, AuthorURI, Status, Tags.&#10;@param string $value Value to mark up.&#10;@param string $translate Whether the header has been translated.&#10;@return string Value, marked up." ilk="function" line="641" lineend="675" name="markup_header" returns="string" signature="string markup_header(string $header, string $value, string $translate)"><variable citdl="string" ilk="argument" line="641" name="header" /><variable citdl="string" ilk="argument" line="