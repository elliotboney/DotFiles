<scope attributes="private" doc="Outputs debugging info via user-defined method&#10;@param string $str" ilk="function" line="117" lineend="123" name="edebug" signature="edebug(string $str)"><variable citdl="string" ilk="argument" line="117" name="str" /></scope><scope attributes="public __ctor__" doc="Initialize the class so that the data is in a known state.&#10;@access public&#10;@return SMTP" ilk="function" line="130" lineend="136" name="__construct" returns="SMTP" signature="SMTP __construct()" /><scope attributes="public" doc="Connect to the server specified on the port specified.&#10;If the port is not specified use the default SMTP_PORT.&#10;If tval is specified then a connection will try and be&#10;established with the server for that number of seconds.&#10;If tval is not specified the default is 30 seconds to&#10;try on the connection.&#10;&#10;SMTP CODE SUCCESS: 220&#10;SMTP CODE FAILURE: 421&#10;@access public&#10;@param string $host&#10;@param int $port&#10;@param int $tval&#10;@return bool" ilk="function" line="158" lineend="208" name="Connect" returns="bool" signature="bool Connect(string $host, int $port = 0, int $tval = 30)"><variable citdl="string" ilk="argument" line="158" name="host" /><variable citdl="int" default="0" ilk="argument" line="158" name="port" /><variable citdl="int" default="30" ilk="argument" line="158" name="tval" /><variable citdl="this.get_lines()" line="201" name="announce" /><variable citdl="ini_get()" line="193" name="max" /></scope><variable line="178" name="port" /><variable line="178" name="errstr" /><variable line="178" name="errno" /><scope attributes="public" doc="Initiate a TLS communication with the server.&#10;&#10;SMTP CODE 220 Ready to start TLS&#10;SMTP CODE 501 Syntax error (no parameters allowed)&#10;SMTP CODE 454 TLS not available due to temporary reason&#10;@access public&#10;@return bool success" ilk="function" line="219" lineend="253" name="StartTLS" returns="bool" signature="bool StartTLS()"><variable citdl=