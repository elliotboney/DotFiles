h and force deletion. Defaults to false.&#10;@return mixed False on failure" ilk="function" line="2294" lineend="2360" name="wp_delete_post" returns="mixed" signature="mixed wp_delete_post(int $postid = 0, bool $force_delete = false)"><variable citdl="int" default="0" ilk="argument" line="2294" name="postid" /><variable citdl="bool" default="false" ilk="argument" line="2294" name="force_delete" /><variable citdl="array()" line="2314" name="parent_where" /><variable attributes="__not_yet_defined__" line="2327" name="revision_id" /><variable attributes="__not_yet_defined__" line="2295" name="wpdb" /><variable citdl="wpdb.delete()" line="2342" name="result" /><variable citdl="wpdb.prepare()" line="2318" name="children_query" /><variable attributes="__not_yet_defined__" line="2351" name="child" /><variable line="2297" name="post" /><variable citdl="wpdb.get_results()" line="2319" name="children" /><variable citdl="wpdb.get_col()" line="2325" name="revision_ids" /><variable attributes="__not_yet_defined__" line="2334" name="comment_id" /><variable attributes="__not_yet_defined__" line="2338" name="mid" /><variable citdl="wpdb.get_col()" line="2337" name="post_meta_ids" /><variable citdl="wpdb.get_col()" line="2333" name="comment_ids" /><variable citdl="array()" line="2313" name="parent_data" /></scope><scope doc="Resets the page_on_front, show_on_front, and page_for_post settings when a&#10;linked page is deleted or trashed.&#10;&#10;Also ensures the post is no longer sticky.&#10;&#10;@access private&#10;@since 3.7.0&#10;@param $post_id" ilk="function" line="2372" lineend="2386" name="_reset_front_page_settings_for_post" signature="_reset_front_page_settings_for_post($post_id)"><variable ilk="argument" line="2372" name="post_id" /><variable citdl="get_post()" line="2373" name="post" /></scope><scope doc="Moves a post or page to the Trash&#10;&#10;If trash is disabled, the post or page is permanently deleted.&#10;&#10;@since 2.9.0&#10;@uses do_action() on 'trash_post' before trashing&#10;@uses do_action() on 'trashed_post' after trashing&#10;@uses wp_delete_post() if trash is disabled&#10;&#10;@param int $post_id Post ID.&#10;@return mixed False on failure" ilk="function" line="2403" lineend="2426" name="wp_trash_post" returns="mixed" signature="mixed wp_trash_post(int $post_id = 0)"><variable citdl="int" default="0" ilk="argument" line="2403" name="post_id" /><variable line="2407" name="post" /></scope><scope doc="Restores a post or page from the Trash&#10;&#10;@since 2.9.0&#10;@uses do_action() on 'untrash_post' before undeletion&#10;@uses do_action() on 'untrashed_post' after undeletion&#10;&#10;@param int $post_id Post ID.&#10;@return mixed False on failure" ilk="function" line="2438" lineend="2461" name="wp_untrash_post" returns="mixed" signature="mixed wp_untrash_post(int $post_id = 0)"><variable citdl="int" default="0" ilk="argument" line="2438" name="post_id" /><variable line="2439" name="post" /><variable citdl="get_post_meta()" line="2447" name="post_status" /></scope><scope doc="Moves comments for a post to the trash&#10;&#10;@since 2.9.0&#10;@uses do_action() on 'trash_post_comments' before trashing&#10;@uses do_action() on 'trashed_post_comments' after trashing&#10;&#10;@param int|object $post Post ID or object.&#10;@return mixed False on failure" ilk="function" line="2473" lineend="2502" name="wp_trash_post_comments" returns="mixed" signature="mixed wp_trash_post_comments($post = null)"><variable default="null" ilk="argument" line="2473" name="post" /><variable citdl="post.ID" line="2480" name="post_id" /><variable attributes="__not_yet_defined__" line="2474" name="wpdb" /><variable citdl="wpdb.get_results()" line="2484" name="comments" /><variable citdl="wpdb.update()" line="2495" name="result" /><variable citdl="array()" line="2489" name="statuses" /><variable attributes="__not_yet_defined__" line="2490" name="comment" /></scope><scope doc="Restore comments for a post from the trash&#10;&#10;@since 2.9.0&#10;@uses do