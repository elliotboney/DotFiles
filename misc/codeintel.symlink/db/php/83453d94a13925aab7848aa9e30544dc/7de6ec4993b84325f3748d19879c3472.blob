="Validate a URL for safe use in the HTTP API.&#10;&#10;@since 3.5.2&#10;&#10;@return mixed URL or false on failure." ilk="function" line="453" lineend="517" name="wp_http_validate_url" returns="mixed" signature="mixed wp_http_validate_url($url)"><variable ilk="argument" line="453" name="url" /><variable citdl="strtolower()" line="470" name="same_host" /><variable citdl="trim()" line="473" name="host" /><variable citdl="array_map()" line="482" name="parts" /><variable citdl="host" line="475" name="ip" /><variable line="468" name="parsed_home" /><variable line="458" name="parsed_url" /><variable citdl="parsed_url" line="509" name="port" /></scope><scope doc="Whitelists allowed redirect hosts for safe HTTP requests as well.&#10;&#10;Attached to the http_request_host_is_external filter.&#10;&#10;@since 3.6.0&#10;&#10;@param bool $is_external&#10;@param string $host&#10;@return bool" ilk="function" line="530" lineend="534" name="allowed_http_request_hosts" returns="bool" signature="bool allowed_http_request_hosts(bool $is_external, string $host)"><variable citdl="bool" ilk="argument" line="530" name="is_external" /><variable citdl="string" ilk="argument" line="530" name="host" /></scope><scope doc="Whitelists any domain in a multisite installation for safe HTTP requests.&#10;&#10;Attached to the http_request_host_is_external filter.&#10;&#10;@since 3.6.0&#10;&#10;@param bool $is_external&#10;@param string $host&#10;@return bool" ilk="function" line="547" lineend="558" name="ms_allowed_http_request_hosts" returns="bool" signature="bool ms_allowed_http_request_hosts(bool $is_external, string $host)"><variable citdl="bool" ilk="argument" line="547" name="is_external" /><variable citdl="string" ilk="argument" line="547" name="host" /><variable attributes="static" citdl="array()" line="549" name="queried" /><variable attributes="__not_yet_defined__" line="548" name="wpdb" /></scope></scope>