<scope ilk="blob" lang="PHP" name="script-loader.php" src="/private/var/www/kw/wp-includes/script-loader.php"><import line="25" module="/class.wp-dependencies.php" /><import line="28" module="/class.wp-scripts.php" /><import line="31" module="/functions.wp-scripts.php" /><import line="34" module="/class.wp-styles.php" /><import line="37" module="/functions.wp-styles.php" /><import line="51" module="/version.php" /><import line="536" module="/version.php" /><scope doc="Register all WordPress scripts.&#10;&#10;Localizes some of them.&#10;args order: $scripts-&gt;add( 'handle', 'url', 'dependencies', 'query-string', 1 );&#10;when last arg === 1 queues the script for the footer&#10;&#10;@since 2.6.0&#10;&#10;@param object $scripts WP_Scripts object." ilk="function" line="50" lineend="518" name="wp_default_scripts" signature="wp_default_scripts(object &amp; $scripts)"><variable citdl="object" ilk="argument" line="50" name="scripts" /><variable citdl="wp_guess_url()" line="56" name="guessurl" /><variable citdl="SCRIPT_DEBUG" line="66" name="suffix" /><variable attributes="__not_yet_defined__" line="53" name="wp_version" /><variable citdl="array()" line="243" name="uploader_l10n" /><variable line="214" name="max_upload_size" /><variable citdl="boolean" line="57" name="guessed_url" /></scope><scope doc="Assign default styles to $styles object.&#10;&#10;Nothing is returned, because the $styles parameter is passed by reference.&#10;Meaning that whatever object is passed will be updated without having to&#10;reassign the variable that was passed back to the same value. This saves&#10;memory.&#10;&#10;Adding default styles is not the only task, it also assigns the base_url&#10;property, the default version, and text direction for the object.&#10;&#10;@since 2.6.0&#10;&#10;@param object $styles" ilk="function" line="535" lineend="620" name="wp_default_styles" signature="wp_default_styles(object &amp; $styles)"><variable citdl="object" ilk="argument" line="535" name="styles" /><variable line="541" name="guessurl" /><variable citdl="SCRIPT_DEBUG" line="550" name="suffix" /><variable attributes="__not_yet_defined__" line="614" name="rtl_style" /><variable attributes="__not_yet_defined__" line="538" name="wp_version" /><variable citdl="array()" line="552" name="rtl_styles" /><variable citdl="_x()" line="570" name="subset" /><variable citdl="string" line="559" name="open_sans_font_url" /><variable citdl="string" line="565" name="subsets" /></scope><scope doc="Reorder JavaScript scripts array to place prototype before jQuery.&#10;&#10;@since 2.3.1&#10;&#10;@param array $js_array JavaScript scripts array&#10;@return array Reordered array, if needed." ilk="function" line="630" lineend="645" name="wp_prototype_before_jquery" returns="array" signature="array wp_prototype_before_jquery(array $js_array)"><variable citdl="array" ilk="argument" line="630" name="js_array" /><variable line="631" name="prototype" /><variable line="634" name="jquery" /></scope><scope doc="Load localized data on print rather than initialization.&#10;&#10;These localizations require information that may not be loaded even by init.&#10;&#10;@since 2.5.0" ilk="function" line="654" lineend="663" name="wp_just_in_time_script_localization" signature="wp_just_in_time_script_localization()" /><scope doc="Administration Screen CSS for changing the styles.&#10;&#10;If installing the 'wp-admin/' directory will be replaced with './'.&#10;&#10;The $_wp_admin_css_colors global manages the Administration Screens CSS&#10;stylesheet that is loaded. The option that is set is 'admin_color' and is the&#10;color and key for the array. The value for the color key is an object with&#10;a 'url' parameter that has the URL path to the CSS file.&#10;&#10;The query from $src parameter will be appended to the URL that is given from&#10;the $_wp_admin_css_colors array value URL.&#10;&#10;@since 2.6.0&#10;@uses $_wp_admin_css_colors&#10;&#10;@param string $src Source URL.&#10;@param string $handle Either 'colors' or 'colors-rtl'.&#10;@return string URL path to CSS stylesheet for Administration Screens." ilk="function" line="685" lineend="709" name="wp_style_loader_src" returns="string" signature="string wp_style_loader_src(string $src, string $handle)"><variable citdl="string" ilk="argument" line="685" name="src" /><variable citdl="string" ilk="argument" line="685" name="handle" /><variable attributes="__not_yet_defined__" line="690" name="_wp_admin_css_colors" /><variable citdl="get_user_option()" line="691" name="color" /><variable citdl="color.url" line="698" name="url" /><variable citdl="parse_url()" line="697" name="parsed" /></scope><scope doc="Prints the script queue in the HTML head on admin pages.&#10;&#10;Postpones the scripts that were queued for the footer.&#10;print_footer_scripts() is called in the footer to print these scripts.&#10;&#10;@since 2.8&#10;&#10;@see wp_print_scripts()" ilk="function" line="721" lineend="741" name="print_head_scripts" returns="wp_scripts.done" signature="print_head_scripts()"><variable attributes="__not_yet_defined__" line="722" name="wp_scripts" /><variable attributes="__not_yet_defined__" line="722" name="concatenate_scripts" /></scope><scope doc="Prints the scripts that were queued for the footer or too late for the HTML head.&#10;&#10;@since 2.8" ilk="function" line="748" lineend="763" name="print_footer_scripts" returns="wp_scripts.done" signature="print_footer_scripts()"><variable attributes="__not_yet_defined__" line="749" name="wp_scripts" /><variable attributes="__not_yet_defined__" line="749" name="concatenate_scripts" /></scope><scope doc="@internal use" ilk="function" line="768" lineend="794" name="_print_scripts" signature="_print_scripts()"><variable citdl="compress_scripts" line="771" name="zip" /><variable attributes="__not_yet_defined__" line="769" name="compress_scripts" /><variable attributes="__not_yet_defined__" line="769" name="wp_scripts" /><variable citdl="wp_scripts.base_url" line="788" name="src" /