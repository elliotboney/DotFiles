2891" name="update_object_term_cache" returns="null" signature="null update_object_term_cache($object_ids, $object_type)"><variable ilk="argument" line="2846" name="object_ids" /><variable ilk="argument" line="2846" name="object_type" /><variable citdl="array()" line="2857" name="ids" /><variable citdl="array()" line="2872" name="object_terms" /><variable citdl="wp_get_object_terms()" line="2870" name="terms" /><variable attributes="__not_yet_defined__" line="2859" name="taxonomy" /><variable citdl="get_object_taxonomies()" line="2855" name="taxonomies" /><variable attributes="__not_yet_defined__" line="2873" name="term" /><variable attributes="__not_yet_defined__" line="2858" name="id" /><variable attributes="__not_yet_defined__" line="2886" name="value" /></scope><scope doc="Updates Terms to Taxonomy in cache.&#10;&#10;@package WordPress&#10;@subpackage Taxonomy&#10;@since 2.3.0&#10;&#10;@param array $terms List of Term objects to change&#10;@param string $taxonomy Optional. Update Term to this taxonomy in cache" ilk="function" line="2903" lineend="2911" name="update_term_cache" signature="update_term_cache(array $terms, string $taxonomy = '')"><variable citdl="array" ilk="argument" line="2903" name="terms" /><variable citdl="string" default="''" ilk="argument" line="2903" name="taxonomy" /><variable attributes="__not_yet_defined__" line="2904" name="term" /><variable citdl="taxonomy" line="2905" name="term_taxonomy" /></scope><scope doc="Retrieves children of taxonomy as Term IDs.&#10;&#10;@package WordPress&#10;@subpackage Taxonomy&#10;@access private&#10;@since 2.3.0&#10;&#10;@uses update_option() Stores all of the children in &quot;$taxonomy_children&quot;&#10; option. That is the name of the taxonomy, immediately followed by '_children'.&#10;&#10;@param string $taxonomy Taxonomy Name&#10;@return array Empty if $taxonomy isn't hierarchical or returns children as Term IDs." ilk="function" line="2931" lineend="2947" name="_get_term_hierarchy" returns="array" sig