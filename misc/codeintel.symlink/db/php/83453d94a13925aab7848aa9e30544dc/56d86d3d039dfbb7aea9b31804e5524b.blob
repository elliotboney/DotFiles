<scope ilk="blob" lang="PHP" name="ms-blogs.php" src="/private/var/www/kw/wp-includes/ms-blogs.php"><scope doc="Update the last_updated field for the current blog.&#10;&#10;@since MU" ilk="function" line="16" lineend="28" name="wpmu_update_blogs_date" signature="wpmu_update_blogs_date()"><variable attributes="__not_yet_defined__" line="17" name="wpdb" /></scope><scope doc="Get a full blog URL, given a blog id.&#10;&#10;@since MU&#10;&#10;@param int $blog_id Blog ID&#10;@return string" ilk="function" line="38" lineend="41" name="get_blogaddress_by_id" returns="string" signature="string get_blogaddress_by_id(int $blog_id)"><variable citdl="int" ilk="argument" line="38" name="blog_id" /><variable citdl="get_blog_details()" line="39" name="bloginfo" /></scope><scope doc="Get a full blog URL, given a blog name.&#10;&#10;@since MU&#10;&#10;@param string $blogname The (subdomain or directory) name&#10;@return string" ilk="function" line="51" lineend="62" name="get_blogaddress_by_name" returns="string" signature="string get_blogaddress_by_name(string $blogname)"><variable citdl="string" ilk="argument" line="51" name="blogname" /><variable citdl="rtrim()" line="55" name="url" /></scope><scope doc="Given a blog's (subdomain or directory) slug, retrieve its id.&#10;&#10;@since MU&#10;&#10;@param string $slug&#10;@return int A blog id" ilk="function" line="72" lineend="93" name="get_id_from_blogname" returns="int" signature="int get_id_from_blogname(string $slug)"><variable citdl="string" ilk="argument" line="72" name="slug" /><variable citdl="get_current_site()" line="75" name="current_site" /><variable citdl="wp_cache_get()" line="78" name="blog_id" /><variable attributes="__not_yet_defined__" line="73" name="wpdb" /><variable citdl="slug" line="83" name="domain" /><variable citdl="current_site.path" line="84" name="path" /></scope><scope doc="Retrieve the details for a blog from the blogs table and blog options.&#10;&#10;@since MU&#10;&#10;@param int|string|array $fields A blog ID, a blog slug, or an array of fields to query against. Optional. If not specified the current blog ID is used.&#10;@param bool $get_all Whether to retrieve all details or only the details in the blogs table. Default is true.&#10;@return object Blog details." ilk="function" line="104" lineend="231" name="get_blog_details" returns="object" signature="object get_blog_details($fields = null, bool $get_all = true)"><variable default="null" ilk="argument" line="104" name="fields" /><variable citdl="bool" default="true" ilk="argument" line="104" name="get_all" /><variable citdl="get_all" line="158" name="all" /><variable attributes="__not_yet_defined__" line="105" name="wpdb" /><variable citdl="wp_cache_get()" line="159" name="details" /><variable citdl="blog.blog_id" line="109" name="blog_id" /><variable citdl="md5()" line="111" name="key" /><variable citdl="wpdb.get_row()" line="112" name="blog" /><variable citdl="substr()" line="116" name="nowww" /></scope><scope doc="Clear the blog details cache.&#10;&#10;@since MU&#10;&#10;@param int $blog_id Blog ID" ilk="function" line="240" lineend="264" name="refresh_blog_details" signature="refresh_blog_details(int $blog_id)"><variable citdl="int" ilk="argument" line="240" name="blog_id" /><variable citdl="get_blog_details()" line="242" name="details" /></scope><scope doc="Update the details for a blog. Updates the blogs table for a given blog id.&#10;&#10;@since MU&#10;&#10;@param int $blog_id Blog ID&#10;@param array $details Array of details keyed by blogs table field names.&#10;@return bool True if update succeeds, false otherwise." ilk="function" line="275" lineend="404" name="update_blog_details" returns="bool" signature="bool update_blog_details(int $blog_id, array $details = array())"><variable citdl="int" ilk="argument" line="275" name="blog_id" /><variable citdl="array" default="array()" ilk="argument" line="275" name="details" /><variable citdl="array()" line="294" name="fields" /><variable attributes="__not_yet_defined__" line="276" name="wpdb" /><variable citdl="wpdb.update()" line="298" name="result" /><variable attributes="__not_yet_defined__" line="295" name="field" /><variable citdl="get_blog_details()" line="284" name="current_details" /><variable citdl="array()" line="293" name="update_details" /></scope><scope doc="Clean the blog cache&#10;&#10;@since 3.5.0&#10;&#10;@param stdClass $blog The blog details as returned from get_blog_details()" ilk="function" line="413" lineend="424" name="clean_blog_cache" signature="clean_blog_cache(stdClass $blog)"><variable citdl="stdClass" ilk="argument" line="413" name="blog" /><variable citdl="blog.blog_id" line="414" name="blog_id" /><variable citdl="md5()" line="415" name="domain_path_key" /></scope><scope doc="Retrieve option value for a given blog id based on name of option.&#10;&#10;If the option does not exist or does not have a value, then the return value&#10;will be false. This is useful to check whether you need to install an option&#10;and is commonly used during installation of plugin options and to test&#10;whether upgrading is required.&#10;&#10;If the option was serialized then it will be unserialized when it is returned.&#10;&#10;@since MU&#10;&#10;@param int $id A blog ID. Can be null to refer to the current blog.&#10;@param string $option Name of option to retrieve. Expected to not be SQL-escaped.&#10;@param mixed $default Optional. Default value to return if the option does not exist.&#10;@return mixed Value set for the option." ilk="function" line="443" lineend="467" name="get_blog_option" returns="mixed" signature="mixed get_blog_option(int $id, string $option, mixed $default = false)"><variable citdl="int" ilk="argument" line="443" name="id" /><variable citdl="string" ilk="argument" line="443" name="option" /><variable citdl="mixed" default="false" ilk="argument" line="443" name="default" /><variable citdl="get_option()" line="453" name="value" /></scope><scope doc="Add a new option for a given blog id.&#10;&#10;You do not need to serialize values. If the value needs to be serialized, then&#10;it will be serialized before it is inserted into the database. Remember,&#10;resources can not be serialized or added as an option.&#10;&#10;You can create options without values and then update the values later.&#10;Existing options will not be updated and checks are performed to ensure that you&#10;aren't adding a protected WordPress option. Care should be taken to not name&#10;options the same as the ones which are protected.&#10;&#10;@since MU&#10;&#10;@param int $id A blog ID. Can be null to refer to the current blog.&#10;@param string $option Name of option to add. Expected to not be SQL-escaped.&#10;@param mixed $value Optional. Option value, can be anything. Expected to not be SQL-escaped.&#10;@return bool False if option was not added and true if option was added." ilk="function" line="488" lineend="502" name="add_blog_option" returns="bool" signature="bool add_blog_option(int $id, string $option, mixed $value)"><variable citdl="int" ilk="argument" line="488" name="id" /><variable citdl="string" ilk="argument" line="488" name="option" /><variable citdl="mixed" ilk="argument" line="488" name="value" /><variable citdl="add_option()" line="498" name="return" /></scope><scope doc="Removes option by name for a given blog id. Prevents removal of protected WordPress options.&#10;&#10;@since MU&#10;&#10;@param int $id A blog ID. Can be null to refer to the current blog.&#10;@param string $option Name of option to remove. Expected to not be SQL-escaped.&#10;@return bool True, if option is successfully deleted. False on failure." ilk="function" line="513" lineend="527" name="delete_blog_option" returns="bool" signature="bool delete_blog_option(int $id, string $option)"><variable citdl="int" ilk="argument" line="513" name="id" /><variable citdl="string" ilk="argument" line="513" name="option" /><variable citdl="delete_option()" line="523" name="return" /></scope><scope doc="Update an option for a particular blog.&#10;&#10;@since MU&#10;&#10;@param int $id The blog id&#10;@param string $option The option key&#10;@param mixed $value The option value&#10;@return bool True on success, false on failure." ilk="function" line="539" lineend="555" name="update_blog_option" returns="bool" signature="bool update_blog_option(int $id, string $option, mixed $value, $deprecated = null)"><variable citdl="int" ilk="argument" line="539" name="id" /><variable citdl="string" ilk="argument" line="539" name="option" /><variable citdl="mixed" ilk="argument" line="539" name="value" /><variable default="null" ilk="argument" line="539" name="deprecated" /><variable citdl="update_option()" line="549" name="return" /></scope><scope doc="Switch the current blog.&#10;&#10;This function is useful if you need to pull posts, or other information,&#10;from other blogs. You can switch back afterwards using restore_current_blog().&#10;&#10;Things that aren't switched:&#10; - autoloaded options. See #14992&#10; - plugins. See #14941&#10;&#10;@see restore_current_blog()&#10;@since MU&#10;&#10;@param int $new_blog The id of the blog you want to switch to. Default: current blog&#10;@param bool $deprecated Deprecated argument&#10;@return bool True on success, false if the validation failed" ilk="function" line="574" lineend="638" name="switch_to_blog" returns="bool" signature="bool switch_to_blog(int $new_blog, bool $deprecated = null)"><variable citdl="int" ilk="argument" line="574" name="new_blog" /><variable citdl="bool" default="null" ilk="argument" line="574" name="deprecated" /><variable attributes="__not_yet_defined__" line="577" name="GLOBALS" /><variable citdl="GLOBALS" line="603" name="prev_blog_id" /><variable attributes="__not_yet_defined__" line="575" name="wpdb" /><variable line="611" name="global_groups" /><variable citdl="wp_get_current_user()" line="629" name="current_user" /><variable attributes="__not_yet_defined__" line="609" name="wp_object_cache" /><variable attributes="__not_yet_defined__" line="575" name="wp_roles" /></scope><scope doc="Restore the current blog, after calling switch_to_blog()&#10;&#10;@see switch_to_blog()&#10;@since MU&#10;&#10;@return bool True on success, false if we're already on the current blog" ilk="function" line="648" lineend="703" name="restore_current_blog" returns="bool" signature="bool restore_current_blog()"><variable attributes="__not_yet_defined__" line="651" name="GLOBALS" /><variable citdl="GLOBALS" line="665" name="prev_blog_id" /><variable attributes="__not_yet_defined__" line="649" name="wpdb" /><variable line="674" name="global_groups" /><variable citdl="wp_get_current_user()" line="692" name="current_user" /><variable attributes="__not_yet_defined__" line="672" name="wp_object_cache" /><variable citdl="array_pop()" line="654" name="blog" /><variable attributes="__not_yet_defined__" line="649" name="wp_roles" /></scope><scope doc="Determines if switch_to_blog() is in effect&#10;&#10;@since 3.5.0&#10;&#10;@return bool True if switched, false otherwise." ilk="function" line="712" lineend="714" name="ms_is_switched" returns="bool" signature="bool ms_is_switched()" /><scope doc="Check if a particular blog is archived.&#10;&#10;@since MU&#10;&#10;@param int $id The blog id&#10;@return string Whether the blog is archived or not" ilk="function" line="724" lineend="726" name="is_archived" returns="string" signature="string is_archived(int $id)"><variable citdl="int" ilk="argument" line="724" name="id" /></scope><scope doc="Update the 'archived' status of a particular blog.&#10;&#10;@since MU&#10;&#10;@param int $id The blog id&#10;@param string $archived The new status&#10;@return string $archived" ilk="function" line="737" lineend="740" name="update_archived" returns="string" signature="string update_archived(int $id, string $archived)"><variable citdl="int" ilk="argument" line="737" name="id" /><variable citdl="string" ilk="argument" line="737" name="archived" /></scope><scope doc="Update a blog details field.&#10;&#10;@since MU&#10;&#10;@param int $blog_id BLog ID&#10;@param string $pref A field name&#10;@param string $value Value for $pref&#10;@return string $value" ilk="function" line="752" lineend="813" name="update_blog_status" returns="string" signature="string update_blog_status(int $blog_id, string $pref, string $value, $deprecated = null)"><variable citdl="int" ilk="argument" line="752" name="blog_id" /><variable citdl="string" ilk="argument" line="752" name="pref" /><variable citdl="string" ilk="argument" line="752" name="value" /><variable default="null" ilk="argument" line="752" name="deprecated" /><variable attributes="__not_yet_defined__" line="753" name="wpdb" /><variable citdl="wpdb.update()" line="761" name="result" /></scope><scope doc="Get a blog details field.&#10;&#10;@since MU&#10;&#10;@param int $id The blog id&#10;@param string $pref A field name&#10;@return bool $value" ilk="function" line="824" lineend="832" name="get_blog_status" returns="bool" signature="bool get_blog_status(int $id, string $pref)"><variable citdl="int" ilk="argument" line="824" name="id" /><variable citdl="string" ilk="argument" line="824" name="pref" /><variable attributes="__not_yet_defined__" line="825" name="wpdb" /><variable citdl="get_blog_details()" line="827" name="details" /></scope><scope doc="Get a list of most recently updated blogs.&#10;&#10;@since MU&#10;&#10;@param mixed $deprecated Not used&#10;@param int $start The offset&#10;@param int $quantity The maximum number of blogs to retrieve. Default is 40.&#10;@return array The list of blogs" ilk="function" line="844" lineend="851" name="get_last_updated" returns="array" signature="array get_last_updated(mixed $deprecated = '', int $start = 0, int $quantity = 40)"><variable citdl="mixed" default="''" ilk="argument" line="844" name="deprecated" /><variable citdl="int" default="0" ilk="argument" line="844" name="start" /><variable citdl="int" default="40" ilk="argument" line="844" name="quantity" /><variable attributes="__not_yet_defined__" line="845" name="wpdb" /></scope><scope doc="Handler for updating the blog date when a post is published or an already published post is changed.&#10;&#10;@since 3.3.0&#10;&#10;@param string $new_status The new post status&#10;@param string $old_status The old post status&#10;@param object $post Post object" ilk="function" line="862" lineend="873" name="_update_blog_date_on_post_publish" signature="_update_blog_date_on_post_publish(string $new_status, string $old_status, object $post)"><variable citdl="string" ilk="argument" line="862" name="new_status" /><variable citdl="string" ilk="argument" line="862" name="old_status" /><variable citdl="object" ilk="argument" line="862" name="post" /><variable citdl="get_post_type_object()" line="863" name="post_type_obj" /></scope><scope doc="Handler for updating the blog date when a published post is deleted.&#10;&#10;@since 3.4.0&#10;&#10;@param int $post_id Post ID" ilk="function" line="882" lineend="893" name="_update_blog_date_on_post_delete" signature="_update_blog_date_on_post_delete(int $post_id)"><variable citdl="int" ilk="argument" line="882" name="post_id" /><variable citdl="get_post()" line="883" name="post" /><variable citdl="get_post_type_object()" line="885" name="post_type_obj" /></scope></scope>