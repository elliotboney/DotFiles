<scope ilk="blob" lang="PHP" name="Extension.php" src="/usr/local/pear/share/pear/PhpDocumentor/src/phpDocumentor/Plugin/Core/Twig/Extension.php"><scope doc="phpDocumentor&#10;&#10;PHP Version 5.3&#10;&#10;@copyright 2010-2013 Mike van Riel / Naenius (http://www.naenius.com)&#10;@license   http://www.opensource.org/licenses/mit-license.php MIT&#10;@link      http://phpdoc.org" ilk="namespace" line="12" name="phpDocumentor\Plugin\Core\Twig"><import line="14" module="dflydev\markdown" symbol="MarkdownExtraParser" /><import line="15" module="phpDocumentor\Descriptor" symbol="Collection" /><import line="16" module="phpDocumentor\Descriptor" symbol="ProjectDescriptor" /><import line="17" module="phpDocumentor\Transformer\Router" symbol="Queue" /><import line="18" module="phpDocumentor\Transformer" symbol="Transformation" /><import line="19" module="phpDocumentor" symbol="Translator" /><scope classrefs="\Twig_Extension" doc="Basic extension adding phpDocumentor specific functionality for Twig&#10;templates.&#10;&#10;Global variables:&#10;&#10;- *ast_node*, the current $data element&#10;&#10;Functions:&#10;&#10;- *path(string)*, converts the given relative path to be based of the projects&#10;  root instead of the current directory" ilk="class" interfacerefs="ExtensionInterface" line="34" lineend="263" name="Extension"><variable attributes="protected" citdl="ProjectDescriptor" doc="@var ProjectDescriptor" line="39" name="data" /><variable attributes="protected" citdl="Queue" doc="@var Queue $router" line="42" name="routers" /><variable attributes="protected" citdl="Translator" doc="@var Translator" line="45" name="translator" /><variable attributes="protected" citdl="string" doc="@var string" line="50" name="destination" /><scope attributes="public __ctor__" doc="Registers the structure and transformation with this extension.&#10;&#10;@param ProjectDescriptor $project        Represents the complete Abstract Syntax Tree.&#10;@param Transformation    $transformation Represents the transformation meta data used in the current generation&#10;    cycle." ilk="function" line="59" lineend="62" name="__construct" signature="__construct(ProjectDescriptor $project, Transformation $transformation)"><variable citdl="ProjectDescriptor" ilk="argument" line="59" name="project" /><variable citdl="Transformation" ilk="argument" line="59" name="transformation" /></scope><scope attributes="public" doc="Returns the name of this extension.&#10;&#10;@return string The extension name" ilk="function" line="69" lineend="72" name="getName" returns="string" signature="string getName()" /><scope attributes="public" doc="@param Queue $router" ilk="function" line="77" lineend="80" name="setRouters" signature="setRouters(Queue $router)"><variable citdl="Queue" ilk="argument" line="77" name="router" /></scope><scope attributes="public" doc="@param Translator $translator" ilk="function" line="85" lineend="88" name="setTranslator" signature="setTranslator(Translator $translator)"><variable citdl="Translator" ilk="argument" line="85" name="translator" /></scope><scope attributes="public" doc="Sets the destination directory relative to the Project's Root.&#10;&#10;The destination is the target directory containing the resulting&#10;file. This destination is relative to the Project's root and can&#10;be used for the calculation of nesting depths, etc.&#10;&#10;For this specific extension the destination is provided in the&#10;Twig writer itself.&#10;&#10;@param string $destination&#10;&#10;@see phpDocumentor\Plugin\Twig\Transformer\Writer\Twig for the invocation&#10;    of this method.&#10;&#10;@return void" ilk="function" line="107" lineend="110" name="setDestination" signature="void setDestination(string $destination)"><variable citdl="string" ilk="argument" line="107" name="destination" /></scope><scope attributes="public" doc="Returns the target directory relative to the Project's Root.&#10;&#10;@return string" ilk="function" line="117" lineend="120" name="getDestination" returns="string" signature="string getDestination()" /><scope attributes="public" doc="Returns a listing of all functions that this extension adds.&#10;&#10;This method is automatically used by Twig upon registering this&#10;extension (which is done automatically by phpDocumentor) to determine&#10;an additional list of functions.&#10;&#10;See the Class' DocBlock for a listing of functionality added by this&#10;Extension.&#10;&#10;@return \Twig_FunctionInterface[]" ilk="function" line="134" lineend="139" name="getFunctions" returns="\Twig_FunctionInterface" signature="\Twig_FunctionInterface getFunctions()" /><scope attributes="public" ilk="function" line="141" lineend="201" name="getFilters" returns="array()" signature="getFilters()"><variable citdl="routers.match()" line="177" name="rule" /><variable citdl="array()" line="169" name="result" /><variable citdl="this" line="143" name="extension" /><variable citdl="rule" line="178" name="url" /><variable citdl="this.translator" line="146" name="translator" /><variable line="173" name="singleResult" /><variable citdl="this.routers" line="144" name="routers" /><variable citdl="MarkdownExtraParser" line="145" name="parser" /><variable attributes="__not_yet_defined__" citdl="array()" line="158" name="context" /><variable attributes="__not_yet_defined__" line="184" name="presentation" /><variable citdl="explode()" line="189" name="parts" /><variable attributes="__not_yet_defined__" citdl="value.getAll()" line="170" name="value" /><variable attributes="__not_yet_defined__" citdl="end()" line="176" name="path" /></scope><scope attributes="public" doc="Returns an array of global variables to inject into a Twig template.&#10;&#10;@return mixed" ilk="function" line="208" lineend="213" name="getGlobals" returns="mixed" signature="mixed getGlobals()" /><scope attributes="public" doc="Converts the given path to be relative to the root of the documentation&#10;target directory.&#10;&#10;It is not possible to use absolute paths in documentation templates since&#10;they may be used locally, or in a subfolder. As such we need to calculate&#10;the number of levels to go up from the current document's directory and&#10;then append the given path.&#10;&#10;For example:&#10;&#10;    Suppose you are in &lt;root&gt;/classes/my/class.html and you want open&#10;    &lt;root&gt;/my/index.html then you provide 'my/index.html' to this method&#10;    and it will convert it into ../../my/index.html (&lt;root&gt;/classes/my is&#10;    two nesting levels until the root).&#10;&#10;This method does not try to normalize or optimize the paths in order to&#10;save on development time and performance, and because it adds no real&#10;value.&#10;&#10;@param string $relative_path&#10;&#10;@return string" ilk="function" line="239" lineend="262" name="convertToRootPath" returns="string" signature="string convertToRootPath(string $relative_path)"><variable citdl="string" ilk="argument" line="239" name="relative_path" /><variable citdl="rule.generate()" line="259" name="generatedPath" /><variable citdl="this.routers.match()" line="254" name="rule" /><variable citdl="explode()" line="242" name="path_parts" /><variable citdl="implode()" line="244" name="path_to_root" /></scope></scope></scope></scope>