<scope ilk="blob" lang="PHP" name="TestListener.php" src="/private/var/www/paperless/wp-content/themes/paperless-agent/iSDK/src/xmlrpc-3.0/test/PHPUnit/TestListener.php"><scope doc="A Listener for test progress.&#10;&#10;Here is an example:&#10;&#10;&lt;code&gt;&#10;&lt;?php&#10;require_once 'PHPUnit.php';&#10;require_once 'PHPUnit/TestListener.php';&#10;&#10;class MathTest extends PHPUnit_TestCase {&#10;    var $fValue1;&#10;    var $fValue2;&#10;&#10;    function MathTest($name) {&#10;        $this-&gt;PHPUnit_TestCase($name);&#10;    }&#10;&#10;    function setUp() {&#10;        $this-&gt;fValue1 = 2;&#10;        $this-&gt;fValue2 = 3;&#10;    }&#10;&#10;    function testAdd() {&#10;        $this-&gt;assertTrue($this-&gt;fValue1 + $this-&gt;fValue2 == 4);&#10;    }&#10;}&#10;&#10;class MyListener extends PHPUnit_TestListener {&#10;    function addError(&amp;$test, &amp;$t) {&#10;        print &quot;MyListener::addError() called.\n&quot;;&#10;    }&#10;&#10;    function addFailure(&amp;$test, &amp;$t) {&#10;        print &quot;MyListener::addFailure() called.\n&quot;;&#10;    }&#10;&#10;    function endTest(&amp;$test) {&#10;        print &quot;MyListener::endTest() called.\n&quot;;&#10;    }&#10;&#10;    function startTest(&amp;$test) {&#10;        print &quot;MyListener::startTest() called.\n&quot;;&#10;    }&#10;}&#10;&#10;$suite = new PHPUnit_TestSuite;&#10;$suite-&gt;addTest(new MathTest('testAdd'));&#10;&#10;$result = new PHPUnit_TestResult;&#10;$result-&gt;addListener(new MyListener);&#10;&#10;$suite-&gt;run($result);&#10;print $result-&gt;toString();&#10;?&gt;&#10;&lt;/code&gt;&#10;&#10;@category   Testing&#10;@package    PHPUnit&#10;@author     Sebastian Bergmann &lt;sb@sebastian-bergmann.de&gt;&#10;@copyright  2002-2005 Sebastian Bergmann &lt;sb@sebastian-bergmann.de&gt;&#10;@license    http://www.php.net/license/3_0.txt  PHP License 3.0&#10;@version    Release: @package_version@&#10;@link       http://pear.php.net/package/PHPUnit&#10;@since      Class available since Release 1.0.0" ilk="class" line="89" lineend="127" name="PHPUnit_TestListener"><scope doc="An error occurred.&#10;&#10;@param  object&#10;@param  object&#10;@access public&#10;@abstract" ilk="function" line="98" lineend="98" name="addError" signature="addError(&amp; $test, &amp; $t)"><variable ilk="argument" line="98" name="test" /><variable ilk="argument" line="98" name="t" /></scope><scope doc="A failure occurred.&#10;&#10;@param  object&#10;@param  object&#10;@access public&#10;@abstract" ilk="function" line="108" lineend="108" name="addFailure" signature="addFailure(&amp; $test, &amp; $t)"><variable ilk="argument" line="108" name="test" /><variable ilk="argument" line="108" name="t" /></scope><scope doc="A test ended.&#10;&#10;@param  object&#10;@access public&#10;@abstract" ilk="function" line="117" lineend="117" name="endTest" signature="endTest(&amp; $test)"><variable ilk="argument" line="117" name="test" /></scope><scope doc="A test started.&#10;&#10;@param  object&#10;@access public&#10;@abstract" ilk="function" line="126" lineend="126" name="startTest" signature="startTest(&amp; $test)"><variable ilk="argument" line="126" name="test" /></scope></scope></scope>