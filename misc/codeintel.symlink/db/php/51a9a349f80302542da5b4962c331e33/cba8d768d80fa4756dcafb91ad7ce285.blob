<scope ilk="blob" lang="PHP" name="TestSuite.php" src="/private/var/www/paperless/wp-content/themes/paperless-agent/iSDK/src/xmlrpc-3.0/test/PHPUnit/TestSuite.php"><import line="23" module="PHPUnit/TestCase.php" /><scope doc="A TestSuite is a Composite of Tests. It runs a collection of test cases.&#10;&#10;Here is an example using the dynamic test definition.&#10;&#10;&lt;code&gt;&#10;&lt;?php&#10;$suite = new PHPUnit_TestSuite();&#10;$suite-&gt;addTest(new MathTest('testPass'));&#10;?&gt;&#10;&lt;/code&gt;&#10;&#10;Alternatively, a TestSuite can extract the tests to be run automatically.&#10;To do so you pass the classname of your TestCase class to the TestSuite&#10;constructor.&#10;&#10;&lt;code&gt;&#10;&lt;?php&#10;$suite = new TestSuite('classname');&#10;?&gt;&#10;&lt;/code&gt;&#10;&#10;This constructor creates a suite with all the methods starting with&#10;&quot;test&quot; that take no arguments.&#10;&#10;@category   Testing&#10;@package    PHPUnit&#10;@author     Sebastian Bergmann &lt;sb@sebastian-bergmann.de&gt;&#10;@copyright  2002-2005 Sebastian Bergmann &lt;sb@sebastian-bergmann.de&gt;&#10;@license    http://www.php.net/license/3_0.txt  PHP License 3.0&#10;@version    Release: @package_version@&#10;@link       http://pear.php.net/package/PHPUnit&#10;@since      Class available since Release 1.0.0" ilk="class" line="59" lineend="230" name="PHPUnit_TestSuite"><variable citdl="string" doc="The name of the test suite.&#10;&#10;@var    string&#10;@access private" line="66" name="_name" /><variable citdl="array" doc="The tests in the test suite.&#10;&#10;@var    array&#10;@access private" line="74" name="_tests" /><scope attributes="__ctor__" doc="Constructs a TestSuite.&#10;&#10;@param  mixed&#10;@access public" ilk="function" line="82" lineend="87" name="PHPUnit_TestSuite" signature="PHPUnit_TestSuite($test = FALSE)"><variable default="FALSE" ilk="argument" line="82" name="test" /></scope><scope doc="Adds a test to the suite.&#10;&#10;@param  object&#10;@access public" ilk="function" line="95" lineend="97" name="addTest" signature="addTest(&amp; $test)"><variable ilk="argument" line="95" name="test" /></scope><scope doc="Adds the tests from the given class to the suite.&#10;&#10;@param  string&#10;@access public" ilk="function" line="105" lineend="122" name="addTestSuite" signature="addTestSuite($testClass)"><variable ilk="argument" line="105" name="testClass" /><variable citdl="array()" line="108" name="parentClasses" /><variable attributes="__not_yet_defined__" line="115" name="method" /><variable citdl="get_class_methods()" line="107" name="methods" /><variable citdl="testClass" line="109" name="parentClass" /></scope><scope doc="Counts the number of test cases that will be run by this test.&#10;&#10;@return integer&#10;@access public" ilk="function" line="130" lineend="138" name="countTestCases" returns="integer" signature="integer countTestCases()"><variable attributes="__not_yet_defined__" line="133" name="test" /><variable citdl="int" line="131" name="count" /></scope><scope doc="Returns the name of the suite.&#10;&#10;@return string&#10;@access public" ilk="function" line="146" lineend="148" name="getName" returns="string" signature="string getName()" /><scope doc="Runs the tests and collects their result in a TestResult.&#10;&#10;@param  object&#10;@access public" ilk="function" line="156" lineend="163" name="run" signature="run(&amp; $result, $show_progress = '')"><variable ilk="argument" line="156" name="result" /><variable default="''" ilk="argument" line="156" name="show_progress" /><variable line="157" name="i" /></scope><scope doc="Runs a test.&#10;&#10;@param  object&#10;@param  object&#10;@access public" ilk="function" line="172" lineend="174" name="runTest" signature="runTest(&amp; $test, &amp; $result)"><variable ilk="argument" line="172" name="test" /><variable ilk="argument" line="172" name="result" /></scope><scope doc="Sets the name of the suite.&#10;&#10;@param  string&#10;@access public" ilk="function" line="182" lineend="184" name="setName" signature="setName($name)"><variable ilk="argument" line="182" name="name" /></scope><scope doc="Returns the test at the given index.&#10;&#10;@param  integer&#10;@return object&#10;@access public" ilk="function" line="193" lineend="199" name="testAt" returns="object" signature="object &amp;testAt($index)"><variable ilk="argument" line="193" name="index" /></scope><scope doc="Returns the number of tests in this suite.&#10;&#10;@return integer&#10;@access public" ilk="function" line="207" lineend="209" name="testCount" returns="integer" signature="integer testCount()" /><scope doc="Returns the tests as an enumeration.&#10;&#10;@return array&#10;@access public" ilk="function" line="217" lineend="219" name="tests" returns="array" signature="array &amp;tests()" /><scope doc="Returns a string representation of the test suite.&#10;&#10;@return string&#10;@access public" ilk="function" line="227" lineend="229" name="toString" returns="string" signature="string toString()" /></scope></scope>