<scope ilk="blob" lang="PHP" name="Build.php" src="/private/var/www/wordpress.staging/plugins/w3-total-cache/lib/Minify/Minify/Build.php"><scope doc="Maintain a single last modification time for a group of Minify sources to&#10;allow use of far off Expires headers in Minify.&#10;&#10;&lt;code&gt;&#10;// in config file&#10;$groupSources = array(&#10;  'js' =&gt; array('file1.js', 'file2.js')&#10;  ,'css' =&gt; array('file1.css', 'file2.css', 'file3.css')&#10;)&#10;&#10;// during HTML generation&#10;$jsBuild = new Minify_Build($groupSources['js']);&#10;$cssBuild = new Minify_Build($groupSources['css']);&#10;&#10;$script = &quot;&lt;script type='text/javascript' src='&quot;&#10;    . $jsBuild-&gt;uri('/min.php/js') . &quot;'&gt;&lt;/script&gt;&quot;;&#10;$link = &quot;&lt;link rel='stylesheet' type='text/css' href='&quot;&#10;    . $cssBuild-&gt;uri('/min.php/css') . &quot;'&gt;&quot;;&#10;&#10;// in min.php&#10;Minify::serve('Groups', array(&#10;  'groups' =&gt; $groupSources&#10;  ,'setExpires' =&gt; (time() + 86400 * 365)&#10;));&#10;&lt;/code&gt;&#10;&#10;@package Minify&#10;@author Stephen Clay &lt;steve@mrclay.org&gt;" ilk="class" line="42" lineend="106" name="Minify_Build"><variable attributes="public" citdl="int" doc="Last modification time of all files in the build&#10;&#10;@var int" line="49" name="lastModified" /><variable attributes="public static" citdl="string" doc="String to use as ampersand in uri(). Set this to '&amp;' if&#10;you are not HTML-escaping URIs.&#10;&#10;@var string" line="57" name="ampersand" /><scope attributes="public" doc="Get a time-stamped URI&#10;&#10;&lt;code&gt;&#10;echo $b-&gt;uri('/site.js');&#10;// outputs &quot;/site.js?1678242&quot;&#10;&#10;echo $b-&gt;uri('/scriptaculous.js?load=effects');&#10;// outputs &quot;/scriptaculous.js?load=effects&amp;amp1678242&quot;&#10;&lt;/code&gt;&#10;&#10;@param string $uri&#10;@param boolean $forceAmpersand (default = false) Force the use of ampersand to&#10;append the timestamp to the URI.&#10;@return string" ilk="function" line="75" lineend="80" name="uri" returns="string" signature="string uri(string $uri, boolean $forceAmpersand = false)"><variable citdl="string" ilk="argument" line="75" name="uri" /><variable citdl="boolean" default="false" ilk="argument" line="75" name="forceAmpersand" /><variable line="78" name="sep" /></scope><scope attributes="public __ctor__" doc="Create a build object&#10;&#10;@param array $sources array of Minify_Source objects and/or file paths&#10;&#10;@return null" ilk="function" line="89" lineend="105" name="__construct" returns="null" signature="null __construct(array $sources)"><variable citdl="array" ilk="argument" line="89" name="sources" /><variable citdl="max()" line="91" name="max" /><variable attributes="__not_yet_defined__" citdl="_SERVER" line="92" name="source" /></scope></scope></scope>