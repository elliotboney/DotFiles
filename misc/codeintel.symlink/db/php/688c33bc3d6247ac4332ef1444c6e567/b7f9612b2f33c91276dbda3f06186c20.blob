<scope ilk="blob" lang="PHP" name="CookieJar.php" src="/private/var/www/kw/plugins/w3-total-cache/lib/Microsoft/Http/CookieJar.php"><import line="29" module="Microsoft/Uri.php" /><import line="33" module="Microsoft/Http/Cookie.php" /><import line="37" module="Microsoft/Http/Response.php" /><import line="137" module="Microsoft/Http/Exception.php" /><import line="152" module="Microsoft/Http/Exception.php" /><import line="196" module="Microsoft/Http/Exception.php" /><import line="232" module="Microsoft/Http/Exception.php" /><import line="255" module="Microsoft/Http/Exception.php" /><scope doc="A Microsoft_Http_CookieJar object is designed to contain and maintain HTTP cookies, and should&#10;be used along with Microsoft_Http_Client in order to manage cookies across HTTP requests and&#10;responses.&#10;&#10;The class contains an array of Microsoft_Http_Cookie objects. Cookies can be added to the jar&#10;automatically from a request or manually. Then, the jar can find and return the cookies&#10;needed for a specific HTTP request.&#10;&#10;A special parameter can be passed to all methods of this class that return cookies: Cookies&#10;can be returned either in their native form (as Microsoft_Http_Cookie objects) or as strings -&#10;the later is suitable for sending as the value of the &quot;Cookie&quot; header in an HTTP request.&#10;You can also choose, when returning more than one cookie, whether to get an array of strings&#10;(by passing Microsoft_Http_CookieJar::COOKIE_STRING_ARRAY) or one unified string for all cookies&#10;(by passing Microsoft_Http_CookieJar::COOKIE_STRING_CONCAT).&#10;&#10;@link       http://wp.netscape.com/newsref/std/cookie_spec.html for some specs.&#10;&#10;@category   Microsoft&#10;@package    Microsoft_Http&#10;@subpackage CookieJar&#10;@copyright  Copyright (c) 2005-2009 Zend Technologies USA Inc. (http://www.zend.com)&#10;@license    http://framework.zend.com/license/new-bsd     New BSD License" ilk="class" interfacerefs="Countable IteratorAggregate" line="63" lineend="406" name="Microsoft_Http_CookieJar"><variable citdl="int" ilk="constant" line="69" name="COOKIE_OBJECT" /><variable citdl="int" ilk="constant" line="75" name="COOKIE_STRING_ARRAY" /><variable citdl="int" ilk="constant" line="81" name="COOKIE_STRING_CONCAT" /><variable attributes="protected" citdl="array" doc="Array storing cookies&#10;&#10;Cookies are stored according to domain and path:&#10;$cookies&#10; + www.mydomain.com&#10;   + /&#10;     - cookie1&#10;     - cookie2&#10;   + /somepath&#10;     - othercookie&#10; + www.otherdomain.net&#10;   + /&#10;     - alsocookie&#10;&#10;@var array" line="100" name="cookies" /><variable attributes="protected" citdl="array" doc="The Microsoft_Http_Cookie array&#10;&#10;@var array" line="107" name="_rawCookies" /><scope attributes="public __ctor__" doc="Construct a new CookieJar object" ilk="function" line="113" lineend="114" name="__construct" signature="__construct()" /><scope attributes="public" doc="Add a cookie to the jar. Cookie should be passed either as a Microsoft_Http_Cookie object&#10;or as a string - in which case an object is created from the string.&#10;&#10;@param Microsoft_Http_Cookie|string $cookie&#10;@param Microsoft_Uri_Http|string    $ref_uri Optional reference URI (for domain, path, secure)" ilk="function" line="123" lineend="140" name="addCookie" signature="addCookie($cookie, $ref_uri = null)"><variable ilk="argument" line="123" name="cookie" /><variable default="null" ilk="argument" line="123" name="ref_uri" /><variable citdl="cookie.getDomain()" line="130" name="domain" /><variable citdl="cookie.getPath()" line="131" name="path" /></scope><scope attributes="public" doc="Parse an HTTP response, adding all the cookies set in that response&#10;to the cookie jar.&#10;&#10;@param Microsoft_Http_Response $response&#10;@param Microsoft_Uri_Http|string $ref_uri Requested URI" ilk="function" line="149" lineend="166" name="addCookiesFromResponse" signature="addCookiesFromResponse(Microsoft_Http_Response $response, $ref_uri)"><variable citdl="Microsoft_Http_Response" ilk="argument" line="149" name="response" /><variable ilk="argument" line="149" name="ref_uri" /><variable citdl="response.getHeader()" line="157" name="cookie_hdrs" /><variable attributes="__not_yet_defined__" line="160" name="cookie" /></scope><scope attributes="public" doc="Get all cookies in the cookie jar as an array&#10;&#10;@param int $ret_as Whether to return cookies as objects of Microsoft_Http_Cookie or as strings&#10;@return array|string" ilk="function" line="174" lineend="178" name="getAllCookies" returns="array" signature="array getAllCookies(int $ret_as = self::COOKIE_OBJECT)"><variable citdl="int" default="self::COOKIE_OBJECT" ilk="argument" line="174" name="ret_as" /><variable citdl="this._flattenCookiesArray()" line="176" name="cookies" /></scope><scope attributes="public" doc="Return an array of all cookies matching a specific request according to the request URI,&#10;whether session cookies should be sent or not, and the time to consider as &quot;now&quot; when&#10;checking cookie expiry time.&#10;&#10;@param string|Microsoft_Uri_Http $uri URI to check against (secure, domain, path)&#10;@param boolean $matchSessionCookies Whether to send session cookies&#10;@param int $ret_as Whether to return cookies as objects of Microsoft_Http_Cookie or as strings&#10;@param int $now Override the current time when checking for expiry time&#10;@return array|string" ilk="function" line="191" lineend="215" name="getMatchingCookies" returns="array" signature="array getMatchingCookies($uri, boolean $matchSessionCookies = true, int $ret_as = self::COOKIE_OBJECT, int $now = null)"><variable ilk="argument" line="191" name="uri" /><variable citdl="boolean" default="true" ilk="argument" line="191" name="matchSessionCookies" /><variable citdl="int" default="self::COOKIE_OBJECT" ilk="argument" line="191" name="ret_as" /><variable citdl="int" default="null" ilk="argument" line="191" name="