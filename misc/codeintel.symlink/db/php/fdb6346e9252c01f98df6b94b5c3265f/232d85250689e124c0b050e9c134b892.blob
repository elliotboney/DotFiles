<scope ilk="blob" lang="PHP" name="HandlerInterface.php" src="/usr/local/pear/share/pear/PhpDocumentor/vendor/monolog/monolog/src/Monolog/Handler/HandlerInterface.php"><scope doc="This file is part of the Monolog package.&#10;&#10;(c) Jordi Boggiano &lt;j.boggiano@seld.be&gt;&#10;&#10;For the full copyright and license information, please view the LICENSE&#10;file that was distributed with this source code." ilk="namespace" line="12" name="Monolog\Handler"><import line="14" module="Monolog\Formatter" symbol="FormatterInterface" /><scope ilk="interface" line="21" lineend="88" name="HandlerInterface" signature="HandlerInterface"><scope attributes="public" doc="Checks whether the given record will be handled by this handler.&#10;&#10;This is mostly done for performance reasons, to avoid calling processors for nothing.&#10;&#10;Handlers should still check the record levels within handle(), returning false in isHandling()&#10;is no guarantee that handle() will not be called, and isHandling() might not be called&#10;for a given record.&#10;&#10;@param array $record&#10;&#10;@return Boolean" ilk="function" line="36" lineend="36" name="isHandling" returns="Boolean" signature="Boolean isHandling(array $record)"><variable citdl="array" ilk="argument" line="36" name="record" /></scope><scope attributes="public" doc="Handles a record.&#10;&#10;All records may be passed to this method, and the handler should discard&#10;those that it does not want to handle.&#10;&#10;The return value of this function controls the bubbling process of the handler stack.&#10;Unless the bubbling is interrupted (by returning true), the Logger class will keep on&#10;calling further handlers in the stack with a given log record.&#10;&#10;@param  array   $record The record to handle&#10;@return Boolean True means that this handler handled the record, and that bubbling is not permitted.&#10;                False means the record was either not processed or that this handler allows bubbling." ilk="function" line="52" lineend="52" name="handle" returns="Boolean" signature="Boolean handle(array $record)"><variable citdl="array" ilk="argument" line="52" name="record" /></scope><scope attributes="public" doc="Handles a set of records at once.&#10;&#10;@param array $records The records to handle (an array of record arrays)" ilk="function" line="59" lineend="59" name="handleBatch" signature="handleBatch(array $records)"><variable citdl="array" ilk="argument" line="59" name="records" /></scope><scope attributes="public" doc="Adds a processor in the stack.&#10;&#10;@param callable $callback" ilk="function" line="66" lineend="66" name="pushProcessor" signature="pushProcessor(callable $callback)"><variable citdl="callable" ilk="argument" line="66" name="callback" /></scope><scope attributes="public" doc="Removes the processor on top of the stack and returns it.&#10;&#10;@return callable" ilk="function" line="73" lineend="73" name="popProcessor" returns="callable" signature="callable popProcessor()" /><scope attributes="public" doc="Sets the formatter.&#10;&#10;@param FormatterInterface $formatter" ilk="function" line="80" lineend="80" name="setFormatter" signature="setFormatter(FormatterInterface $formatter)"><variable citdl="FormatterInterface" ilk="argument" line="80" name="formatter" /></scope><scope attributes="public" doc="Gets the formatter.&#10;&#10;@return FormatterInterface" ilk="function" line="87" lineend="87" name="getFormatter" returns="FormatterInterface" signature="FormatterInterface getFormatter()" /></scope></scope></scope>