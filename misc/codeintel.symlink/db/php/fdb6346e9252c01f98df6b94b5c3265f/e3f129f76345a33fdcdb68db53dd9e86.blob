ActivationStrategyInterface $activationStrategy Strategy which determines when this handler takes action&#10;@param int                             $bufferSize         How many entries should be buffered at most, beyond that the oldest items are removed from the buffer.&#10;@param Boolean                         $bubble             Whether the messages that are handled can bubble up the stack or not&#10;@param Boolean                         $stopBuffering      Whether the handler should stop buffering after being triggered (default true)" ilk="function" line="46" lineend="62" name="__construct" signature="__construct($handler, $activationStrategy = null, int $bufferSize = 0, Boolean $bubble = true, Boolean $stopBuffering = true)"><variable ilk="argument" line="46" name="handler" /><variable default="null" ilk="argument" line="46" name="activationStrategy" /><variable citdl="int" default="0" ilk="argument" line="46" name="bufferSize" /><variable citdl="Boolean" default="true" ilk="argument" line="46" name="bubble" /><variable citdl="Boolean" default="true" ilk="argument" line="46" name="stopBuffering" /></scope><variable citdl="bubble" line="60" name="bubble" /><scope attributes="public" doc="{@inheritdoc}" ilk="function" line="67" lineend="70" name="isHandling" returns="boolean" signature="isHandling(array $record)"><variable citdl="array" ilk="argument" line="67" name="record" /></scope><scope attributes="public" doc="{@inheritdoc}" ilk="function" line="75" lineend="109" name="handle" returns="boolean" signature="handle(array $record)"><variable citdl="array" ilk="argument" line="75" name="record" /><variable attributes="__not_yet_defined__" line="78" name="processor" /></scope><scope attributes="public" doc="Resets the state of the handler. Stops forwarding records to the wrapped handler." ilk="function" line="114" lineend="117" name="reset" signature="reset()" /></scope></scope></scope>