<scope ilk="blob" lang="PHP" name="CommentPreserver.php" src="/private/var/www/kw/plugins/w3-total-cache/lib/Minify/Minify/CommentPreserver.php"><scope doc="Process a string in pieces preserving C-style comments that begin with &quot;/*!&quot;&#10;&#10;@package Minify&#10;@author Stephen Clay &lt;steve@mrclay.org&gt;" ilk="class" line="13" lineend="90" name="Minify_CommentPreserver"><variable attributes="public static" citdl="string" doc="String to be prepended to each preserved comment&#10;&#10;@var string" line="20" name="prepend" /><variable attributes="public static" citdl="string" doc="String to be appended to each preserved comment&#10;&#10;@var string" line="27" name="append" /><scope attributes="public static" doc="Process a string outside of C-style comments that begin with &quot;/*!&quot;&#10;&#10;On each non-empty string outside these comments, the given processor &#10;function will be called. The first &quot;!&quot; will be removed from the &#10;preserved comments, and the comments will be surrounded by &#10;Minify_CommentPreserver::$preprend and Minify_CommentPreserver::$append.&#10;&#10;@param string $content&#10;@param callback $processor function&#10;@param array $args array of extra arguments to pass to the processor &#10;function (default = array())&#10;@return string" ilk="function" line="43" lineend="60" name="process" returns="string" signature="string process(string $content, callback $processor, array $args = array())"><variable citdl="string" ilk="argument" line="43" name="content" /><variable citdl="callback" ilk="argument" line="43" name="processor" /><variable citdl="array" default="array()" ilk="argument" line="43" name="args" /><variable citdl="string" line="45" name="ret" /><variable attributes="__not_yet_defined__" line="47" name="afterComment" /><variable attributes="__not_yet_defined__" line="47" name="comment" /><variable citdl="args" line="49" name="callArgs" /><variable attributes="__not_yet_defined__" line="47" name="beforeComment" /></scope><scope attributes="private static" doc="Extract comments that YUI Compressor preserves.&#10;&#10;@param string $in input&#10;&#10;@return array 3 elements are returned. If a YUI comment is found, the&#10;2nd element is the comment and the 1st and 2nd are the surrounding&#10;strings. If no comment is found, the entire string is returned as the &#10;1st element and the other two are false." ilk="function" line="72" lineend="89" name="_nextComment" returns="array" signature="array _nextComment(string $in)"><variable citdl="string" ilk="argument" line="72" name="in" /><variable citdl="array()" line="83" name="ret" /><variable line="74" name="start" /><variable line="84" name="endChars" /><variable line="74" name="end" /></scope></scope></scope>