<scope ilk="blob" lang="PHP" name="ArgumentInterface.php" src="/usr/local/pear/share/pear/PhpDocumentor/src/phpDocumentor/Descriptor/Interfaces/ArgumentInterface.php"><scope doc="phpDocumentor&#10;&#10;PHP Version 5.3&#10;&#10;@copyright 2010-2013 Mike van Riel / Naenius (http://www.naenius.com)&#10;@license   http://www.opensource.org/licenses/mit-license.php MIT&#10;@link      http://phpdoc.org" ilk="namespace" line="12" name="phpDocumentor\Descriptor\Interfaces"><scope ilk="interface" interfacerefs="BaseInterface" line="17" lineend="80" name="ArgumentInterface" signature="ArgumentInterface extends BaseInterface"><scope attributes="public" doc="Sets a normalized list of types that the argument represents.&#10;&#10;Arguments should have one of the types mentioned in this array. If this array is empty than that is considered&#10;to be the type `mixed` (meaning: can be anything).&#10;&#10;Any Type representing a class/interface/trait should be normalized to its complete FQCN, including preceding&#10;backslash. Types that do not represent a class/interface/trait should be written in lowercaps and should not be&#10;preceded by a backslash.&#10;&#10;@param string[] $types An array of normalized types that should be in this Argument&#10;&#10;@link https://github.com/phpDocumentor/phpDocumentor2/blob/develop/docs/PSR.md#appendix-a-types Definition of a&#10;    type.&#10;&#10;@todo update link to point to the final destination for the PHPDoc Standard.&#10;&#10;@return void" ilk="function" line="38" lineend="38" name="setTypes" signature="void setTypes(array $types)"><variable citdl="array" ilk="argument" line="38" name="types" /></scope><scope attributes="public" doc="Returns a normalized list of types.&#10;&#10;@see self::setTypes() for details on what types represent.&#10;&#10;@return string[]" ilk="function" line="47" lineend="47" name="getTypes" returns="string" signature="string getTypes()" /><scope attributes="public" doc="Sets the default value for an argument expressed as a string.&#10;&#10;@param string $value A textual representation of the default value.&#10;&#10;@return void" ilk="function" line="56" lineend="56" name="setDefault" signature="void setDefault(string $value)"><variable citdl="string" ilk="argument" line="56" name="value" /></scope><scope attributes="public" doc="Returns the default value for an argument as string or null is no default is set.&#10;&#10;@return string|null A textual representation of the default value, or null if no default value is present." ilk="function" line="63" lineend="63" name="getDefault" returns="string" signature="string getDefault()" /><scope attributes="public" doc="Sets whether this argument passes its parameter by reference or by value.&#10;&#10;@param boolean $byReference True if the parameter is passed by reference, otherwise it is by value.&#10;&#10;@return void" ilk="function" line="72" lineend="72" name="setByReference" signature="void setByReference(boolean $byReference)"><variable citdl="boolean" ilk="argument" line="72" name="byReference" /></scope><scope attributes="public" doc="Returns whether the parameter is passed by reference or by value.&#10;&#10;@return boolean True if the parameter is passed by reference, otherwise it is by value." ilk="function" line="79" lineend="79" name="isByReference" returns="boolean" signature="boolean isByReference()" /></scope></scope></scope>