cBlock($word, $pevent)"><variable ilk="argument" line="677" name="word" /><variable ilk="argument" line="677" name="pevent" /><variable citdl="this.checkEventPush()" line="679" name="a" /><variable citdl="this.p_vars" line="689" name="e" /></scope><scope doc="handler for ESCAPE.&#10;this event handler parses &lt;code&gt;&quot;this string \&quot;with its escape backslashes\&quot;&quot;&lt;/code&gt; and returns:&#10;&lt;code&gt;this string &quot;with its escape backslashes&quot;&lt;/code&gt;&#10;to make it human-readable" ilk="function" line="705" lineend="708" name="handleEscape" signature="handleEscape($word, $pevent)"><variable ilk="argument" line="705" name="word" /><variable ilk="argument" line="705" name="pevent" /></scope><scope doc="handler for COMMENT.&#10;this event handler parses single-line comments like:&#10;// this one" ilk="function" line="716" lineend="724" name="handleComment" signature="handleComment($word, $pevent)"><variable ilk="argument" line="716" name="word" /><variable ilk="argument" line="716" name="pevent" /></scope><scope doc="handler for ARRAY.&#10;this event handler parses arrays in default values of function and var definitions" ilk="function" line="731" lineend="757" name="handleArray" signature="handleArray($word, $pevent)"><variable ilk="argument" line="731" name="word" /><variable ilk="argument" line="731" name="pevent" /><variable citdl="this.checkEventPush()" line="733" name="e" /></scope><scope doc="handler for DEFINE.&#10;handles define(constant, value); statements" ilk="function" line="764" lineend="791" name="handleDefine" signature="handleDefine($word, $pevent)"><variable ilk="argument" line="764" name="word" /><variable ilk="argument" line="764" name="pevent" /></scope><scope doc="handler for DEFINE_PARAMS.&#10;handles the parsing of constant and value in define(constant, value);" ilk="function" line="798" lineend="867" name="handleDefineParams" signature="handleDefineParams($word, $pevent)"><variable ilk="argument" line="798" name="word" /><variable ilk="argument" line="798" name="pevent" /></scope><scope doc="handler for DEFINE_PARAMS_PARENTHESIS.&#10;this handler takes all parenthetical statements within constant or value in:&#10;define(constant, value) of a define statement, and handles them properly" ilk="function" line="875" lineend="885" name="handleDefineParamsParenthesis" signature="handleDefineParamsParenthesis($word, $pevent)"><variable ilk="argument" line="875" name="word" /><variable ilk="argument" line="875" name="pevent" /></scope><scope doc="handler for CLASS.&#10;this handler parses a class statement" ilk="function" line="892" lineend="928" name="handleClass" signature="handleClass($word, $pevent)"><variable ilk="argument" line="892" name="word" /><variable ilk="argument" line="892" name="pevent" /><variable citdl="this.checkEventPush()" line="895" name="a" /></scope><scope doc="handler for VAR.&#10;handle a var $varname = default_value; or var $varname; statement in a class definition" ilk="function" line="935" lineend="996" name="handleVar" signature="handleVar($word, $pevent)"><variable ilk="argument" line="935" name="word" /><variable ilk="argument" line="935" name="pevent" /><variable citdl="this.checkEventPush()" line="943" name="e" /></scope><scope doc="handler for QUOTE.&#10;this handler recognizes strings defined with double quotation marks (&quot;) and handles them correctly&#10;in any place that they legally appear in php code" ilk="function" line="1004" lineend="1020" name="handleQuote" signature="handleQuote($word, $pevent)"><variable ilk="argument" line="1004" name="word" /><variable ilk="argument" line="1004" name="pevent" /></scope><scope doc="handler for SINGLEQUOTE.&#10;this handler recognizes strings defined with single quotation marks (') and handles them correctly&#10;in any place that they legally appear in php code" ilk="function" line="1028" lineend="1040" name="handleSingleQuote" signature="handleSingleQuote($word, $pevent)"><variable ilk="argum