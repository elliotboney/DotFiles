ty" doc="template for the class currently being processed&#10;@var Smarty" line="165" name="class_data" /><variable citdl="parserPage" doc="current procedural page being processed&#10;@var parserPage" line="171" name="curpage" /><variable citdl="array" doc="alphabetical index of all elements sorted by package, subpackage, page,&#10;and class.&#10;@var array Format: array(package =&gt; array(subpackage =&gt; array('page'|'class' =&gt; array(path|classname =&gt; array(element, element,...)))))&#10;@uses $sort_absolutely_everything if true, then $package_elements is used,&#10;      otherwise, the {@link ParserData::$classelements} and&#10;      {@link ParserData::$pageelements} variables are used" line="180" name="package_elements" /><variable citdl="array" doc="alphabetical index of all elements&#10;&#10;@var array Format: array(first letter of element name =&gt; array({@link parserElement} or {@link parserPage},...))&#10;@see formatIndex(), HTMLframesConverter::formatIndex()" line="187" name="elements" /><variable citdl="array" doc="alphabetized index of procedural pages by package&#10;&#10;@see $leftindex&#10;@var array Format: array(package =&gt; array(subpackage =&gt; array({@link pageLink} 1,{@link pageLink} 2,...)" line="194" name="page_elements" /><variable citdl="array" doc="alphabetized index of defines by package&#10;&#10;@see $leftindex&#10;@var array Format: array(package =&gt; array(subpackage =&gt; array({@link defineLink} 1,{@link defineLink} 2,...)" line="201" name="define_elements" /><variable citdl="array" doc="alphabetized index of classes by package&#10;&#10;@see $leftindex&#10;@var array Format: array(package =&gt; array(subpackage =&gt; array({@link classLink} 1,{@link classLink} 2,...)" line="208" name="class_elements" /><variable citdl="array" doc="alphabetized index of global variables by package&#10;&#10;@see $leftindex&#10;@var array Format: array(package =&gt; array(subpackage =&gt; array({@link globalLink} 1,{@link globalLink} 2,...)" line