<scope ilk="blob" lang="PHP" name="phpDocumentorTWordParser.inc" src="/usr/local/pear/share/pear/PhpDocumentor/phpDocumentor/phpDocumentorTWordParser.inc"><scope classrefs="WordParser" doc="Like WordParser, but expects an array of tokens from the tokenizer &#10;instead of a string.&#10;&#10;@category   ToolsAndUtilities&#10;@package    phpDocumentor&#10;@subpackage WordParsers&#10;@author     Gregory Beaver &lt;cellog@php.net&gt;&#10;@copyright  2002-2007 Gregory Beaver&#10;@license    http://www.opensource.org/licenses/lgpl-license.php LGPL&#10;@version    Release: 1.4.4&#10;@link       http://www.phpdoc.org&#10;@link       http://pear.php.net/PhpDocumentor&#10;@since      1.2&#10;@todo       CS cleanup - change package to PhpDocumentor&#10;@todo       CS cleanup - change classname to PhpDocumentor_*" ilk="class" line="59" lineend="385" name="phpDocumentorTWordParser"><variable citdl="array" doc="tokenized array from {@link token_get_all()}&#10;@var array" line="68" name="_all" /><variable citdl="array" doc="List of tokens that can contain a newline&#10;@var array" line="83" name="_nl_check" /><variable citdl="array" doc="@var array" line="87" name="_global_search" /><variable citdl="integer" doc="current source line number (relative)&#10;@var integer" line="92" name="_sourceline" /><variable citdl="array" doc="Source of the entire file, parsed into arrays of tokens on each line&#10;@var array" line="97" name="_file_source" /><variable citdl="integer" doc="Line number the last comment was on&#10;@var integer" line="102" name="_docblock_linenum" /><scope doc="Uses {@link token_get_all()} to tokenize the source code.&#10;{@internal&#10;Also, it divides the source tokens into separate lines for use by&#10;the @filesource tag.&#10;&#10;{@source}}}&#10;&#10;@param string &amp;$input source code&#10;&#10;@return void" ilk="function" line="117" lineend="128" name="setup" signature="void setup(&amp; $input)"><variable ilk="argument" line="117" name="input" /></scope><varia