.ext or @name alias,&#10;                    or FALSE if it's not set" ilk="function" line="188" lineend="194" name="getFile" returns="string" signature="string getFile()" /><scope doc="sets the path to the file&#10;&#10;@param string $path full path to file&#10;&#10;@return void" ilk="function" line="203" lineend="211" name="setPath" signature="void setPath(string $path)"><variable citdl="string" ilk="argument" line="203" name="path" /></scope><scope doc="gets the path&#10;&#10;@return string fully delimited path (OS-dependent format),&#10;               or FALSE if it's not set" ilk="function" line="219" lineend="225" name="getPath" returns="string" signature="string getPath()" /><scope doc="loads the package output array&#10;&#10;@param array $packages array of packages to display in documentation &#10;                       (package1,package2,...)&#10;&#10;@return void&#10;@see phpDocumentor_IntermediateParser::$packageoutput" ilk="function" line="236" lineend="239" name="setPackageOutput" signature="void setPackageOutput(array $packages)"><variable citdl="array" ilk="argument" line="236" name="packages" /></scope><scope doc="gets the package output array&#10;&#10;@return array array of packages (package1,package2,...)&#10;@see phpDocumentor_IntermediateParser::$packageoutput" ilk="function" line="247" lineend="250" name="getPackageOutput" returns="array" signature="array getPackageOutput()" /><scope doc="sets the name&#10;&#10;@param string $name phpdoc-safe name (only _, numbers and letters) &#10;                    set by Parser::parse()&#10;&#10;@return void&#10;@see Parser::parse()" ilk="function" line="261" lineend="265" name="setName" signature="void setName(string $name)"><variable citdl="string" ilk="argument" line="261" name="name" /></scope><scope doc="gets the name&#10;&#10;@return string phpdoc-safe name (only _, numbers and letters),&#10;               or FALSE if it's not set" ilk="function" line="273" lineend="279" name="getName" returns="string"