<scope ilk="blob" lang="PHP" name="ParserData.inc" src="/usr/local/pear/share/pear/PhpDocumentor/phpDocumentor/ParserData.inc"><scope doc="Contains information about a PHP file, used to group procedural elements&#10;together.&#10;&#10;@category   ToolsAndUtilities&#10;@package    phpDocumentor&#10;@subpackage ParserData&#10;@author     Gregory Beaver &lt;cellog@php.net&gt;&#10;@copyright  2002-2008 Gregory Beaver&#10;@license    http://www.opensource.org/licenses/lgpl-license.php LGPL&#10;@version    Release: 1.4.4&#10;@filesource&#10;@link       http://www.phpdoc.org&#10;@link       http://pear.php.net/PhpDocumentor&#10;@since      1.0rc1&#10;@todo       CS cleanup - change package to PhpDocumentor&#10;@todo       CS cleanup - change classname to PhpDocumentor_*" ilk="class" line="59" lineend="337" name="parserPage"><variable citdl="string" doc="Type is used by many functions to skip the hassle of if&#10;&lt;code&gt;phpDocumentor_get_class($blah) == 'parserBlah'&lt;/code&gt;&#10;@var string" line="66" name="type" /><variable citdl="string" doc="not implemented in this version, will be used to link xml output pages&#10;@var string" line="71" name="id" /><variable citdl="string" doc="filename.ext (no path)&#10;@var string" line="76" name="file" /><variable citdl="string" doc="relative source location&#10;@var string" line="81" name="sourceLocation" /><variable citdl="string" doc="phpdoc-safe name (only letters, numbers and _)&#10;@var string" line="86" name="name" /><variable citdl="string" doc="original phpdoc-safe name (only letters, numbers and _)&#10;&#10;This fixes [ 1391432 ] Too many underscores in include links.&#10;@var string" line="93" name="origName" /><variable citdl="string" doc="@var string" line="97" name="category" /><variable citdl="string" doc="@var string" line="101" name="package" /><variable citdl="string" doc="@var string" line="105" name="subpackage" /><variable citdl="string" doc="@var string" line="109" name="parserVersion" /><variable citdl