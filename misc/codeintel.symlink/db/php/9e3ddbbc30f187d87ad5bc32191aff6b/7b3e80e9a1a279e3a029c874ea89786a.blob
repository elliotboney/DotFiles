ks ({@link parserDocBlock}).&#10;&#10;This class works in coordination with {@link phpDocumentor_IntermediateParser}&#10;to take output from {@link Parser::handleEvent()} and create indexes, links,&#10;and other assorted things (all documented in phpDocumentor_IntermediateParser&#10;and {@link Converter})&#10;&#10;@category   ToolsAndUtilities&#10;@package    phpDocumentor&#10;@subpackage ParserData&#10;@author     Gregory Beaver &lt;cellog@php.net&gt;&#10;@copyright  2002-2008 Gregory Beaver&#10;@license    http://www.opensource.org/licenses/lgpl-license.php LGPL&#10;@version    Release: 1.4.4&#10;@filesource&#10;@link       http://www.phpdoc.org&#10;@link       http://pear.php.net/PhpDocumentor&#10;@since      1.0rc1&#10;@todo       CS cleanup - change package to PhpDocumentor" ilk="class" line="363" lineend="691" name="parserData"><variable citdl="array" doc="array of parsed elements&#10;@var array" line="375" name="elements" /><variable citdl="boolean" doc="@var boolean&#10;@access private" line="380" name="_hasclasses" /><variable citdl="boolean" doc="@var boolean&#10;@access private" line="385" name="_hasinterfaces" /><variable citdl="array" doc="array of parsed elements with @access private&#10;@var array" line="390" name="privateelements" /><variable citdl="array" doc="array of parsed class elements&#10;@var array" line="395" name="classelements" /><variable citdl="parserTutorial" doc="@var parserTutorial|false" line="400" name="tutorial" /><variable citdl="array" doc="array of parsed class elements with @access private&#10;@var array" line="405" name="privateclasselements" /><variable citdl="array" doc="array of links descended from {@link abstractLink}&#10;@var array&#10;@see pageLink, defineLink, classLink, functionLink, methodLink, varLink" line="411" name="links" /><variable citdl="boolean" doc="used by {@link phpDocumentor_IntermediateParser::handleDocBlock()} to&#10;determine whether a docblock is a page-level docblock or not.  $clean is&#10;true as long as only 0 or 1 docblock has been parsed, and no element&#10;other than parserPage has been parsed&#10;@var boolean" line="419" name="clean" /><variable citdl="boolean" doc="DocBlock ({@link parserDocBlock}) for this page, or false if not set&#10;@var mixed" line="424" name="docblock" /><variable citdl="boolean" doc="Flag used to determine whether a page-level docblock is present&#10;@var boolean&#10;@access private" line="430" name="_explicitdocblock" /><variable citdl="string" doc="Type is used by many functions to skip the hassle of if&#10;&lt;code&gt;phpDocumentor_get_class($blah) == 'parserBlah'&lt;/code&gt;&#10;always 'page', used in element indexing and conversion functions found in&#10;{@link Converter}&#10;@var string" line="438" name="type" /><scope doc="add a new element to the tracking array&#10;&#10;@param parserElement &amp;$element add a parsed element to the &#10;                               {@link $elements} array,&#10;                               also sets {@link $clean} to false&#10;&#10;@return void" ilk="function" line="449" lineend="469" name="addElement" signature="void addElement(&amp; $element)"><variable ilk="argument" line="449" name="element" /></scope><scope doc="Does this package have interfaces?&#10;&#10;@return bool" ilk="function" line="476" lineend="479" name="hasInterfaces" returns="bool" signature="bool hasInterfaces()" /><scope doc="Does this package have classes?&#10;&#10;@return boolean" ilk="function" line="486" lineend="489" name="hasClasses" returns="boolean" signature="boolean hasClasses()" /><scope doc="adds a tutorial parser&#10;&#10;@param parserTutorial $t  a tutorial parser&#10;@param Converter      &amp;$c the output converter&#10;&#10;@return void" ilk="function" line="499" lineend="504" name="addTutorial" signature="void addTutorial(parserTutorial $t, &amp; $c)"><variable citdl="parserTutorial" ilk="argument" line="499" name="t" /><variable ilk="argument" line="499" name="c" /></scope><scope doc="If this file has a tutorial associated with it, &#10;returns a link to the tutorial.&#10;&#10;@return tutorialLink" ilk="function" line="512" lineend="515" name="getTutorial" returns="tutorialLink" signature="tutorialLink getTutorial()" /><scope doc="If the page-level DocBlock was present in the source, returns true&#10;&#10;@return bool" ilk="function" line="522" lineend="525" name="hasExplicitDocBlock" returns="bool" signature="bool hasExplicitDocBlock()" /><scope doc="Tells this page that its DocBlock was not implicit&#10;&#10;@return bool" ilk="function" line="532" lineend="535" name="explicitDocBlock" returns="bool" signature="bool explicitDocBlock()" /><scope doc="adds a link&#10;&#10;@param parserElement &amp;$element       element to add a new link (descended from&#10;                                     {@link abstractLink}) to the&#10;                                     {@link $links} array&#10;@param string        $classorpackage classname for elements that are&#10;                                     class-based (this may be deprecated in&#10;                                     the future, as the classname should be&#10;                                     contained within the element.  if&#10;                                     $element is a page, this parameter is a&#10;                                     package name&#10;@param string        $subpackage     subpackage name for page elements&#10;&#10;@return string" ilk="function" line="553" lineend="605" name="addLink" returns="string" signature="string addLink(&amp; $element, string $classorpackage = '', string $subpackage = '')"><variable ilk="argument" line="553" name="element" /><variable citdl="string" default="''" ilk="argument" line="553" name="classorpackage" /><variable citdl="string" default="''" ilk="argument" line="553" name="subpackage" /><variable citdl="functionLink" line="558" name="x" /></scope><scope doc="returns a link&#10;&#10;@param Converter &amp;$c   the output converter&#10;@param bool