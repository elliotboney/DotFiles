<scope ilk="blob" lang="PHP" name="PackagePageElements.inc" src="/usr/local/pear/share/pear/PhpDocumentor/phpDocumentor/PackagePageElements.inc"><scope classrefs="parserStringWithInlineTags" doc="Represents &lt;![CDATA[ ]]&gt; sections.&#10;&#10;These sections are interpreted as plain text&#10;&#10;@category   ToolsAndUtilities&#10;@package    phpDocumentor&#10;@subpackage Tutorial&#10;@author     Gregory Beaver &lt;cellog@php.net&gt;&#10;@copyright  2002-2008 Gregory Beaver&#10;@license    http://www.opensource.org/licenses/lgpl-license.php LGPL&#10;@version    Release: 1.4.4&#10;@tutorial   tutorials.pkg&#10;@link       http://www.phpdoc.org&#10;@link       http://pear.php.net/PhpDocumentor&#10;@todo       CS cleanup - change package to PhpDocumentor&#10;@todo       CS cleanup - change classname to PhpDocumentor_*" ilk="class" line="72" lineend="99" name="parserCData"><scope doc="calls the output conversion&#10;&#10;@param Converter &amp;$c          the output converter&#10;@param bool      $postprocess if postprocessing is needed&#10;&#10;@return string&#10;@uses Converter::getCData() convert contents to text&#10;@todo CS cleanup - rename to convert for camelCase rule" ilk="function" line="84" lineend="98" name="Convert" returns="string" signature="string Convert(&amp; $c, bool $postprocess = true)"><variable ilk="argument" line="84" name="c" /><variable citdl="bool" default="true" ilk="argument" line="84" name="postprocess" /><variable citdl="this.value" line="86" name="val" /><variable line="95" name="x" /><variable attributes="__not_yet_defined__" line="88" name="value" /><variable line="88" name="key" /></scope><variable citdl="boolean" line="94" name="cache" /><variable citdl="val" line="96" name="value" /></scope><scope classrefs="parserStringWithInlineTags" doc="a standard XML DocBook Tag&#10;&#10;This class is designed to represent all DocBook tags.  It is intelligent&#10;enough to understand the &lt;title&gt; tag, and also the &lt;refname&gt; tag for&#10;as title for &lt;refentry&gt;&#10;&#10;@category   ToolsAndUtilities&#10;@package    phpDocumentor&#10;@subpackage Tutorial&#10;@author     Gregory Beaver &lt;cellog@php.net&gt;&#10;@copyright  2002-2008 Gregory Beaver&#10;@license    http://www.opensource.org/licenses/lgpl-license.php LGPL&#10;@version    Release: 1.4.4&#10;@tutorial   tutorials.pkg&#10;@link       http://www.phpdoc.org&#10;@link       http://pear.php.net/PhpDocumentor&#10;@since      1.2&#10;@todo       CS cleanup - change package to PhpDocumentor&#10;@todo       CS cleanup - change classname to PhpDocumentor_*&#10;@todo       CS cleanup - rename to parserXmlDocBookTag for camelCase rule" ilk="class" line="122" lineend="458" name="parserXMLDocBookTag"><variable citdl="array" doc="Attributes from the XML tag&#10;&#10;Format: array(attrname =&gt; attrvalue, attrname =&gt; attrvalue,...)&#10;@var array" line="130" name="attributes" /><variable citdl="string" doc="Name of the tag&#10;@var string" line="135" name="name" /><variable citdl="parserCData" doc="@var parserCData" line="142" name="_cdata" /><variable citdl="parserTag" doc="@var parserTag" line="146" name="_title" /><variable citdl="parserIdLineTag" doc="@var parserIdLineTag" line="150" name="_id" /><variable citdl="parserTag" doc="Set to &lt;refpurpose&gt; in &lt;refsynopsisdiv&gt;&#10;@var parserTag" line="155" name="_description" /><scope attributes="__ctor__" doc="sets up the tag&#10;&#10;@param string $name tag name&#10;&#10;@todo CS cleanup - rename to parserXmlDocBookTag for camelCase rule" ilk="function" line="165" lineend="168" name="parserXMLDocBookTag" signature="parserXMLDocBookTag(string $name)"><variable citdl="string" ilk="argument" line="165" name="name" /></scope><scope doc="calls the output conversion&#10;&#10;@param Converter &amp;$c          the output converter&#10;@param bool      $postprocess if postprocessing is needed&#10;&#10;@return string&#10;@uses Converter::TranslateTag() Calls this to enclose the contents of the&#10;      DocBook tag based on the values in template options.ini file" ilk="function" line="180" lineend="193" name="Convert" returns="string" signature="string Convert(&amp; $c, bool $postprocess = true)"><variable ilk="argument" line="180" name="c" /><variable citdl="bool" default="true" ilk="argument" line="180" name="postprocess" /><variable attributes="__not_yet_defined__" line="184" name="v" /><variable line="183" name="simvalue" /><variable line="184" name="a" /><variable line="182" name="value" /></scope><scope doc="Begin a new CData section&#10;&#10;@return void&#10;@see addCData()" ilk="function" line="201" lineend="204" name="startCData" signature="void startCData()" /><scope doc="Adds {@link $_cdata} to {@link $value}&#10;&#10;@return void" ilk="function" line="211" lineend="215" name="endCData" signature="void endCData()" /><scope doc="Retrieve either the table of contents index, &#10;or the location that the TOC will go&#10;&#10;@param false|integer $state either an index of the {@}toc} tag in $this-&gt;value&#10;                            or false, if the next index value of $this-&gt;value&#10;                            is needed&#10;&#10;@return int&#10;@see setTOC()" ilk="function" line="228" lineend="234" name="getTOC" returns="int" signature="int getTOC($state = false)"><variable default="false" ilk="argument" line="228" name="state" /></scope><scope doc="sets the TOC value&#10;&#10;@param integer            $state index of the TOC in $this-&gt;value&#10;@param parserTocInlineTag $val   tag value&#10;&#10;@return void" ilk="function" line="244" lineend="247" name="setTOC" signature="void setTOC(integer $state, parserTocInlineTag $val)"><variable citdl="integer" ilk="argument" line="244" name="state" /><variable citdl="parserTocInlineTag" ilk="argument" line="244" name="val" /></scope><scope doc="add a word to CData&#10;&#10;@param string $word word to add&#10;&#10;@return void" ilk="function" line="256" lineend="259" name="addCData" signature="void addCData(string $word)"><variable citdl="string" ilk="argument" line="256" name="word" /></scope><scope doc="Add an xml tag attribute name=&quot;value&quot; pair&#10;&#10;if the attribute is id, value must be a {@link parserIdInlineTag}&#10;&#10;@param string                   $name  attribute name&#10;@param string|parserIdInlineTag $value value of attribute&#10;&#10;@return void" ilk="function" line="271" lineend="283" name="addAttribute" signature="void addAttribute(string $name, $value)"><variable citdl="string" ilk="argument" line="271" name="name" /><variable ilk="argument" line="271" name="value" /></scope><scope doc="Set the title of a DocBook tag section.&#10;&#10;For most DocBook tags, the title is represented with a &lt;title&gt;&lt;/title&gt;&#10;tag pair.  The &lt;refentry&gt; top-level tag is a little different.  Instead&#10;of using &lt;title&gt;&lt;/title&gt;, phpDocumentor uses the contents of the&#10;&lt;refname&gt; tag in the &lt;refnamediv&gt; tag&#10;&#10;@param parserXMLDocBookTag $title the title element&#10;&#10;@return void" ilk="function" line="297" lineend="300" name="setTitle" signature="void setTitle(parserXMLDocBookTag $title)"><variable citdl="parserXMLDocBookTag" ilk="argument" line="297" name="title" /></scope><scope doc="If the id attribute is present, this method will set its id&#10;&#10;@param parserIdInlineTag $id the id value&#10;&#10;@return void" ilk="function" line="309" lineend="312" name="setId" signature="void setId(parserIdInlineTag $id)"><variable citdl="parserIdInlineTag" ilk="argument" line="309" name="id" /></scope><scope doc="Return converter-specific formatting of ID.&#10;&#10;Passes $c to {@link parserIdInlineTag::Convert()}&#10;&#10;@param Converter &amp;$c the output converter&#10;&#10;@return string" ilk="function" line="323" lineend="328" name="getId" returns="string" signature="string getId(&amp; $c)"><variable ilk="argument" line="323" name="c" /></scope><scope doc="Determine whether the docbook element has a title&#10;&#10;@return boolean" ilk="function" line="335" lineend="338" name="hasTitle" returns="boolean" signature="boolean hasTitle()" /><scope doc="Retrieve Converter-specific formatting of the title of this element&#10;&#10;@param Converter &amp;$c the output converter&#10;&#10;@return string" ilk="function" line="347" lineend="388" name="getTitle" returns="string" signature="string getTitle(&amp; $c)"><variable ilk="argument" line="347" name="c" /><variable attributes="__not_yet_defined__" line="361" name="val" /><variable attributes="__not_yet_defined__" line="350" name="tag" /><variable citdl="parserStringWithInlineTags" line="360" name="t" /></scope><scope doc="Retrieve the contents of a subsection&#10;&#10;This method uses the $_id members of nested docbook tags to retrieve&#10;the section defined by $subsection&#10;&#10;@param Converter &amp;$c         the output converter&#10;@param string    $subsection converter-specific subsection&#10;&#10;@return bool|string" ilk="function" line="401" lineend="424" name="getSubsection" returns="bool" signature="bool getSubsection(&amp; $c, string $subsection)"><variable ilk="argument" line="401" name="c" /><variable citdl="string" ilk="argument" line="401" name="subsection" /><variable citdl="phpDocumentor_clone()" line="406" name="search" /><variable attributes="__not_yet_defined__" line="414" name="el" /><variable line="418" name="a" /></scope><scope doc="Add contents to this tag.&#10;&#10;There are four kinds of data in a DocBook tutorial:&#10; 1. &lt;b&gt;tags&lt;/b&gt; - normal tags like &lt;refentry&gt;&#10; 2. &lt;b&gt;entities&lt;/b&gt; - normal entities like &amp;rdquo;&#10; 3. &lt;b&gt;&lt;![CDATA[&lt;/b&gt; - character data that should not be interpreted,&#10;    like &lt;programlisting&gt; contents&#10; 4. &lt;b&gt;text&lt;/b&gt; - normal non-markup text&#10;&#10;All four kinds of data are added here&#10;&#10;@param parserEntity|parserCData|parserXMLDocBookTag|string $el nested tag,&#10;                                                               entity, or text&#10;&#10;@return mixed" ilk="function" line="443" lineend="457" name="add" returns="mixed" signature="mixed add($el)"><variable ilk="argument" line="443" name="el" /></scope></scope><scope doc="a standard entity like &amp;rdquo;&#10;&#10;This class is designed to represent all DocBook entities.&#10;&#10;@category   ToolsAndUtilities&#10;@package    phpDocumentor&#10;@subpackage Tutorial&#10;@author     Gregory Beaver &lt;cellog@php.net&gt;&#10;@copyright  2002-2008 Gregory Beaver&#10;@license    http://www.opensource.org/licenses/lgpl-license.php LGPL&#10;@version    Release: 1.4.4&#10;@tutorial   tutorials.pkg&#10;@link       http://www.phpdoc.org&#10;@link       http://pear.php.net/PhpDocumentor&#10;@since      1.2&#10;@todo       CS cleanup - change package to PhpDocumentor&#10;@todo       CS cleanup - change classname to PhpDocumentor_*" ilk="class" line="479" lineend="512" name="parserEntity"><scope attributes="__ctor__" doc="sets up the entity&#10;&#10;@param string $name entity name" ilk="function" line="486" lineend="489" name="parserEntity" signature="parserEntity(string $name)"><variable citdl="string" ilk="argument" line="486" name="name" /></scope><variable citdl="name" line="488" name="value" /><scope doc="calls the output conversion&#10;&#10;@param Converter &amp;$c          the output converter&#10;@param bool      $postprocess if postprocessing is needed&#10;&#10;@return string&#10;@uses Converter::TranslateEntity() convert contents to text&#10;@todo CS cleanup - rename to convert for camelCase rule" ilk="function" line="501" lineend="511" name="Convert" returns="string" signature="string Convert(&amp; $c, bool $postprocess = true)"><variable ilk="argument" line="501" name="c" /><variable citdl="bool" default="true" ilk="argument" line="501" name="postprocess" /><variable citdl="strtr()" line="508" name="ret" /><variable citdl="get_html_translation_table()" line="506" name="trans_tbl" /></scope></scope></scope>