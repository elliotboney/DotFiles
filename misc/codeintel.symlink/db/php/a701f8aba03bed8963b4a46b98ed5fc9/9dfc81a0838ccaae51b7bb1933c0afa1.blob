<scope ilk="blob" lang="PHP" name="xdiff.php" src="/private/var/www/kw/wp-includes/Text/Diff/Engine/xdiff.php"><scope doc="Class used internally by Diff to actually compute the diffs.&#10;&#10;This class uses the xdiff PECL package (http://pecl.php.net/package/xdiff)&#10;to compute the differences between the two input arrays.&#10;&#10;Copyright 2004-2010 The Horde Project (http://www.horde.org/)&#10;&#10;See the enclosed file COPYING for license information (LGPL). If you did&#10;not receive this file, see http://opensource.org/licenses/lgpl-license.php.&#10;&#10;@author  Jon Parise &lt;jon@horde.org&gt;&#10;@package Text_Diff" ilk="class" line="16" lineend="64" name="Text_Diff_Engine_xdiff"><scope ilk="function" line="20" lineend="62" name="diff" returns="edits" signature="diff($from_lines, $to_lines)"><variable ilk="argument" line="20" name="from_lines" /><variable ilk="argument" line="20" name="to_lines" /><variable citdl="implode()" line="26" name="from_string" /><variable citdl="array()" line="41" name="edits" /><variable citdl="implode()" line="27" name="to_string" /><variable attributes="__not_yet_defined__" line="42" name="line" /><variable citdl="xdiff_string_diff()" line="30" name="diff" /></scope></scope></scope>