<scope ilk="blob" lang="PHP" name="ArrayUtils.php" src="/usr/local/pear/share/pear/PhpDocumentor/vendor/zendframework/zend-stdlib/Zend/Stdlib/ArrayUtils.php"><scope doc="Zend Framework (http://framework.zend.com/)&#10;&#10;@link      http://github.com/zendframework/zf2 for the canonical source repository&#10;@copyright Copyright (c) 2005-2013 Zend Technologies USA Inc. (http://www.zend.com)&#10;@license   http://framework.zend.com/license/new-bsd New BSD License" ilk="namespace" line="10" name="Zend\Stdlib"><import line="12" module="" symbol="Traversable" /><scope attributes="abstract" doc="Utility class for testing and manipulation of PHP arrays.&#10;&#10;Declared abstract, as we have no need for instantiation." ilk="class" line="19" lineend="275" name="ArrayUtils"><scope attributes="public static" doc="Test whether an array contains one or more string keys&#10;&#10;@param  mixed $value&#10;@param  bool  $allowEmpty    Should an empty array() return true&#10;@return bool" ilk="function" line="28" lineend="39" name="hasStringKeys" returns="bool" signature="bool hasStringKeys(mixed $value, bool $allowEmpty = false)"><variable citdl="mixed" ilk="argument" line="28" name="value" /><variable citdl="bool" default="false" ilk="argument" line="28" name="allowEmpty" /></scope><scope attributes="public static" doc="Test whether an array contains one or more integer keys&#10;&#10;@param  mixed $value&#10;@param  bool  $allowEmpty    Should an empty array() return true&#10;@return bool" ilk="function" line="48" lineend="59" name="hasIntegerKeys" returns="bool" signature="bool hasIntegerKeys(mixed $value, bool $allowEmpty = false)"><variable citdl="mixed" ilk="argument" line="48" name="value" /><variable citdl="bool" default="false" ilk="argument" line="48" name="allowEmpty" /></scope><scope attributes="public static" doc="Test whether an array contains one or more numeric keys.&#10;&#10;A numeric key can be one of the following:&#10;- an integer 1,&#10;- a string with a number '20'&#10;- a string with negative number: '-1000'&#10;- a float: 2.2120, -78.150999&#10;- a string with float:  '4000.99999', '-10.10'&#10;&#10;@param  mixed $value&#10;@param  bool  $allowEmpty    Should an empty array() return true&#10;@return bool" ilk="function" line="75" lineend="86" name="hasNumericKeys" returns="bool" signature="bool hasNumericKeys(mixed $value, bool $allowEmpty = false)"><variable citdl="mixed" ilk="argument" line="75" name="value" /><variable citdl="bool" default="false" ilk="argument" line="75" name="allowEmpty" /></scope><scope attributes="public static" doc="Test whether an array is a list&#10;&#10;A list is a collection of values assigned to continuous integer keys&#10;starting at 0 and ending at count() - 1.&#10;&#10;For example:&#10;&lt;code&gt;&#10;$list = array('a', 'b', 'c', 'd');&#10;$list = array(&#10;    0 =&gt; 'foo',&#10;    1 =&gt; 'bar',&#10;    2 =&gt; array('foo' =&gt; 'baz'),&#10;);&#10;&lt;/code&gt;&#10;&#10;@param  mixed $value&#10;@param  bool  $allowEmpty    Is an empty list a valid list?&#10;@return bool" ilk="function" line="108" lineend="119" name="isList" returns="bool" signature="bool isList(mixed $value, bool $allowEmpty = false)"><variable citdl="mixed" ilk="argument" line="108" name="value" /><variable citdl="bool" default="false" ilk="argument" line="108" name="allowEmpty" /></scope><scope attributes="public static" doc="Test whether an array is a hash table.&#10;&#10;An array is a hash table if:&#10;&#10;1. Contains one or more non-integer keys, or&#10;2. Integer keys are non-continuous or misaligned (not starting with 0)&#10;&#10;For example:&#10;&lt;code&gt;&#10;$hash = array(&#10;    'foo' =&gt; 15,&#10;    'bar' =&gt; false,&#10;);&#10;$hash = array(&#10;    1995  =&gt; 'Birth of PHP',&#10;    2009  =&gt; 'PHP 5.3.0',&#10;    2012  =&gt; 'PHP 5.4.0',&#10;);&#10;$hash = array(&#10;    'formElement,&#10;    'options' =&gt; array( 'debug' =&gt; true ),&#10;);&#10;&lt;/code&gt;&#10;&#10;@param  mixed $value&#10;@param  bool  $allowEmpty    Is an empty array() a valid hash table?&#10;@return bool" ilk="function" line="150" lineend="161" name="isHashTable" returns="bool" signature="bool isHashTable(mixed $value, bool $allowEmpty = false)"><variable citdl="mixed" ilk="argument" line="150" name="value" /><variable citdl="bool" default="false" ilk="argument" line="150" name="allowEmpty" /></scope><scope attributes="public static" doc="Checks if a value exists in an array.&#10;&#10;Due to &quot;foo&quot; == 0 === TRUE with in_array when strict = false, an option&#10;has been added to prevent this. When $strict = 0/false, the most secure&#10;non-strict check is implemented. if $strict = -1, the default in_array&#10;non-strict behaviour is used.&#10;&#10;@param mixed $needle&#10;@param array $haystack&#10;@param int|bool $strict&#10;@return bool" ilk="function" line="176" lineend="191" name="inArray" returns="bool" signature="bool inArray(mixed $needle, array $haystack, $strict = false)"><variable citdl="mixed" ilk="argument" line="176" name="needle" /><variable citdl="array" ilk="argument" line="176" name="haystack" /><variable default="false" ilk="argument" line="176" name="strict" /><variable attributes="__not_yet_defined__" citdl="string" line="183" name="h" /></scope><scope attributes="public static" doc="Convert an iterator to an array.&#10;&#10;Converts an iterator to an array. The $recursive flag, on by default,&#10;hints whether or not you want to do so recursively.&#10;&#10;@param  array|Traversable  $iterator     The array or Traversable object to convert&#10;@param  bool               $recursive    Recursively check all nested structures&#10;@throws Exception\InvalidArgumentException if $iterator is not an array or a Traversable object&#10;@return array" ilk="function" line="204" lineend="243" name="iteratorToArray" returns="array" signature="array iteratorToArray($iterator, bool $recursive = true)"><variable ilk="argument" line="204" name="iterator" /><variable citdl="bool" default="true" ilk="argument" line="204" name="recursive" /><variable line="223" name="key" /><variable citdl="array()" line="222" name="array" /><variable attributes="__not_yet_defined__" line="223" name="value" /></scope><scope attributes="public static" doc="Merge two arrays together.&#10;&#10;If an integer key exists in both arrays, the value from the second array&#10;will be appended the the first array. If both values are arrays, they&#10;are merged together, else the value of the second array overwrites the&#10;one of the first array.&#10;&#10;@param  array $a&#10;@param  array $b&#10;@return array" ilk="function" line="257" lineend="274" name="merge" returns="array" signature="array merge(array $a, array $b)"><variable citdl="array" ilk="argument" line="257" name="a" /><variable citdl="array" ilk="argument" line="257" name="b" /><variable line="259" name="key" /><variable attributes="__not_yet_defined__" line="259" name="value" /></scope></scope></scope></scope>