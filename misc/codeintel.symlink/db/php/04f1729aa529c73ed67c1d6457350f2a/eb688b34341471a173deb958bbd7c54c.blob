<scope ilk="blob" lang="PHP" name="PriorityQueue.php" src="/usr/local/pear/share/pear/PhpDocumentor/vendor/zendframework/zend-stdlib/Zend/Stdlib/PriorityQueue.php"><scope doc="Zend Framework (http://framework.zend.com/)&#10;&#10;@link      http://github.com/zendframework/zf2 for the canonical source repository&#10;@copyright Copyright (c) 2005-2013 Zend Technologies USA Inc. (http://www.zend.com)&#10;@license   http://framework.zend.com/license/new-bsd New BSD License" ilk="namespace" line="10" name="Zend\Stdlib"><import line="12" module="" symbol="Countable" /><import line="13" module="" symbol="IteratorAggregate" /><import line="14" module="" symbol="Serializable" /><scope doc="Re-usable, serializable priority queue implementation&#10;&#10;SplPriorityQueue acts as a heap; on iteration, each item is removed from the&#10;queue. If you wish to re-use such a queue, you need to clone it first. This&#10;makes for some interesting issues if you wish to delete items from the queue,&#10;or, as already stated, iterate over it multiple times.&#10;&#10;This class aggregates items for the queue itself, but also composes an&#10;&quot;inner&quot; iterator in the form of an SplPriorityQueue object for performing&#10;the actual iteration." ilk="class" interfacerefs="Countable IteratorAggregate Serializable" line="28" lineend="302" name="PriorityQueue"><variable citdl="int" ilk="constant" line="30" name="EXTR_DATA" /><variable citdl="int" ilk="constant" line="31" name="EXTR_PRIORITY" /><variable citdl="int" ilk="constant" line="32" name="EXTR_BOTH" /><variable attributes="protected" citdl="string" doc="Inner queue class to use for iteration&#10;@var string" line="38" name="queueClass" /><variable attributes="protected" citdl="array" doc="Actual items aggregated in the priority queue. Each item is an array&#10;with keys &quot;data&quot; and &quot;priority&quot;.&#10;@var array" line="45" name="items" /><variable attributes="protected" citdl="SplPriorityQueue" doc="Inner queue object&#10;@var SplPriorityQueue" line="51" name="queue" /><scope attributes="public" doc="Insert an item into the queue&#10;&#10;Priority defaults to 1 (low priority) if none provided.&#10;&#10;@param  mixed $data&#10;@param  int $priority&#10;@return PriorityQueue" ilk="function" line="62" lineend="71" name="insert" returns="PriorityQueue" signature="PriorityQueue insert(mixed $data, int $priority = 1)"><variable citdl="mixed" ilk="argument" line="62" name="data" /><variable citdl="int" default="1" ilk="argument" line="62" name="priority" /></scope><scope attributes="public" doc="Remove an item from the queue&#10;&#10;This is different than {@link extract()}; its purpose is to dequeue an&#10;item.&#10;&#10;This operation is potentially expensive, as it requires&#10;re-initialization and re-population of the inner queue.&#10;&#10;Note: this removes the first item matching the provided item found. If&#10;the same item has been added multiple times, it will not remove other&#10;instances.&#10;&#10;@param  mixed $datum&#10;@return bool False if the item was not found, true otherwise." ilk="function" line="89" lineend="111" name="remove" returns="bool" signature="bool remove(mixed $datum)"><variable citdl="mixed" ilk="argument" line="89" name="datum" /><variable line="92" name="key" /><variable citdl="this.getQueue()" line="103" name="queue" /><variable attributes="__not_yet_defined__" line="92" name="item" /><variable citdl="boolean" line="91" name="found" /></scope><scope attributes="public" doc="Is the queue empty?&#10;&#10;@return bool" ilk="function" line="118" lineend="121" name="isEmpty" returns="bool" signature="bool isEmpty()" /><scope attributes="public" doc="How many items are in the queue?&#10;&#10;@return int" ilk="function" line="128" lineend="131" name="count" returns="int" signature="int count()" /><scope attributes="public" doc="Peek at the top node in the queue, based on priority.&#10;&#10;@return mixed" ilk="function" line="138" lineend="141" name="top" returns="mixed" signature="mixed top()" /><scope attributes="public" doc="Extract a node from the inner queue and sift up&#10;&#10;@return mixed" ilk="function" line="148" lineend="151" name="extract" returns="mixed" signature="mixed extract()" /><scope attributes="public" doc="Retrieve the inner iterator&#10;&#10;SplPriorityQueue acts as a heap, which typically implies that as items&#10;are iterated, they are also removed. This does not work for situations&#10;where the queue may be iterated multiple times. As such, this class&#10;aggregates the values, and also injects an SplPriorityQueue. This method&#10;retrieves the inner queue object, and clones it for purposes of&#10;iteration.&#10;&#10;@return SplPriorityQueue" ilk="function" line="165" lineend="169" name="getIterator" returns="SplPriorityQueue" signature="SplPriorityQueue getIterator()"><variable citdl="this.getQueue()" line="167" name="queue" /></scope><scope attributes="public" doc="Serialize the data structure&#10;&#10;@return string" ilk="function" line="176" lineend="179" name="serialize" returns="string" signature="string serialize()" /><scope attributes="public" doc="Unserialize a string into a PriorityQueue object&#10;&#10;Serialization format is compatible with {@link Zend\Stdlib\SplPriorityQueue}&#10;&#10;@param  string $data&#10;@return void" ilk="function" line="189" lineend="194" name="unserialize" signature="void unserialize(string $data)"><variable citdl="string" ilk="argument" line="189" name="data" /><variable attributes="__not_yet_defined__" line="191" name="item" /></scope><scope attributes="public" doc="Serialize to an array&#10;&#10;By default, returns only the item data, and in the order registered (not&#10;sorted). You may provide one of the EXTR_* flags as an argument, allowing&#10;the ability to return priorities or both data and priority.&#10;&#10;@param  int $flag&#10;@return array" ilk="function" line="206" lineend="222" name="toArray" returns="array" signature="array toArray(int $flag = self::EXTR_DATA)"><variable citdl="int" default="self::EXTR_DATA" ilk="argument" line="206" name="flag" /></scope><scope attributes="public" doc="Specify the internal queue class&#10;&#10;Please see {@link getIterator()} for details on the necessity of an&#10;internal queue class. The class provided should extend SplPriorityQueue.&#10;&#10;@param  string $class&#10;@return PriorityQueue" ilk="function" line="233" lineend="237" name="setInternalQueueClass" returns="PriorityQueue" signature="PriorityQueue setInternalQueueClass(string $class)"><variable citdl="string" ilk="argument" line="233" name="class" /></scope><scope attributes="public" doc="Does the queue contain the given datum?&#10;&#10;@param  mixed $datum&#10;@return bool" ilk="function" line="245" lineend="253" name="contains" returns="bool" signature="bool contains(mixed $datum)"><variable citdl="mixed" ilk="argument" line="245" name="datum" /><variable attributes="__not_yet_defined__" line="247" name="item" /></scope><scope attributes="public" doc="Does the queue have an item with the given priority?&#10;&#10;@param  int $priority&#10;@return bool" ilk="function" line="261" lineend="269" name="hasPriority" returns="bool" signature="bool hasPriority(int $priority)"><variable citdl="int" ilk="argument" line="261" name="priority" /><variable attributes="__not_yet_defined__" line="263" name="item" /></scope><scope attributes="protected" doc="Get the inner priority queue instance&#10;&#10;@throws \DomainException&#10;@return SplPriorityQueue" ilk="function" line="277" lineend="289" name="getQueue" returns="SplPriorityQueue" signature="SplPriorityQueue getQueue()" /><scope attributes="public" doc="Add support for deep cloning&#10;&#10;@return void" ilk="function" line="296" lineend="301" name="__clone" signature="void __clone()" /></scope></scope></scope>