e" /><variable ilk="argument" line="215" name="anchor" /><variable default="''" ilk="argument" line="215" name="text" /><variable default="false" ilk="argument" line="215" name="link" /></scope><scope doc="Return a line of highlighted source code with formatted line number&#10;&#10;If the $path is a full path, then an anchor to the line number will be&#10;added as well&#10;@param integer line number&#10;@param string highlighted source code line&#10;@param false|string full path to @filesource file this line is a part of,&#10;       if this is a single line from a complete file.&#10;@return string formatted source code line with line number" ilk="function" line="236" lineend="252" name="sourceLine" returns="string" signature="string sourceLine($linenumber, $line, $path = false)"><variable ilk="argument" line="236" name="linenumber" /><variable ilk="argument" line="236" name="line" /><variable default="false" ilk="argument" line="236" name="path" /><variable citdl="string" line="238" name="extra" /></scope><scope doc="Used to convert the &lt;&lt;code&gt;&gt; tag in a docblock&#10;@param string&#10;@param boolean&#10;@return string" ilk="function" line="260" lineend="265" name="ProgramExample" returns="string" signature="string ProgramExample($example, $tutorial = false, $inlinesourceparse = null, $class = null, $linenum = null, $filesourcepath = null)"><variable ilk="argument" line="260" name="example" /><variable default="false" ilk="argument" line="260" name="tutorial" /><variable default="null" ilk="argument" line="260" name="inlinesourceparse" /><variable default="null" ilk="argument" line="260" name="class" /><variable default="null" ilk="argument" line="260" name="linenum" /><variable default="null" ilk="argument" line="260" name="filesourcepath" /></scope><scope doc="@param string" ilk="function" line="270" lineend="282" name="TutorialExample" returns="example" signature="TutorialExample($example)"><variable ilk="argument" line="270" name="example" /><variable