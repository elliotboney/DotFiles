<scope ilk="blob" lang="PHP" name="composite.php" src="/usr/local/Cellar/php55/5.5.7/lib/php/Log/composite.php"><scope classrefs="Log" doc="The Log_composite:: class implements a Composite pattern which&#10;allows multiple Log implementations to receive the same events.&#10;&#10;@author  Chuck Hagenbuch &lt;chuck@horde.org&gt;&#10;@author  Jon Parise &lt;jon@php.net&gt;&#10;&#10;@since Horde 1.3&#10;@since Log 1.0&#10;@package Log&#10;&#10;@example composite.php   Using the composite handler." ilk="class" line="23" lineend="274" name="Log_composite"><variable citdl="array" doc="Array holding all of the Log instances to which log events should be&#10;sent.&#10;&#10;@var array&#10;@access private" line="32" name="_children" /><scope attributes="__ctor__" doc="Constructs a new composite Log object.&#10;&#10;@param boolean   $name       This parameter is ignored.&#10;@param boolean   $ident      This parameter is ignored.&#10;@param boolean   $conf       This parameter is ignored.&#10;@param boolean   $level      This parameter is ignored.&#10;&#10;@access public" ilk="function" line="45" lineend="49" name="Log_composite" signature="Log_composite(boolean $name, boolean $ident = '', boolean $conf = array(), boolean $level = PEAR_LOG_DEBUG)"><variable citdl="boolean" ilk="argument" line="45" name="name" /><variable citdl="boolean" default="''" ilk="argument" line="45" name="ident" /><variable citdl="boolean" default="array()" ilk="argument" line="45" name="conf" /><variable citdl="boolean" default="PEAR_LOG_DEBUG" ilk="argument" line="45" name="level" /></scope><variable citdl="ident" line="48" name="_ident" /><scope doc="Opens all of the child instances.&#10;&#10;@return  True if all of the child instances were successfully opened.&#10;&#10;@access public" ilk="function" line="58" lineend="68" name="open" returns="True" signature="True open()"><variable attributes="__not_yet_defined__" line="62" name="child" /></scope><variable citdl="boolean" line="61" name="_opened" />