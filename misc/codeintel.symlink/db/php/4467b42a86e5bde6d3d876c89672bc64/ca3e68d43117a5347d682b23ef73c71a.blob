<scope ilk="blob" lang="PHP" name="mdb2.php" src="/usr/local/Cellar/php55/5.5.7/lib/php/Log/mdb2.php"><import line="10" module="MDB2.php" /><scope classrefs="Log" doc="The Log_mdb2 class is a concrete implementation of the Log:: abstract class&#10;which sends messages to an SQL server.  Each entry occupies a separate row&#10;in the database.&#10;&#10;This implementation uses PEAR's MDB2 database abstraction layer.&#10;&#10;CREATE TABLE log_table (&#10; id          INT NOT NULL,&#10; logtime     TIMESTAMP NOT NULL,&#10; ident       CHAR(16) NOT NULL,&#10; priority    INT NOT NULL,&#10; message     VARCHAR(200),&#10; PRIMARY KEY (id)&#10;);&#10;&#10;@author  Lukas Smith &lt;smith@backendmedia.com&gt;&#10;@author  Jon Parise &lt;jon@php.net&gt;&#10;@since   Log 1.9.0&#10;@package Log" ilk="class" line="34" lineend="358" name="Log_mdb2"><variable citdl="string" doc="Variable containing the DSN information.&#10;@var mixed&#10;@access private" line="41" name="_dsn" /><variable citdl="array" doc="Array containing our set of DB configuration options.&#10;@var array&#10;@access private" line="48" name="_options" /><variable citdl="conf" doc="Object holding the database handle.&#10;@var object&#10;@access private" line="55" name="_db" /><variable citdl="resource" doc="Resource holding the prepared statement handle.&#10;@var resource&#10;@access private" line="62" name="_statement" /><variable citdl="boolean" doc="Flag indicating that we're using an existing database connection.&#10;@var boolean&#10;@access private" line="69" name="_existingConnection" /><variable citdl="string" doc="String holding the database table to use.&#10;@var string&#10;@access private" line="76" name="_table" /><variable citdl="string" doc="String holding the name of the ID sequence.&#10;@var string&#10;@access private" line="83" name="_sequence" /><variable citdl="integer" doc="Maximum length of the $ident string.  This corresponds to the size of&#10;the 'ident' column in the SQL table.&#10;@var integer&#10;@access private" line="91" name="_identLimit" /><variable citdl="array" doc="Set of field types used in the database table.&#10;@var array&#10;@access private" line="104" name="_types" /><scope attributes="__ctor__" doc="Constructs a new sql logging object.&#10;&#10;@param string $name         The target SQL table.&#10;@param string $ident        The identification field.&#10;@param array $conf          The connection configuration array.&#10;@param int $level           Log messages up to and including this level.&#10;@access public" ilk="function" line="115" lineend="152" name="Log_mdb2" signature="Log_mdb2(string $name, string $ident = '', array $conf = array(), int $level = PEAR_LOG_DEBUG)"><variable citdl="string" ilk="argument" line="115" name="name" /><variable citdl="string" default="''" ilk="argument" line="115" name="ident" /><variable citdl="array" default="array()" ilk="argument" line="115" name="conf" /><variable citdl="int" default="PEAR_LOG_DEBUG" ilk="argument" line="115" name="level" /></scope><variable citdl="md5()" line="118" name="_id" /><variable citdl="Log.UPTO()" line="120" name="_mask" /><variable citdl="boolean" line="144" name="_opened" /><scope doc="Opens a connection to the database, if it has not already&#10;been opened. This is implicitly called by log(), if necessary.&#10;&#10;@return boolean   True on success, false on failure.&#10;@access public" ilk="function" line="161" lineend="180" name="open" returns="boolean" signature="boolean open()" /><scope doc="Closes the connection to the database if it is still open and we were&#10;the ones that opened it.  It is the caller's responsible to close an&#10;existing connection that was passed to us via $conf['db'].&#10;&#10;@return boolean   True on success, false on failure.&#10;@access public" ilk="function" line="190" lineend="205" name="close" returns="boolean" signature="boolean close()" /><scope doc="Sets this Log instance's identification string.  Note that this&#10;SQL-specific implementation will limit the length of the $ident string&#10;to sixteen (16) characters.&#10;&#10;@param string    $ident      The new identification string.&#10;&#10;@access  public&#10;@since   Log 1.8.5" ilk="function" line="217" lineend="220" name="setIdent" signature="setIdent(string $ident)"><variable citdl="string" ilk="argument" line="217" name="ident" /></scope><variable citdl="substr()" line="219" name="_ident" /><scope doc="Inserts $message to the currently open database.  Calls open(),&#10;if necessary.  Also passes the message along to any Log_observer&#10;instances that are observing this Log.&#10;&#10;@param mixed  $message  String or object containing the message to log.&#10;@param string $priority The priority of the message.  Valid&#10;                 values are: PEAR_LOG_EMERG, PEAR_LOG_ALERT,&#10;                 PEAR_LOG_CRIT, PEAR_LOG_ERR, PEAR_LOG_WARNING,&#10;                 PEAR_LOG_NOTICE, PEAR_LOG_INFO, and PEAR_LOG_DEBUG.&#10;@return boolean  True on success or false on failure.&#10;@access public" ilk="function" line="235" lineend="302" name="log" returns="boolean" signature="boolean log(mixed $message, string $priority = null)"><variable citdl="mixed" ilk="argument" line="235" name="message" /><variable citdl="string" default="null" ilk="argument" line="235" name="priority" /><variable citdl="array()" line="267" name="values" /><variable citdl="this._statement.execute()" line="271" name="result" /></scope><scope doc="Create the log table in the database.&#10;&#10;@return boolean  True on success or false on failure.&#10;@access private" ilk="function" line="310" lineend="337" name="_createTable" returns="boolean" signature="boolean _createTable()"><variable citdl="this._db.manager.createTable()" line="322" name="result" /></scope><scope doc="Prepare the SQL insertion statement.&#10;&#10;@return boolean  True if the statement was successfully created.&#10;&#10;@access  private&#10;@since   Log 1.9.0" ilk="function" line="347" lineen