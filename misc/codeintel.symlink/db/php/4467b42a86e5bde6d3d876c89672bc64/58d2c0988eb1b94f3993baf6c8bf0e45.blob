<scope ilk="blob" lang="PHP" name="win.php" src="/usr/local/Cellar/php55/5.5.7/lib/php/Log/win.php"><scope classrefs="Log" doc="The Log_win class is a concrete implementation of the Log abstract&#10;class that logs messages to a separate browser window.&#10;&#10;The concept for this log handler is based on part by Craig Davis' article&#10;entitled &quot;JavaScript Power PHP Debugging:&#10;&#10; http://www.zend.com/zend/tut/tutorial-DebugLib.php&#10;&#10;@author  Jon Parise &lt;jon@php.net&gt;&#10;@since   Log 1.7.0&#10;@package Log&#10;&#10;@example win.php     Using the window handler." ilk="class" line="24" lineend="286" name="Log_win"><variable citdl="string" doc="The name of the output window.&#10;@var string&#10;@access private" line="31" name="_name" /><variable citdl="string" doc="The title of the output window.&#10;@var string&#10;@access private" line="38" name="_title" /><variable citdl="array" doc="Mapping of log priorities to styles.&#10;@var array&#10;@access private" line="54" name="_styles" /><variable citdl="array" doc="String buffer that holds line that are pending output.&#10;@var array&#10;@access private" line="61" name="_buffer" /><scope attributes="__ctor__" doc="Constructs a new Log_win object.&#10;&#10;@param string $name     Ignored.&#10;@param string $ident    The identity string.&#10;@param array  $conf     The configuration array.&#10;@param int    $level    Log messages up to and including this level.&#10;@access public" ilk="function" line="72" lineend="93" name="Log_win" signature="Log_win(string $name, string $ident = '', array $conf = array(), int $level = PEAR_LOG_DEBUG)"><variable citdl="string" ilk="argument" line="72" name="name" /><variable citdl="string" default="''" ilk="argument" line="72" name="ident" /><variable citdl="array" default="array()" ilk="argument" line="72" name="conf" /><variable citdl="int" default="PEAR_LOG_DEBUG" ilk="argument" line="72" name="level" /><variable attributes="__not_yet_defined__" line="87" name="color" /></scope><variable citdl="md5()" line="75" name="_id" /><variable citdl="ident" line="77" name="_ident" /><variable citdl="Log.UPTO()" line="78" name="_mask" /><scope doc="Destructor" ilk="function" line="98" lineend="103" name="_Log_win" signature="_Log_win()" /><scope doc="The first time open() is called, it will open a new browser window and&#10;prepare it for output.&#10;&#10;This is implicitly called by log(), if necessary.&#10;&#10;@access public" ilk="function" line="113" lineend="164" name="open" returns="this._opened" signature="open()"><variable citdl="string" line="120" name="identHeader" /><variable citdl="this._name" line="116" name="win" /><variable citdl="this._styles" line="117" name="styles" /></scope><variable citdl="boolean" line="160" name="_opened" /><scope doc="Closes the output stream if it is open.  If there are still pending&#10;lines in the output buffer, the output window will be opened so that&#10;the buffer can be drained.&#10;&#10;@access public" ilk="function" line="173" lineend="191" name="close" signature="close()" /><scope doc="Writes the contents of the output buffer to the output window.&#10;&#10;@access private" ilk="function" line="198" lineend="210" name="_drainBuffer" signature="_drainBuffer()"><variable attributes="__not_yet_defined__" line="201" name="line" /><variable citdl="this._name" line="200" name="win" /></scope><scope doc="Writes a single line of text to the output buffer.&#10;&#10;@param string    $line   The line of text to write.&#10;&#10;@access private" ilk="function" line="219" lineend="236" name="_writeln" signature="_writeln(string $line)"><variable citdl="string" ilk="argument" line="219" name="line" /></scope><scope doc="Logs $message to the output window.  The message is also passed along&#10;to any Log_observer instances that are observing this Log.&#10;&#10;@param mixed  $message  String or object containing the message to log.&#10;@param string $priority The priority of the message.  Valid&#10;                 values are: PEAR_LOG_EMERG, PEAR_LOG_ALERT,&#10;                 PEAR_LOG_CRIT, PEAR_LOG_ERR, PEAR_LOG_WARNING,&#10;                 PEAR_LOG_NOTICE, PEAR_LOG_INFO, and PEAR_LOG_DEBUG.&#10;@return boolean  True on success or false on failure.&#10;@access public" ilk="function" line="250" lineend="284" name="log" returns="boolean" signature="boolean log(mixed $message, string $priority = null)"><variable citdl="mixed" ilk="argument" line="250" name="message" /><variable citdl="string" default="null" ilk="argument" line="250" name="priority" /><variable attributes="__not_yet_defined__" line="266" name="sec" /><variable citdl="string" line="269" name="line" /><variable attributes="__not_yet_defined__" line="266" name="usec" /></scope></scope></scope>