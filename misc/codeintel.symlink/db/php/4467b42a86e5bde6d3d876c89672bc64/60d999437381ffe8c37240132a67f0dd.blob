<scope ilk="blob" lang="PHP" name="display.php" src="/usr/local/Cellar/php55/5.5.7/lib/php/Log/display.php"><scope classrefs="Log" doc="The Log_display class is a concrete implementation of the Log::&#10;abstract class which writes message into browser in usual PHP maner.&#10;This may be useful because when you use PEAR::setErrorHandling in&#10;PEAR_ERROR_CALLBACK mode error messages are not displayed by&#10;PHP error handler.&#10;&#10;@author  Paul Yanchenko &lt;pusher@inaco.ru&gt;&#10;@since   Log 1.8.0&#10;@package Log&#10;&#10;@example display.php     Using the display handler." ilk="class" line="22" lineend="181" name="Log_display"><variable citdl="string" doc="String containing the format of a log line.&#10;@var string&#10;@access private" line="29" name="_lineFormat" /><variable citdl="string" doc="String containing the timestamp format.  It will be passed directly to&#10;strftime().  Note that the timestamp string will generated using the&#10;current locale.&#10;@var string&#10;@access private" line="38" name="_timeFormat" /><variable citdl="boolean" doc="Flag indicating whether raw message text should be passed directly to &#10;the log system.  Otherwise, the text will be converted to an HTML-safe &#10;representation.&#10;@var boolean&#10;@access private" line="47" name="_rawText" /><scope attributes="__ctor__" doc="Constructs a new Log_display object.&#10;&#10;@param string $name     Ignored.&#10;@param string $ident    The identity string.&#10;@param array  $conf     The configuration array.&#10;@param int    $level    Log messages up to and including this level.&#10;@access public" ilk="function" line="58" lineend="110" name="Log_display" signature="Log_display(string $name = '', string $ident = '', array $conf = array(), int $level = PEAR_LOG_DEBUG)"><variable citdl="string" default="''" ilk="argument" line="58" name="name" /><variable citdl="string" default="''" ilk="argument" line="58" name="ident" /><variable citdl="array" default="array()" ilk="argument" line="58" name="conf" /><variable citdl="int" default="PEAR_LOG_DEBUG" ilk="argument" line="58" name="level" /><variable citdl="conf" line="84" name="append" /><variable citdl="conf" line="73" name="prepend" /></scope><variable citdl="md5()" line="61" name="_id" /><variable citdl="ident" line="62" name="_ident" /><variable citdl="Log.UPTO()" line="63" name="_mask" /><scope doc="Opens the display handler.&#10;&#10;@access  public&#10;@since   Log 1.9.6" ilk="function" line="118" lineend="122" name="open" returns="boolean" signature="open()" /><variable citdl="boolean" line="120" name="_opened" /><scope doc="Closes the display handler.&#10;&#10;@access  public&#10;@since   Log 1.9.6" ilk="function" line="130" lineend="134" name="close" returns="boolean" signature="close()" /><scope doc="Writes $message to the text browser. Also, passes the message&#10;along to any Log_observer instances that are observing this Log.&#10;&#10;@param mixed  $message    String or object containing the message to log.&#10;@param string $priority The priority of the message.  Valid&#10;                 values are: PEAR_LOG_EMERG, PEAR_LOG_ALERT,&#10;                 PEAR_LOG_CRIT, PEAR_LOG_ERR, PEAR_LOG_WARNING,&#10;                 PEAR_LOG_NOTICE, PEAR_LOG_INFO, and PEAR_LOG_DEBUG.&#10;@return boolean  True on success or false on failure.&#10;@access public" ilk="function" line="148" lineend="179" name="log" returns="boolean" signature="boolean log(mixed $message, string $priority = null)"><variable citdl="mixed" ilk="argument" line="148" name="message" /><variable citdl="string" default="null" ilk="argument" line="148" name="priority" /></scope></scope></scope>