<scope ilk="blob" lang="PHP" name="file.php" src="/usr/local/Cellar/php55/5.5.7/lib/php/Log/file.php"><scope classrefs="Log" doc="The Log_file class is a concrete implementation of the Log abstract&#10;class that logs messages to a text file.&#10;&#10;@author  Jon Parise &lt;jon@php.net&gt;&#10;@author  Roman Neuhauser &lt;neuhauser@bellavista.cz&gt;&#10;@since   Log 1.0&#10;@package Log&#10;&#10;@example file.php    Using the file handler." ilk="class" line="20" lineend="316" name="Log_file"><variable citdl="string" doc="String containing the name of the log file.&#10;@var string&#10;@access private" line="27" name="_filename" /><variable citdl="resource" doc="Handle to the log file.&#10;@var resource&#10;@access private" line="34" name="_fp" /><variable citdl="boolean" doc="Should new log entries be append to an existing log file, or should the&#10;a new log file overwrite an existing one?&#10;@var boolean&#10;@access private" line="42" name="_append" /><variable citdl="boolean" doc="Should advisory file locking (i.e., flock()) be used?&#10;@var boolean&#10;@access private" line="49" name="_locking" /><variable citdl="integer" doc="Integer (in octal) containing the log file's permissions mode.&#10;@var integer&#10;@access private" line="56" name="_mode" /><variable citdl="integer" doc="Integer (in octal) specifying the file permission mode that will be&#10;used when creating directories that do not already exist.&#10;@var integer&#10;@access private" line="64" name="_dirmode" /><variable citdl="string" doc="String containing the format of a log line.&#10;@var string&#10;@access private" line="71" name="_lineFormat" /><variable citdl="string" doc="String containing the timestamp format.  It will be passed directly to&#10;strftime().  Note that the timestamp string will generated using the&#10;current locale.&#10;@var string&#10;@access private" line="80" name="_timeFormat" /><variable citdl="string" doc="String containing the end-on-line character sequence.&#10;@var string&#10;@access private" line="87" name="_eol" /><scope attributes="__ctor__" doc="Constructs a new Log_file object.&#10;&#10;@param string $name     Ignored.&#10;@param string $ident    The identity string.&#10;@param array  $conf     The configuration array.&#10;@param int    $level    Log messages up to and including this level.&#10;@access public" ilk="function" line="98" lineend="147" name="Log_file" signature="Log_file(string $name, string $ident = '', array $conf = array(), int $level = PEAR_LOG_DEBUG)"><variable citdl="string" ilk="argument" line="98" name="name" /><variable citdl="string" default="''" ilk="argument" line="98" name="ident" /><variable citdl="array" default="array()" ilk="argument" line="98" name="conf" /><variable citdl="int" default="PEAR_LOG_DEBUG" ilk="argument" line="98" name="level" /></scope><variable citdl="md5()" line="101" name="_id" /><variable citdl="ident" line="103" name="_ident" /><variable citdl="Log.UPTO()" line="104" name="_mask" /><scope doc="Destructor" ilk="function" line="152" lineend="157" name="_Log_file" signature="_Log_file()" /><scope doc="Creates the given directory path.  If the parent directories don't&#10;already exist, they will be created, too.&#10;&#10;This implementation is inspired by Python's os.makedirs function.&#10;&#10;@param   string  $path       The full directory path to create.&#10;@param   integer $mode       The permissions mode with which the&#10;                             directories will be created.&#10;&#10;@return  True if the full path is successfully created or already&#10;         exists.&#10;&#10;@access  private" ilk="function" line="174" lineend="193" name="_mkpath" returns="True" signature="True _mkpath(string $path, integer $mode = 0700)"><variable citdl="string" ilk="argument" line="174" name="path" /><variable citdl="integer" default="0700" ilk="argument" line="174" name="mode" /><variable citdl="dirname()" line="177" name="head" /><variable citdl="basename()" line="178" name="tail" /></scope><scope doc="Opens the log file for output.  If the specified log file does not&#10;already exist, it will be created.  By default, new log entries are&#10;appended to the end of the log file.&#10;&#10;This is implicitly called by log(), if necessary.&#10;&#10;@access public" ilk="function" line="204" lineend="228" name="open" returns="this._opened" signature="open()"><variable line="213" name="creating" /></scope><variable citdl="boolean" line="219" name="_opened" /><scope doc="Closes the log file if it is open.&#10;&#10;@access public" ilk="function" line="235" lineend="243" name="close" signature="close()" /><scope doc="Flushes all pending data to the file handle.&#10;&#10;@access public&#10;@since Log 1.8.2" ilk="function" line="251" lineend="258" name="flush" returns="fflush()" signature="flush()" /><scope doc="Logs $message to the output window.  The message is also passed along&#10;to any Log_observer instances that are observing this Log.&#10;&#10;@param mixed  $message  String or object containing the message to log.&#10;@param string $priority The priority of the message.  Valid&#10;                 values are: PEAR_LOG_EMERG, PEAR_LOG_ALERT,&#10;                 PEAR_LOG_CRIT, PEAR_LOG_ERR, PEAR_LOG_WARNING,&#10;                 PEAR_LOG_NOTICE, PEAR_LOG_INFO, and PEAR_LOG_DEBUG.&#10;@return boolean  True on success or false on failure.&#10;@access public" ilk="function" line="272" lineend="314" name="log" returns="boolean" signature="boolean log(mixed $message, string $priority = null)"><variable citdl="mixed" ilk="argument" line="272" name="message" /><variable citdl="string" default="null" ilk="argument" line="272" name="priority" /><variable line="303" name="success" /><variable citdl="this._format()" line="295" name="line" /></scope></scope></scope>