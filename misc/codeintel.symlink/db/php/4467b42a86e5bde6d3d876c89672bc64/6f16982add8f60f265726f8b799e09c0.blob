<scope ilk="blob" lang="PHP" name="daemon.php" src="/usr/local/Cellar/php55/5.5.7/lib/php/Log/daemon.php"><scope classrefs="Log" doc="The Log_daemon class is a concrete implementation of the Log::&#10;abstract class which sends messages to syslog daemon on UNIX-like machines.&#10;This class uses the syslog protocol: http://www.ietf.org/rfc/rfc3164.txt&#10;&#10;@author  Bart van der Schans &lt;schans@dds.nl&gt;&#10;@version $Revision: 250926 $&#10;@package Log" ilk="class" line="18" lineend="235" name="Log_daemon"><variable citdl="string" doc="Integer holding the log facility to use.&#10;@var string" line="24" name="_name" /><variable citdl="resource" doc="Var holding the resource pointer to the socket&#10;@var resource" line="30" name="_socket" /><variable citdl="string" doc="The ip address or servername&#10;@see http://www.php.net/manual/en/transports.php&#10;@var string" line="37" name="_ip" /><variable citdl="string" doc="Protocol to use (tcp, udp, etc.)&#10;@see http://www.php.net/manual/en/transports.php&#10;@var string" line="44" name="_proto" /><variable citdl="int" doc="Port to connect to&#10;@var int" line="50" name="_port" /><variable citdl="int" doc="Maximum message length in bytes&#10;@var int" line="56" name="_maxsize" /><variable citdl="int" doc="Socket timeout in seconds&#10;@var int" line="62" name="_timeout" /><scope attributes="__ctor__" doc="Constructs a new syslog object.&#10;&#10;@param string $name     The syslog facility.&#10;@param string $ident    The identity string.&#10;@param array  $conf     The configuration array.&#10;@param int    $maxLevel Maximum level at which to log.&#10;@access public" ilk="function" line="74" lineend="105" name="Log_daemon" signature="Log_daemon(string $name, string $ident = '', array $conf = array(), $level = PEAR_LOG_DEBUG, int $maxLevel)"><variable citdl="string" ilk="argument" line="74" name="name" /><variable citdl="string" default="''" ilk="argument" line="74" name="ident" /><variable citdl="array" default="array()" ilk="argument" line="74" name="conf" /><variable default="PEAR_LOG_DEBUG" ilk="argument" line="74" name="level" /><variable citdl="int" ilk="argument" line="74" name="maxLevel" /></scope><variable citdl="md5()" line="82" name="_id" /><variable citdl="ident" line="84" name="_ident" /><variable citdl="Log.UPTO()" line="85" name="_mask" /><scope doc="Destructor.&#10;&#10;@access private" ilk="function" line="112" lineend="115" name="_Log_daemon" signature="_Log_daemon()" /><scope doc="Opens a connection to the system logger, if it has not already&#10;been opened.  This is implicitly called by log(), if necessary.&#10;@access public" ilk="function" line="122" lineend="133" name="open" returns="this._opened" signature="open()" /><variable citdl="boolean" line="130" name="_opened" /><scope doc="Closes the connection to the system logger, if it is open.&#10;@access public" ilk="function" line="139" lineend="146" name="close" returns="fclose()" signature="close()" /><scope doc="Sends $message to the currently open syslog connection.  Calls&#10;open() if necessary. Also passes the message along to any Log_observer&#10;instances that are observing this Log.&#10;&#10;@param string $message  The textual message to be logged.&#10;@param int $priority (optional) The priority of the message.  Valid&#10;                 values are: LOG_EMERG, LOG_ALERT, LOG_CRIT,&#10;                 LOG_ERR, LOG_WARNING, LOG_NOTICE, LOG_INFO,&#10;                 and LOG_DEBUG.  The default is LOG_INFO.&#10;@access public" ilk="function" line="160" lineend="198" name="log" returns="boolean" signature="log(string $message, int $priority = null)"><variable citdl="string" ilk="argument" line="160" name="message" /><variable citdl="int" default="null" ilk="argument" line="160" name="priority" /><variable citdl="intval()" line="182" name="facility_level" /></scope><scope doc="Converts a PEAR_LOG_* constant into a syslog LOG_* constant.&#10;&#10;This function exists because, under Windows, not all of the LOG_*&#10;constants have unique values.  Instead, the PEAR_LOG_* were introduced&#10;for global use, with the conversion to the LOG_* constants kept local to&#10;to the syslog driver.&#10;&#10;@param int $priority     PEAR_LOG_* value to convert to LOG_* value.&#10;&#10;@return  The LOG_* representation of $priority.&#10;&#10;@access private" ilk="function" line="214" lineend="233" name="_toSyslog" returns="The" signature="The _toSyslog(int $priority)"><variable citdl="int" ilk="argument" line="214" name="priority" /><variable attributes="__not_yet_defined__" line="228" name="priorities" /></scope><variable attributes="static" citdl="array()" line="225" name="priorities" /></scope></scope>