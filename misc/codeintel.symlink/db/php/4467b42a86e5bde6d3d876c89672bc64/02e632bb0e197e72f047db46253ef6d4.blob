<scope ilk="blob" lang="PHP" name="console.php" src="/usr/local/Cellar/php55/5.5.7/lib/php/Log/console.php"><scope classrefs="Log" doc="The Log_console class is a concrete implementation of the Log::&#10;abstract class which writes message to the text console.&#10;&#10;@author  Jon Parise &lt;jon@php.net&gt;&#10;@since   Log 1.1&#10;@package Log&#10;&#10;@example console.php     Using the console handler." ilk="class" line="19" lineend="222" name="Log_console"><variable citdl="resource" doc="Handle to the current output stream.&#10;@var resource&#10;@access private" line="26" name="_stream" /><variable citdl="bool" doc="Is this object responsible for closing the stream resource?&#10;@var bool&#10;@access private" line="33" name="_closeResource" /><variable citdl="string" doc="Should the output be buffered or displayed immediately?&#10;@var string&#10;@access private" line="40" name="_buffering" /><variable citdl="string" doc="String holding the buffered output.&#10;@var string&#10;@access private" line="47" name="_buffer" /><variable citdl="string" doc="String containing the format of a log line.&#10;@var string&#10;@access private" line="54" name="_lineFormat" /><variable citdl="string" doc="String containing the timestamp format.  It will be passed directly to&#10;strftime().  Note that the timestamp string will generated using the&#10;current locale.&#10;@var string&#10;@access private" line="63" name="_timeFormat" /><scope attributes="__ctor__" doc="Constructs a new Log_console object.&#10;&#10;@param string $name     Ignored.&#10;@param string $ident    The identity string.&#10;@param array  $conf     The configuration array.&#10;@param int    $level    Log messages up to and including this level.&#10;@access public" ilk="function" line="74" lineend="111" name="Log_console" signature="Log_console(string $name, string $ident = '', array $conf = array(), int $level = PEAR_LOG_DEBUG)"><variable citdl="string" ilk="argument" line="74" name="name" /><variable citdl=