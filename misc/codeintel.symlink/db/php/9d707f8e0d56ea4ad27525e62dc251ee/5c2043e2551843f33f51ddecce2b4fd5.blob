t" line="50" name="context" /></scope><scope attributes="public" doc="Runtime errors that do not require immediate action but should typically&#10;be logged and monitored.&#10;&#10;@param string $message&#10;@param array $context&#10;@return null" ilk="function" line="63" lineend="66" name="error" returns="null" signature="null error(string $message, array $context=array())"><variable citdl="string" ilk="argument" line="63" name="message" /><variable citdl="array" ilk="argument" line="63" name="context" /></scope><scope attributes="public" doc="Exceptional occurrences that are not errors.&#10;&#10;Example: Use of deprecated APIs, poor use of an API, undesirable things&#10;that are not necessarily wrong.&#10;&#10;@param string $message&#10;@param array $context&#10;@return null" ilk="function" line="78" lineend="81" name="warning" returns="null" signature="null warning(string $message, array $context=array())"><variable citdl="string" ilk="argument" line="78" name="message" /><variable citdl="array" ilk="argument" line="78" name="context" /></scope><scope attributes="public" doc="Normal but significant events.&#10;&#10;@param string $message&#10;@param array $context&#10;@return null" ilk="function" line="90" lineend="93" name="notice" returns="null" signature="null notice(string $message, array $context=array())"><variable citdl="string" ilk="argument" line="90" name="message" /><variable citdl="array" ilk="argument" line="90" name="context" /></scope><scope attributes="public" doc="Interesting events.&#10;&#10;Example: User logs in, SQL logs.&#10;&#10;@param string $message&#10;@param array $context&#10;@return null" ilk="function" line="104" lineend="107" name="info" returns="null" signature="null info(string $message, array $context=array())"><variable citdl="string" ilk="argument" line="104" name="message" /><variable citdl="array" ilk="argument" line="104" name="context" /></scope><scope attributes="public" doc="Detailed debug information.&#10;&#10;@param strin