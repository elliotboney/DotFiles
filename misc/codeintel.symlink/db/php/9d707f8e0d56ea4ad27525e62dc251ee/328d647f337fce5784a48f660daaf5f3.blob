<scope ilk="blob" lang="PHP" name="NullLogger.php" src="/usr/local/pear/share/pear/PhpDocumentor/vendor/psr/log/Psr/Log/NullLogger.php"><scope ilk="namespace" line="3" name="Psr\Log"><scope classrefs="AbstractLogger" doc="This Logger can be used to avoid conditional log calls&#10;&#10;Logging should always be optional, and if no logger is provided to your&#10;library creating a NullLogger instance to have something to throw logs at&#10;is a good way to avoid littering your code with `if ($this-&gt;logger) { }`&#10;blocks." ilk="class" line="13" lineend="27" name="NullLogger"><scope attributes="public" doc="Logs with an arbitrary level.&#10;&#10;@param mixed $level&#10;@param string $message&#10;@param array $context&#10;@return null" ilk="function" line="23" lineend="26" name="log" returns="null" signature="null log(mixed $level, string $message, array $context=array())"><variable citdl="mixed" ilk="argument" line="23" name="level" /><variable citdl="string" ilk="argument" line="23" name="message" /><variable citdl="array" ilk="argument" line="23" name="context" /></scope></scope></scope></scope>