ine="51" name="context" /></scope><scope attributes="public" doc="Runtime errors that do not require immediate action but should typically&#10;be logged and monitored.&#10;&#10;@param string $message&#10;@param array $context&#10;@return null" ilk="function" line="64" lineend="67" name="error" returns="null" signature="null error(string $message, array $context=array())"><variable citdl="string" ilk="argument" line="64" name="message" /><variable citdl="array" ilk="argument" line="64" name="context" /></scope><scope attributes="public" doc="Exceptional occurrences that are not errors.&#10;&#10;Example: Use of deprecated APIs, poor use of an API, undesirable things&#10;that are not necessarily wrong.&#10;&#10;@param string $message&#10;@param array $context&#10;@return null" ilk="function" line="79" lineend="82" name="warning" returns="null" signature="null warning(string $message, array $context=array())"><variable citdl="string" ilk="argument" line="79" name="message" /><variable citdl="array" ilk="argument" line="79" name="context" /></scope><scope attributes="public" doc="Normal but significant events.&#10;&#10;@param string $message&#10;@param array $context&#10;@return null" ilk="function" line="91" lineend="94" name="notice" returns="null" signature="null notice(string $message, array $context=array())"><variable citdl="string" ilk="argument" line="91" name="message" /><variable citdl="array" ilk="argument" line="91" name="context" /></scope><scope attributes="public" doc="Interesting events.&#10;&#10;Example: User logs in, SQL logs.&#10;&#10;@param string $message&#10;@param array $context&#10;@return null" ilk="function" line="105" lineend="108" name="info" returns="null" signature="null info(string $message, array $context=array())"><variable citdl="string" ilk="argument" line="105" name="message" /><variable citdl="array" ilk="argument" line="105" name="context" /></scope><scope attributes="public" doc="Detailed debug information.&#10;&#10;@param string $m