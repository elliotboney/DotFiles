<scope ilk="blob" lang="PHP" name="Notification.php" src="/usr/local/Cellar/php55/5.5.7/lib/php/Event/Notification.php"><variable citdl="int" ilk="constant" line="41" name="EVENT_NOTIFICATION_STATE_DEFAULT" /><variable citdl="int" ilk="constant" line="46" name="EVENT_NOTIFICATION_STATE_CANCELLED" /><scope doc="A Notification object&#10;&#10;The Notification object can be easily subclassed and serves as a container&#10;for the information about the notification. It holds an object which is &#10;usually a reference to the object that posted the notification,&#10;a notification name used to identify the notification and some user&#10;information which can be anything you need.&#10;&#10;@category   Event&#10;@package    Event_Dispatcher&#10;@author     Bertrand Mansion &lt;bmansion@mamasam.com&gt;&#10;@author     Stephan Schmidt &lt;schst@php.net&gt;&#10;@copyright  1997-2005 The PHP Group&#10;@license    http://www.opensource.org/licenses/bsd-license.php BSD License&#10;@version    Release: @package_version@&#10;@link       http://pear.php.net/package/Event_Dispatcher" ilk="class" line="66" lineend="193" name="Event_Notification"><variable citdl="string" doc="name of the notofication&#10;@var string&#10;@access private" line="73" name="_notificationName" /><variable citdl="object" doc="object of interesed (the sender of the notification, in most cases)&#10;@var object&#10;@access private" line="80" name="_notificationObject" /><variable citdl="array()" doc="additional information about the notification&#10;@var mixed&#10;@access private" line="87" name="_notificationInfo" /><variable citdl="integer" doc="state of the notification&#10;&#10;This may be:&#10;- EVENT_NOTIFICATION_STATE_DEFAULT&#10;- EVENT_NOTIFICATION_STATE_CANCELLED&#10;&#10;@var integer&#10;@access private" line="99" name="_notificationState" /><variable citdl="int" doc="amount of observers that received this notification&#10;@var mixed&#10;@access private" line="106" name="_notificationCount" /><scope attributes="__ctor__" doc="Constructor&#10;&#10;@access  public&#10;@param   object      The object of interest for the notification,&#10;                     usually is the posting object&#10;@param   string      Notification name&#10;@param   array       Free information array" ilk="function" line="117" lineend="122" name="Event_Notification" signature="Event_Notification(&amp; $object, $name, $info = array())"><variable ilk="argument" line="117" name="object" /><variable ilk="argument" line="117" name="name" /><variable default="array()" ilk="argument" line="117" name="info" /></scope><scope doc="Returns the notification name&#10;@return  string Notification name" ilk="function" line="128" lineend="131" name="getNotificationName" returns="string" signature="string getNotificationName()" /><scope doc="Returns the contained object&#10;@return  object Contained object" ilk="function" line="137" lineend="140" name="getNotificationObject" returns="object" signature="object &amp;getNotificationObject()" /><scope doc="Returns the user info array&#10;@return  array user info" ilk="function" line="146" lineend="149" name="getNotificationInfo" returns="array" signature="array getNotificationInfo()" /><scope doc="Increase the internal count&#10;&#10;@access   public" ilk="function" line="156" lineend="159" name="increaseNotificationCount" signature="increaseNotificationCount()" /><scope doc="Get the number of posted notifications&#10;&#10;@access   public&#10;@return   int" ilk="function" line="167" lineend="170" name="getNotificationCount" returns="int" signature="int getNotificationCount()" /><scope doc="Cancel the notification&#10;&#10;@access   public&#10;@return   void" ilk="function" line="178" lineend="181" name="cancelNotification" signature="void cancelNotification()" /><scope doc="Checks whether the notification has been cancelled&#10;&#10;@access   public&#10;@return   boolean" ilk="function" line="189" lineend="192" name="isNotificationCancelled" returns="boolean" signature="boolean isNotificationCancelled()" /></scope></scope>