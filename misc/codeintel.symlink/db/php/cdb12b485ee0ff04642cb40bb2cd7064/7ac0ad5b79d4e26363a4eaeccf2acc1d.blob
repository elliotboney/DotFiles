="argument" line="142" name="body" /><variable citdl="string" default="'1.1'" ilk="argument" line="142" name="version" /><variable citdl="string" default="null" ilk="argument" line="142" name="message" /></scope><scope attributes="public static" doc="Create a new Microsoft_Http_Response_Stream object from a string&#10;&#10;@param string $response_str&#10;@param resource $stream&#10;@return Microsoft_Http_Response_Stream" ilk="function" line="159" lineend="167" name="fromStream" returns="Microsoft_Http_Response_Stream" signature="Microsoft_Http_Response_Stream fromStream(string $response_str, resource $stream)"><variable citdl="string" ilk="argument" line="159" name="response_str" /><variable citdl="resource" ilk="argument" line="159" name="stream" /><variable citdl="self.extractCode()" line="161" name="code" /><variable citdl="self.extractVersion()" line="163" name="version" /><variable citdl="self.extractMessage()" line="164" name="message" /><variable citdl="self.extractHeaders()" line="162" name="headers" /></scope><scope attributes="public" doc="Get the response body as string&#10;&#10;This method returns the body of the HTTP response (the content), as it&#10;should be in it's readable version - that is, after decoding it (if it&#10;was decoded), deflating it (if it was gzip compressed), etc.&#10;&#10;If you want to get the raw body (as transfered on wire) use&#10;$this-&gt;getRawBody() instead.&#10;&#10;@return string" ilk="function" line="181" lineend="187" name="getBody" returns="string" signature="string getBody()" /><scope attributes="public" doc="Get the raw response body (as transfered &quot;on wire&quot;) as string&#10;&#10;If the body is encoded (with Transfer-Encoding, not content-encoding -&#10;IE &quot;chunked&quot; body), gzip compressed, etc. it will not be decoded.&#10;&#10;@return string" ilk="function" line="197" lineend="203" name="getRawBody" returns="string" signature="string getRawBody()" /><scope attributes="protected" doc="Read stream content and return it as string&#10;&#10;Function reads the remainder of the body from the stream and closes the stream.&#10;&#10;@return string" ilk="function" line="212" lineend="225" name="readStream" returns="string" signature="string readStream()"><variable attributes="__not_yet_defined__" line="218" name="headers" /></scope><variable citdl="stream_get_contents()" line="219" name="body" /><scope attributes="public" ilk="function" line="227" lineend="236" name="__destruct" signature="__destruct()" /></scope></scope>