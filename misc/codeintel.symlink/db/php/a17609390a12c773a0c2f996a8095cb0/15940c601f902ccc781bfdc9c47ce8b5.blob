<scope ilk="blob" lang="PHP" name="jsmin.php" src="/private/var/www/wordpress.staging/minify/jsmin.php"><scope doc="jsmin.php - PHP implementation of Douglas Crockford's JSMin.&#10;&#10;This is pretty much a direct port of jsmin.c to PHP with just a few&#10;PHP-specific performance tweaks. Also, whereas jsmin.c reads from stdin and&#10;outputs to stdout, this library accepts a string as input and returns another&#10;string as output.&#10;&#10;PHP 5 or higher is required.&#10;&#10;Permission is hereby granted to use this version of the library under the&#10;same terms as jsmin.c, which has the following license:&#10;&#10;--&#10;Copyright (c) 2002 Douglas Crockford  (www.crockford.com)&#10;&#10;Permission is hereby granted, free of charge, to any person obtaining a copy of&#10;this software and associated documentation files (the &quot;Software&quot;), to deal in&#10;the Software without restriction, including without limitation the rights to&#10;use, copy, modify, merge, publish, distribute, sublicense, and/or sell copies&#10;of the Software, and to permit persons to whom the Software is furnished to do&#10;so, subject to the following conditions:&#10;&#10;The above copyright notice and this permission notice shall be included in all&#10;copies or substantial portions of the Software.&#10;&#10;The Software shall be used for Good, not Evil.&#10;&#10;THE SOFTWARE IS PROVIDED &quot;AS IS&quot;, WITHOUT WARRANTY OF ANY KIND, EXPRESS OR&#10;IMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF MERCHANTABILITY,&#10;FITNESS FOR A PARTICULAR PURPOSE AND NONINFRINGEMENT. IN NO EVENT SHALL THE&#10;AUTHORS OR COPYRIGHT HOLDERS BE LIABLE FOR ANY CLAIM, DAMAGES OR OTHER&#10;LIABILITY, WHETHER IN AN ACTION OF CONTRACT, TORT OR OTHERWISE, ARISING FROM,&#10;OUT OF OR IN CONNECTION WITH THE SOFTWARE OR THE USE OR OTHER DEALINGS IN THE&#10;SOFTWARE.&#10;--&#10;&#10;@package JSMin&#10;@author Ryan Grove &lt;ryan@wonko.com&gt;&#10;@copyright 2002 Douglas Crockford &lt;douglas@crockford.com&gt; (jsmin.c)&#10;@copyright 2008 Ryan Grove &lt;ryan@wonko.com&gt; (PHP port)&#10;@license http://opensource.org/licenses/mit-license.php MIT License&#10;@version 1.1.1 (2008-03-02)&#10;@link https://github.com/rgrove/jsmin-php/" ilk="class" line="48" lineend="371" name="JSMin"><variable citdl="int" ilk="constant" line="49" name="ORD_LF" /><variable citdl="int" ilk="constant" line="50" name="ORD_SPACE" /><variable citdl="int" ilk="constant" line="51" name="ACTION_KEEP_A" /><variable citdl="int" ilk="constant" line="52" name="ACTION_DELETE_A" /><variable citdl="int" ilk="constant" line="53" name="ACTION_DELETE_A_B" /><variable attributes="protected" citdl="this.get()" line="55" name="a" /><variable attributes="protected" citdl="string" line="56" name="b" /><variable attributes="protected" citdl="string" line="57" name="input" /><variable attributes="protected" citdl="int" line="58" name="inputIndex" /><variable attributes="protected" citdl="int" line="59" name="inputLength" /><variable attributes="protected" citdl="this.get()" line="60" name="lookAhead" /><variable attributes="protected" citdl="string" line="61" name="output" /><scope attributes="public static" doc="Minify Javascript&#10;&#10;@uses __construct()&#10;@uses min()&#10;@param string $js Javascript to be minified&#10;@return string" ilk="function" line="73" lineend="76" name="minify" returns="string" signature="string minify(string $js)"><variable citdl="string" ilk="argument" line="73" name="js" /><variable citdl="JSMin" line="74" name="jsmin" /></scope><scope attributes="public __ctor__" doc="Constructor&#10;&#10;@param string $input Javascript to be minified" ilk="function" line="85" lineend="88" name="__construct" signature="__construct(string $input)"><variable citdl="string" ilk="argument" line="85" name="input" /></scope><scope attributes="protected" doc="Action -- do something! What to do is determined by the $command argument.&#10;&#10;action treats a string as a single character. Wow!&#10;action recognizes a regular expression if it is preceded by ( or , or =.&#10;&#10;@uses next()&#10;@uses get()&#10;@throws JSMinException If parser errors are found:&#10;        - Unterminated string literal&#10;        - Unterminated regular expression set in regex literal&#10;        - Unterminated regular expression literal&#10;@param int $command One of class constants:&#10;     ACTION_KEEP_A      Output A. Copy B to A. Get the next B.&#10;     ACTION_DELETE_A    Copy B to A. Get the next B. (Delete A).&#10;     ACTION_DELETE_A_B  Get the next B. (Delete B)." ilk="function" line="109" lineend="185" name="action" signature="action(int $command)"><variable citdl="int" ilk="argument" line="109" name="command" /></scope><scope attributes="protected" doc="Get next char. Convert ctrl char to space.&#10;&#10;@return string|null" ilk="function" line="192" lineend="214" name="get" returns="string" signature="string get()"><variable citdl="this.lookAhead" line="193" name="c" /></scope><scope attributes="protected" doc="Is $c a letter, digit, underscore, dollar sign, or non-ASCII character.&#10;&#10;@return bool" ilk="function" line="221" lineend="223" name="isAlphaNum" returns="bool" signature="bool isAlphaNum($c)"><variable ilk="argument" line="221" name="c" /></scope><scope attributes="protected" doc="Perform minification, return result&#10;&#10;@uses action()&#10;@uses isAlphaNum()&#10;@return string" ilk="function" line="232" lineend="311" name="min" returns="string" signature="string min()" /><scope attributes="protected" doc="Get the next character, skipping over comments. peek() is used to see&#10; if a '/' is followed by a '/' or '*'.&#10;&#10;@uses get()&#10;@uses peek()&#10;@throws JSMinException On unterminated comment.&#10;@return string" ilk="function" line="322" lineend="359" name="next" returns="string" signature="string next()"><variable citdl="this.get()" line="323" name="c" /></scope><scope attributes="protected" doc="Get next char. If is ctrl character, translate to a space or newline.&#10;&#10;@uses get()&#10;@return string|null" ilk="function" line="367" lineend="370" name="peek" returns="string" signature="string peek()" /></scope><scope classrefs="Exception" doc="-- Exceptions ---------------------------------------------------------------" ilk="class" line="374" lineend="374" name="JSMinException" /></scope>