<scope ilk="blob" lang="PHP" name="Compressor.php" src="/private/var/www/wordpress.staging/min/lib/Minify/CSS/Compressor.php"><scope doc="Compress CSS&#10;&#10;This is a heavy regex-based removal of whitespace, unnecessary&#10;comments and tokens, and some CSS value minimization, where practical.&#10;Many steps have been taken to avoid breaking comment-based hacks, &#10;including the ie5/mac filter (and its inversion), but expect tricky&#10;hacks involving comment tokens in 'content' value strings to break&#10;minimization badly. A test suite is available.&#10;&#10;@package Minify&#10;@author Stephen Clay &lt;steve@mrclay.org&gt;&#10;@author http://code.google.com/u/1stvamp/ (Issue 64 patch)" ilk="class" line="21" lineend="249" name="Minify_CSS_Compressor"><scope attributes="public static" doc="Minify a CSS string&#10;&#10;@param string $css&#10;&#10;@param array $options (currently ignored)&#10;&#10;@return string" ilk="function" line="32" lineend="36" name="process" returns="string" signature="string process(string $css, array $options = array())"><variable citdl="string" ilk="argument" line="32" name="css" /><variable citdl="array" default="array()" ilk="argument" line="32" name="options" /><variable citdl="Minify_CSS_Compressor" line="34" name="obj" /></scope><variable attributes="protected" citdl="array" doc="@var array" line="41" name="_options" /><variable attributes="protected" citdl="bool" doc="Are we &quot;in&quot; a hack? I.e. are some browsers targetted until the next comment?&#10;&#10;@var bool" line="48" name="_inHack" /><scope attributes="private __ctor__" doc="Constructor&#10;&#10;@param array $options (currently ignored)" ilk="function" line="56" lineend="58" name="__construct" signature="__construct(array $options)"><variable citdl="array" ilk="argument" line="56" name="options" /></scope><scope attributes="protected" doc="Minify a CSS string&#10;&#10;@param string $css&#10;&#10;@return string" ilk="function" line="67" lineend="153" name="_process" returns="string" signature="string _process(string $css)"><variable citdl="string" ilk="argument" line="67" name="css" /></scope><scope attributes="protected" doc="Replace what looks like a set of selectors  &#10;&#10;@param array $m regex matches&#10;&#10;@return string" ilk="function" line="162" lineend="166" name="_selectorsCB" returns="string" signature="string _selectorsCB(array $m)"><variable citdl="array" ilk="argument" line="162" name="m" /></scope><scope attributes="protected" doc="Process a comment and return a replacement&#10;&#10;@param array $m regex matches&#10;&#10;@return string" ilk="function" line="175" lineend="226" name="_commentCB" returns="string" signature="string _commentCB(array $m)"><variable citdl="array" ilk="argument" line="175" name="m" /><variable attributes="__not_yet_defined__" line="194" name="n" /><variable line="177" name="hasSurroundingWs" /></scope><scope attributes="protected" doc="Process a font-family listing and return a replacement&#10;&#10;@param array $m regex matches&#10;&#10;@return string" ilk="function" line="235" lineend="248" name="_fontFamilyCB" returns="string" signature="string _fontFamilyCB(array $m)"><variable citdl="array" ilk="argument" line="235" name="m" /><variable citdl="preg_split()" line="238" name="pieces" /><variable citdl="string" line="239" name="out" /><variable citdl="preg_replace()" line="240" name="piece" /></scope></scope></scope>