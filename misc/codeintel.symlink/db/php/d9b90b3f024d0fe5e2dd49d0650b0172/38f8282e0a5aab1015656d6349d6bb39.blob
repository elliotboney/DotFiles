<scope ilk="blob" lang="PHP" name="UriRewriter.php" src="/private/var/www/wordpress.staging/min/lib/Minify/CSS/UriRewriter.php"><scope doc="Rewrite file-relative URIs as root-relative in CSS files&#10;&#10;@package Minify&#10;@author Stephen Clay &lt;steve@mrclay.org&gt;" ilk="class" line="13" lineend="310" name="Minify_CSS_UriRewriter"><variable attributes="public static" citdl="string" doc="rewrite() and rewriteRelative() append debugging information here&#10;&#10;@var string" line="20" name="debugText" /><scope attributes="public static" doc="In CSS content, rewrite file relative URIs as root relative&#10;&#10;@param string $css&#10;&#10;@param string $currentDir The directory of the current CSS file.&#10;&#10;@param string $docRoot The document root of the web site in which &#10;the CSS file resides (default = $_SERVER['DOCUMENT_ROOT']).&#10;&#10;@param array $symlinks (default = array()) If the CSS file is stored in &#10;a symlink-ed directory, provide an array of link paths to&#10;target paths, where the link paths are within the document root. Because &#10;paths need to be normalized for this to work, use &quot;//&quot; to substitute &#10;the doc root in the link paths (the array keys). E.g.:&#10;&lt;code&gt;&#10;array('//symlink' =&gt; '/real/target/path') // unix&#10;array('//static' =&gt; 'D:\\staticStorage')  // Windows&#10;&lt;/code&gt;&#10;&#10;@return string" ilk="function" line="44" lineend="77" name="rewrite" returns="string" signature="string rewrite(string $css, string $currentDir, string $docRoot = null, array $symlinks = array())"><variable citdl="string" ilk="argument" line="44" name="css" /><variable citdl="string" ilk="argument" line="44" name="currentDir" /><variable citdl="string" default="null" ilk="argument" line="44" name="docRoot" /><variable citdl="array" default="array()" ilk="argument" line="44" name="symlinks" /><variable citdl="strtr()" line="53" name="link" /><variable attributes="__not_yet_defined__" line="53" name="target" /></scope><variable citdl="self._realpath()" line="48" name="_docRoot" /><variable citdl="self._realpath()" line="49" name="_currentDir" /><variable citdl="array()" line="50" name="_symlinks" /><scope attributes="public static" doc="In CSS content, prepend a path to relative URIs&#10;&#10;@param string $css&#10;&#10;@param string $path The path to prepend.&#10;&#10;@return string" ilk="function" line="88" lineend="102" name="prepend" returns="string" signature="string prepend(string $css, string $path)"><variable citdl="string" ilk="argument" line="88" name="css" /><variable citdl="string" ilk="argument" line="88" name="path" /></scope><variable citdl="path" line="90" name="_prependPath" /><scope attributes="public static" doc="Get a root relative URI from a file relative URI&#10;&#10;&lt;code&gt;&#10;Minify_CSS_UriRewriter::rewriteRelative(&#10;      '../img/hello.gif'&#10;    , '/home/user/www/css'  // path of CSS file&#10;    , '/home/user/www'      // doc root&#10;);&#10;// returns '/img/hello.gif'&#10;&#10;// example where static files are stored in a symlinked directory&#10;Minify_CSS_UriRewriter::rewriteRelative(&#10;      'hello.gif'&#10;    , '/var/staticFiles/theme'&#10;    , '/home/user/www'&#10;    , array('/home/user/www/static' =&gt; '/var/staticFiles')&#10;);&#10;// returns '/static/theme/hello.gif'&#10;&lt;/code&gt;&#10;&#10;@param string $uri file relative URI&#10;&#10;@param string $realCurrentDir realpath of the current file's directory.&#10;&#10;@param string $realDocRoot realpath of the site document root.&#10;&#10;@param array $symlinks (default = array()) If the file is stored in &#10;a symlink-ed directory, provide an array of link paths to&#10;real target paths, where the link paths &quot;appear&quot; to be within the document &#10;root. E.g.:&#10;&lt;code&gt;&#10;array('/home/foo/www/not/real/path' =&gt; '/real/target/path') // unix&#10;array('C:\\htdocs\\not\\real' =&gt; 'D:\\real\\target\\path')  // Windows&#10;&lt;/code&gt;&#10;&#10;@return string" ilk="function" line="142" lineend="174" name="rewriteRelative" returns="string" signature="string rewriteRelative(string $uri, string $realCurrentDir, string $realDocRoot, array $symlinks = array())"><variable citdl="string" ilk="argument" line="142" name="uri" /><variable citdl="string" ilk="argument" line="142" name="realCurrentDir" /><variable citdl="string" ilk="argument" line="142" name="realDocRoot" /><variable citdl="array" default="array()" ilk="argument" line="142" name="symlinks" /><variable line="152" name="link" /><variable attributes="__not_yet_defined__" line="152" name="target" /><variable citdl="strtr()" line="146" name="path" /></scope><scope attributes="public static" doc="Remove instances of &quot;./&quot; and &quot;../&quot; where possible from a root-relative URI&#10;&#10;@param string $uri&#10;&#10;@return string" ilk="function" line="183" lineend="191" name="removeDots" returns="string" signature="string removeDots(string $uri)"><variable citdl="string" ilk="argument" line="183" name="uri" /><variable attributes="__not_yet_defined__" line="189" name="changed" /></scope><variable attributes="protected static" citdl="string" doc="Defines which class to call as part of callbacks, change this&#10;if you extend Minify_CSS_UriRewriter&#10;&#10;@var string" line="199" name="className" /><scope attributes="protected static" doc="Get realpath with any trailing slash removed. If realpath() fails,&#10;just remove the trailing slash.&#10;&#10;@param string $path&#10;&#10;@return mixed path with no trailing slash" ilk="function" line="209" lineend="216" name="_realpath" returns="mixed" signature="mixed _realpath(string $path)"><variable citdl="string" ilk="argument" line="209" name="path" /><variable citdl="realpath()" line="211" name="realPath" /></scope><scope attributes="private static" doc="@param string $css&#10;&#10;@return string" ilk="function" line="252" lineend="261" name="_trimUrls" returns="string" signature="string _trimUrls(string $css)"><variable citdl="string" ilk="argument" line="252" name="css" /></scope><scope attributes="private static" doc="@param array $m&#10;&#10;@return string" ilk="function" line="268" lineend="309" name="_processUriCB" returns="string" signature="string _processUriCB(array $m)"><variable citdl="array" ilk="argument" line="268" name="m" /><variable citdl="string" line="296" name="root" /><variable citdl="root" line="275" name="uri" /><variable line="271" name="isImport" /><variable citdl="m" line="274" name="quoteChar" /><variable citdl="uri" line="297" name="rootRelative" /></scope></scope></scope>