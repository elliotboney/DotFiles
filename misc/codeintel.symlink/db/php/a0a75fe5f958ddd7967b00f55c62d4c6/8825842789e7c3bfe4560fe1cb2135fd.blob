fore the key cell&#10;    end_td_key       : string,  Text to insert after the key cell&#10;    start_td_type    : string,  Text to insert before the type cell&#10;    end_td_type      : string,  Text to insert after the type cell&#10;    start_td_value   : string,  Text to insert before the value cell&#10;    end_td_value     : string,  Text to insert after the value cell&#10;    start_td_colspan : string,  Text to insert before a group cell&#10;    end_td_colspan   : string,  Text to insert after a group cell&#10;    start_caption    : string,  Text to insert before the caption&#10;    end_caption      : string,  Text to insert after the caption&#10;&#10;@var array&#10;@access public" line="124" name="defaultOptions" /><scope attributes="__ctor__" doc="Class constructor.&#10;&#10;@param array $options Parameters for the rendering.&#10;@access public" ilk="function" line="132" lineend="135" name="Var_Dump_Renderer_Table" signature="Var_Dump_Renderer_Table(array $options = array())"><variable citdl="array" default="array()" ilk="argument" line="132" name="options" /></scope><scope doc="Returns the string representation of a variable&#10;&#10;@return string The string representation of the variable.&#10;@access public" ilk="function" line="143" lineend="150" name="toString" returns="string" signature="string toString()" /><scope doc="Returns the string representation of a single variable&#10;&#10;@return string The string representation of a single variable.&#10;@access private" ilk="function" line="158" lineend="183" name="_toString_Single" returns="string" signature="string _toString_Single()"><variable citdl="htmlspecialchars()" line="160" name="string" /></scope><scope doc="Returns the string representation of a multiple variable&#10;&#10;@return string The string representation of a multiple variable.&#10;@access private" ilk="function" line="191" lineend="270" name="_toString_Array" returns="string" signature="string _toString_Array()"><variable citdl="htmlspec