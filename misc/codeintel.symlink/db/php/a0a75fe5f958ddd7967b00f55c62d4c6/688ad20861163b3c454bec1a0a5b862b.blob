re the operator&#10;    after_operator  : string,  Text to insert after the operator&#10;    before_type     : string,  Text to insert before a type&#10;    after_type      : string,  Text to insert after a type&#10;    before_value    : string,  Text to insert before a value&#10;    after_value     : string,  Text to insert after a value&#10;&#10;@var    array&#10;@access public" line="115" name="defaultOptions" /><scope attributes="__ctor__" doc="Class constructor.&#10;&#10;@param array $options Parameters for the rendering.&#10;@access public" ilk="function" line="123" lineend="126" name="Var_Dump_Renderer_Text" signature="Var_Dump_Renderer_Text(array $options = array())"><variable citdl="array" default="array()" ilk="argument" line="123" name="options" /></scope><scope doc="Returns the string representation of a variable.&#10;&#10;@return string The string representation of the variable.&#10;@access public" ilk="function" line="134" lineend="235" name="toString" returns="string" signature="string toString()"><variable citdl="array()" line="137" name="stackOffset" /><variable citdl="count()" line="140" name="counter" /><variable citdl="this.options" line="139" name="txt" /><variable citdl="this.depth" line="138" name="offset" /><variable attributes="__not_yet_defined__" line="144" name="parent" /><variable line="141" name="c" /></scope><scope doc="Returns the lenght of the shift (string without tags).&#10;&#10;@param string $string The string.&#10;@return integer Length of the shift.&#10;@access private" ilk="function" line="244" lineend="251" name="_len" returns="integer" signature="integer _len(string $string)"><variable citdl="string" ilk="argument" line="244" name="string" /></scope><scope doc="Returns the operator symbol.&#10;&#10;@return string The operator symbol.&#10;@access private" ilk="function" line="259" lineend="269" name="_getOperator" returns="string" signature="string _getOperator()"><variable citdl="this.options" line="261" name="txt" /></scope>