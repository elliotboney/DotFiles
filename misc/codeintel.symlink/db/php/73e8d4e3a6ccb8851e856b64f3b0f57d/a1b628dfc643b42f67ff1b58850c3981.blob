<scope ilk="blob" lang="PHP" name="plugin-install.php" src="/private/var/www/kw/wp-admin/includes/plugin-install.php"><scope doc="Retrieve plugin installer pages from WordPress Plugins API.&#10;&#10;It is possible for a plugin to override the Plugin API result with three&#10;filters. Assume this is for plugins, which can extend on the Plugin Info to&#10;offer more choices. This is very powerful and must be used with care, when&#10;overriding the filters.&#10;&#10;The first filter, 'plugins_api_args', is for the args and gives the action as&#10;the second parameter. The hook for 'plugins_api_args' must ensure that an&#10;object is returned.&#10;&#10;The second filter, 'plugins_api', is the result that would be returned.&#10;&#10;@since 2.7.0&#10;&#10;@param string $action&#10;@param array|object $args Optional. Arguments to serialize for the Plugin Info API.&#10;@return object plugins_api response object on success, WP_Error on failure." ilk="function" line="29" lineend="102" name="plugins_api" returns="object" signature="object plugins_api(string $action, $args = null)"><variable citdl="string" ilk="argument" line="29" name="action" /><variable default="null" ilk="argument" line="29" name="args" /><variable citdl="http_url" line="63" name="url" /><variable line="64" name="ssl" /><variable citdl="apply_filters()" line="60" name="res" /><variable citdl="wp_remote_post()" line="74" name="request" /></scope><scope doc="Retrieve popular WordPress plugin tags.&#10;&#10;@since 2.7.0&#10;&#10;@param array $args&#10;@return array" ilk="function" line="112" lineend="125" name="install_popular_tags" returns="array" signature="array install_popular_tags(array $args = array())"><variable citdl="array" default="array()" ilk="argument" line="112" name="args" /><variable citdl="md5()" line="113" name="key" /><variable citdl="plugins_api()" line="114" name="tags" /></scope><scope ilk="function" line="127" lineend="155" name="install_dashboard" signature="install_dashboard()"><variable attributes="__not_yet_defined__" line="146" name="tag" /><variable attributes="__not_yet_defined__" line="141" name="api_tags" /><variable citdl="array()" line="145" name="tags" /></scope><scope doc="Display search form for searching plugins.&#10;&#10;@since 2.7.0" ilk="function" line="163" lineend="180" name="install_search_form" signature="install_search_form($type_selector = true)"><variable default="true" ilk="argument" line="163" name="type_selector" /><variable line="164" name="type" /><variable line="165" name="term" /></scope><scope doc="Upload from zip&#10;@since 2.8.0&#10;&#10;@param string $page" ilk="function" line="188" lineend="199" name="install_plugins_upload" signature="install_plugins_upload(string $page = 1)"><variable citdl="string" default="1" ilk="argument" line="188" name="page" /></scope><scope doc="Show a username form for the favorites page&#10;@since 3.5.0" ilk="function" line="207" lineend="220" name="install_plugins_favorites_form" signature="install_plugins_favorites_form()"><variable line="208" name="user" /></scope><scope doc="Display plugin content based on plugin list.&#10;&#10;@since 2.7.0" ilk="function" line="227" lineend="234" name="display_plugins_table" signature="display_plugins_table()"><variable attributes="__not_yet_defined__" line="230" name="_GET" /><variable attributes="__not_yet_defined__" line="228" name="wp_list_table" /></scope><scope doc="Determine the status we can perform on a plugin.&#10;&#10;@since 3.0.0" ilk="function" line="246" lineend="303" name="install_plugin_install_status" returns="install_plugin_install_status()" signature="install_plugin_install_status($api, $loop = false)"><variable ilk="argument" line="246" name="api" /><variable default="false" ilk="argument" line="246" name="loop" /><variable line="258" name="file" /><variable citdl="array_keys()" line="277" name="key" /><variable citdl="boolean" line="253" name="url" /><variable citdl="get_site_transient()" line="256" name="update_plugins" /><variable attributes="__not_yet_defined__" line="299" name="_GET" /><variable citdl="get_plugins()" line="272" name="installed_plugin" /><variable attributes="__not_yet_defined__" line="258" name="plugin" /><variable citdl="plugin.new_version" line="262" name="version" /><variable citdl="string" line="252" name="status" /><variable citdl="file" line="261" name="update_file" /></scope><scope doc="Display plugin information in dialog box form.&#10;&#10;@since 2.7.0" ilk="function" line="310" lineend="451" name="install_plugin_information" signature="install_plugin_information()"><variable citdl="plugins_api()" line="313" name="api" /><variable attributes="__not_yet_defined__" line="311" name="tab" /><variable line="355" name="title" /><variable citdl="install_plugin_install_status()" line="373" name="status" /><variable citdl="array()" line="325" name="plugins_allowedtags" /><variable attributes="__not_yet_defined__" citdl="links_add_base_url()" line="337" name="content" /><variable attributes="__not_yet_defined__" line="422" name="GLOBALS" /><variable citdl="array_shift()" line="344" name="section" /><variable line="360" name="class" /><variable citdl="array()" line="334" name="plugins_section_titles" /><variable citdl="add_query_arg()" line="361" name="href" /><variable citdl="esc_attr()" line="363" name="san_section" /><variable attributes="__not_yet_defined__" line="339" name="key" /><variable line="337" name="section_name" /><variable citdl="array_keys()" line="346" name="section_titles" /><variable line="440" name="display" /></scope></scope>