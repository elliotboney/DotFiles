<scope ilk="blob" lang="PHP" name="ArgvInput.php" src="/usr/local/pear/share/pear/PhpDocumentor/vendor/symfony/console/Symfony/Component/Console/Input/ArgvInput.php"><scope doc="This file is part of the Symfony package.&#10;&#10;(c) Fabien Potencier &lt;fabien@symfony.com&gt;&#10;&#10;For the full copyright and license information, please view the LICENSE&#10;file that was distributed with this source code." ilk="namespace" line="12" name="Symfony\Component\Console\Input"><scope classrefs="Input" doc="ArgvInput represents an input coming from the CLI arguments.&#10;&#10;Usage:&#10;&#10;    $input = new ArgvInput();&#10;&#10;By default, the `$_SERVER['argv']` array is used for the input values.&#10;&#10;This can be overridden by explicitly passing the input values in the constructor:&#10;&#10;    $input = new ArgvInput($_SERVER['argv']);&#10;&#10;If you pass it yourself, don't forget that the first element of the array&#10;is the name of the running application.&#10;&#10;When passing an argument to the constructor, be sure that it respects&#10;the same rules as the argv one. It's almost always better to use the&#10;`StringInput` when you want to provide your own input.&#10;&#10;@author Fabien Potencier &lt;fabien@symfony.com&gt;&#10;&#10;@see    http://www.gnu.org/software/libc/manual/html_node/Argument-Syntax.html&#10;@see    http://www.opengroup.org/onlinepubs/009695399/basedefs/xbd_chap12.html#tag_12_02&#10;&#10;@api" ilk="class" line="41" lineend="349" name="ArgvInput"><variable attributes="private" citdl="argv" line="43" name="tokens" /><variable attributes="private" citdl="this.tokens" line="44" name="parsed" /><scope attributes="public __ctor__" doc="Constructor.&#10;&#10;@param array           $argv       An array of parameters from the CLI (in the argv format)&#10;@param InputDefinition $definition A InputDefinition instance&#10;&#10;@api" ilk="function" line="54" lineend="66" name="__construct" signature="__construct(array $argv=null, InputDefinition $definition=null)"><variable citdl="array" ilk="argument" line="54" name="argv" /><variable citdl="InputDefinition" ilk="argument" line="54" name="definition" /></scope><scope attributes="protected" ilk="function" line="68" lineend="71" name="setTokens" signature="setTokens(array $tokens)"><variable citdl="array" ilk="argument" line="68" name="tokens" /></scope><scope attributes="protected" doc="Processes command line arguments." ilk="function" line="76" lineend="93" name="parse" signature="parse()"><variable line="80" name="token" /><variable citdl="boolean" line="78" name="parseOptions" /></scope><scope attributes="private" doc="Parses a short option.&#10;&#10;@param string $token The current token." ilk="function" line="100" lineend="114" name="parseShortOption" signature="parseShortOption(string $token)"><variable citdl="string" ilk="argument" line="100" name="token" /><variable citdl="substr()" line="102" name="name" /></scope><scope attributes="private" doc="Parses a short option set.&#10;&#10;@param string $name The current token&#10;&#10;@throws \RuntimeException When option given doesn't exist" ilk="function" line="123" lineend="140" name="parseShortOptionSet" signature="parseShortOptionSet(string $name)"><variable citdl="string" ilk="argument" line="123" name="name" /><variable citdl="strlen()" line="125" name="len" /><variable citdl="this.definition.getOptionForShortcut()" line="131" name="option" /><variable line="126" name="i" /></scope><scope attributes="private" doc="Parses a long option.&#10;&#10;@param string $token The current token" ilk="function" line="147" lineend="156" name="parseLongOption" signature="parseLongOption(string $token)"><variable citdl="string" ilk="argument" line="147" name="token" /><variable line="151" name="pos" /><variable citdl="substr()" line="149" name="name" /></scope><scope attributes="private" doc="Parses an argument.&#10;&#10;@param string $token The current token&#10;&#10;@throws \RuntimeException When too many arguments are given" ilk="function" line="165" lineend="183" name="parseArgument" signature="parseArgument(string $token)"><variable citdl="string" ilk="argument" line="165" name="token" /><variable citdl="count()" line="167" name="c" /><variable citdl="this.definition.getArgument()" line="171" name="arg" /></scope><scope attributes="private" doc="Adds a short option value.&#10;&#10;@param string $shortcut The short option key&#10;@param mixed  $value    The value for the option&#10;&#10;@throws \RuntimeException When option given doesn't exist" ilk="function" line="193" lineend="200" name="addShortOption" signature="addShortOption(string $shortcut, mixed $value)"><variable citdl="string" ilk="argument" line="193" name="shortcut" /><variable citdl="mixed" ilk="argument" line="193" name="value" /></scope><scope attributes="private" doc="Adds a long option value.&#10;&#10;@param string $name  The long option key&#10;@param mixed  $value The value for the option&#10;&#10;@throws \RuntimeException When option given doesn't exist" ilk="function" line="210" lineend="255" name="addLongOption" signature="addLongOption(string $name, mixed $value)"><variable citdl="string" ilk="argument" line="210" name="name" /><variable citdl="mixed" ilk="argument" line="210" name="value" /><variable citdl="array_shift()" line="230" name="next" /><variable citdl="this.definition.getOption()" line="216" name="option" /></scope><scope attributes="public" doc="Returns the first argument from the raw parameters (not parsed).&#10;&#10;@return string The value of the first argument or null otherwise" ilk="function" line="262" lineend="271" name="getFirstArgument" returns="string" signature="string getFirstArgument()"><variable attributes="__not_yet_defined__" line="264" name="token" /></scope><scope attributes="public" doc="Returns true if the raw parameters (not parsed) contain a value.&#10;&#10;This method is to be used to introspect the input parameters&#10;before they have been validated. It must be used carefully.&#10;&#10;@param string|array $values The value(s) to look for in the raw parameters (can be an array)&#10;&#10;@return Boolean true if the value is contained in the raw parameters" ilk="function" line="283" lineend="294" name="hasParameterOption" returns="Boolean" signature="Boolean hasParameterOption($values)"><variable ilk="argument" line="283" name="values" /><variable attributes="__not_yet_defined__" line="287" name="v" /></scope><scope attributes="public" doc="Returns the value of a raw option (not parsed).&#10;&#10;This method is to be used to introspect the input parameters&#10;before they have been validated. It must be used carefully.&#10;&#10;@param string|array $values  The value(s) to look for in the raw parameters (can be an array)&#10;@param mixed        $default The default value to return if no result is found&#10;&#10;@return mixed The option value" ilk="function" line="307" lineend="325" name="getParameterOption" returns="mixed" signature="mixed getParameterOption($values, mixed $default = false)"><variable ilk="argument" line="307" name="values" /><variable citdl="mixed" default="false" ilk="argument" line="307" name="default" /><variable line="312" name="token" /><variable line="315" name="pos" /><variable citdl="this.tokens" line="311" name="tokens" /><variable attributes="__not_yet_defined__" line="313" name="value" /></scope><scope attributes="public" doc="Returns a stringified representation of the args passed to the command&#10;&#10;@return string" ilk="function" line="332" lineend="348" name="__toString" returns="string" signature="string __toString()"><variable attributes="__not_yet_defined__" line="336" name="token" /><variable citdl="array_map()" line="335" name="tokens" /><variable attributes="__not_yet_defined__" line="336" name="match" /></scope></scope></scope></scope>