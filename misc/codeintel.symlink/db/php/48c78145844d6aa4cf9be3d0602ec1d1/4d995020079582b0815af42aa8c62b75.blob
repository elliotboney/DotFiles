<scope ilk="blob" lang="PHP" name="PluralizationRulesTest.php" src="/usr/local/pear/share/pear/PhpDocumentor/vendor/symfony/translation/Symfony/Component/Translation/Tests/PluralizationRulesTest.php"><scope doc="This file is part of the Symfony package.&#10;&#10;(c) Fabien Potencier &lt;fabien@symfony.com&gt;&#10;&#10;For the full copyright and license information, please view the LICENSE&#10;file that was distributed with this source code." ilk="namespace" line="12" name="Symfony\Component\Translation\Tests"><import line="14" module="Symfony\Component\Translation" symbol="PluralizationRules" /><scope classrefs="\PHPUnit_Framework_TestCase" doc="Test should cover all languages mentioned on http://translate.sourceforge.net/wiki/l10n/pluralforms&#10;and Plural forms mentioned on http://www.gnu.org/software/gettext/manual/gettext.html#Plural-forms&#10;&#10;See also https://developer.mozilla.org/en/Localization_and_Plurals which mentions 15 rules having a maximum of 6 forms.&#10;The mozilla code is also interesting to check for.&#10;&#10;As mentioned by chx http://drupal.org/node/1273968 we can cover all by testing number from 0 to 199&#10;&#10;The goal to cover all languages is to far fetched so this test case is smaller.&#10;&#10;@author Clemens Tolboom clemens@build2be.nl" ilk="class" line="29" lineend="124" name="PluralizationRulesTest"><scope attributes="public" doc="We test failed langcode here.&#10;&#10;TODO: The languages mentioned in the data provide need to get fixed somehow within PluralizationRules.&#10;&#10;@dataProvider failingLangcodes" ilk="function" line="39" lineend="43" name="testFailedLangcodes" signature="testFailedLangcodes($nplural, $langCodes)"><variable ilk="argument" line="39" name="nplural" /><variable ilk="argument" line="39" name="langCodes" /><variable citdl="this.generateTestData()" line="41" name="matrix" /></scope><scope attributes="public" doc="@dataProvider successLangcodes" ilk="function" line="48" lineend="52" name="testLangcodes" signature="testLangcodes($nplural, $langCodes)"><variable ilk="argument" line="48" name="nplural" /><variable ilk="argument" line="48" name="langCodes" /><variable citdl="this.generateTestData()" line="50" name="matrix" /></scope><scope attributes="public" doc="This array should contain all currently known langcodes.&#10;&#10;As it is impossible to have this ever complete we should try as hard as possible to have it almost complete.&#10;&#10;@return type" ilk="function" line="61" lineend="71" name="successLangcodes" returns="type" signature="type successLangcodes()" /><scope attributes="public" doc="This array should be at least empty within the near future.&#10;&#10;This both depends on a complete list trying to add above as understanding&#10;the plural rules of the current failing languages.&#10;&#10;@return array with nplural together with langcodes" ilk="function" line="81" lineend="91" name="failingLangcodes" returns="array" signature="array failingLangcodes()" /><scope attributes="protected" doc="We validate only on the plural coverage. Thus the real rules is not tested.&#10;&#10;@param string  $nplural       plural expected&#10;@param array   $matrix        containing langcodes and their plural index values.&#10;@param boolean $expectSuccess" ilk="function" line="100" lineend="110" name="validateMatrix" signature="validateMatrix(string $nplural, array $matrix, boolean $expectSuccess = true)"><variable citdl="string" ilk="argument" line="100" name="nplural" /><variable citdl="array" ilk="argument" line="100" name="matrix" /><variable citdl="boolean" default="true" ilk="argument" line="100" name="expectSuccess" /><variable line="102" name="langCode" /><variable attributes="__not_yet_defined__" line="102" name="data" /><variable citdl="array_flip()" line="103" name="indexes" /></scope><scope attributes="protected" ilk="function" line="112" lineend="123" name="generateTestData" returns="matrix" signature="generateTestData($plural, $langCodes)"><variable ilk="argument" line="112" name="plural" /><variable ilk="argument" line="112" name="langCodes" /><variable attributes="__not_yet_defined__" line="115" name="langCode" /><variable citdl="array()" line="114" name="matrix" /><variable line="116" name="count" /></scope></scope></scope></scope>