ect" ilk="function" line="123" lineend="129" name="__destruct" signature="__destruct()" /><scope attributes="public" doc="Get data for an item-level element&#10;&#10;This method allows you to get access to ANY element/attribute that is a&#10;sub-element of the item/entry tag.&#10;&#10;See {@see SimplePie::get_feed_tags()} for a description of the return value&#10;&#10;@since 1.0&#10;@see http://simplepie.org/wiki/faq/supported_xml_namespaces&#10;@param string $namespace The URL of the XML namespace of the elements you're trying to access&#10;@param string $tag Tag name&#10;@return array" ilk="function" line="145" lineend="155" name="get_item_tags" returns="array" signature="array get_item_tags(string $namespace, string $tag)"><variable citdl="string" ilk="argument" line="145" name="namespace" /><variable citdl="string" ilk="argument" line="145" name="tag" /></scope><scope attributes="public" doc="Get the base URL value from the parent feed&#10;&#10;Uses `&lt;xml:base&gt;`&#10;&#10;@param array $element&#10;@return string" ilk="function" line="165" lineend="168" name="get_base" returns="string" signature="string get_base(array $element = array())"><variable citdl="array" default="array()" ilk="argument" line="165" name="element" /></scope><scope attributes="public" doc="Sanitize feed data&#10;&#10;@access private&#10;@see SimplePie::sanitize()&#10;@param string $data Data to sanitize&#10;@param int $type One of the SIMPLEPIE_CONSTRUCT_* constants&#10;@param string $base Base URL to resolve URLs against&#10;@return string Sanitized data" ilk="function" line="180" lineend="183" name="sanitize" returns="string" signature="string sanitize(string $data, int $type, string $base = '')"><variable citdl="string" ilk="argument" line="180" name="data" /><variable citdl="int" ilk="argument" line="180" name="type" /><variable citdl="string" default="''" ilk="argument" line="180" name="base" /></scope><scope attributes="public" doc="Get the parent feed&#10;&#10;Note: this may not 