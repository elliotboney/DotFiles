rns="boolean" signature="boolean disconnect()" /><scope doc="Build a standardized string describing the current SMTP error.&#10;&#10;@param string $text  Custom string describing the error context.&#10;@param object $error Reference to the current PEAR_Error object.&#10;&#10;@return string       A string describing the current SMTP error.&#10;&#10;@since  1.1.7&#10;@access private" ilk="function" line="433" lineend="442" name="_error" returns="string" signature="string _error(string $text, object &amp; $error)"><variable citdl="string" ilk="argument" line="433" name="text" /><variable citdl="object" ilk="argument" line="433" name="error" /><variable attributes="__not_yet_defined__" line="436" name="response" /><variable attributes="__not_yet_defined__" line="436" name="code" /></scope></scope></scope>