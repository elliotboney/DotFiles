 name="url" /><variable citdl="string" default="null" ilk="argument" line="200" name="proxy" /><variable citdl="array" default="null" ilk="argument" line="200" name="helpers" /></scope><scope attributes="public" doc="Destructs the instance. Closes opened file handles.&#10;&#10;@return $this A reference to the current instance." ilk="function" line="233" lineend="246" name="__destruct" returns="this" signature="__destruct()" /><scope attributes="public" doc="Sets the credentials to use for authentication.&#10;&#10;@param string $user (Required) The username to authenticate with.&#10;@param string $pass (Required) The password to authenticate with.&#10;@return $this A reference to the current instance." ilk="function" line="259" lineend="264" name="set_credentials" returns="this" signature="set_credentials(string $user, string $pass)"><variable citdl="string" ilk="argument" line="259" name="user" /><variable citdl="string" ilk="argument" line="259" name="pass" /></scope><scope attributes="public" doc="Adds a custom HTTP header to the cURL request.&#10;&#10;@param string $key (Required) The custom HTTP header to set.&#10;@param mixed $value (Required) The value to assign to the custom HTTP header.&#10;@return $this A reference to the current instance." ilk="function" line="273" lineend="277" name="add_header" returns="this" signature="add_header(string $key, mixed $value)"><variable citdl="string" ilk="argument" line="273" name="key" /><variable citdl="mixed" ilk="argument" line="273" name="value" /></scope><scope attributes="public" doc="Removes an HTTP header from the cURL request.&#10;&#10;@param string $key (Required) The custom HTTP header to set.&#10;@return $this A reference to the current instance." ilk="function" line="285" lineend="292" name="remove_header" returns="this" signature="remove_header(string $key)"><variable citdl="string" ilk="argument" line="285" name="key" /></scope><scope attributes="public" doc="Set the method type for the request.&#10;&#10;@param string $method (Required) One of the following constants: &lt;HTTP_GET&gt;, &lt;HTTP_POST&gt;, &lt;HTTP_PUT&gt;, &lt;HTTP_HEAD&gt;, &lt;HTTP_DELETE&gt;.&#10;@return $this A reference to the current instance." ilk="function" line="300" lineend="304" name="set_method" returns="this" signature="set_method(string $method)"><variable citdl="string" ilk="argument" line="300" name="method" /></scope><scope attributes="public" doc="Sets a custom useragent string for the class.&#10;&#10;@param string $ua (Required) The useragent string to use.&#10;@return $this A reference to the current instance." ilk="function" line="312" lineend="316" name="set_useragent" returns="this" signature="set_useragent(string $ua)"><variable citdl="string" ilk="argument" line="312" name="ua" /></scope><scope attributes="public" doc="Set the body to send in the request.&#10;&#10;@param string $body (Required) The textual content to send along in the body of the request.&#10;@return $this A reference to the current instance." ilk="function" line="324" lineend="328" name="set_body" returns="this" signature="set_body(string $body)"><variable citdl="string" ilk="argument" line="324" name="body" /></scope><scope attributes="public" doc="Set the URL to make the request to.&#10;&#10;@param string $url (Required) The URL to make the request to.&#10;@return $this A reference to the current instance." ilk="function" line="336" lineend="340" name="set_request_url" returns="this" signature="set_request_url(string $url)"><variable citdl="string" ilk="argument" line="336" name="url" /></scope><scope attributes="public" doc="Set additional CURLOPT settings. These will merge with the default settings, and override if&#10;there is a duplicate.&#10;&#10;@param array $curlopts (Optional) A set of key-value pairs that set `CURLOPT` options. These will merge with the existing CURLOPTs, and ones passed here will override the defaults. Keys should be the `CURLOPT_*` constants, not strings.&#10;@return $this A reference to the current instance." ilk="function" line="349" lineend="353" name="set_curlopts" returns="this" signature="set_curlopts(array $curlopts)"><variable citdl="array" ilk="argument" line="349" name="curlopts" /></scope><scope attributes="public" doc="Sets the length in bytes to read from the stream while streaming up.&#10;&#10;@param integer $size (Required) The length in bytes to read from the stream.&#10;@return $this A reference to the current instance." ilk="function" line="361" lineend="366" name="set_read_stream_size" returns="this" signature="set_read_stream_size(integer $size)"><variable citdl="integer" ilk="argument" line="361" name="size" /></scope><scope attributes="public" doc="Sets the resource to read from while streaming up. Reads the stream from its current position until&#10;EOF or `$size` bytes have been read. If `$size` is not given it will be determined by &lt;php:fstat()&gt; and&#10;&lt;php:ftell()&gt;.&#10;&#10;@param resource $resource (Required) The readable resource to read from.&#10;@param integer $size (Optional) The size of the stream to read.&#10;@return $this A reference to the current instance." ilk="function" line="377" lineend="397" name="set_read_stream" returns="this.set_read_stream_size()" signature="set_read_stream(resource $resource, integer $size = null)"><variable citdl="resource" ilk="argument" line="377" name="resource" /><variable citdl="integer" default="null" ilk="argument" line="377" name="size" /><variable citdl="fstat()" line="381" name="stats" /><variable citdl="ftell()" line="385" name="position" /></scope><scope attributes="public" doc="Sets the file to read from while streaming up.&#10;&#10;@param string $location (Required) The readable location to read from.&#10;@return $this A reference to the current instance." ilk="function" line="405" lineend="411" name="set_read_file" returns="this.set_read_stream()" signature="set_read_file(string $location)"><variable citdl="string" ilk="argument" line="405" name="location" /><variable citdl="fopen()" line="408" name="read_file_handle" /></scope><scope attributes="public" doc="Sets the resource to write to while streaming down.&#10;&#10;@param resource $resource (Required) The writeable resource to write to.&#10;@return $this A reference to the current instance." ilk="function" line="419" lineend="424" name="set_write_stream" returns="this" signature="set_write_stream(resource $resource)"><variable citdl="resource" ilk="argument" line="419" name="resource" /></scope><scope attributes="public" doc="Sets the file to write to while streaming down.&#10;&#10;@param string $location (Required) The writeable location to write to.&#10;@return $this A reference to the current instance." ilk="function" line="432" lineend="438" name="set_write_file" returns="this.set_write_stream()" signature="set_write_file(string $location)"><variable citdl="string" ilk="argument" line="432" name="location" /><variable citdl="fopen()" line="435" name="write_file_handle" /></scope><scope attributes="public" doc="Set the proxy to use for making requests.&#10;&#10;@param string $proxy (Required) The faux-url to use for proxy settings. Takes the following format: `proxy://user:pass@hostname:port`&#10;@return $this A reference to the current instance." ilk="function" line="446" lineend="454" name="set_proxy" returns="this" signature="set_proxy(string $proxy)"><variable citdl="string" ilk="argument" line="446" name="proxy" /></scope><scope attributes="public" doc="Set the intended starting seek position.&#10;&#10;@param integer $position (Required) The byte-position of the stream to begin reading from.&#10;@return $this A reference to the current instance." ilk="function" line="462" lineend="467" name="set_seek_position" returns="this" signature="set_seek_position(integer $position)"><variable citdl="integer" ilk="argument" line="462" name="position" /></scope><scope attributes="public" doc="Register a callback function to execute whenever a data stream is read from using&#10;&lt;CFRequest::streaming_read_callback()&gt;.&#10;&#10;The user-defined callback function should accept three arguments:&#10;&#10;&lt;ul&gt;&#10;	&lt;li&gt;&lt;code&gt;$curl_handle&lt;/code&gt; - &lt;code&gt;resource&lt;/code&gt; - Required - The cURL handle resource that represents the in-progress transfer.&lt;/li&gt;&#10;	&lt;li&gt;&lt;code&gt;$file_handle&lt;/code&gt; - &lt;code&gt;resource&lt;/code&gt; - Required - The file handle resource that represents the file on the local file system.&lt;/li&gt;&#10;	&lt;li&gt;&lt;code&gt;$length&lt;/code&gt; - &lt;code&gt;integer&lt;/code&gt; - Required - The length in kilobytes of the data chunk that was transferred.&lt;/li&gt;&#10;&lt;/ul&gt;&#10;&#10;@param string|array|function $callback (Required) The callback function is called by &lt;php:call_user_func()&gt;, so you can pass the following values: &lt;ul&gt;&#10;	&lt;li&gt;The name of a global function to execute, passed as a string.&lt;/li&gt;&#10;	&lt;li&gt;A method to execute, passed as &lt;code&gt;array('ClassName', 'MethodName')&lt;/code&gt;.&lt;/li&gt;&#10;	&lt;li&gt;An anonymous function (PHP 5.3+).&lt;/li&gt;&lt;/ul&gt;&#10;@return $this A reference to the current instance." ilk="function" line="487" lineend="492" name="register_streaming_read_callback" returns="this" signature="register_streaming_read_callback($callback)"><variable ilk="argument" line="487" name="callback" /></scope><scope attributes="public" doc="Register a callback function to execute whenever a data stream is written to using&#10;&lt;CFRequest::streaming_write_callback()&gt;.&#10;&#10;The user-defined callback function should accept two arguments:&#10;&#10;&lt;ul&gt;&#10;	&lt;li&gt;&lt;code&gt;$curl_handle&lt;/code&gt; - &lt;code&gt;resource&lt;/code&gt; - Required - The cURL handle resource that represents the in-progress transfer.&lt;/li&gt;&#10;	&lt;li&gt;&lt;code&gt;$length&lt;/code&gt; - &lt;code&gt;integer&lt;/code&gt; - Required - The length in kilobytes of the data chunk that was transferred.&lt;/li&gt;&#10;&lt;/ul&gt;&#10;&#10;@param string|array|function $callback (Required) The callback function is called by &lt;php:call_user_func()&gt;, so you can pass the following values: &lt;ul&gt;&#10;	&lt;li&gt;The name of a global function to execute, passed as a string.&lt;/li&gt;&#10;	&lt;li&gt;A method to execute, passed as &lt;code&gt;array('ClassName', 'MethodName')&lt;/code&gt;.&lt;/li&gt;&#10;	&lt;li&gt;An anonymous function (PHP 5.3+).&lt;/li&gt;&lt;/ul&gt;&#10;@return $this A reference to the current instance." ilk="function" line="511" lineend="516" name="register_streaming_write_callback" returns="this" signature="register_streaming_write_callback($callback)"><variable ilk="argument" line="511" name="callback" /></scope><scope attributes="public" doc="A callback function that is invoked by cURL for streaming up.&#10;&#10;@param resource $curl_handle (Required) The cURL handle for the request.&#10;@param resource $file_handle (Required) The open file handle resource.&#10;@param integer $length (Required) The maximum number of bytes to read.&#10;@return binary Binary data from a stream." ilk="function" line="530" lineend="560" name="streaming_read_callback" returns="binary" signature="binary streaming_read_callback(resource $curl_handle, resource $file_handle, integer $length)"><variable citdl="resource" ilk="argument" line="530" name="curl_handle" /><variable citdl="resource" ilk="argument" line="530" name="file_handle" /><variable citdl="integer" ilk="argument" line="530" name="length" /><variable citdl="read" line="551" name="out" /><variable citdl="fread()" line="548" name="read" /></scope><scope attributes="public" doc="A callback function that is invoked by cURL for streaming down.&#10;&#10;@param resource $curl_handle (Required) The cURL handle for the request.&#10;@param binary $data (Required) The data to write.&#10;@return integer The number of bytes written." ilk="function" line="569" lineend="594" name="streaming_write_callback" returns="integer" signature="integer streaming_write_callback(resource $curl_handle, binary $data)"><variable citdl="resource" ilk="argument" line="569" name="curl_handle" /><variable citdl="binary" ilk="argument" line="569" name="data" /><variable citdl="int" line="573" name="written_last" /><variable citdl="strlen()" line="571" name="length" /><variable citdl="int" line="572" name="written_total" /></scope><scope attributes="public" doc="Prepares and adds the details of the cURL request. This can be passed along to a &lt;php:curl_multi_exec()&gt;&#10;function.&#10;&#10;@return resource The handle for the cURL object." ilk="function" line="602" lineend="750" name="prep_request" returns="resource" signature="resource prep_request()"><variable citdl="array()" line="686" name="temp_headers" /><variable attributes="__not_yet_defined__" line="688" name="v" /><variable citdl="curl_init()" line="604" name="curl_handle" /><variable line="688" name="k" /><variable citdl="this.proxy" line="660" name="host" /></scope><scope attributes="public" doc="Take the post-processed cURL data and break it down into useful header/body/info chunks. Uses the&#10;data stored in the `curl_handle` and `response` properties unless replacement data is passed in via&#10;parameters.&#10;&#10;@param resource $curl_handle (Optional) The reference to the already executed cURL request.&#10;@param string $response (Optional) The actual response content itself that needs to be parsed.&#10;@return ResponseCore A &lt;ResponseCore&gt; object containing a parsed HTTP response." ilk="function" line="761" lineend="807" name="process_response" returns="ResponseCore" signature="ResponseCore process_response(resource $curl_handle = null, string $response = null)"><variable citdl="resource" default="null" ilk="argument" line="761" name="curl_handle" /><variable citdl="string" default="null" ilk="argument" line="761" name="response" /><variable citdl="explode()" line="790" name="kv" /><variable citdl="curl_getinfo()" line="774" name="header_size" /><variable attributes="__not_yet_defined__" line="788" name="header" /><variable citdl="array()" line="787" name="header_assoc" /></scope><scope attributes="public" doc="Sends the request, calling necessary utility functions to update built-in properties.&#10;&#10;@param boolean $parse (Optional) Whether to parse the response with ResponseCore or not.&#10;@return string The resulting unparsed data from the request." ilk="function" line="815" lineend="837" name="send_request" returns="string" signature="string send_request(boolean $parse = false)"><variable citdl="boolean" default="false" ilk="argument" line="815" name="parse" /><variable citdl="this.process_response()" line="827" name="parsed_response" /><variable citdl="this.prep_request()" line="819" name="curl_handle" /></scope><scope attributes="public" doc="Sends the request using &lt;php:curl_multi_exec()&gt;, enabling parallel requests. Uses the &quot;rolling&quot; method.&#10;&#10;@param array $handles (Required) An indexed array of cURL handles to process simultaneously.&#10;@param array $opt (Optional) An associative array of parameters that can have the following keys: &lt;ul&gt;&#10;	&lt;li&gt;&lt;code&gt;callback&lt;/code&gt; - &lt;code&gt;string|array&lt;/code&gt; - Optional - The string name of a function to pass the response data to. If this is a method, pass an array where the &lt;code&gt;[0]&lt;/code&gt; index is the class and the &lt;code&gt;[1]&lt;/code&gt; index is the method name.&lt;/li&gt;&#10;	&lt;li&gt;&lt;code&gt;limit&lt;/code&gt; - &lt;code&gt;integer&lt;/code&gt; - Optional - The number of simultaneous requests to make. This can be useful for scaling around slow server responses. Defaults to trusting cURLs judgement as to how many to use.&lt;/li&gt;&lt;/ul&gt;&#10;@return array Post-processed cURL responses." ilk="function" line="848" lineend="929" name="send_multi_request" returns="array" signature="array send_multi_request(array $handles, array $opt = null)"><variable citdl="array" ilk="argument" line="848" name="handles" /><variable citdl="array" default="null" ilk="argument" line="848" name="opt" /><variable line="862" name="http" /><variable line="892" name="done" /><variable line="883" name="status" /><variable citdl="array()" line="864" name="handles_post" /><variable citdl="count()" line="865" name="added" /><variable citdl="curl_multi_init()" line="863" name="multi_handle" /><variable citdl="array_search()" line="911" name="key" /><variable citdl="array()" line="890" name="to_process" /><variable citdl="handles" line="861" name="handle_list" /><variable line="858" name="limit" /><variable citdl="http.process_response()" line="910" name="response" /><variable citdl="int" line="867" name="count" /><variable line="908" name="pkey" /><variable line="866" name="last_handle" /><variable citdl="int" line="868" name="i" /><variable citdl="boolean" line="880" name="active" /></scope><scope attributes="public" doc="Get the HTTP response headers from the request.&#10;&#10;@param string $header (Optional) A specific header value to return. Defaults to all headers.&#10;@return string|array All or selected header values." ilk="function" line="941" lineend="948" name="get_response_header" returns="string" signature="string get_response_header(string $header = null)"><variable citdl="string" default="null" ilk="argument" line="941" name="header" /></scope><scope attributes="public" doc="Get the HTTP response body from the request.&#10;&#10;@return string The response body." ilk="function" line="955" lineend="958" name="get_response_body" returns="string" signature="string get_response_body()" /><scope attributes="public" doc="Get the HTTP response code from the request.&#10;&#10;@return string The HTTP response code." ilk="function" line="965" lineend="968" name="get_response_code" returns="string" signature="string get_response_code()" /></scope><scope doc="Container for all response-related methods." ilk="class" line="975" lineend="1024" name="ResponseCore"><variable attributes="public" citdl="header" line="980" name="header" /><variable attributes="public" citdl="body" line="985" name="body" /><variable attributes="public" citdl="status" line="990" name="status" /><scope attributes="public __ctor__" doc="Constructs a new instance of this class.&#10;&#10;@param array $header (Required) Associative array of HTTP headers (typically returned by &lt;RequestCore::get_response_header()&gt;).&#10;@param string $body (Required) XML-formatted response from AWS.&#10;@param integer $status (Optional) HTTP response status code from the request.&#10;@return object Contains an &lt;php:array&gt; `header` property (HTTP headers as an associative array), a &lt;php:SimpleXMLElement&gt; or &lt;php:string&gt; `body` property, and an &lt;php:integer&gt; `status` code." ilk="function" line="1000" lineend="1007" name="__construct" returns="object" signature="object __construct(array $header, string $body, integer $status = null)"><variable citdl="array" ilk="argument" line="1000" name="header" /><variable citdl="string" ilk="argument" line="1000" name="body" /><variable citdl="integer" default="null" ilk="argument" line="1000" name="status" /></scope><scope attributes="public" doc="Did we receive the status code we expected?&#10;&#10;@param integer|array $codes (Optional) The status code(s) to expect. Pass an &lt;php:integer&gt; for a single acceptable value, or an &lt;php:array&gt; of integers for multiple acceptable values.&#10;@return boolean Whether we received the expected status code or not." ilk="function" line="1015" lineend="1023" name="isOK" returns="boolean" signature="boolean isOK($codes = array(200,201,204,206))"><variable default="array(200,201,204,206)" ilk="argument" line="1015" name="codes" /></scope></scope><scope classrefs="Exception" doc="Default RequestCore Exception." ilk="class" line="1029" lineend="1029" name="RequestCore_Exception" /></scope>