<scope ilk="blob" lang="PHP" name="requestcore.class.php" src="/private/var/www/wordpress.staging/plugins/w3-total-cache/lib/SNS/lib/requestcore/requestcore.class.php"><scope doc="Handles all HTTP requests using cURL and manages the responses.&#10;&#10;@version 2011.06.07&#10;@copyright 2006-2011 Ryan Parman&#10;@copyright 2006-2010 Foleeo Inc.&#10;@copyright 2010-2011 Amazon.com, Inc. or its affiliates.&#10;@copyright 2008-2011 Contributors&#10;@license http://opensource.org/licenses/bsd-license.php Simplified BSD License" ilk="class" line="12" lineend="969" name="RequestCore"><variable attributes="public" citdl="url" line="17" name="request_url" /><variable attributes="public" citdl="array()" line="22" name="request_headers" /><variable attributes="public" citdl="string" line="27" name="request_body" /><variable attributes="public" citdl="response" line="32" name="response" /><variable attributes="public" citdl="explode()" line="37" name="response_headers" /><variable attributes="public" citdl="substr()" line="42" name="response_body" /><variable attributes="public" citdl="curl_getinfo()" line="47" name="response_code" /><variable attributes="public" citdl="curl_getinfo()" line="52" name="response_info" /><variable attributes="public" citdl="curl_handle" line="57" name="curl_handle" /><variable attributes="public" citdl="self.HTTP_GET" line="62" name="method" /><variable attributes="public" citdl="proxy" line="67" name="proxy" /><variable attributes="public" citdl="user" line="72" name="username" /><variable attributes="public" citdl="pass" line="77" name="password" /><variable attributes="public" citdl="curlopts" line="82" name="curlopts" /><variable attributes="public" citdl="boolean" line="87" name="debug_mode" /><variable attributes="public" citdl="string" line="92" name="request_class" /><variable attributes="public" citdl="string" line="97" name="response_class" /><variable attributes="public" citdl="string" line="102" name="useragent" /><variable attributes