><variable citdl="phpcsFile.getTokensAsString()" line="174" name="commentString" /><variable citdl="strpos()" line="194" name="eolPos" /><variable citdl="trim()" line="224" name="testLong" /><variable citdl="comment.getLongComment()" line="213" name="long" /><variable citdl="this.commentParser.getComment()" line="186" name="comment" /><variable citdl="this.commentParser.getWords()" line="284" name="words" /><variable citdl="phpcsFile.findNext()" line="159" name="nextTokenStart" /><variable citdl="phpcsFile.findNext()" line="136" name="commentNext" /><variable citdl="this.commentParser.getTagOrders()" line="232" name="tags" /><variable citdl="array()" line="274" name="data" /><variable citdl="phpcsFile.findNext()" line="139" name="newlineToken" /><variable attributes="__not_yet_defined__" line="271" name="errorTag" /><variable citdl="substr()" line="195" name="firstLine" /></scope><scope attributes="protected" doc="Processes each required or optional tag.&#10;&#10;@param int $commentStart The position in the stack where the comment started.&#10;@param int $commentEnd   The position in the stack where the comment ended.&#10;&#10;@return void" ilk="function" line="305" lineend="410" name="processTags" signature="void processTags(int $commentStart, int $commentEnd)"><variable citdl="int" ilk="argument" line="305" name="commentStart" /><variable citdl="int" ilk="argument" line="305" name="commentEnd" /><variable citdl="string" line="325" name="error" /><variable citdl="this.commentParser" line="340" name="tagElement" /><variable citdl="int" line="317" name="errorPos" /><variable line="321" name="tag" /><variable line="398" name="expected" /><variable citdl="string" line="381" name="method" /><variable attributes="__not_yet_defined__" line="391" name="indentInfo" /><variable citdl="array_keys()" line="350" name="foundIndexes" /><variable citdl="int" line="319" name="longestTag" /><variable line="399" name="space" /><variable attributes="__not_yet_defined__" line="321" nam