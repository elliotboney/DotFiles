" line="47" name="strictWildcardSlash" /><variable citdl="boolean" line="50" name="escaping" /><variable line="54" name="i" /><variable citdl="glob" line="55" name="car" /><variable citdl="boolean" line="49" name="firstByte" /><variable citdl="int" line="51" name="inCurlies" /><variable citdl="string" line="52" name="regex" /><variable citdl="strlen()" line="53" name="sizeGlob" /></scope></scope></scope></scope>