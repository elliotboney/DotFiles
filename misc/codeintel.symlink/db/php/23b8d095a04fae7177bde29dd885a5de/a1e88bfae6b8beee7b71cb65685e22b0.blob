<scope ilk="blob" lang="PHP" name="Finder.php" src="/usr/local/pear/share/pear/PhpDocumentor/vendor/symfony/finder/Symfony/Component/Finder/Finder.php"><scope doc="This file is part of the Symfony package.&#10;&#10;(c) Fabien Potencier &lt;fabien@symfony.com&gt;&#10;&#10;For the full copyright and license information, please view the LICENSE&#10;file that was distributed with this source code." ilk="namespace" line="12" name="Symfony\Component\Finder"><import line="14" module="Symfony\Component\Finder\Adapter" symbol="AdapterInterface" /><import line="15" module="Symfony\Component\Finder\Adapter" symbol="GnuFindAdapter" /><import line="16" module="Symfony\Component\Finder\Adapter" symbol="BsdFindAdapter" /><import line="17" module="Symfony\Component\Finder\Adapter" symbol="PhpAdapter" /><import line="18" module="Symfony\Component\Finder\Exception" symbol="ExceptionInterface" /><scope doc="Finder allows to build rules to find files and directories.&#10;&#10;It is a thin wrapper around several specialized iterator classes.&#10;&#10;All rules may be invoked several times.&#10;&#10;All methods return the current Finder object to allow easy chaining:&#10;&#10;$finder = Finder::create()-&gt;files()-&gt;name('*.php')-&gt;in(__DIR__);&#10;&#10;@author Fabien Potencier &lt;fabien@symfony.com&gt;&#10;&#10;@api" ilk="class" interfacerefs="\IteratorAggregate \Countable" line="35" lineend="829" name="Finder"><variable citdl="int" ilk="constant" line="37" name="IGNORE_VCS_FILES" /><variable citdl="int" ilk="constant" line="38" name="IGNORE_DOT_FILES" /><variable attributes="private" citdl="int" line="40" name="mode" /><variable attributes="private" citdl="array()" line="41" name="names" /><variable attributes="private" citdl="array()" line="42" name="notNames" /><variable attributes="private" citdl="array_merge()" line="43" name="exclude" /><variable attributes="private" citdl="array()" line="44" name="filters" /><variable attributes="private" citdl="array()" line="45" name="depths" /><variable attributes="private" citdl="array()" line="46" name="sizes" /><variable attributes="private" citdl="boolean" line="47" name="followLinks" /><variable attributes="private" citdl="boolean" line="48" name="sort" /><variable attributes="private" citdl="this.ignore" line="49" name="ignore" /><variable attributes="private" citdl="array()" line="50" name="dirs" /><variable attributes="private" citdl="array()" line="51" name="dates" /><variable attributes="private" citdl="array()" line="52" name="iterators" /><variable attributes="private" citdl="array()" line="53" name="contains" /><variable attributes="private" citdl="array()" line="54" name="notContains" /><variable attributes="private" citdl="array()" line="55" name="adapters" /><variable attributes="private" citdl="array()" line="56" name="paths" /><variable attributes="private" citdl="array()" line="57" name="notPaths" /><variable attributes="private" citdl="boolean" line="58" name="ignoreUnreadableDirs" /><variable attributes="private static" citdl="array()" line="60" name="vcsPatterns" /><scope attributes="public __ctor__" doc="Constructor." ilk="function" line="65" lineend="75" name="__construct" signature="__construct()" /><scope attributes="public static" doc="Creates a new Finder.&#10;&#10;@return Finder A new Finder instance&#10;&#10;@api" ilk="function" line="84" lineend="87" name="create" returns="Finder" signature="Finder create()" /><scope attributes="public" doc="Registers a finder engine implementation.&#10;&#10;@param AdapterInterface $adapter  An adapter instance&#10;@param integer          $priority Highest is selected first&#10;&#10;@return Finder The current Finder instance" ilk="function" line="97" lineend="106" name="addAdapter" returns="Finder" signature="Finder addAdapter(AdapterInterface \AdapterInterface $adapter, integer $priority = 0)"><variable citdl="AdapterInterface" ilk="argument" line="97" name="adapter" /><variable citdl="integer" default="0" ilk="argument" line="97" name="priority" /></scope><scope attributes="public" doc="Sets the selected adapter to the best one according to the current platform the code is run on.&#10;&#10;@return Finder The current Finder instance" ilk="function" line="113" lineend="118" name="useBestAdapter" returns="Finder" signature="Finder useBestAdapter()" /><scope attributes="public" doc="Selects the adapter to use.&#10;&#10;@param string $name&#10;&#10;@throws \InvalidArgumentException&#10;&#10;@return Finder The current Finder instance" ilk="function" line="129" lineend="139" name="setAdapter" returns="Finder" signature="Finder setAdapter(string $name)"><variable citdl="string" ilk="argument" line="129" name="name" /></scope><scope attributes="public" doc="Removes all adapters registered in the finder.&#10;&#10;@return Finder The current Finder instance" ilk="function" line="146" lineend="151" name="removeAdapters" returns="Finder" signature="Finder removeAdapters()" /><scope attributes="public" doc="Returns registered adapters ordered by priority without extra information.&#10;&#10;@return AdapterInterface[]" ilk="function" line="158" lineend="163" name="getAdapters" returns="AdapterInterface" signature="AdapterInterface getAdapters()" /><scope attributes="public" doc="Restricts the matching to directories only.&#10;&#10;@return Finder The current Finder instance&#10;&#10;@api" ilk="function" line="172" lineend="177" name="directories" returns="Finder" signature="Finder directories()" /><scope attributes="public" doc="Restricts the matching to files only.&#10;&#10;@return Finder The current Finder instance&#10;&#10;@api" ilk="function" line="186" lineend="191" name="files" returns="Finder" signature="Finder files()" /><scope attributes="public" doc="Adds tests for the directory depth.&#10;&#10;Usage:&#10;&#10;  $finder-&gt;depth('&gt; 1') // the Finder will start matching at level 1.&#10;  $finder-&gt;depth('&lt; 3') // the Finder will descend at most 3 levels of directories below the starting point.&#10;&#10;@param int $level The depth level expression&#10;&#10;@return Finder The current Finder instance&#10;&#10;@see Symfony\Component\Finder\Iterator\DepthRangeFilterIterator&#10;@see Symfony\Component\Finder\Comparator\NumberComparator&#10;&#10;@api" ilk="function" line="210" lineend="215" name="depth" returns="Finder" signature="Finder depth(int $level)"><variable citdl="int" ilk="argument" line="210" name="level" /></scope><scope attributes="public" doc="Adds tests for file dates (last modified).&#10;&#10;The date must be something that strtotime() is able to parse:&#10;&#10;  $finder-&gt;date('since yesterday');&#10;  $finder-&gt;date('until 2 days ago');&#10;  $finder-&gt;date('&gt; now - 2 hours');&#10;  $finder-&gt;date('&gt;= 2005-10-15');&#10;&#10;@param string $date A date rage string&#10;&#10;@return Finder The current Finder instance&#10;&#10;@see strtotime&#10;@see Symfony\Component\Finder\Iterator\DateRangeFilterIterator&#10;@see Symfony\Component\Finder\Comparator\DateComparator&#10;&#10;@api" ilk="function" line="237" lineend="242" name="date" returns="Finder" signature="Finder date(string $date)"><variable citdl="string" ilk="argument" line="237" name="date" /></scope><scope attributes="public" doc="Adds rules that files must match.&#10;&#10;You can use patterns (delimited with / sign), globs or simple strings.&#10;&#10;$finder-&gt;name('*.php')&#10;$finder-&gt;name('/\.php$/') // same as above&#10;$finder-&gt;name('test.php')&#10;&#10;@param string $pattern A pattern (a regexp, a glob, or a string)&#10;&#10;@return Finder The current Finder instance&#10;&#10;@see Symfony\Component\Finder\Iterator\FilenameFilterIterator&#10;&#10;@api" ilk="function" line="261" lineend="266" name="name" returns="Finder" signature="Finder name(string $pattern)"><variable citdl="string" ilk="argument" line="261" name="pattern" /></scope><scope attributes="public" doc="Adds rules that files must not match.&#10;&#10;@param string $pattern A pattern (a regexp, a glob, or a string)&#10;&#10;@return Finder The current Finder instance&#10;&#10;@see Symfony\Component\Finder\Iterator\FilenameFilterIterator&#10;&#10;@api" ilk="function" line="279" lineend="284" name="notName" returns="Finder" signature="Finder notName(string $pattern)"><variable citdl="string" ilk="argument" line="279" name="pattern" /></scope><scope attributes="public" doc="Adds tests that file contents must match.&#10;&#10;Strings or PCRE patterns can be used:&#10;&#10;$finder-&gt;contains('Lorem ipsum')&#10;$finder-&gt;contains('/Lorem ipsum/i')&#10;&#10;@param string $pattern A pattern (string or regexp)&#10;&#10;@return Finder The current Finder instance&#10;&#10;@see Symfony\Component\Finder\Iterator\FilecontentFilterIterator" ilk="function" line="300" lineend="305" name="contains" returns="Finder" signature="Finder contains(string $pattern)"><variable citdl="string" ilk="argument" line="300" name="pattern" /></scope><scope attributes="public" doc="Adds tests that file contents must not match.&#10;&#10;Strings or PCRE patterns can be used:&#10;&#10;$finder-&gt;notContains('Lorem ipsum')&#10;$finder-&gt;notContains('/Lorem ipsum/i')&#10;&#10;@param string $pattern A pattern (string or regexp)&#10;&#10;@return Finder The current Finder instance&#10;&#10;@see Symfony\Component\Finder\Iterator\FilecontentFilterIterator" ilk="function" line="321" lineend="326" name="notContains" returns="Finder" signature="Finder notContains(string $pattern)"><variable citdl="string" ilk="argument" line="321" name="pattern" /></scope><scope attributes="public" doc="Adds rules that filenames must match.&#10;&#10;You can use patterns (delimited with / sign) or simple strings.&#10;&#10;$finder-&gt;path('some/special/dir')&#10;$finder-&gt;path('/some\/special\/dir/') // same as above&#10;&#10;Use only / as dirname separator.&#10;&#10;@param string $pattern A pattern (a regexp or a string)&#10;&#10;@return Finder The current Finder instance&#10;&#10;@see Symfony\Component\Finder\Iterator\FilenameFilterIterator" ilk="function" line="344" lineend="349" name="path" returns="Finder" signature="Finder path(string $pattern)"><variable citdl="string" ilk="argument" line="344" name="pattern" /></scope><scope attributes="public" doc="Adds rules that filenames must not match.&#10;&#10;You can use patterns (delimited with / sign) or simple strings.&#10;&#10;$finder-&gt;notPath('some/special/dir')&#10;$finder-&gt;notPath('/some\/special\/dir/') // same as above&#10;&#10;Use only / as dirname separator.&#10;&#10;@param string $pattern A pattern (a regexp or a string)&#10;&#10;@return Finder The current Finder instance&#10;&#10;@see Symfony\Component\Finder\Iterator\FilenameFilterIterator" ilk="function" line="367" lineend="372" name="notPath" returns="Finder" signature="Finder notPath(string $pattern)"><variable citdl="string" ilk="argument" line="367" name="pattern" /></scope><scope attributes="public" doc="Adds tests for file sizes.&#10;&#10;$finder-&gt;size('&gt; 10K');&#10;$finder-&gt;size('&lt;= 1Ki');&#10;$finder-&gt;size(4);&#10;&#10;@param string $size A size range string&#10;&#10;@return Finder The current Finder instance&#10;&#10;@see Symfony\Component\Finder\Iterator\SizeRangeFilterIterator&#10;@see Symfony\Component\Finder\Comparator\NumberComparator&#10;&#10;@api" ilk="function" line="390" lineend="395" name="size" returns="Finder" signature="Finder size(string $size)"><variable citdl="string" ilk="argument" line="390" name="size" /></scope><scope attributes="public" doc="Excludes directories.&#10;&#10;@param string|array $dirs A directory path or an array of directories&#10;&#10;@return Finder The current Finder instance&#10;&#10;@see Symfony\Component\Finder\Iterator\ExcludeDirectoryFilterIterator&#10;&#10;@api" ilk="function" line="408" lineend="413" name="exclude" returns="Finder" signature="Finder exclude($dirs)"><variable ilk="argument" line="408" name="dirs" /></scope><scope attributes="public" doc="Excludes &quot;hidden&quot; directories and files (starting with a dot).&#10;&#10;@param Boolean $ignoreDotFiles Whether to exclude &quot;hidden&quot; files or not&#10;&#10;@return Finder The current Finder instance&#10;&#10;@see Symfony\Component\Finder\Iterator\ExcludeDirectoryFilterIterator&#10;&#10;@api" ilk="function" line="426" lineend="435" name="ignoreDotFiles" returns="Finder" signature="Finder ignoreDotFiles(Boolean $ignoreDotFiles)"><variable citdl="Boolean" ilk="argument" line="426" name="ignoreDotFiles" /></scope><scope attributes="public" doc="Forces the finder to ignore version control directories.&#10;&#10;@param Boolean $ignoreVCS Whether to exclude VCS files or not&#10;&#10;@return Finder The current Finder instance&#10;&#10;@see Symfony\Component\Finder\Iterator\ExcludeDirectoryFilterIterator&#10;&#10;@api" ilk="function" line="448" lineend="457" name="ignoreVCS" returns="Finder" signature="Finder ignoreVCS(Boolean $ignoreVCS)"><variable citdl="Boolean" ilk="argument" line="448" name="ignoreVCS" /></scope><scope attributes="public static" doc="Adds VCS patterns.&#10;&#10;@see ignoreVCS&#10;&#10;@param string|string[] $pattern VCS patterns to ignore" ilk="function" line="466" lineend="473" name="addVCSPattern" signature="addVCSPattern($pattern)"><variable ilk="argument" line="466" name="pattern" /><variable attributes="__not_yet_defined__" line="468" name="p" /></scope><scope attributes="public" doc="Sorts files and directories by an anonymous function.&#10;&#10;The anonymous function receives two \SplFileInfo instances to compare.&#10;&#10;This can be slow as all the matching files and directories must be retrieved for comparison.&#10;&#10;@param \Closure $closure An anonymous function&#10;&#10;@return Finder The current Finder instance&#10;&#10;@see Symfony\Component\Finder\Iterator\SortableIterator&#10;&#10;@api" ilk="function" line="490" lineend="495" name="sort" returns="Finder" signature="Finder sort(\Closure $closure)"><variable citdl="\Closure" ilk="argument" line="490" name="closure" /></scope><scope attributes="public" doc="Sorts files and directories by name.&#10;&#10;This can be slow as all the matching files and directories must be retrieved for comparison.&#10;&#10;@return Finder The current Finder instance&#10;&#10;@see Symfony\Component\Finder\Iterator\SortableIterator&#10;&#10;@api" ilk="function" line="508" lineend="513" name="sortByName" returns="Finder" signature="Finder sortByName()" /><scope attributes="public" doc="Sorts files and directories by type (directories before files), then by name.&#10;&#10;This can be slow as all the matching files and directories must be retrieved for comparison.&#10;&#10;@return Finder The current Finder instance&#10;&#10;@see Symfony\Component\Finder\Iterator\SortableIterator&#10;&#10;@api" ilk="function" line="526" lineend="531" name="sortByType" returns="Finder" signature="Finder sortByType()" /><scope attributes="public" doc="Sorts files and directories by the last accessed time.&#10;&#10;This is the time that the file was last accessed, read or written to.&#10;&#10;This can be slow as all the matching files and directories must be retrieved for comparison.&#10;&#10;@return Finder The current Finder instance&#10;&#10;@see Symfony\Component\Finder\Iterator\SortableIterator&#10;&#10;@api" ilk="function" line="546" lineend="551" name="sortByAccessedTime" returns="Finder" signature="Finder sortByAccessedTime()" /><scope attributes="public" doc="Sorts files and directories by the last inode changed time.&#10;&#10;This is the time that the inode information was last modified (permissions, owner, group or other metadata).&#10;&#10;On Windows, since inode is not available, changed time is actually the file creation time.&#10;&#10;This can be slow as all the matching files and directories must be retrieved for comparison.&#10;&#10;@return Finder The current Finder instance&#10;&#10;@see Symfony\Component\Finder\Iterator\SortableIterator&#10;&#10;@api" ilk="function" line="568" lineend="573" name="sortByChangedTime" returns="Finder" signature="Finder sortByChangedTime()" /><scope attributes="public" doc="Sorts files and directories by the last modified time.&#10;&#10;This is the last time the actual contents of the file were last modified.&#10;&#10;This can be slow as all the matching files and directories must be retrieved for comparison.&#10;&#10;@return Finder The current Finder instance&#10;&#10;@see Symfony\Component\Finder\Iterator\SortableIterator&#10;&#10;@api" ilk="function" line="588" lineend="593" name="sortByModifiedTime" returns="Finder" signature="Finder sortByModifiedTime()" /><scope attributes="public" doc="Filters the iterator with an anonymous function.&#10;&#10;The anonymous function receives a \SplFileInfo and must return false&#10;to remove files.&#10;&#10;@param \Closure $closure An anonymous function&#10;&#10;@return Finder The current Finder instance&#10;&#10;@see Symfony\Component\Finder\Iterator\CustomFilterIterator&#10;&#10;@api" ilk="function" line="609" lineend="614" name="filter" returns="Finder" signature="Finder filter(\Closure $closure)"><variable citdl="\Closure" ilk="argument" line="609" name="closure" /></scope><scope attributes="public" doc="Forces the following of symlinks.&#10;&#10;@return Finder The current Finder instance&#10;&#10;@api" ilk="function" line="623" lineend="628" name="followLinks" returns="Finder" signature="Finder followLinks()" /><scope attributes="public" doc="Tells finder to ignore unreadable directories.&#10;&#10;By default, scanning unreadable directories content throws an AccessDeniedException.&#10;&#10;@param boolean $ignore&#10;&#10;@return Finder The current Finder instance" ilk="function" line="639" lineend="644" name="ignoreUnreadableDirs" returns="Finder" signature="Finder ignoreUnreadableDirs(boolean $ignore = true)"><variable citdl="boolean" default="true" ilk="argument" line="639" name="ignore" /></scope><scope attributes="public" doc="Searches files and directories which match defined rules.&#10;&#10;@param string|array $dirs A directory path or an array of directories&#10;&#10;@return Finder The current Finder instance&#10;&#10;@throws \InvalidArgumentException if one of the directories does not exist&#10;&#10;@api" ilk="function" line="657" lineend="674" name="in" returns="Finder" signature="Finder in($dirs)"><variable ilk="argument" line="657" name="dirs" /><variable attributes="__not_yet_defined__" line="661" name="dir" /><variable line="664" name="glob" /><variable citdl="array()" line="659" name="resolvedDirs" /></scope><scope attributes="public" doc="Returns an Iterator for the current Finder configuration.&#10;&#10;This method implements the IteratorAggregate interface.&#10;&#10;@return \Iterator An iterator&#10;&#10;@throws \LogicException if the in() method has not been called" ilk="function" line="685" lineend="705" name="getIterator" returns="\Iterator" signature="\Iterator getIterator()"><variable citdl="\AppendIterator" line="695" name="iterator" /><variable attributes="__not_yet_defined__" line="700" name="it" /><variable attributes="__not_yet_defined__" line="696" name="dir" /></scope><scope attributes="public" doc="Appends an existing set of files/directories to the finder.&#10;&#10;The set can be another Finder, an Iterator, an IteratorAggregate, or even a plain array.&#10;&#10;@param mixed $iterator&#10;&#10;@return Finder The finder&#10;&#10;@throws \InvalidArgumentException When the given argument is not iterable." ilk="function" line="718" lineend="735" name="append" returns="Finder" signature="Finder append(mixed $iterator)"><variable citdl="mixed" ilk="argument" line="718" name="iterator" /><variable attributes="__not_yet_defined__" line="726" name="file" /><variable citdl="\ArrayIterator" line="725" name="it" /></scope><scope attributes="public" doc="Counts all the results collected by the iterators.&#10;&#10;@return int" ilk="function" line="742" lineend="745" name="count" returns="int" signature="int count()" /><scope attributes="private" doc="@return Finder The current Finder instance" ilk="function" line="750" lineend="761" name="sortAdapters" returns="Finder" signature="Finder sortAdapters()"><variable attributes="__not_yet_defined__" line="753" name="b" /><variable attributes="__not_yet_defined__" line="753" name="a" /></scope><scope attributes="private" doc="@param $dir&#10;&#10;@return \Iterator&#10;&#10;@throws \RuntimeException When none of the adapters are supported" ilk="function" line="770" lineend="791" name="searchInDirectory" returns="\Iterator" signature="\Iterator searchInDirectory($dir)"><variable ilk="argument" line="770" name="dir" /><variable attributes="__not_yet_defined__" line="780" name="adapter" /><variable attributes="__not_yet_defined__" line="786" name="e" /></scope><scope attributes="private" doc="@param AdapterInterface $adapter&#10;&#10;@return AdapterInterface" ilk="function" line="798" lineend="816" name="buildAdapter" returns="AdapterInterface" signature="AdapterInterface buildAdapter(AdapterInterface $adapter)"><variable citdl="AdapterInterface" ilk="argument" line="798" name="adapter" /></scope><scope attributes="private" doc="Unselects all adapters." ilk="function" line="821" lineend="828" name="resetAdapterSelection" returns="properties" signature="resetAdapterSelection()" /></scope></scope></scope>