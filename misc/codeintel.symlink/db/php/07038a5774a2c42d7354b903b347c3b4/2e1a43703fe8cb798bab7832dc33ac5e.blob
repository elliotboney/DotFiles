<scope ilk="blob" lang="PHP" name="PackageUpdate.php" src="/usr/local/Cellar/php55/5.5.7/lib/php/test/PHP_CompatInfo/tests/parseFile/PackageUpdate.php"><import line="24" module="PEAR/ErrorStack.php" /><import line="25" module="PEAR/Config.php" /><import line="918" module="PEAR/Command.php" /><variable citdl="int" ilk="constant" line="28" name="PEAR_PACKAGEUPDATE_PREF_NOUPDATES" /><variable citdl="int" ilk="constant" line="29" name="PEAR_PACKAGEUPDATE_PREF_NEXTRELEASE" /><variable citdl="int" ilk="constant" line="30" name="PEAR_PACKAGEUPDATE_PREF_TYPE" /><variable citdl="int" ilk="constant" line="31" name="PEAR_PACKAGEUPDATE_PREF_STATE" /><variable citdl="string" ilk="constant" line="34" name="PEAR_PACKAGEUPDATE_STATE_DEVEL" /><variable citdl="string" ilk="constant" line="35" name="PEAR_PACKAGEUPDATE_STATE_ALPHA" /><variable citdl="string" ilk="constant" line="36" name="PEAR_PACKAGEUPDATE_STATE_BETA" /><variable citdl="string" ilk="constant" line="37" name="PEAR_PACKAGEUPDATE_STATE_STABLE" /><variable citdl="string" ilk="constant" line="40" name="PEAR_PACKAGEUPDATE_TYPE_BUG" /><variable citdl="string" ilk="constant" line="41" name="PEAR_PACKAGEUPDATE_TYPE_MINOR" /><variable citdl="string" ilk="constant" line="42" name="PEAR_PACKAGEUPDATE_TYPE_MAJOR" /><variable ilk="constant" line="45" name="PEAR_PACKAGEUPDATE_ERROR_NOPACKAGE" /><variable ilk="constant" line="46" name="PEAR_PACKAGEUPDATE_ERROR_NOCHANNEL" /><variable ilk="constant" line="47" name="PEAR_PACKAGEUPDATE_ERROR_NOINFO" /><variable ilk="constant" line="48" name="PEAR_PACKAGEUPDATE_ERROR_NOTINSTALLED" /><variable ilk="constant" line="49" name="PEAR_PACKAGEUPDATE_ERROR_PREFFILE_READACCESS" /><variable ilk="constant" line="50" name="PEAR_PACKAGEUPDATE_ERROR_PREFFILE_WRITEACCESS" /><variable ilk="constant" line="51" name="PEAR_PACKAGEUPDATE_ERROR_PREFFILE_WRITEERROR" /><variable ilk="constant" line="52" name="PEAR_PACKAGEUPDATE_ERROR_PREFFILE_CORRUPTED" /><variable ilk="constant" line="53" name="PEAR_PACKAGEUPDATE_ERROR_INVALIDTYPE" /><variable ilk="constant" line="54" name="PEAR_PACKAGEUPDATE_ERROR_INVALIDSTATE" /><variable ilk="constant" line="55" name="PEAR_PACKAGEUPDATE_ERROR_INVALIDPREF" /><variable ilk="constant" line="56" name="PEAR_PACKAGEUPDATE_ERROR_NONEXISTENTDRIVER" /><scope doc="The package allows a developer to add a few lines of code to&#10;their existing packages and have the ability to update their&#10;package automatically. This auto-update ability allows users&#10;to stay up to date much more easily than requiring them to&#10;update manually.&#10;&#10;This package keeps track of user preferences such as &quot;don't&#10;remind me again&quot;.&#10;&#10;This package is designed to be a backend to different front&#10;ends written for this package. For example, this package can&#10;be used to drive a PHP-GTK 2, CLI or web front end. The API&#10;for this package should be flexible enough to allow any type&#10;of front end to be used and also to allow the package to be&#10;used directly in another package without a front end driver.&#10;&#10;The interface for this package must allow for the following&#10;functionality:&#10;- check to see if a new version is available for a given&#10;  package on a given channel&#10;  - check minimum state&#10;- present information regarding the upgrade (version, size)&#10;  - inform user about dependencies&#10;- allow user to confirm or cancel upgrade&#10;- download and install the package&#10;- track preferences on a per package basis&#10;  - don't ask again&#10;  - don't ask until next release&#10;  - only ask for state XXXX or higher&#10;  - bug/minor/major updates only&#10;- update channel automatically&#10;- force application to exit when upgrade complete&#10;  - PHP-GTK/CLI apps must exit to allow classes to reload&#10;  - web front end could send headers to reload certain page&#10;&#10;This class is simply a wrapper for PEAR classes that actually&#10;do the work.&#10;&#10;EXAMPLE:&#10;&lt;code&gt;&#10;&lt;?php&#10; class Goo {&#10;     function __construct()&#10;     {&#10;         // Check for updates...&#10;         require_once 'PEAR/PackageUpdate.php';&#10;         $ppu =&amp; PEAR_PackageUpdate::factory('Gtk2', 'Goo', 'pear');&#10;         if ($ppu !== false) {&#10;             if ($ppu-&gt;checkUpdate()) {&#10;                 // Use a dialog window to ask permission to update.&#10;                 if ($ppu-&gt;presentUpdate()) {&#10;                     if ($ppu-&gt;update()) {&#10;                         // If the update succeeded, the application should&#10;                         // be restarted.&#10;                         $ppu-&gt;forceRestart();&#10;                     }&#10;                 }&#10;             }&#10;         }&#10;         // ...&#10;     }&#10;     // ...&#10; }&#10;?&gt;&#10;&lt;/code&gt;&#10;&#10;@category   PEAR&#10;@package    PEAR_PackageUpdate&#10;@author     Scott Mattocks&#10;@copyright  2006 Scott Mattocks&#10;@license    http://www.php.net/license/3_01.txt  PHP License 3.01&#10;@version    Release: 0.5.0&#10;@link       http://pear.php.net/package/PEAR_PackageUpdate&#10;@since      Class available since Release 0.4.0a1" ilk="class" line="164" lineend="1087" name="PEAR_PackageUpdate"><variable citdl="array" doc="The user's update preferences.&#10;&#10;@access public&#10;@var    array&#10;@since  0.4.0a1" line="173" name="preferences" /><variable citdl="string" doc="The name of the package.&#10;&#10;@access public&#10;@var    string&#10;@since  0.4.0a1" line="182" name="packageName" /><variable citdl="string" doc="The channel the package is hosted on.&#10;&#10;@access public&#10;@var    string&#10;@since  0.4.0a1" line="191" name="channel" /><variable citdl="string" doc="The latest version available for the given package.&#10;&#10;@access public&#10;@var    string&#10;@since  0.4.0a1" line="200" name="latestVersion" /><variable citdl="array" doc="Information about the latest version of the package.&#10;&#10;@access public&#10;@var    array&#10;@since  0.4.0a1" line="209" name="info" /><variable citdl="string" doc="The current installed version of the package.&#10;&#10;@access public&#10;@var    string&#10;@since  0.4.0a1" line="218" name="instVersion" /><variable citdl="PEAR_ErrorStack.singleton()" doc="A collection of errors that have occurred.&#10;&#10;@access public&#10;@var    object&#10;@since  0.4.0a1" line="227" name="errors" /><scope attributes="__ctor__" doc="PHP 4 style constructor. Calls the PHP 5 style constructor.&#10;&#10;@access public&#10;@param  string $packageName The package to update.&#10;@param  string $channel     The channel the package resides on.&#10;@return void&#10;@since  0.4.0a1" ilk="function" line="238" lineend="241" name="PEAR_PackageUpdate" signature="void PEAR_PackageUpdate(string $packageName, string $channel)"><variable citdl="string" ilk="argument" line="238" name="packageName" /><variable citdl="string" ilk="argument" line="238" name="channel" /></scope><scope attributes="__ctor__" doc="PHP 5 style constructor. Loads the user preferences.&#10;&#10;@access public&#10;@param  string $packageName The package to update.&#10;@param  string $channel     The channel the package resides on.&#10;@return void&#10;@since  0.4.0a1" ilk="function" line="252" lineend="264" name="__construct" signature="void __construct(string $packageName, string $channel)"><variable citdl="string" ilk="argument" line="252" name="packageName" /><variable citdl="string" ilk="argument" line="252" name="channel" /></scope><scope doc="Callback that generates context information (location of error)&#10;for the package error stack.&#10;&#10;@access private&#10;@return mixed  backtrace context array or false is unavailable&#10;@since  0.4.3" ilk="function" line="274" lineend="283" name="_getBacktrace" returns="mixed" signature="mixed _getBacktrace()"><variable citdl="debug_backtrace()" line="277" name="backtrace" /></scope><scope doc="Creates an instance of the given update class.&#10;&#10;@access public&#10;@param  string $driver The type of PPU to create.&#10;@param  string $packageName The package to update.&#10;@param  string $channel     The channel the package resides on.&#10;@return object An instance of type PEAR_PackageUpdate_$driver&#10;@since  0.4.0a1&#10;@throws PEAR_PACKAGEUPDATE_ERROR_NONEXISTENTDRIVER" ilk="function" line="296" lineend="332" name="factory" returns="object" signature="object &amp;factory(string $driver, string $packageName, string $channel)"><variable citdl="string" ilk="argument" line="296" name="driver" /><variable citdl="string" ilk="argument" line="296" name="packageName" /><variable citdl="string" ilk="argument" line="296" name="channel" /><variable citdl="string" line="306" name="file" /><variable citdl="boolean" line="316" name="false" /><variable line="330" name="instance" /><variable citdl="string" line="298" name="class" /></scope><scope doc="Returns whether or not a path is in the include path.&#10;&#10;@static&#10;@access public&#10;@param  string  $path&#10;@return boolean true if the path is in the include path.&#10;@since  0.4.2" ilk="function" line="343" lineend="356" name="isIncludable" returns="boolean" signature="boolean isIncludable(string $path)"><variable citdl="string" ilk="argument" line="343" name="path" /><variable attributes="__not_yet_defined__" line="346" name="ip" /></scope><scope doc="Loads the user's preferences from a file.&#10;&#10;The preferences are stored in the user's home directory&#10;as the file .ppurc. The file contains a serialized array&#10;of preferences for each package that has been checked for&#10;updates so far.&#10;&#10;@access protected&#10;@return boolean   true on success, false on error&#10;@since  0.4.0a1&#10;@throws PEAR_PACKAGEUPDATE_ERROR_PREFFILE_READACCESS,&#10;        PEAR_PACKAGEUPDATE_ERROR_PREFFILE_CORRUPTED" ilk="function" line="372" lineend="408" name="loadPreferences" returns="boolean" signature="boolean loadPreferences()"><variable citdl="unserialize()" line="396" name="preferences" /><variable citdl="file_get_contents()" line="393" name="contents" /><variable citdl="this.determinePrefFile()" line="375" name="prefFile" /></scope><scope doc="Returns the path to the preferences file.&#10;&#10;@access protected&#10;@return string&#10;@since  0.4.0a1" ilk="function" line="417" lineend="430" name="determinePrefFile" returns="string" signature="string determinePrefFile()"><variable citdl="PEAR_CONFIG_SYSCONFDIR" line="424" name="prefFile" /><variable line="422" name="ds" /></scope><scope doc="Checks to see if an update is available.&#10;&#10;Respects the user preferences when determining if an&#10;update is avaiable. Returns true if an update is available&#10;and the user may want to update the package.&#10;&#10;@access public&#10;@return boolean true if an update is available.&#10;@since  0.4.0a1" ilk="function" line="443" lineend="463" name="checkUpdate" returns="boolean" signature="boolean checkUpdate()" /><scope doc="Returns the latest information about the given package.&#10;&#10;@access protected&#10;@return boolean   true on success, false on error&#10;@since  0.4.0a1&#10;@throws PEAR_PACKAGEUPDATE_ERROR_NOPACKAGE,&#10;        PEAR_PACKAGEUPDATE_ERROR_NOCHANNEL,&#10;        PEAR_PACKAGEUPDATE_ERROR_NOINFO" ilk="function" line="475" lineend="538" name="getPackageInfo" returns="boolean" signature="boolean getPackageInfo()"><variable citdl="config.getRegistry()" line="497" name="reg" /><variable citdl="config.getRemote()" line="509" name="r" /><variable citdl="reg.parsePackageName()" line="500" name="parsed" /><variable citdl="r.call()" line="512" name="info" /><variable citdl="PEAR_Config" line="494" name="config" /></scope><scope doc="Returns the preferences associated with the given package.&#10;&#10;The preferences returned are an array with the folling values:&#10;- don't ask again&#10;- don't ask until next version&#10;- only ask for state x&#10;- bug/minor/major updates only&#10;&#10;@access public&#10;@return array&#10;@since  0.4.0a1" ilk="function" line="553" lineend="560" name="getPackagePreferences" returns="array" signature="array getPackagePreferences()" /><scope doc="Saves the current prefernces to the RC file.&#10;&#10;@access public&#10;@return boolean true on success, false on error&#10;@since  0.4.0a1&#10;@throws PEAR_PACKAGEUPDATE_ERROR_PREFFILE_WRITEACCESS,&#10;        PEAR_PACKAGEUPDATE_ERROR_PREFFILE_WRITEERROR" ilk="function" line="571" lineend="605" name="savePreferences" returns="boolean" signature="boolean savePreferences()"><variable citdl="serialize()" line="586" name="serialCont" /><variable citdl="fopen()" line="577" name="fp" /><variable citdl="this.determinePrefFile()" line="574" name="prefFile" /></scope><scope doc="Returns whether or not the user's preferences will allow an update to&#10;take place.&#10;&#10;The user's preferences may define restrictions such as:&#10;  - don't update&#10;  - don't ask until next version (remembers last version asked)&#10;  - only ask for state XXXX or higher&#10;  - minor or higher (no bug fix)&#10;  - major only&#10;&#10;@access public&#10;@return boolean true if the preferences will allow an update for the&#10;                latest version.&#10;@since  0.4.0a1" ilk="function" line="623" lineend="676" name="preferencesAllowUpdate" returns="boolean" signature="boolean preferencesAllowUpdate()"><variable citdl="array()" line="666" name="releases" /><variable citdl="this.getPackagePreferences()" line="626" name="prefs" /><variable citdl="array()" line="653" name="states" /></scope><scope doc="Returns the type of release. (bug|minor|major);&#10;&#10;@access protected&#10;@return string&#10;@since  0.4.0a1" ilk="function" line="685" lineend="700" name="releaseType" returns="string" signature="string releaseType()"><variable citdl="explode()" line="688" name="latest" /><variable citdl="explode()" line="689" name="current" /><variable citdl="PEAR_PACKAGEUPDATE_TYPE_MAJOR" line="692" name="type" /></scope><scope doc="Sets the user's preference for asking about all updates for this&#10;package.&#10;&#10;@access public&#10;@param  boolean $dontAsk&#10;@return boolean true on success, false on failure&#10;@since  0.4.0a1" ilk="function" line="711" lineend="718" name="setDontAskAgain" returns="boolean" signature="boolean setDontAskAgain(boolean $dontAsk)"><variable citdl="boolean" ilk="argument" line="711" name="dontAsk" /></scope><scope doc="Sets the user's preference for asking about updates again until the next&#10;release.&#10;&#10;@access public&#10;@param  boolean $nextrelease&#10;@return boolean true on success, false on failure&#10;@since  0.4.0a1&#10;@throws PEAR_PACKAGEUPDATE_ERROR_NOINFO" ilk="function" line="730" lineend="746" name="setDontAskUntilNextRelease" returns="boolean" signature="boolean setDontAskUntilNextRelease(boolean $nextrelease)"><variable citdl="boolean" ilk="argument" line="730" name="nextrelease" /></scope><scope doc="Sets the user's preference for asking about release types.&#10;&#10;@access public&#10;@param  string  $minType The minimum release type to allow.&#10;@return boolean true on success, false on failure&#10;@since  0.4.0a1&#10;@throws PEAR_PACKAGEUPDATE_ERROR_INVALIDTYPE" ilk="function" line="757" lineend="772" name="setMinimumReleaseType" returns="boolean" signature="boolean setMinimumReleaseType(string $minType)"><variable citdl="string" ilk="argument" line="757" name="minType" /></scope><scope doc="Sets the user's preference for asking about release states.&#10;&#10;@access public&#10;@param  string  $minState The minimum release state to allow.&#10;@return boolean true on success, false on failure&#10;@since  0.4.0a1&#10;@throws PEAR_PACKAGEUPDATE_ERROR_INVALIDSTATE" ilk="function" line="783" lineend="799" name="setMinimumState" returns="boolean" signature="boolean setMinimumState(string $minState)"><variable citdl="string" ilk="argument" line="783" name="minState" /></scope><scope doc="Sets the given preference to the given value.&#10;&#10;Don't take any chances. Anytime a preference is set, the preferences are&#10;saved. We can't rely on the developer to call savePreferences.&#10;&#10;@access protected&#10;@param  integer   $pref  One of the preference constants.&#10;@param  mixed     $value The value of the preference.&#10;@return boolean   true if the preference was set and saved properly.&#10;@since  0.4.0a1&#10;@throws PEAR_PACKAGEUPDATE_ERROR_INVALIDPREF" ilk="function" line="814" lineend="844" name="setPreference" returns="boolean" signature="boolean setPreference(integer $pref, mixed $value)"><variable citdl="integer" ilk="argument" line="814" name="pref" /><variable citdl="mixed" ilk="argument" line="814" name="value" /></scope><scope doc="Sets all preferences at once.&#10;&#10;@access public&#10;@param  array   $preferences&#10;@return boolean true if the preferences were set and saved.&#10;@since  0.4.0a1" ilk="function" line="854" lineend="880" name="setPreferences" returns="boolean" signature="boolean setPreferences(array $preferences)"><variable citdl="array" ilk="argument" line="854" name="preferences" /><variable line="860" name="pref" /><variable attributes="__not_yet_defined__" line="860" name="value" /></scope><scope doc="Updates the source for the package.&#10;&#10;We have to update required dependencies automatically to make sure that&#10;everything still works properly.&#10;&#10;It is the developers responsibility to make sure the user is given the&#10;option to update any optional dependencies if needed. This can be done&#10;by creating a new instance of PEAR_PackageUpdate for the optional&#10;dependency.&#10;&#10;@access public&#10;@return boolean true if the update was successful.&#10;@since  0.4.0a1&#10;@throws PEAR_PACKAGEUPDATE_ERROR_NOTINSTALLED" ilk="function" line="898" lineend="937" name="update" returns="boolean" signature="boolean update()"><variable citdl="upgrade.doInstall()" line="925" name="result" /><variable citdl="this.channel" line="922" name="channelPackage" /><variable citdl="config.get()" line="905" name="verbose" /><variable citdl="PEAR_Config" line="901" name="config" /><variable citdl="PEAR_Command.factory()" line="919" name="upgrade" /></scope><scope doc="Redirects or exits to force the user to restart the application.&#10;&#10;@abstract&#10;@access public&#10;@return void&#10;@since  0.4.0a1" ilk="function" line="947" lineend="951" name="forceRestart" signature="void forceRestart()" /><scope doc="Presents the user with the option to update.&#10;&#10;@abstract&#10;@access public&#10;@return boolean true if the user wants to update&#10;@since  0.4.0a1" ilk="function" line="961" lineend="968" name="presentUpdate" returns="boolean" signature="boolean presentUpdate()" /><scope doc="Pushes an error onto an error stack.&#10;&#10;This method is just for collecting errors that occur while checking for&#10;updates and updating a package. The child class is responsible for&#10;displaying all errors and handling them properly. This is because the&#10;way errors are handled varies greatly depending on the driver used.&#10;&#10;@access public&#10;@param int    $code      Package-specific error code&#10;@param string $level     Error level.  This is NOT spell-checked&#10;@param array  $params    associative array of error parameters&#10;@param string $msg       Error message, or a portion of it if the&#10;                         message is to be generated&#10;@param array  $repackage If this error re-packages an error pushed by&#10;                         another package, place the array returned from&#10;                         {@link pop()} in this parameter&#10;@param array  $backtrace Protected parameter: use this to pass in the&#10;                         {@link debug_backtrace()} that should be used&#10;                         to find error context&#10;@return PEAR_Error|array|Exception&#10;                         if compatibility mode is on, a PEAR_Error is&#10;                         also thrown.  If the class Exception exists,&#10;                         then one is returned.&#10;@since  0.4.0a1" ilk="function" line="996" lineend="1016" name="pushError" returns="PEAR_Error" signature="PEAR_Error pushError(int $code, string $level = 'error', array $params = array(), string $msg = false, array $repackage = false, array $backtrace = false)"><variable citdl="int" ilk="argument" line="996" name="code" /><variable citdl="string" default="'error'" ilk="argument" line="996" name="level" /><variable citdl="array" default="array()" ilk="argument" line="996" name="params" /><variable citdl="string" default="false" ilk="argument" line="996" name="msg" /><variable citdl="array" default="false" ilk="argument" line="996" name="repackage" /><variable citdl="array" default="false" ilk="argument" line="996" name="backtrace" /><variable attributes="__not_yet_defined__" line="1005" name="GLOBALS" /></scope><scope doc="Repackages PEAR_Errors for use with ErrorStack.&#10;&#10;@author Ian Eure&#10;&#10;@access public&#10;@param  object $error A PEAR_Error&#10;@return mixed  The return from PEAR::ErrorStack::push()&#10;@since  0.4.0a1" ilk="function" line="1028" lineend="1057" name="repackagePEAR_Error" returns="mixed" signature="mixed repackagePEAR_Error(object &amp; $error)"><variable citdl="object" ilk="argument" line="1028" name="error" /><variable attributes="__not_yet_defined__" citdl="array()" line="1031" name="map" /></scope><variable attributes="static" line="1030" name="map" /><scope doc="Pops an error off the error stack.&#10;&#10;This method is just for collecting errors that occur while checking for&#10;updates and updating a package. The child class is responsible for&#10;displaying all errors and handling them properly. This is because the&#10;way errors are handled varies greatly depending on the driver used.&#10;&#10;@access public&#10;@return object A PEAR_Error instance or false if no errors exist.&#10;@since  0.4.0a1" ilk="function" line="1071" lineend="1074" name="popError" returns="object" signature="object popError()" /><scope doc="Returns whether or not errors have occurred (and been captured).&#10;&#10;@access public&#10;@return boolean&#10;@since  0.4.0a1" ilk="function" line="1083" lineend="1086" name="hasErrors" returns="boolean" signature="boolean hasErrors()" /></scope></scope>