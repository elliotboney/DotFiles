="Package method to match via 'shell' pattern. Provided in global&#10;scope, because it should be called like 'preg_match' and 'eregi'&#10;and can be easily copied into other packages&#10;&#10;@author techtonik &lt;techtonik@php.net&gt;&#10;@return mixed bool on success and PEAR_Error on failure" ilk="function" line="353" lineend="393" name="File_Find_match_shell" returns="mixed" signature="mixed File_Find_match_shell($pattern, $filename)"><variable ilk="argument" line="353" name="pattern" /><variable ilk="argument" line="353" name="filename" /><variable attributes="__not_yet_defined__" citdl="_File_Find_match_shell_get_pattern()" line="363" name="negative" /><variable citdl="pattern" line="356" name="positive" /><variable citdl="substr_count()" line="357" name="negation" /><variable attributes="__not_yet_defined__" line="378" name="type" /></scope><scope doc="function used by File_Find_match_shell to convert 'shell' mask&#10;into pcre regexp. Some of the rules (see testcases for more): &#10; escaping all special chars and replacing &#10;   . with \.&#10;   * with .*&#10;   ? with .{1}&#10;   also adding ^ and $ as the pattern matches whole filename&#10;&#10;@author techtonik &lt;techtonik@php.net&gt;&#10;@return string pcre regexp for preg_match" ilk="function" line="407" lineend="476" name="_File_Find_match_shell_get_pattern" returns="string" signature="string _File_Find_match_shell_get_pattern($mask)"><variable ilk="argument" line="407" name="mask" /><variable citdl="preg_split()" line="410" name="premasks" /><variable attributes="__not_yet_defined__" line="417" name="masks" /><variable citdl="preg_replace()" line="439" name="regexmask" /><variable citdl="explode()" line="422" name="tarr" /><variable attributes="__not_yet_defined__" line="426" name="te" /><variable citdl="int" line="415" name="pi" /><variable attributes="__not_yet_defined__" line="416" name="pm" /></scope></scope>