<scope ilk="blob" lang="PHP" name="Error.php" src="/usr/local/pear/share/pear/PhpDocumentor/vendor/twig/twig/lib/Twig/Error.php"><scope classrefs="Exception" doc="Twig base exception.&#10;&#10;This exception class and its children must only be used when&#10;an error occurs during the loading of a template, when a syntax error&#10;is detected in a template, or when rendering a template. Other&#10;errors must use regular PHP exception classes (like when the template&#10;cache directory is not writable for instance).&#10;&#10;To help debugging template issues, this class tracks the original template&#10;name and line where the error occurred.&#10;&#10;Whenever possible, you must set these information (original template name&#10;and line number) yourself by passing them to the constructor. If some or all&#10;these information are not available from where you throw the exception, then&#10;this class will guess them automatically (when the line number is set to -1&#10;and/or the filename is set to null). As this is a costly operation, this&#10;can be disabled by passing false for both the filename and the line number&#10;when creating a new instance of this class.&#10;&#10;@author Fabien Potencier &lt;fabien@symfony.com&gt;" ilk="class" line="34" lineend="243" name="Twig_Error"><variable attributes="protected" citdl="lineno" line="36" name="lineno" /><variable attributes="protected" citdl="filename" line="37" name="filename" /><variable attributes="protected" citdl="message" line="38" name="rawMessage" /><variable attributes="protected" citdl="previous" line="39" name="previous" /><scope attributes="public __ctor__" doc="Constructor.&#10;&#10;Set both the line number and the filename to false to&#10;disable automatic guessing of the original template name&#10;and line number.&#10;&#10;Set the line number to -1 to enable its automatic guessing.&#10;Set the filename to null to enable its automatic guessing.&#10;&#10;By default, automatic guessing is enabled.&#10;&#10;@param string    $message  The error message&#10;@param integer   $lineno   The template line where the error occurred&#10;@param string    $filename The template file name where the error occurred&#10;@param Exception $previous The previous exception" ilk="function" line="58" lineend="77" name="__construct" signature="__construct(string $message, integer $lineno = -1, string $filename = null, Exception $previous=null)"><variable citdl="string" ilk="argument" line="58" name="message" /><variable citdl="integer" default="-1" ilk="argument" line="58" name="lineno" /><variable citdl="string" default="null" ilk="argument" line="58" name="filename" /><variable citdl="Exception" ilk="argument" line="58" name="previous" /></scope><scope attributes="public" doc="Gets the raw message.&#10;&#10;@return string The raw message" ilk="function" line="84" lineend="87" name="getRawMessage" returns="string" signature="string getRawMessage()" /><scope attributes="public" doc="Gets the filename where the error occurred.&#10;&#10;@return string The filename" ilk="function" line="94" lineend="97" name="getTemplateFile" returns="string" signature="string getTemplateFile()" /><scope attributes="public" doc="Sets the filename where the error occurred.&#10;&#10;@param string $filename The filename" ilk="function" line="104" lineend="109" name="setTemplateFile" signature="setTemplateFile(string $filename)"><variable citdl="string" ilk="argument" line="104" name="filename" /></scope><scope attributes="public" doc="Gets the template line where the error occurred.&#10;&#10;@return integer The template line" ilk="function" line="116" lineend="119" name="getTemplateLine" returns="integer" signature="integer getTemplateLine()" /><scope attributes="public" doc="Sets the template line where the error occurred.&#10;&#10;@param integer $lineno The template line" ilk="function" line="126" lineend="131" name="setTemplateLine" signature="setTemplateLine(integer $lineno)"><variable citdl="integer" ilk="argument" line="126" name="lineno" /></scope><scope attributes="public" ilk="function" line="133" lineend="137" name="guess" signature="guess()" /><scope attributes="public" doc="For PHP &lt; 5.3.0, provides access to the getPrevious() method.&#10;&#10;@param string $method    The method name&#10;@param array  $arguments The parameters to be passed to the method&#10;&#10;@return Exception The previous exception or null&#10;&#10;@throws BadMethodCallException" ilk="function" line="149" lineend="156" name="__call" returns="Exception" signature="Exception __call(string $method, array $arguments)"><variable citdl="string" ilk="argument" line="149" name="method" /><variable citdl="array" ilk="argument" line="149" name="arguments" /></scope><scope attributes="protected" ilk="function" line="158" lineend="184" name="updateRepr" signature="updateRepr()"><variable citdl="boolean" line="162" name="dot" /><variable citdl="sprintf()" line="170" name="filename" /></scope><variable citdl="this.rawMessage" line="160" name="message" /><scope attributes="protected" ilk="function" line="186" lineend="242" name="guessTemplateInfo" signature="guessTemplateInfo()"><variable citdl="r.getFileName()" line="218" name="file" /><variable citdl="get_class()" line="199" name="currentClass" /><variable citdl="array()" line="220" name="exceptions" /><variable line="232" name="codeLine" /><variable attributes="__not_yet_defined__" line="221" name="e" /><variable attributes="__not_yet_defined__" line="197" name="trace" /><variable citdl="e.getTrace()" line="226" name="traces" /><variable attributes="__not_yet_defined__" line="232" name="templateLine" /><variable citdl="ReflectionObject" line="217" name="r" /><variable citdl="int" line="200" name="isEmbedContainer" /><variable citdl="trace" line="188" name="template" /><variable citdl="debug_backtrace()" line="192" name="backtrace" /><variable citdl="get_class()" line="189" name="templateClass" /></scope></scope></scope>