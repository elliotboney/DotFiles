<scope ilk="blob" lang="PHP" name="UnifiedAssetInstaller.php" src="/usr/local/pear/share/pear/PhpDocumentor/vendor/phpdocumentor/unified-asset-installer/src/phpDocumentor/Composer/UnifiedAssetInstaller.php"><scope doc="phpDocumentor&#10;&#10;PHP Version 5&#10;&#10;@copyright 2010-2013 Mike van Riel / Naenius (http://www.naenius.com)&#10;@license   http://www.opensource.org/licenses/mit-license.php MIT&#10;@link      http://phpdoc.org" ilk="namespace" line="12" name="phpDocumentor\Composer"><import line="14" module="Composer\Installer" symbol="LibraryInstaller" /><import line="15" module="Composer\Package" symbol="PackageInterface" /><scope classrefs="LibraryInstaller" ilk="class" line="17" lineend="92" name="UnifiedAssetInstaller"><scope attributes="public" doc="Determines the install path for templates,&#10;&#10;The installation path is determined by checking whether the package is included in another composer configuration&#10;or installed as part of the normal phpDocumentor installation.&#10;&#10;When the package is included as part of a different project it will be installed in the `data/templates` folder&#10;of phpDocumentor (thus `/phpdocumentor/phpdocumentor/data/templates`); if it is installed as part of&#10;phpDocumentor it will be installed in the root of the project (thus `/data/templates`).&#10;&#10;@param PackageInterface $package&#10;&#10;@throws \InvalidArgumentException if the name of the package does not start with `phpdocumentor/template-`.&#10;&#10;@return string a path relative to the root of the composer.json that is being installed." ilk="function" line="35" lineend="45" name="getInstallPath" returns="string" signature="string getInstallPath(PackageInterface $package)"><variable citdl="PackageInterface" ilk="argument" line="35" name="package" /></scope><scope attributes="protected" doc="Extract the first 23 characters of the package name; which is expected to be the prefix.&#10;&#10;@param PackageInterface $package&#10;&#10;@return string" ilk="function" line="54" lineend="57" name="extractPrefix" returns="string" signature="string extractPrefix(PackageInterface $package)"><variable citdl="PackageInterface" ilk="argument" line="54" name="package" /></scope><scope attributes="protected" doc="Extract the everything after the first 23 characters of the package name; which is expected to be the short name.&#10;&#10;@param PackageInterface $package&#10;&#10;@return string" ilk="function" line="66" lineend="69" name="extractShortName" returns="string" signature="string extractShortName(PackageInterface $package)"><variable citdl="PackageInterface" ilk="argument" line="66" name="package" /></scope><scope attributes="protected" doc="Returns the root installation path for templates.&#10;&#10;@return string a path relative to the root of the composer.json that is being installed where the templates&#10;    are stored." ilk="function" line="77" lineend="83" name="getTemplateRootPath" returns="string" signature="string getTemplateRootPath()" /><scope attributes="public" doc="{@inheritDoc}" ilk="function" line="88" lineend="91" name="supports" returns="boolean" signature="supports($packageType)"><variable ilk="argument" line="88" name="packageType" /></scope></scope></scope></scope>