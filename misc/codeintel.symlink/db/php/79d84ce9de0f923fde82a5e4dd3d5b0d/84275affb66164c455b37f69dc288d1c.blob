 citdl="array" doc="An array of directories searched for plugins.&#10;&#10;@var array" line="105" name="plugins_dir" /><variable citdl="boolean" doc="If debugging is enabled, a debug console window will display&#10;when the page loads (make sure your browser allows unrequested&#10;popup windows)&#10;&#10;@var boolean" line="114" name="debugging" /><variable citdl="string" doc="This is the path to the debug console template. If not set,&#10;the default one will be used.&#10;&#10;@var string" line="122" name="debug_tpl" /><variable citdl="string" doc="This determines if debugging is enable-able from the browser.&#10;&lt;ul&gt;&#10; &lt;li&gt;NONE =&gt; no debugging control allowed&lt;/li&gt;&#10; &lt;li&gt;URL =&gt; enable debugging when SMARTY_DEBUG is found in the URL.&lt;/li&gt;&#10;&lt;/ul&gt;&#10;@link http://www.foo.dom/index.php?SMARTY_DEBUG&#10;@var string" line="133" name="debugging_ctrl" /><variable citdl="boolean" doc="This tells Smarty whether to check for recompiling or not. Recompiling&#10;does not need to happen unless a template or config file is changed.&#10;Typically you enable this during development, and disable for&#10;production.&#10;&#10;@var boolean" line="143" name="compile_check" /><variable citdl="boolean" doc="This forces templates to compile every time. Useful for development&#10;or debugging.&#10;&#10;@var boolean" line="151" name="force_compile" /><variable citdl="integer" doc="This enables template caching.&#10;&lt;ul&gt;&#10; &lt;li&gt;0 = no caching&lt;/li&gt;&#10; &lt;li&gt;1 = use class cache_lifetime value&lt;/li&gt;&#10; &lt;li&gt;2 = use cache_lifetime in cache file&lt;/li&gt;&#10;&lt;/ul&gt;&#10;@var integer" line="162" name="caching" /><variable citdl="string" doc="The name of the directory for cache files.&#10;&#10;@var string" line="169" name="cache_dir" /><variable citdl="integer" doc="This is the number of seconds cached content will persist.&#10;&lt;ul&gt;&#10; &lt;li&gt;0 = always regenerate cache&lt;/li&gt;&#10; &lt;li&gt;-1 = never expires&lt;/li&gt;&#10;&lt;/ul&gt;&#10;&#10;@var integer" line="180" name="cache_lifetime" /><variable citdl="boolean" doc="Only used when $caching is enabled. If true, then If-Modified-Since headers&#10;are respected with cached content, and appropriate HTTP headers are sent.&#10;This way repeated hits to a cached page do not send the entire page to the&#10;client every time.&#10;&#10;@var boolean" line="190" name="cache_modified_check" /><variable citdl="integer" doc="This determines how Smarty handles &quot;&lt;?php ... ?&gt;&quot; tags in templates.&#10;possible values:&#10;&lt;ul&gt;&#10; &lt;li&gt;SMARTY_PHP_PASSTHRU -&gt; print tags as plain text&lt;/li&gt;&#10; &lt;li&gt;SMARTY_PHP_QUOTE    -&gt; escape tags as entities&lt;/li&gt;&#10; &lt;li&gt;SMARTY_PHP_REMOVE   -&gt; remove php tags&lt;/li&gt;&#10; &lt;li&gt;SMARTY_PHP_ALLOW    -&gt; execute php tags&lt;/li&gt;&#10;&lt;/ul&gt;&#10;&#10;@var integer" line="204" name="php_handling" /><variable citdl="boolean" doc="This enables template security. When enabled, many things are restricted&#10;in the templates that normally would go unchecked. This is useful when&#10;untrusted parties are editing templates and you want a reasonable level&#10;of security. (no direct execution of PHP in templates for example)&#10;&#10;@var boolean" line="214" name="security" /><variable citdl="array" doc="This is the list of template directories that are considered secure. This&#10;is used only if {@link $security} is enabled. One directory per array&#10;element.  {@link $template_dir} is in this list implicitly.&#10;&#10;@var array" line="223" name="secure_dir" /><variable citdl="array" doc="These are the security settings for Smarty. They are used only when&#10;{@link $security} is enabled.&#10;&#10;@var array" line="242" name="security_settings" /><variable citdl="array" doc="This is an array of directories where trusted php scripts reside.&#10;{@link $security} is disabled during their inclusion/execution.&#10;&