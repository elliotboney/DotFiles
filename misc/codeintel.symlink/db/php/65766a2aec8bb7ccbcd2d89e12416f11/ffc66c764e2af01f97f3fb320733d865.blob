ion Path to the destination file.&#10;@param bool   $overwrite   Optional. Whether to overwrite the destination file if it exists.&#10;                           Default false.&#10;@param int    $mode        Optional. The permissions as octal number, usually 0644 for files, 0755 for dirs.&#10;                           Default false.&#10;@return bool True if file copied successfully, False otherwise." ilk="function" line="553" lineend="555" name="copy" returns="bool" signature="bool copy(string $source, string $destination, bool $overwrite = false, int $mode = false)"><variable citdl="string" ilk="argument" line="553" name="source" /><variable citdl="string" ilk="argument" line="553" name="destination" /><variable citdl="bool" default="false" ilk="argument" line="553" name="overwrite" /><variable citdl="int" default="false" ilk="argument" line="553" name="mode" /></scope><scope doc="Move a file.&#10;&#10;@since 2.5.0&#10;&#10;@param string $source      Path to the source file.&#10;@param string $destination Path to the destination file.&#10;@param bool   $overwrite   Optional. Whether to overwrite the destination file if it exists.&#10;                           Default false.&#10;@return bool True if file copied successfully, False otherwise." ilk="function" line="568" lineend="570" name="move" returns="bool" signature="bool move(string $source, string $destination, bool $overwrite = false)"><variable citdl="string" ilk="argument" line="568" name="source" /><variable citdl="string" ilk="argument" line="568" name="destination" /><variable citdl="bool" default="false" ilk="argument" line="568" name="overwrite" /></scope><scope doc="Delete a file or directory.&#10;&#10;@since 2.5.0&#10;&#10;@param string $file      Path to the file.&#10;@param bool   $recursive Optional. If set True changes file group recursively. Defaults to False.&#10;                         Default false.&#10;@param bool   $type      Type of resource. 'f' for file, 'd' for directory.&#10;         