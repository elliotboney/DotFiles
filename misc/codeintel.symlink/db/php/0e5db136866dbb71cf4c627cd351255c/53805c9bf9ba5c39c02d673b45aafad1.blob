<scope ilk="blob" lang="PHP" name="module.tag.xmp.php" src="/private/var/www/paperless/wp-content/old-plugins/podpress/getid3/module.tag.xmp.php"><scope doc="************************************************************************************************&#10; SWISScenter Source                                                              Nigel Barnes&#10;&#10; 	Provides functions for reading information from the 'APP1' Extensible Metadata&#10;	Platform (XMP) segment of JPEG format files.&#10;	This XMP segment is XML based and contains the Resource Description Framework (RDF)&#10;	data, which itself can contain the Dublin Core Metadata Initiative (DCMI) information.&#10;&#10; 	This code uses segments from the JPEG Metadata Toolkit project by Evan Hunter.&#10;***********************************************************************************************" ilk="class" line="33" lineend="422" name="Image_XMP"><variable citdl="string" doc="@var string&#10;The name of the image file that contains the XMP fields to extract and modify.&#10;@see Image_XMP()" line="40" name="_sFilename" /><variable citdl="array" doc="@var array&#10;The XMP fields that were extracted from the image or updated by this class.&#10;@see getAllTags()" line="47" name="_aXMP" /><variable citdl="boolean" doc="@var boolean&#10;True if an APP1 segment was found to contain XMP metadata.&#10;@see isValid()" line="54" name="_bXMPParse" /><scope doc="Returns the status of XMP parsing during instantiation&#10;&#10;You'll normally want to call this method before trying to get XMP fields.&#10;&#10;@return boolean&#10;Returns true if an APP1 segment was found to contain XMP metadata." ilk="function" line="64" lineend="67" name="isValid" returns="boolean" signature="boolean isValid()" /><scope doc="Get a copy of all XMP tags extracted from the image&#10;&#10;@return array - An array of XMP fields as it extracted by the XMPparse() function" ilk="function" line="74" lineend="77" name="getAllTags" returns="array" si