<scope ilk="blob" lang="PHP" name="Loader.php" src="/usr/local/pear/share/pear/PhpDocumentor/vendor/twig/twig/lib/Twig/Error/Loader.php"><scope classrefs="Twig_Error" doc="Exception thrown when an error occurs during template loading.&#10;&#10;Automatic template information guessing is always turned off as&#10;if a template cannot be loaded, there is nothing to guess.&#10;However, when a template is loaded from another one, then, we need&#10;to find the current context and this is automatically done by&#10;Twig_Template::displayWithErrorHandling().&#10;&#10;This strategy makes Twig_Environment::resolveTemplate() much faster.&#10;&#10;@author Fabien Potencier &lt;fabien@symfony.com&gt;" ilk="class" line="25" lineend="31" name="Twig_Error_Loader"><scope attributes="public __ctor__" ilk="function" line="27" lineend="30" name="__construct" signature="__construct($message, $lineno = -1, $filename = null, Exception $previous=null)"><variable ilk="argument" line="27" name="message" /><variable default="-1" ilk="argument" line="27" name="lineno" /><variable default="null" ilk="argument" line="27" name="filename" /><variable citdl="Exception" ilk="argument" line="27" name="previous" /></scope></scope></scope>