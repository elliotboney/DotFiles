<scope ilk="blob" lang="PHP" name="Batch.php" src="/usr/local/Cellar/php55/5.5.7/lib/php/PHP/Beautifier/Batch.php"><import line="26" module="Decorator.php" /><import line="30" module="Batch/Output.php" /><scope classrefs="PHP_Beautifier_Decorator" doc="Adds functionality to handle multiple files.&#10;- STDIN  : As normal&#10;- STDOUT : Send all the scripts, prepended with the name of the original route&#10;- One in, one out: as normal&#10;- Multiple In, one out: determine the type of out.&#10;  - Without '/' at the end, same as STDOUT.&#10;  - With '/' at the end, copy the base structure and copy all the scripts&#10;&#10;You must define an input file. By default, the output is &quot;./&quot;, so the saving&#10;of files will be done on the directory of your command prompt.&#10;&#10;If the file out end in .tgz, the output will be a tar archive. The same action&#10;will be obtained with {@link setCompress()} to true&#10;Use:&#10;&lt;code&gt;&#10;require &quot;PHP/Beautifier.php&quot;;&#10;require &quot;PHP/Beautifier/Batch.php&quot;;&#10;$oBeaut= new PHP_Beautifier();&#10;$oBatch= new PHP_Beautifier_Batch($oBeaut); // Decorator&#10;$oBatch-&gt;setInputFile(__FILE__);&#10;$oBatch-&gt;setOutputFile(dirname(__FILE__).&quot;/beautified/&quot;);&#10;$oBatch-&gt;process();&#10;$oBatch-&gt;save();&#10;&lt;/code&gt;&#10;&#10;@category     PHP&#10;@package      PHP_Beautifier&#10;@subpackage   Batch&#10;@author       Claudio Bustos &lt;cdx@users.sourceforge.com&gt;&#10;@copyright    2004-2006 Claudio Bustos&#10;@link         http://pear.php.net/package/PHP_Beautifier&#10;@link         http://beautifyphp.sourceforge.net&#10;@license      http://www.php.net/license/3_0.txt  PHP License 3.0&#10;@version      Release: 0.1.15" ilk="class" line="70" lineend="311" name="PHP_Beautifier_Batch"><variable attributes="private" citdl="string" doc="Compression method (for now, false, 'gz' and 'bz2')&#10;@var string" line="75" name="sCompress" /><variable attributes="private" citdl="array" doc="Array or STDIN of paths to parse&#10;@var array" line="80" name="mPreInputFiles" /><variable attributes="private" citdl="string" line="84" name="sPreOutputFile" /><variable attributes="private" citdl="PHP_Beautifier_Batch_Output" doc="@var PHP_Beautifier_Batch_Output" line="88" name="oBatchOutput" /><variable attributes="private" citdl="array" doc="@var array    PHP_Beautifier_Batch_Input" line="92" name="aBatchInputs" /><variable attributes="public" line="93" name="mInputFiles" /><variable attributes="private" citdl="PHP_Beautifier_Batch.FILES" line="98" name="sOutputMode" /><variable citdl="string" ilk="constant" line="99" name="FILES" /><variable citdl="string" ilk="constant" line="100" name="DIRECTORY" /><variable attributes="public" citdl="bool" doc="Recursive search on dirs&#10;@var bool" line="105" name="bRecursive" /><scope attributes="public" doc="Set recursive search for files in dirs on&#10;@param bool" ilk="function" line="112" lineend="115" name="setRecursive" signature="setRecursive($bRecursive = true)"><variable default="true" ilk="argument" line="112" name="bRecursive" /></scope><scope attributes="public" doc="Set compression on/off&#10;@param mixed bool(false, true for gzip) or string ('gz' or 'gz2')" ilk="function" line="120" lineend="130" name="setCompress" signature="setCompress($mCompress = true)"><variable default="true" ilk="argument" line="120" name="mCompress" /></scope><scope attributes="public" doc="Set the input(s) files&#10;Could be STDIN or a name, with special chars (?,*)&#10;@param mixed STDIN or string(path)&#10;@return bool" ilk="function" line="137" lineend="153" name="setInputFile" returns="bool" signature="bool setInputFile($mFiles)"><variable ilk="argument" line="137" name="mFiles" /><variable line="139" name="bCli" /></scope><scope attributes="public" doc="Set the output file&#10;Could be STDOUT or a path to a file or dir (with '/' at the end)&#10;@param mixed STDOUT or string (path)&#10;@return true" ilk="function" line="16