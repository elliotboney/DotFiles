<scope ilk="blob" lang="PHP" name="Filter.php" src="/usr/local/Cellar/php55/5.5.7/lib/php/PHP/Beautifier/Filter.php"><scope attributes="abstract" doc="PHP_Beautifier_Filter&#10;&#10;Definition for creation of Filters&#10;For concrete details, please see {@link PHP_Beautifier_Filter_Default}&#10;@category     PHP&#10;@package      PHP_Beautifier&#10;@subpackage   Filter&#10;@tutorial     PHP_Beautifier/Filter/Filter.create.pkg&#10;@author       Claudio Bustos &lt;cdx@users.sourceforge.com&gt;&#10;@copyright    2004-2006 Claudio Bustos&#10;@link         http://pear.php.net/package/PHP_Beautifier&#10;@link         http://beautifyphp.sourceforge.net&#10;@license      http://www.php.net/license/3_0.txt  PHP License 3.0&#10;@version      Release: 0.1.15" ilk="class" line="38" lineend="256" name="PHP_Beautifier_Filter"><variable attributes="protected" citdl="PHP_Beautifier" doc="Stores a reference to main PHP_Beautifier&#10;@var PHP_Beautifier" line="44" name="oBeaut" /><variable attributes="protected" citdl="array" doc="Associative array of functions to use when some token are found&#10;@var array" line="49" name="aFilterTokenFunctions" /><variable attributes="protected" citdl="array" doc="Settings for the Filter&#10;@var array" line="54" name="aSettings" /><variable attributes="protected" citdl="array" doc="Definition of the settings&#10;Should be an associative array. The keys are the names of settings&#10;and the values are an array with the keys 'type' and '&#10;@var array" line="61" name="aSettingsDefinition" /><variable attributes="protected" citdl="string" doc="Description of the Filter&#10;@var string" line="66" name="sDescription" /><variable citdl="string" ilk="constant" line="71" name="BYPASS" /><variable attributes="protected" citdl="bool" doc="Switch to 'turn' on and off the filter&#10;@var bool" line="76" name="bOn" /><variable attributes="protected" citdl="boolean" line="80" name="aToken" /><scope attributes="public __ctor__" doc="Constructor&#10;If you need to overload this (for example, to create a&#10;definition for setting with {@link addSettingDefinition()}&#10;remember call the parent constructor.&#10;&lt;code&gt;&#10;parent::__construct($oBeaut, $aSettings)&#10;&lt;/code&gt;&#10;@param PHP_Beautifier&#10;@param array settings for the Filter" ilk="function" line="92" lineend="98" name="__construct" signature="__construct(PHP_Beautifier $oBeaut, $aSettings = array())"><variable citdl="PHP_Beautifier" ilk="argument" line="92" name="oBeaut" /><variable default="array()" ilk="argument" line="92" name="aSettings" /></scope><scope attributes="protected" doc="Add a setting definition&#10;@param string" ilk="function" line="103" lineend="109" name="addSettingDefinition" signature="addSettingDefinition($sSetting, $sType, $sDescription)"><variable ilk="argument" line="103" name="sSetting" /><variable ilk="argument" line="103" name="sType" /><variable ilk="argument" line="103" name="sDescription" /></scope><scope attributes="public" doc="return @string" ilk="function" line="113" lineend="116" name="getName" returns="str_ireplace()" signature="getName()" /><scope attributes="final public" doc="Turn on the Filter&#10;Use inside the code to beautify&#10;Ex.&#10;&lt;code&gt;&#10;...some code...&#10;// ArrayNested-&gt;on()&#10;...other code ...&#10;&lt;/code&gt;" ilk="function" line="127" lineend="130" name="on" signature="on()" /><scope attributes="public" doc="Turn off the Filter&#10;Use inside the code to beautify&#10;Ex.&#10;&lt;code&gt;&#10;...some code...&#10;// ArrayNested-&gt;off()&#10;...other code ...&#10;&lt;/code&gt;" ilk="function" line="141" lineend="144" name="off" signature="off()" /><scope attributes="final public" doc="Get a setting of the Filter&#10;@param string name of setting&#10;@return mixed value of setting or false" ilk="function" line="150" lineend="153" name="getSetting" returns="mixed" signature="mixed getSetting($sSetting)"><variable ilk="argument" line="150" name="sSetting" /></scope><scope attributes="final public" doc="Set a value of a Setting&#10;@param string name of setting&#10;@param mixed value of setting" ilk="function" line="159" lineend="164" name="setSetting" signature="setSetting($sSetting, $sValue)"><variable ilk="argument" line="159" name="sSetting" /><variable ilk="argument" line="159" name="sValue" /></scope><scope attributes="public" doc="Function called from {@link PHP_Beautifier::process()} to process the tokens.&#10;&#10;If the received token is one of the keys of {@link $aFilterTokenFunctions}&#10;a function with the same name of the value of that key is called.&#10;If the method doesn't exists, {@link __call()} is called, and return&#10;{@link PHP_Beautifier_Filter::BYPASS}. PHP_Beautifier, now, call the next Filter is its list.&#10;If the method exists, it can return true or {@link PHP_Beautifier_Filter::BYPASS}.&#10;@param array token&#10;@return bool true if the token is processed, false bypass to the next Filter&#10;@see PHP_Beautifier::process()" ilk="function" line="177" lineend="204" name="handleToken" returns="bool" signature="bool handleToken($token)"><variable ilk="argument" line="177" name="token" /><variable citdl="token" line="190" name="sValue" /><variable citdl="sValue" line="183" name="sMethod" /></scope><scope attributes="public" doc="@param string metodo&#10;@param array arguments&#10;@return mixed null or {@link PHP_Beautifier_Filter::BYPASS}" ilk="function" line="210" lineend="213" name="__call" returns="mixed" signature="mixed __call($sMethod, $aArgs)"><variable ilk="argument" line="210" name="sMethod" /><variable ilk="argument" line="210" name="aArgs" /></scope><scope attributes="public" doc="Called from {@link PHP_Beautifier::process()} at the beginning&#10;of the processing&#10;@return void" ilk="function" line="219" lineend="221" name="preProcess" signature="void preProcess()" /><scope attributes="public" doc="Called from {@link PHP_Beautifier::process()} at the end of processing&#10;The post-process must be made in {@link PHP_Beautifier::$aOut}&#10;@return void" ilk="function" line="227" lineend="229" name="postProcess" signature="void postProcess()" /><scope attributes="public" ilk="function" line="230" lineend="235" name="__sleep" returns="array()" signature="__sleep()" /><scope attributes="public" ilk="function" line="236" lineend="239" name="getDescription" returns="this.sDescription" signature="getDescription()" /><scope attributes="public" ilk="function" line="240" lineend="255" name="__toString" returns="sOut" signature="__toString()"><variable citdl="string" line="244" name="sOut" /><variable attributes="__not_yet_defined__" line="249" name="aSettings" /><variable line="249" name="sSetting" /></scope></scope></scope>