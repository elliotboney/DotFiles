<scope ilk="blob" lang="PHP" name="Collection.php" src="/usr/local/pear/share/pear/PhpDocumentor/src/phpDocumentor/Descriptor/Collection.php"><scope doc="phpDocumentor&#10;&#10;PHP Version 5.3&#10;&#10;@copyright 2010-2013 Mike van Riel / Naenius (http://www.naenius.com)&#10;@license   http://www.opensource.org/licenses/mit-license.php MIT&#10;@link      http://phpdoc.org" ilk="namespace" line="12" name="phpDocumentor\Descriptor"><scope doc="Represents an easily accessible collection of elements.&#10;&#10;The goal for this class is to allow Descriptors to be easily retrieved and set so that interaction in&#10;templates becomes easier." ilk="class" interfacerefs="\Countable \IteratorAggregate \ArrayAccess" line="20" lineend="199" name="Collection"><variable attributes="protected" citdl="array()" doc="@var mixed[] $items" line="23" name="items" /><scope attributes="public __ctor__" doc="Constructs a new collection object with optionally a series of items, generally Descriptors.&#10;&#10;@param DescriptorAbstract[]|mixed[] $items" ilk="function" line="30" lineend="33" name="__construct" signature="__construct($items = array())"><variable default="array()" ilk="argument" line="30" name="items" /></scope><scope attributes="public" doc="Adds a new item to this collection, generally a Descriptor.&#10;&#10;@param DescriptorAbstract|mixed $item&#10;&#10;@return void" ilk="function" line="42" lineend="45" name="add" signature="void add($item)"><variable ilk="argument" line="42" name="item" /></scope><scope attributes="public" doc="Sets a new object onto the collection or clear it using null.&#10;&#10;@param string|integer                $index An index value to recognize this item with.&#10;@param DescriptorAbstract|mixed|null $item  The item to store, generally a Descriptor but may be something else.&#10;&#10;@return void" ilk="function" line="55" lineend="58" name="set" signature="void set($index, $item)"><variable ilk="argument" line="55" name="index" /><variable ilk="argument" line="55" name="item" /></scope><scope attributes="public" doc="Retrieves a specific item from the Collection with its index.&#10;&#10;Please note that this method (intentionally) has the side effect that whenever a key does not exist that it will&#10;be created with the value provided by the $valueIfEmpty argument. This will allow for easy initialization during&#10;tree building operations.&#10;&#10;@param string|integer $index&#10;@param mixed          $valueIfEmpty If the index does not exist it will be created with this value and returned.&#10;&#10;@return mixed The contents of the element with the given index and the provided default if the key doesn't exist." ilk="function" line="72" lineend="79" name="get" returns="mixed" signature="mixed get($index, mixed $valueIfEmpty = null)"><variable ilk="argument" line="72" name="index" /><variable citdl="mixed" default="null" ilk="argument" line="72" name="valueIfEmpty" /></scope><scope attributes="public" doc="Retrieves all items from this collection as PHP Array.&#10;&#10;@return mixed[]" ilk="function" line="86" lineend="89" name="getAll" returns="mixed" signature="mixed getAll()" /><scope attributes="public" doc="Retrieves an iterator to traverse this object.&#10;&#10;@return \Traversable|\ArrayIterator" ilk="function" line="96" lineend="99" name="getIterator" returns="\Traversable" signature="\Traversable getIterator()" /><scope attributes="public" doc="Returns a count of the number of elements in this collection.&#10;&#10;@return integer" ilk="function" line="106" lineend="109" name="count" returns="integer" signature="integer count()" /><scope attributes="public" doc="Empties the collection.&#10;&#10;@return void" ilk="function" line="116" lineend="119" name="clear" signature="void clear()" /><scope attributes="public" doc="Retrieves an item as if it were a property of the collection.&#10;&#10;@param string $name&#10;&#10;@return mixed" ilk="function" line="128" lineend="131" name="__get" returns="mixed" signature="mixed __get(string $name)"><variable citdl="string" ilk="argument" line="128" name="name" /></scope><scope attributes="public" doc="Checks whether an item in this collection exists.&#10;&#10;@param string|integer $offset The index to check on.&#10;&#10;@return boolean" ilk="function" line="140" lineend="143" name="offsetExists" returns="boolean" signature="boolean offsetExists($offset)"><variable ilk="argument" line="140" name="offset" /></scope><scope attributes="public" doc="Retrieves an item from the collection with the given index.&#10;&#10;@param string|integer $offset The offset to retrieve.&#10;&#10;@return mixed" ilk="function" line="152" lineend="155" name="offsetGet" returns="mixed" signature="mixed offsetGet($offset)"><variable ilk="argument" line="152" name="offset" /></scope><scope attributes="public" doc="Sets an item at the given index.&#10;&#10;@param string|integer $offset The offset to assign the value to.&#10;@param mixed          $value  The value to set.&#10;&#10;@throws \InvalidArgumentException if the key is null or an empty string.&#10;&#10;@return void" ilk="function" line="167" lineend="174" name="offsetSet" signature="void offsetSet($offset, mixed $value)"><variable ilk="argument" line="167" name="offset" /><variable citdl="mixed" ilk="argument" line="167" name="value" /></scope><scope attributes="public" doc="Removes an item with the given index from the collection.&#10;&#10;@param string|integer $offset The offset to unset.&#10;&#10;@return void" ilk="function" line="183" lineend="186" name="offsetUnset" signature="void offsetUnset($offset)"><variable ilk="argument" line="183" name="offset" /></scope><scope attributes="public" doc="Returns a new collection with the items from this collection and the provided combined.&#10;&#10;@param Collection $collection&#10;&#10;@return Collection" ilk="function" line="195" lineend="198" name="merge" returns="Collection" signature="Collection merge(Collection $collection)"><variable citdl="Collection" ilk="argument" line="195" name="collection" /></scope></scope></scope></scope>