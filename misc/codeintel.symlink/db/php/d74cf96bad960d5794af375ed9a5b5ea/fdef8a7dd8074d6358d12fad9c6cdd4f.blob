/><variable line="213" name="file" /><variable attributes="__not_yet_defined__" line="254" name="_GET" /><variable citdl="get_site_transient()" line="211" name="update_plugins" /><variable citdl="boolean" line="208" name="url" /><variable citdl="plugin.new_version" line="217" name="version" /></scope><scope doc="Display plugin information in dialog box form.&#10;&#10;@since 2.7.0" ilk="function" line="265" lineend="406" name="install_plugin_information" signature="install_plugin_information()"><variable line="395" name="display" /><variable citdl="plugins_api()" line="268" name="api" /><variable citdl="add_query_arg()" line="314" name="href" /><variable citdl="esc_attr()" line="316" name="san_section" /><variable attributes="__not_yet_defined__" line="294" name="key" /><variable attributes="__not_yet_defined__" line="266" name="tab" /><variable citdl="install_plugin_install_status()" line="326" name="status" /><variable line="292" name="section_name" /><variable line="300" name="section_titles" /><variable attributes="__not_yet_defined__" citdl="links_add_base_url()" line="292" name="content" /><variable citdl="array()" line="280" name="plugins_allowedtags" /><variable line="299" name="section" /><variable line="308" name="title" /><variable citdl="array()" line="289" name="plugins_section_titles" /><variable line="313" name="class" /><variable attributes="__not_yet_defined__" line="377" name="GLOBALS" /></scope></scope>