ng:&#10;    remove_action( 'admin_enqueue_scripts', array( 'WP_Internal_Pointers', 'enqueue_scripts' ) );&#10;&#10;Individual pointers (e.g. wp330_toolbar) can be disabled using the following:&#10;    remove_action( 'admin_print_footer_scripts', array( 'WP_Internal_Pointers', 'pointer_wp330_toolbar' ) );" ilk="function" line="1728" lineend="1780" name="enqueue_scripts" signature="enqueue_scripts($hook_suffix)"><variable ilk="argument" line="1728" name="hook_suffix" /><variable citdl="boolean" line="1760" name="got_pointers" /><variable citdl="explode()" line="1758" name="dismissed" /><variable attributes="__not_yet_defined__" line="1763" name="cap" /><variable citdl="array()" line="1748" name="pointers" /><variable citdl="array()" line="1742" name="registered_pointers" /><variable citdl="array()" line="1755" name="caps_required" /><variable attributes="__not_yet_defined__" line="1761" name="pointer" /></scope><scope attributes="private static" doc="Print the pointer javascript data.&#10;&#10;@since 3.3.0&#10;&#10;@param string $pointer_id The pointer ID.&#10;@param string $selector The HTML elements, on which the pointer should be attached.&#10;@param array  $args Arguments to be passed to the pointer JS (see wp-pointer.js)." ilk="function" line="1791" lineend="1826" name="print_js" signature="print_js(string $pointer_id, string $selector, array $args)"><variable citdl="string" ilk="argument" line="1791" name="pointer_id" /><variable citdl="string" ilk="argument" line="1791" name="selector" /><variable citdl="array" ilk="argument" line="1791" name="args" /></scope><scope attributes="public static" ilk="function" line="1828" lineend="1839" name="pointer_wp330_toolbar" signature="pointer_wp330_toolbar()"><variable citdl="string" line="1829" name="content" /></scope><scope attributes="public static" doc="Print 'Updated Media Uploader' for 3.3.0.&#10;&#10;@since 3.3.0" ilk="function" line="1846" lineend="1846" name="pointer_wp330_media_uploader" signature="pointer_wp330