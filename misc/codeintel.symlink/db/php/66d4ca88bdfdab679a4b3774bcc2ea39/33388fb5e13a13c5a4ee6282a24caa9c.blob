<scope ilk="blob" lang="PHP" name="Memcache.php" src="/private/var/www/kw/wp-includes/SimplePie/Cache/Memcache.php"><scope doc="Caches data to memcache&#10;&#10;Registered for URLs with the &quot;memcache&quot; protocol&#10;&#10;For example, `memcache://localhost:11211/?timeout=3600&amp;prefix=sp_` will&#10;connect to memcache on `localhost` on port 11211. All tables will be&#10;prefixed with `sp_` and data will expire after 3600 seconds&#10;&#10;@package SimplePie&#10;@subpackage Caching&#10;@uses Memcache" ilk="class" interfacerefs="SimplePie_Cache_Base" line="58" lineend="183" name="SimplePie_Cache_Memcache"><variable attributes="protected" citdl="Memcache" doc="Memcache instance&#10;&#10;@var Memcache" line="65" name="cache" /><variable attributes="protected" citdl="array" doc="Options&#10;&#10;@var array" line="72" name="options" /><variable attributes="protected" citdl="string" doc="Cache name&#10;&#10;@var string" line="79" name="name" /><scope attributes="public __ctor__" doc="Create a new cache object&#10;&#10;@param string $location Location string (from SimplePie::$cache_location)&#10;@param string $name Unique ID for the cache&#10;@param string $type Either TYPE_FEED for SimplePie data, or TYPE_IMAGE for image data" ilk="function" line="88" lineend="106" name="__construct" signature="__construct(string $location, string $name, string $type)"><variable citdl="string" ilk="argument" line="88" name="location" /><variable citdl="string" ilk="argument" line="88" name="name" /><variable citdl="string" ilk="argument" line="88" name="type" /><variable citdl="SimplePie_Cache.parse_URL()" line="98" name="parsed" /></scope><scope attributes="public" doc="Save data to the cache&#10;&#10;@param array|SimplePie $data Data to store in the cache. If passed a SimplePie object, only cache the $data property&#10;@return bool Successfulness" ilk="function" line="114" lineend="121" name="save" returns="bool" signature="bool save($data)"><variable ilk="argument" line="114" na