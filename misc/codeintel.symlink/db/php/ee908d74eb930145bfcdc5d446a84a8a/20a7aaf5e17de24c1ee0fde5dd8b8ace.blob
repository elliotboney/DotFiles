<scope ilk="blob" lang="PHP" name="custom-header.php" src="/private/var/www/kw/content/themes/twentytwelve/inc/custom-header.php"><scope doc="Set up the WordPress core custom header arguments and settings.&#10;&#10;@uses add_theme_support() to register support for 3.4 and up.&#10;@uses twentytwelve_header_style() to style front-end.&#10;@uses twentytwelve_admin_header_style() to style wp-admin form.&#10;@uses twentytwelve_admin_header_image() to add custom markup to wp-admin form.&#10;&#10;@since Twenty Twelve 1.0" ilk="function" line="22" lineend="47" name="twentytwelve_custom_header_setup" signature="twentytwelve_custom_header_setup()"><variable citdl="array()" line="44" name="args" /></scope><scope doc="Load our special font CSS file.&#10;&#10;@since Twenty Twelve 1.2&#10;&#10;@return void" ilk="function" line="57" lineend="61" name="twentytwelve_custom_header_fonts" signature="void twentytwelve_custom_header_fonts()"><variable citdl="twentytwelve_get_font_url()" line="58" name="font_url" /></scope><scope doc="Style the header text displayed on the blog.&#10;&#10;get_header_textcolor() options: 515151 is default, hide text (returns 'blank'), or any hex value.&#10;&#10;@since Twenty Twelve 1.0" ilk="function" line="71" lineend="102" name="twentytwelve_header_style" signature="twentytwelve_header_style()"><variable citdl="get_header_textcolor()" line="72" name="text_color" /></scope><scope doc="Style the header image displayed on the Appearance &gt; Header admin panel.&#10;&#10;@since Twenty Twelve 1.0" ilk="function" line="109" lineend="142" name="twentytwelve_admin_header_style" signature="twentytwelve_admin_header_style()" /><scope doc="Output markup to be displayed on the Appearance &gt; Header admin panel.&#10;&#10;This callback overrides the default markup displayed there.&#10;&#10;@since Twenty Twelve 1.0" ilk="function" line="151" lineend="167" name="twentytwelve_admin_header_image" signature="twentytwelve_admin_header_image()"><variable line="155" name="style" /><variable citdl="get_header_image()" line="162" name="header_image" /></scope></scope>