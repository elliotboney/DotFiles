<scope ilk="blob" lang="PHP" name="modifier.cat.php" src="/usr/local/pear/share/pear/PhpDocumentor/phpDocumentor/Smarty-2.6.0/libs/plugins/modifier.cat.php"><scope doc="Smarty cat modifier plugin&#10;&#10;Type:     modifier&lt;br&gt;&#10;Name:     cat&lt;br&gt;&#10;Date:     Feb 24, 2003&#10;Purpose:  catenate a value to a variable&#10;Input:    string to catenate&#10;Example:  {$var|cat:&quot;foo&quot;}&#10;@link http://smarty.php.net/manual/en/language.modifier.cat.php cat&#10;         (Smarty online manual)&#10;@author	 Monte Ohrt &lt;monte@ispi.net&gt;&#10;@version 1.0&#10;@param string&#10;@param string&#10;@return string" ilk="function" line="26" lineend="29" name="smarty_modifier_cat" returns="string" signature="string smarty_modifier_cat($string, $cat)"><variable ilk="argument" line="26" name="string" /><variable ilk="argument" line="26" name="cat" /></scope></scope>