<scope ilk="blob" lang="PHP" name="modifier.spacify.php" src="/usr/local/pear/share/pear/PhpDocumentor/phpDocumentor/Smarty-2.6.0/libs/plugins/modifier.spacify.php"><scope doc="Smarty spacify modifier plugin&#10;&#10;Type:     modifier&lt;br&gt;&#10;Name:     spacify&lt;br&gt;&#10;Purpose:  add spaces between characters in a string&#10;@link http://smarty.php.net/manual/en/language.modifier.spacify.php&#10;         spacify (Smarty online manual)&#10;@param string&#10;@param string&#10;@return string" ilk="function" line="21" lineend="25" name="smarty_modifier_spacify" returns="string" signature="string smarty_modifier_spacify($string, $spacify_char = ' ')"><variable ilk="argument" line="21" name="string" /><variable default="' '" ilk="argument" line="21" name="spacify_char" /></scope></scope>