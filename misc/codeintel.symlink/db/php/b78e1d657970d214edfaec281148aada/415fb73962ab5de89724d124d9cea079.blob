<scope ilk="blob" lang="PHP" name="outputfilter.trimwhitespace.php" src="/usr/local/pear/share/pear/PhpDocumentor/phpDocumentor/Smarty-2.6.0/libs/plugins/outputfilter.trimwhitespace.php"><scope doc="Smarty trimwhitespace outputfilter plugin&#10;&#10;File:     outputfilter.trimwhitespace.php&lt;br&gt;&#10;Type:     outputfilter&lt;br&gt;&#10;Name:     trimwhitespace&lt;br&gt;&#10;Date:     Jan 25, 2003&lt;br&gt;&#10;Purpose:  trim leading white space and blank lines from&#10;          template source after it gets interpreted, cleaning&#10;          up code and saving bandwidth. Does not affect&#10;          &lt;&lt;PRE&gt;&gt;&lt;/PRE&gt; and &lt;SCRIPT&gt;&lt;/SCRIPT&gt; blocks.&lt;br&gt;&#10;Install:  Drop into the plugin directory, call &#10;          &lt;code&gt;$smarty-&gt;load_filter('output','trimwhitespace');&lt;/code&gt;&#10;          from application.&#10;@author   Monte Ohrt &lt;monte@ispi.net&gt;&#10;@author Contributions from Lars Noschinski &lt;lars@usenet.noschinski.de&gt;&#10;@version  1.3&#10;@param string&#10;@param Smarty" ilk="function" line="28" lineend="62" name="smarty_outputfilter_trimwhitespace" returns="source" signature="smarty_outputfilter_trimwhitespace($source, &amp; $smarty)"><variable ilk="argument" line="28" name="source" /><variable ilk="argument" line="28" name="smarty" /><variable citdl="match" line="38" name="_pre_blocks" /><variable citdl="match" line="44" name="_textarea_blocks" /><variable citdl="match" line="32" name="_script_blocks" /></scope><scope ilk="function" line="64" lineend="73" name="smarty_outputfilter_trimwhitespace_replace" signature="smarty_outputfilter_trimwhitespace_replace($search_str, $replace, &amp; $subject)"><variable ilk="argument" line="64" name="search_str" /><variable ilk="argument" line="64" name="replace" /><variable ilk="argument" line="64" name="subject" /><variable citdl="int" line="66" name="_pos" /><variable line="67" name="_count" /><variable line="67" name="_i" /><variable citdl="strlen()" li