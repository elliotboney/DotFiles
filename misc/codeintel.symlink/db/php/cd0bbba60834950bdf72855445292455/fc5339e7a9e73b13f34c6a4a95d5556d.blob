nd="149" name="setIdentifiers" returns="EventManager" signature="EventManager setIdentifiers($identifiers)"><variable ilk="argument" line="141" name="identifiers" /></scope><scope attributes="public" doc="Add some identifier(s) (appends to any currently set identifiers)&#10;&#10;@param string|int|array|Traversable $identifiers&#10;@return EventManager Provides a fluent interface" ilk="function" line="157" lineend="165" name="addIdentifiers" returns="EventManager" signature="EventManager addIdentifiers($identifiers)"><variable ilk="argument" line="157" name="identifiers" /></scope><scope attributes="public" doc="Trigger all listeners for a given event&#10;&#10;Can emulate triggerUntil() if the last argument provided is a callback.&#10;&#10;@param  string $event&#10;@param  string|object $target Object calling emit, or symbol describing target (such as static method name)&#10;@param  array|ArrayAccess $argv Array of arguments; typically, should be associative&#10;@param  null|callable $callback&#10;@return ResponseCollection All listener return values&#10;@throws Exception\InvalidCallbackException" ilk="function" line="179" lineend="208" name="trigger" returns="ResponseCollection" signature="ResponseCollection trigger(string $event, $target = null, $argv = array(), $callback = null)"><variable citdl="string" ilk="argument" line="179" name="event" /><variable default="null" ilk="argument" line="179" name="target" /><variable default="array()" ilk="argument" line="179" name="argv" /><variable default="null" ilk="argument" line="179" name="callback" /><variable citdl="event" line="182" name="e" /></scope><scope attributes="public" doc="Trigger listeners until return value of one causes a callback to&#10;evaluate to true&#10;&#10;Triggers listeners until the provided callback evaluates the return&#10;value of one as true, or until all listeners have been executed.&#10;&#10;@param  string $event&#10;@param  string|object $target Object calling emit, or symbol describing target (such as static method name)&#10;@param  array|ArrayAccess $argv Array of arguments; typically, should be associative&#10;@param  callable $callback&#10;@return ResponseCollection&#10;@throws Exception\InvalidCallbackException if invalid callable provided" ilk="function" line="224" lineend="253" name="triggerUntil" returns="ResponseCollection" signature="ResponseCollection triggerUntil(string $event, $target, $argv = null, callable $callback = null)"><variable citdl="string" ilk="argument" line="224" name="event" /><variable ilk="argument" line="224" name="target" /><variable default="null" ilk="argument" line="224" name="argv" /><variable citdl="callable" default="null" ilk="argument" line="224" name="callback" /><variable citdl="event" line="227" name="e" /></scope><scope attributes="public" doc="Attach a listener to an event&#10;&#10;The first argument is the event, and the next argument describes a&#10;callback that will respond to that event. A CallbackHandler instance&#10;describing the event listener combination will be returned.&#10;&#10;The last argument indicates a priority at which the event should be&#10;executed. By default, this value is 1; however, you may set it for any&#10;integer value. Higher values have higher priority (i.e., execute first).&#10;&#10;You can specify &quot;*&quot; for the event name. In such cases, the listener will&#10;be triggered for every event.&#10;&#10;@param  string|array|ListenerAggregateInterface $event An event or array of event names. If a ListenerAggregateInterface, proxies to {@link attachAggregate()}.&#10;@param  callable|int $callback If string $event provided, expects PHP callback; for a ListenerAggregateInterface $event, this will be the priority&#10;@param  int $priority If provided, the priority at which to register the callable&#10;@return CallbackHandler|mixed CallbackHandler if attaching callable (to allow later unsubscribe); mixed if attaching aggregate&#10;@throws Exception\InvalidArgumentException" ilk="function" line="275" lineend="310" name="attach" returns="CallbackHandler" signature="CallbackHandler attach($event, $callback = null, int $priority = 1)"><variable ilk="argument" line="275" name="event" /><variable default="null" ilk="argument" line="275" name="callback" /><variable citdl="int" default="1" ilk="argument" line="275" name="priority" /><variable citdl="CallbackHandler" line="305" name="listener" /><variable citdl="array()" line="292" name="listeners" /><variable attributes="__not_yet_defined__" line="293" name="name" /></scope><scope attributes="public" doc="Attach a listener aggregate&#10;&#10;Listener aggregates accept an EventManagerInterface instance, and call attach()&#10;one or more times, typically to attach to multiple events using local&#10;methods.&#10;&#10;@param  ListenerAggregateInterface $aggregate&#10;@param  int $priority If provided, a suggested priority for the aggregate to use&#10;@return mixed return value of {@link ListenerAggregateInterface::attach()}" ilk="function" line="323" lineend="326" name="attachAggregate" returns="mixed" signature="mixed attachAggregate(ListenerAggregateInterface $aggregate, int $priority = 1)"><variable citdl="ListenerAggregateInterface" ilk="argument" line="323" name="aggregate" /><variable citdl="int" default="1" ilk="argument" line="323" name="priority" /></scope><scope attributes="public" doc="Unsubscribe a listener from an event&#10;&#10;@param  CallbackHandler|ListenerAggregateInterface $listener&#10;@return bool Returns true if event and listener found, and unsubscribed; returns false if either event or listener not found&#10;@throws Exception\InvalidArgumentException if invalid listener provided" ilk="function" line="335" lineend="361" name="detach" returns="bool" signature="bool detach($listener)"><variable ilk="argument" line="335" name="listener" /><variable citdl="this.events" line="353" name="return" /><variable citdl="listener.getMetadatum()" line="349" name="event" /></scope><scope attributes="public" doc="Detach a listener aggregate&#10;&#10;Listener aggregates accept an EventManagerInterface instance, and call detach()&#10;of all previously attached listeners.&#10;&#10;@param  ListenerAggregateInterface $aggregate&#10;@return mixed return value of {@link ListenerAggregateInterface::detach()}" ilk="function" line="372" lineend="375" name="detachAggregate" returns="mixed" signature="mixed detachAggregate(ListenerAggregateInterface $aggregate)"><variable citdl="ListenerAggregateInterface" ilk="argument" line="372" name="aggregate" /></scope><scope attributes="public" doc="Retrieve all registered events&#10;&#10;@return array" ilk="function" line="382" lineend="385" name="getEvents" returns="array" signature="array getEvents()" /><scope attributes="public" doc="Retrieve all listeners for a given event&#10;&#10;@param  string $event&#10;@return PriorityQueue" ilk="function" line="393" lineend="399" name="getListeners" returns="PriorityQueue" signature="PriorityQueue getListeners(string $event)"><variable citdl="string" ilk="argument" line="393" name="event" /></scope><scope attributes="public" doc="Clear all listeners for a given event&#10;&#10;@param  string $event&#10;@return void" ilk="function" line="407" lineend="412" name="clearListeners" signature="void clearListeners(string $event)"><variable citdl="string" ilk="argument" line="407" name="event" /></scope><scope attributes="public" doc="Prepare arguments&#10;&#10;Use this method if you want to be able to modify arguments from within a&#10;listener. It returns an ArrayObject of the arguments, which may then be&#10;passed to trigger() or triggerUntil().&#10;&#10;@param  array $args&#10;@return ArrayObject" ilk="function" line="424" lineend="427" name="prepareArgs" returns="ArrayObject" signature="ArrayObject prepareArgs(array $args)"><variable citdl="array" ilk="argument" line="424" name="args" /></scope><scope attributes="protected" doc="Trigger listeners&#10;&#10;Actual functionality for tri