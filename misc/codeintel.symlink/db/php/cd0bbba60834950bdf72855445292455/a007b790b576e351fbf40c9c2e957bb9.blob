<scope ilk="blob" lang="PHP" name="SharedEventManager.php" src="/usr/local/pear/share/pear/PhpDocumentor/vendor/zendframework/zend-eventmanager/Zend/EventManager/SharedEventManager.php"><scope doc="Zend Framework (http://framework.zend.com/)&#10;&#10;@link      http://github.com/zendframework/zf2 for the canonical source repository&#10;@copyright Copyright (c) 2005-2013 Zend Technologies USA Inc. (http://www.zend.com)&#10;@license   http://framework.zend.com/license/new-bsd New BSD License" ilk="namespace" line="10" name="Zend\EventManager"><import line="12" module="Zend\Stdlib" symbol="CallbackHandler" /><import line="13" module="Zend\Stdlib" symbol="PriorityQueue" /><scope doc="Shared/contextual EventManager&#10;&#10;Allows attaching to EMs composed by other classes without having an instance first.&#10;The assumption is that the SharedEventManager will be injected into EventManager&#10;instances, and then queried for additional listeners when triggering an event." ilk="class" interfacerefs="SharedEventAggregateAwareInterface SharedEventManagerInterface" line="22" lineend="176" name="SharedEventManager"><variable attributes="protected" citdl="array" doc="Identifiers with event connections&#10;@var array" line="30" name="identifiers" /><scope attributes="public" doc="Attach a listener to an event&#10;&#10;Allows attaching a callback to an event offered by one or more&#10;identifying components. As an example, the following connects to the&#10;&quot;getAll&quot; event of both an AbstractResource and EntityResource:&#10;&#10;&lt;code&gt;&#10;$sharedEventManager = new SharedEventManager();&#10;$sharedEventManager-&gt;attach(&#10;    array('My\Resource\AbstractResource', 'My\Resource\EntityResource'),&#10;    'getAll',&#10;    function ($e) use ($cache) {&#10;        if (!$id = $e-&gt;getParam('id', false)) {&#10;            return;&#10;        }&#10;        if (!$data = $cache-&gt;load(get_class($resource) . '::getOne::' . $id )) {&#10;            return;&#10;        }&#10;        return $data;&#10;    }&#10;);&#10;&lt;/code&gt;&#10;&#10;@param  string|array $id Identifier(s) for event emitting component(s)&#10;@param  string $event&#10;@param  callable $callback PHP Callback&#10;@param  int $priority Priority at which listener should execute&#10;@return CallbackHandler|array Either CallbackHandler or array of CallbackHandlers" ilk="function" line="62" lineend="76" name="attach" returns="CallbackHandler" signature="CallbackHandler attach($id, string $event, callable $callback, int $priority = 1)"><variable ilk="argument" line="62" name="id" /><variable citdl="string" ilk="argument" line="62" name="event" /><variable citdl="callable" ilk="argument" line="62" name="callback" /><variable citdl="int" default="1" ilk="argument" line="62" name="priority" /><variable citdl="array()" line="65" name="listeners" /><variable citdl="array()" line="64" name="ids" /></scope><scope attributes="public" doc="Attach a listener aggregate&#10;&#10;Listener aggregates accept an EventManagerInterface instance, and call attachShared()&#10;one or more times, typically to attach to multiple events using local&#10;methods.&#10;&#10;@param  SharedListenerAggregateInterface $aggregate&#10;@param  int $priority If provided, a suggested priority for the aggregate to use&#10;@return mixed return value of {@link ListenerAggregateInterface::attachShared()}" ilk="function" line="89" lineend="92" name="attachAggregate" returns="mixed" signature="mixed attachAggregate(SharedListenerAggregateInterface $aggregate, int $priority = 1)"><variable citdl="SharedListenerAggregateInterface" ilk="argument" line="89" name="aggregate" /><variable citdl="int" default="1" ilk="argument" line="89" name="priority" /></scope><scope attributes="public" doc="Detach a listener from an event offered by a given resource&#10;&#10;@param  string|int $id&#10;@param  CallbackHandler $listener&#10;@return bool Returns true if event and listener found, and unsubscribed; returns false if either event or listener not found" ilk="function" line="101" lineend="107" name="detach" returns="bool" signature="bool detach($id, CallbackHandler $listener)"><variable ilk="argument" line="101" name="id" /><variable citdl="CallbackHandler" ilk="argument" line="101" name="listener" /></scope><scope attributes="public" doc="Detach a listener aggregate&#10;&#10;Listener aggregates accept an SharedEventManagerInterface instance, and call detachShared()&#10;of all previously attached listeners.&#10;&#10;@param  SharedListenerAggregateInterface $aggregate&#10;@return mixed return value of {@link SharedListenerAggregateInterface::detachShared()}" ilk="function" line="118" lineend="121" name="detachAggregate" returns="mixed" signature="mixed detachAggregate(SharedListenerAggregateInterface $aggregate)"><variable citdl="SharedListenerAggregateInterface" ilk="argument" line="118" name="aggregate" /></scope><scope attributes="public" doc="Retrieve all registered events for a given resource&#10;&#10;@param  string|int $id&#10;@return array" ilk="function" line="129" lineend="139" name="getEvents" returns="array" signature="array getEvents($id)"><variable ilk="argument" line="129" name="id" /></scope><scope attributes="public" doc="Retrieve all listeners for a given identifier and event&#10;&#10;@param  string|int $id&#10;@param  string|int $event&#10;@return false|PriorityQueue" ilk="function" line="148" lineend="154" name="getListeners" returns="false" signature="false getListeners($id, $event)"><variable ilk="argument" line="148" name="id" /><variable ilk="argument" line="148" name="event" /></scope><scope attributes="public" doc="Clear all listeners for a given identifier, optionally for a specific event&#10;&#10;@param  string|int $id&#10;@param  null|string $event&#10;@return bool" ilk="function" line="163" lineend="175" name="clearListeners" returns="bool" signature="bool clearListeners($id, $event = null)"><variable ilk="argument" line="163" name="id" /><variable default=