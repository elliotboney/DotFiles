<scope ilk="blob" lang="PHP" name="Base.php" src="/private/var/www/wordpress.staging/min/lib/Minify/Controller/Base.php"><scope attributes="abstract" doc="Base class for Minify controller&#10;&#10;The controller class validates a request and uses it to create sources&#10;for minification and set options like contentType. It's also responsible&#10;for loading minifier code upon request.&#10;&#10;@package Minify&#10;@author Stephen Clay &lt;steve@mrclay.org&gt;" ilk="class" line="17" lineend="222" name="Minify_Controller_Base"><scope attributes="abstract public" doc="Setup controller sources and set an needed options for Minify::source&#10;&#10;You must override this method in your subclass controller to set &#10;$this-&gt;sources. If the request is NOT valid, make sure $this-&gt;sources &#10;is left an empty array. Then strip any controller-specific options from &#10;$options and return it. To serve files, $this-&gt;sources must be an array of&#10;Minify_Source objects.&#10;&#10;@param array $options controller and Minify options&#10;&#10;@return array $options Minify::serve options" ilk="function" line="32" lineend="32" name="setupSources" returns="array" signature="array setupSources(array $options)"><variable citdl="array" ilk="argument" line="32" name="options" /></scope><scope attributes="public" doc="Get default Minify options for this controller.&#10;&#10;Override in subclass to change defaults&#10;&#10;@return array options for Minify" ilk="function" line="41" lineend="65" name="getDefaultMinifyOptions" returns="array" signature="array getDefaultMinifyOptions()" /><scope attributes="public" doc="Get default minifiers for this controller.&#10;&#10;Override in subclass to change defaults&#10;&#10;@return array minifier callbacks for common types" ilk="function" line="74" lineend="79" name="getDefaultMinifers" returns="array" signature="array getDefaultMinifers()" /><scope attributes="public static" doc="Is a user-given file within an allowable directory, existing,&#10;and having an extension js/css/html/txt ?&#10;&#10;This is a convenience function for controllers that have to accept&#10;user-given paths&#10;&#10;@param string $file full file path (already processed by realpath())&#10;&#10;@param array $safeDirs directories where files are safe to serve. Files can also&#10;be in subdirectories of these directories.&#10;&#10;@return bool file is safe&#10;&#10;@deprecated use checkAllowDirs, checkNotHidden instead" ilk="function" line="97" lineend="112" name="_fileIsSafe" returns="bool" signature="bool _fileIsSafe(string $file, array $safeDirs)"><variable citdl="string" ilk="argument" line="97" name="file" /><variable citdl="array" ilk="argument" line="97" name="safeDirs" /><variable citdl="boolean" line="99" name="pathOk" /><variable citdl="basename()" line="106" name="base" /><variable attributes="__not_yet_defined__" line="110" name="revExt" /><variable attributes="__not_yet_defined__" line="100" name="safeDir" /></scope><scope attributes="public static" doc="@param string $file&#10;@param array $allowDirs&#10;@param string $uri&#10;@return bool&#10;@throws Exception" ilk="function" line="121" lineend="131" name="checkAllowDirs" returns="bool" signature="bool checkAllowDirs(string $file, array $allowDirs, string $uri)"><variable citdl="string" ilk="argument" line="121" name="file" /><variable citdl="array" ilk="argument" line="121" name="allowDirs" /><variable citdl="string" ilk="argument" line="121" name="uri" /><variable attributes="__not_yet_defined__" line="123" name="allowDir" /></scope><scope attributes="public static" doc="@param string $file&#10;@throws Exception" ilk="function" line="137" lineend="143" name="checkNotHidden" signature="checkNotHidden(string $file)"><variable citdl="string" ilk="argument" line="137" name="file" /><variable citdl="basename()" line="139" name="b" /></scope><variable attributes="public" citdl="array" doc="instances of Minify_Source, which provide content and any individual minification needs.&#10;&#10;@var array&#10;&#10;@see Minify_Source" line="152" name="sources" /><variable attributes="public" citdl="string" doc="Short name to place inside cache id&#10;&#10;The setupSources() method may choose to set this, making it easier to&#10;recognize a particular set of sources/settings in the cache folder. It&#10;will be filtered and truncated to make the final cache id &lt;= 250 bytes.&#10;&#10;@var string" line="163" name="selectionId" /><scope attributes="public final" doc="Mix in default controller options with user-given options&#10;&#10;@param array $options user options&#10;&#10;@return array mixed options" ilk="function" line="172" lineend="184" name="mixInDefaultOptions" returns="array" signature="array mixInDefaultOptions(array $options)"><variable citdl="array" ilk="argument" line="172" name="options" /><variable citdl="array_merge()" line="176" name="ret" /></scope><scope attributes="public final" doc="Analyze sources (if there are any) and set $options 'contentType' &#10;and 'lastModifiedTime' if they already aren't.&#10;&#10;@param array $options options for Minify&#10;&#10;@return array options for Minify" ilk="function" line="194" lineend="210" name="analyzeSources" returns="array" signature="array analyzeSources(array $options = array())"><variable citdl="array" default="array()" ilk="argument" line="194" name="options" /><variable citdl="int" line="202" name="max" /><variable attributes="__not_yet_defined__" line="203" name="source" /></scope><scope attributes="public" doc="Send message to the Minify logger&#10;&#10;@param string $msg&#10;&#10;@return null" ilk="function" line="219" lineend="221" name="log" returns="null" signature="null log(string $msg)"><variable citdl="string" ilk="argument" line="219" name="msg" /></scope></scope></scope>