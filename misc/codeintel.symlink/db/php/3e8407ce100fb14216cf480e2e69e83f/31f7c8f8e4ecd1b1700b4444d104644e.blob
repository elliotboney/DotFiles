<scope ilk="blob" lang="PHP" name="JumbledIncrementerSniff.php" src="/usr/local/pear/share/pear/PHP/CodeSniffer/Standards/Generic/Sniffs/CodeAnalysis/JumbledIncrementerSniff.php"><scope doc="Detects incrementer jumbling in for loops.&#10;&#10;This rule is based on the PMD rule catalog. The jumbling incrementer sniff&#10;detects the usage of one and the same incrementer into an outer and an inner&#10;loop. Even it is intended this is confusing code.&#10;&#10;&lt;code&gt;&#10;class Foo&#10;{&#10;    public function bar($x)&#10;    {&#10;        for ($i = 0; $i &lt; 10; $i++)&#10;        {&#10;            for ($k = 0; $k &lt; 20; $i++)&#10;            {&#10;                echo 'Hello';&#10;            }&#10;        }&#10;    }&#10;}&#10;&lt;/code&gt;&#10;&#10;@category  PHP&#10;@package   PHP_CodeSniffer&#10;@author    Manuel Pichler &lt;mapi@manuel-pichler.de&gt;&#10;@copyright 2007-2008 Manuel Pichler. All rights reserved.&#10;@license   http://www.opensource.org/licenses/bsd-license.php BSD License&#10;@version   Release: 1.4.6&#10;@link      http://pear.php.net/package/PHP_CodeSniffer" ilk="class" interfacerefs="PHP_CodeSniffer_Sniff" line="47" lineend="146" name="Generic_Sniffs_CodeAnalysis_JumbledIncrementerSniff"><scope attributes="public" doc="Registers the tokens that this sniff wants to listen for.&#10;&#10;@return array(integer)" ilk="function" line="56" lineend="60" name="register" returns="array" signature="array register()" /><scope attributes="public" doc="Processes this test, when one of its tokens is encountered.&#10;&#10;@param PHP_CodeSniffer_File $phpcsFile The file being scanned.&#10;@param int                  $stackPtr  The position of the current token&#10;                                       in the stack passed in $tokens.&#10;&#10;@return void" ilk="function" line="72" lineend="109" name="process" signature="void process(PHP_CodeSniffer_File $phpcsFile, int $stackPtr)"><variable citdl="PHP_CodeSniffer_File" ilk="argument" line="72" name="phpcsFile" /><variable citdl="int" ilk="argument" line="72" name="stackPtr" /><variable line="92" name="end" /><variable citdl="array()" line="104" name="data" /><variable line="91" name="start" /><variable citdl="tokens" line="75" name="token" /><variable citdl="this.findIncrementers()" line="99" name="inner" /><variable citdl="this.findIncrementers()" line="83" name="outer" /><variable citdl="string" line="103" name="error" /><variable citdl="phpcsFile.getTokens()" line="74" name="tokens" /><variable citdl="array_intersect()" line="100" name="diff" /></scope><scope attributes="protected" doc="Get all used variables in the incrementer part of a for statement.&#10;&#10;@param array(integer=&gt;array) $tokens Array with all code sniffer tokens.&#10;@param array(string=&gt;mixed)  $token  Current for loop token&#10;&#10;@return array(string) List of all found incrementer variables." ilk="function" line="120" lineend="143" name="findIncrementers" returns="array" signature="array findIncrementers(array $tokens, array $token)"><variable citdl="array" ilk="argument" line="120" name="tokens" /><variable citdl="array" ilk="argument" line="120" name="token" /><variable citdl="int" line="131" name="semicolons" /><variable line="132" name="next" /><variable line="127" name="start" /><variable citdl="tokens" line="133" name="code" /><variable line="128" name="end" /><variable citdl="array()" line="130" name="incrementers" /></scope></scope></scope>