<scope ilk="blob" lang="PHP" name="EmptyStatementSniff.php" src="/usr/local/pear/share/pear/PHP/CodeSniffer/Standards/Generic/Sniffs/CodeAnalysis/EmptyStatementSniff.php"><scope doc="This sniff class detected empty statement.&#10;&#10;This sniff implements the common algorithm for empty statement body detection.&#10;A body is considered as empty if it is completely empty or it only contains&#10;whitespace characters and|or comments.&#10;&#10;&lt;code&gt;&#10;stmt {&#10;  // foo&#10;}&#10;stmt (conditions) {&#10;  // foo&#10;}&#10;&lt;/code&gt;&#10;&#10;Statements covered by this sniff are &lt;b&gt;catch&lt;/b&gt;, &lt;b&gt;do&lt;/b&gt;, &lt;b&gt;else&lt;/b&gt;,&#10;&lt;b&gt;elsif&lt;/b&gt;, &lt;b&gt;for&lt;/b&gt;, &lt;b&gt;foreach&lt;b&gt;, &lt;b&gt;if&lt;/b&gt;, &lt;b&gt;switch&lt;/b&gt;, &lt;b&gt;try&lt;/b&gt;&#10;and &lt;b&gt;while&lt;/b&gt;.&#10;&#10;@category  PHP&#10;@package   PHP_CodeSniffer&#10;@author    Manuel Pichler &lt;mapi@manuel-pichler.de&gt;&#10;@copyright 2007-2008 Manuel Pichler. All rights reserved.&#10;@license   http://www.opensource.org/licenses/bsd-license.php  BSD License&#10;@version   Release: 1.4.6&#10;@link      http://pear.php.net/package/PHP_CodeSniffer" ilk="class" interfacerefs="PHP_CodeSniffer_Sniff" line="44" lineend="126" name="Generic_Sniffs_CodeAnalysis_EmptyStatementSniff"><variable attributes="protected" citdl="array" doc="List of block tokens that this sniff covers.&#10;&#10;The key of this hash identifies the required token while the boolean&#10;value says mark an error or mark a warning.&#10;&#10;@var array" line="66" name="checkedTokens" /><scope attributes="public" doc="Registers the tokens that this sniff wants to listen for.&#10;&#10;@return array(integer)" ilk="function" line="74" lineend="78" name="register" returns="array" signature="array register()" /><scope attributes="public" doc="Processes this test, when one of its tokens is encountered.&#10;&#10;@param PHP_CodeSniffer_File $phpcsFile The file being scanned.&#10;@param int                  $stackPtr  The position of the current token&#10;                                       in the stack passed in $tokens.&#10;&#10;@return void" ilk="function" line="90" lineend="123" name="process" signature="void process(PHP_CodeSniffer_File $phpcsFile, int $stackPtr)"><variable citdl="PHP_CodeSniffer_File" ilk="argument" line="90" name="phpcsFile" /><variable citdl="int" ilk="argument" line="90" name="stackPtr" /><variable citdl="array()" line="115" name="data" /><variable line="100" name="next" /><variable citdl="tokens" line="93" name="token" /><variable citdl="boolean" line="103" name="emptyBody" /><variable line="101" name="end" /><variable citdl="phpcsFile.getTokensAsString()" line="113" name="name" /><variable citdl="string" line="114" name="error" /><variable citdl="phpcsFile.getTokens()" line="92" name="tokens" /></scope></scope></scope>