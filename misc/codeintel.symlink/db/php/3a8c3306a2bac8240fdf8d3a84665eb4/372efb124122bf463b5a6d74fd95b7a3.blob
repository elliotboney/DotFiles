<scope ilk="blob" lang="PHP" name="AbstractDocElement.php" src="/usr/local/pear/share/pear/PHP/CodeSniffer/CommentParser/AbstractDocElement.php"><variable citdl="string" line="17" name="error" /><scope attributes="abstract" doc="A class to handle most of the parsing operations of a doc comment element.&#10;&#10;Extending classes should implement the getSubElements method to return&#10;a list of elements that the doc comment element contains, in the order that&#10;they appear in the element. For example a function parameter element has a&#10;type, a variable name and a comment. It should therefore implement the method&#10;as follows:&#10;&#10;&lt;code&gt;&#10;   protected function getSubElements()&#10;   {&#10;       return array(&#10;               'type',&#10;               'variable',&#10;               'comment',&#10;              );&#10;   }&#10;&lt;/code&gt;&#10;&#10;The processSubElement will be called for each of the sub elements to allow&#10;the extending class to process them. So for the parameter element we would&#10;have:&#10;&#10;&lt;code&gt;&#10;   protected function processSubElement($name, $content, $whitespaceBefore)&#10;   {&#10;       if ($name === 'type') {&#10;           echo 'The name of the variable was '.$content;&#10;       }&#10;       // Process other tags.&#10;   }&#10;&lt;/code&gt;&#10;&#10;@category  PHP&#10;@package   PHP_CodeSniffer&#10;@author    Greg Sherwood &lt;gsherwood@squiz.net&gt;&#10;@author    Marc McIntyre &lt;mmcintyre@squiz.net&gt;&#10;@copyright 2006-2012 Squiz Pty Ltd (ABN 77 084 670 600)&#10;@license   https://github.com/squizlabs/PHP_CodeSniffer/blob/master/licence.txt BSD Licence&#10;@version   Release: 1.4.6&#10;@link      http://pear.php.net/package/PHP_CodeSniffer" ilk="class" interfacerefs="PHP_CodeSniffer_CommentParser_DocElement" line="64" lineend="351" name="PHP_CodeSniffer_CommentParser_AbstractDocElement"><variable attributes="protected" citdl="PHP_CodeSniffer_CommentParser_DocElement" doc="The element previous to this element.&#10;&#10;@var PHP_CodeSniffer_CommentParser_DocElement" line="72" name="previousElement" /><variable attributes="protected" citdl="PHP_CodeSniffer_CommentParser_DocElement" doc="The element proceeding this element.&#10;&#10;@var PHP_CodeSniffer_CommentParser_DocElement" line="79" name="nextElement" /><variable attributes="protected" citdl="string" doc="The whitespace the occurs after this element and its sub elements.&#10;&#10;@var string" line="86" name="afterWhitespace" /><variable attributes="protected" citdl="array" doc="The tokens that comprise this element.&#10;&#10;@var array(string)" line="93" name="tokens" /><variable attributes="protected" citdl="array" doc="The file this element is in.&#10;&#10;@var array(string)" line="100" name="phpcsFile" /><variable attributes="protected" citdl="string" doc="The tag that this element represents (omitting the @ symbol).&#10;&#10;@var string" line="107" name="tag" /><scope attributes="public __ctor__" doc="Constructs a Doc Element.&#10;&#10;@param PHP_CodeSniffer_CommentParser_DocElement $previousElement The element&#10;                                                                 that ocurred&#10;                                                                 before this.&#10;@param array                                    $tokens          The tokens of&#10;                                                                 this element.&#10;@param string                                   $tag             The doc&#10;                                                                 element tag&#10;                                                                 this element&#10;                                                                 represents.&#10;@param PHP_CodeSniffer_File                     $phpcsFile       The file that&#10;                                                                 this element&#10;                                                                 is in.&#10;&#10;@throws Exception If $previousElement in not a DocElement or if&#10;                  getSubElements() does not return an array." ilk="function" line="129" lineend="196" name="__construct" signature="__construct(PHP_CodeSniffer_CommentParser_DocElement $previousElement, array $tokens, string $tag, PHP_CodeSniffer_File $phpcsFile)"><variable citdl="PHP_CodeSniffer_CommentParser_DocElement" ilk="argument" line="129" name="previousElement" /><variable citdl="array" ilk="argument" line="129" name="tokens" /><variable citdl="string" ilk="argument" line="129" name="tag" /><variable citdl="PHP_CodeSniffer_File" ilk="argument" line="129" name="phpcsFile" /><variable citdl="string" line="138" name="error" /><variable citdl="this.getSubElements()" line="152" name="subElements" /><variable attributes="__not_yet_defined__" line="164" name="token" /><variable citdl="string" line="160" name="lastElement" /><variable citdl="whitespace" line="161" name="lastElementWhitespace" /><variable citdl="string" line="158" name="whitespace" /><variable citdl="count()" line="162" name="numSubElements" /><variable citdl="int" line="159" name="currElem" /><variable citdl="subElements" line="185" name="lastElementName" /><variable citdl="subElements" line="169" name="element" /></scope><scope attributes="public" doc="Returns the element that exists before this.&#10;&#10;@return PHP_CodeSniffer_CommentParser_DocElement" ilk="function" line="204" lineend="208" name="getPreviousElement" returns="PHP_CodeSniffer_CommentParser_DocElement" signature="PHP_CodeSniffer_CommentParser_DocElement getPreviousElement()" /><scope attributes="public" doc="Returns the element that exists after this.&#10;&#10;@return PHP_CodeSniffer_CommentParser_DocElement" ilk="function" line="216" lineend="220" name="getNextElement" returns="PHP_CodeSniffer_CommentParser_DocElement" signature="PHP_CodeSniffer_CommentParser_DocElement getNextElement()" /><scope attributes="public" doc="Returns the whitespace that exists before this element.&#10;&#10;@return string" ilk="function" line="228" lineend="236" name="getWhitespaceBefore" returns="string" signature="string getWhitespaceBefore()" /><scope attributes="public" doc="Returns the whitespace that exists after this element.&#10;&#10;@return string" ilk="function" line="244" lineend="248" name="getWhitespaceAfter" returns="string" signature="string getWhitespaceAfter()" /><scope attributes="public" doc="Returns the order that this element appears in the comment.&#10;&#10;@return int" ilk="function" line="256" lineend="264" name="getOrder" returns="int" signature="int getOrder()" /><scope attributes="public" doc="Returns the tag that this element represents, ommiting the @ symbol.&#10;&#10;@return string" ilk="function" line="272" lineend="276" name="getTag" returns="string" signature="string getTag()" /><scope attributes="public" doc="Returns the raw content of this element, ommiting the tag.&#10;&#10;@return string" ilk="function" line="284" lineend="288" name="getRawContent" returns="string" signature="string getRawContent()" /><scope attributes="public" doc="Returns the comment tokens.&#10;&#10;@return array" ilk="function" line="296" lineend="300" name="getTokens" returns="array" signature="array getTokens()" /><scope attributes="public" doc="Returns the line in which this element first occured.&#10;&#10;@return int" ilk="function" line="308" lineend="320" name="getLine" returns="int" signature="int getLine()"><variable citdl="this.previousElement.getLine()" line="315" name="previousLine" /><variable citdl="this.previousElement.getRawContent()" line="314" name="previousContent" /></scope><scope attributes="abstract protected" doc="Returns the sub element names that make up this element in the order they&#10;appear in the element.&#10;&#10;@return array(string)&#10;@see processSubElement()" ilk="function" line="330" lineend="330" name="getSubElements" returns="array" signature="array getSubElements()" /><scope attributes="abstract protected" doc="Called to process each sub element as sepcified in the return value&#10;of getSubElements().&#10;&#10;@param string $name             The name of the element to process.&#10;@param string $content          The content of the the element.&#10;@param string $whitespaceBefore The whitespace found before this element.&#10;&#10;@return void&#10;@see getSubElements()" ilk="function" line="344" lineend="344" name="processSubElement" signature="void processSubElement(string $name, string $content, string $whitespaceBefore)"><variable citdl="string" ilk="argument" line="344" name="name" /><variable citdl="string" ilk="argument" line="344" name="content" /><variable citdl="string" ilk="argument" line="344" name="whitespaceBefore" /></scope></scope></scope>