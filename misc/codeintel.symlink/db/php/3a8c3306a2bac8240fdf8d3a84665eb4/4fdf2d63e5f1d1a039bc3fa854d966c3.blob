rseLink($tokens)"><variable ilk="argument" line="493" name="tokens" /><variable citdl="PHP_CodeSniffer_CommentParser_SingleElement" line="500" name="link" /></scope><scope attributes="public" doc="Returns the see elements that appear in this doc comment.&#10;&#10;@return array(SingleElement)" ilk="function" line="513" lineend="517" name="getSees" returns="array" signature="array getSees()" /><scope attributes="public" doc="Returns the comment element that appears at the top of this doc comment.&#10;&#10;@return CommentElement" ilk="function" line="525" lineend="529" name="getComment" returns="CommentElement" signature="CommentElement getComment()" /><scope attributes="public" doc="Returns the word list.&#10;&#10;@return array" ilk="function" line="537" lineend="541" name="getWords" returns="array" signature="array getWords()" /><scope attributes="public" doc="Returns the list of found tags.&#10;&#10;@return array" ilk="function" line="549" lineend="553" name="getTags" returns="array" signature="array getTags()" /><scope attributes="public" doc="Returns the link elements found in this comment.&#10;&#10;Returns an empty array if no links are found in the comment.&#10;&#10;@return array(SingleElement)" ilk="function" line="563" lineend="567" name="getLinks" returns="array" signature="array getLinks()" /><scope attributes="public" doc="Returns the deprecated element found in this comment.&#10;&#10;Returns null if no element exists in the comment.&#10;&#10;@return SingleElement" ilk="function" line="577" lineend="581" name="getDeprecated" returns="SingleElement" signature="SingleElement getDeprecated()" /><scope attributes="public" doc="Returns the since element found in this comment.&#10;&#10;Returns null if no element exists in the comment.&#10;&#10;@return SingleElement" ilk="function" line="591" lineend="595" name="getSince" returns="SingleElement" signature="SingleElement getSince()" /><scope attributes="protected" doc="Parses the specified tag.&#10;&#10;@param string $tag   The tag name to parse (omitting the @ symbol from&#10;                     the tag)&#10;@param int    $start The position in the word tokens where this element&#10;                     started.&#10;@param int    $end   The position in the word tokens where this element&#10;                     ended.&#10;&#10;@return void&#10;@throws Exception If the process method for the tag cannot be found." ilk="function" line="611" lineend="642" name="parseTag" signature="void parseTag(string $tag, int $start, int $end)"><variable citdl="string" ilk="argument" line="611" name="tag" /><variable citdl="int" ilk="argument" line="611" name="start" /><variable citdl="int" ilk="argument" line="611" name="end" /><variable citdl="array_keys()" line="616" name="allowedTagNames" /><variable citdl="string" line="620" name="error" /><variable citdl="string" line="618" name="method" /><variable citdl="array_slice()" line="613" name="tokens" /><variable line="615" name="allowedTags" /></scope><scope attributes="protected abstract" doc="Returns a list of tags that this comment parser allows for it's comment.&#10;&#10;Each tag should indicate if only one entry of this tag can exist in the&#10;comment by specifying true as the array value, or false if more than one&#10;is allowed. Each tag should omit the @ symbol. Only tags other than&#10;the standard tags should be returned.&#10;&#10;@return array(string =&gt; boolean)" ilk="function" line="655" lineend="655" name="getAllowedTags" returns="array" signature="array getAllowedTags()" /><scope attributes="public" doc="Returns the tag orders (index =&gt; tagName).&#10;&#10;@return array" ilk="function" line="663" lineend="667" name="getTagOrders" returns="array" signature="array getTagOrders()" /><scope attributes="public" doc="Returns the unknown tags.&#10;&#10;@return array" ilk="function" line="675" lineend="679" name="getUnknown" returns="array" signature="array getUnknown()" /></scope></scope>