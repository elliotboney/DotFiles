<scope ilk="blob" lang="PHP" name="Interval.php" src="/usr/local/pear/share/pear/PhpDocumentor/vendor/symfony/translation/Symfony/Component/Translation/Interval.php"><scope doc="This file is part of the Symfony package.&#10;&#10;(c) Fabien Potencier &lt;fabien@symfony.com&gt;&#10;&#10;For the full copyright and license information, please view the LICENSE&#10;file that was distributed with this source code." ilk="namespace" line="12" name="Symfony\Component\Translation"><scope doc="Tests if a given number belongs to a given math interval.&#10;&#10;An interval can represent a finite set of numbers:&#10;&#10; {1,2,3,4}&#10;&#10;An interval can represent numbers between two numbers:&#10;&#10; [1, +Inf]&#10; ]-1,2[&#10;&#10;The left delimiter can be [ (inclusive) or ] (exclusive).&#10;The right delimiter can be [ (exclusive) or ] (inclusive).&#10;Beside numbers, you can use -Inf and +Inf for the infinite.&#10;&#10;@author Fabien Potencier &lt;fabien@symfony.com&gt;&#10;&#10;@see    http://en.wikipedia.org/wiki/Interval_%28mathematics%29#The_ISO_notation" ilk="class" line="34" lineend="107" name="Interval"><scope attributes="public static" doc="Tests if the given number is in the math interval.&#10;&#10;@param integer $number   A number&#10;@param string  $interval An interval&#10;&#10;@return Boolean&#10;&#10;@throws \InvalidArgumentException" ilk="function" line="46" lineend="71" name="test" returns="Boolean" signature="Boolean test(integer $number, string $interval)"><variable citdl="integer" ilk="argument" line="46" name="number" /><variable citdl="string" ilk="argument" line="46" name="interval" /><variable citdl="self.convertNumber()" line="61" name="leftNumber" /><variable citdl="self.convertNumber()" line="62" name="rightNumber" /><variable attributes="__not_yet_defined__" line="55" name="n" /><variable attributes="__not_yet_defined__" line="54" name="matches" /></scope><scope attributes="public static" doc="Returns a Regexp that matches valid intervals.&#10;&#10;@return string A Regexp (without the delimiters)" ilk="function" line="78" lineend="95" name="getIntervalRegexp" returns="string" signature="string getIntervalRegexp()" /><scope attributes="private static" ilk="function" line="97" lineend="106" name="convertNumber" returns="log()" signature="convertNumber($number)"><variable ilk="argument" line="97" name="number" /></scope></scope></scope></scope>