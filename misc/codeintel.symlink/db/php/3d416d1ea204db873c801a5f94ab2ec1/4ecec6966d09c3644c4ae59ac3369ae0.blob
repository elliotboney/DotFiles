<scope ilk="blob" lang="PHP" name="SandboxedPrint.php" src="/usr/local/pear/share/pear/PhpDocumentor/vendor/twig/twig/lib/Twig/Node/SandboxedPrint.php"><scope classrefs="Twig_Node_Print" doc="Twig_Node_SandboxedPrint adds a check for the __toString() method&#10;when the variable is an object and the sandbox is activated.&#10;&#10;When there is a simple Print statement, like {{ article }},&#10;and if the sandbox is enabled, we need to check that the __toString()&#10;method is allowed if 'article' is an object.&#10;&#10;@author Fabien Potencier &lt;fabien@symfony.com&gt;" ilk="class" line="22" lineend="59" name="Twig_Node_SandboxedPrint"><scope attributes="public __ctor__" ilk="function" line="24" lineend="27" name="__construct" signature="__construct(Twig_Node_Expression $expr, $lineno, $tag = null)"><variable citdl="Twig_Node_Expression" ilk="argument" line="24" name="expr" /><variable ilk="argument" line="24" name="lineno" /><variable default="null" ilk="argument" line="24" name="tag" /></scope><scope attributes="public" doc="Compiles the node to PHP.&#10;&#10;@param Twig_Compiler A Twig_Compiler instance" ilk="function" line="34" lineend="42" name="compile" signature="compile(Twig_Compiler $compiler)"><variable citdl="Twig_Compiler" ilk="argument" line="34" name="compiler" /></scope><scope attributes="protected" doc="Removes node filters.&#10;&#10;This is mostly needed when another visitor adds filters (like the escaper one).&#10;&#10;@param Twig_Node $node A Node" ilk="function" line="51" lineend="58" name="removeNodeFilter" returns="this.removeNodeFilter()" signature="removeNodeFilter(Twig_Node $node)"><variable citdl="Twig_Node" ilk="argument" line="51" name="node" /></scope></scope></scope>