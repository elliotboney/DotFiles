<scope ilk="blob" lang="PHP" name="AutoEscape.php" src="/usr/local/pear/share/pear/PhpDocumentor/vendor/twig/twig/lib/Twig/Node/AutoEscape.php"><scope classrefs="Twig_Node" doc="Represents an autoescape node.&#10;&#10;The value is the escaping strategy (can be html, js, ...)&#10;&#10;The true value is equivalent to html.&#10;&#10;If autoescaping is disabled, then the value is false.&#10;&#10;@author Fabien Potencier &lt;fabien@symfony.com&gt;" ilk="class" line="23" lineend="39" name="Twig_Node_AutoEscape"><scope attributes="public __ctor__" ilk="function" line="25" lineend="28" name="__construct" signature="__construct($value, Twig_NodeInterface $body, $lineno, $tag = 'autoescape')"><variable ilk="argument" line="25" name="value" /><variable citdl="Twig_NodeInterface" ilk="argument" line="25" name="body" /><variable ilk="argument" line="25" name="lineno" /><variable default="'autoescape'" ilk="argument" line="25" name="tag" /></scope><scope attributes="public" doc="Compiles the node to PHP.&#10;&#10;@param Twig_Compiler A Twig_Compiler instance" ilk="function" line="35" lineend="38" name="compile" signature="compile(Twig_Compiler $compiler)"><variable citdl="Twig_Compiler" ilk="argument" line="35" name="compiler" /></scope></scope></scope>