rent&#10;    step in the process and the total number of steps involved.&#10;&#10;@return PreXslWriterEvent" ilk="function" line="65" lineend="70" name="setProgress" returns="PreXslWriterEvent" signature="PreXslWriterEvent setProgress($progress)"><variable ilk="argument" line="65" name="progress" /></scope><scope attributes="public" doc="Returns the current step and tot number of steps as progress.&#10;&#10;@see setProgress() for a complete description of this array.&#10;&#10;@return int[]" ilk="function" line="79" lineend="82" name="getProgress" returns="int" signature="int getProgress()" /></scope></scope></scope>