rieve posts in the proper&#10;freshness order. By updating the menu_order accordingly, we're able to&#10;leverage core WordPress query ordering much more effectively.&#10;&#10;@since bbPress (r3933)&#10;&#10;@global type $wpdb&#10;@param type $reply_id&#10;@param type $reply_position&#10;@return mixed" ilk="function" line="2128" lineend="2147" name="bbp_update_reply_position" returns="mixed" signature="mixed bbp_update_reply_position(type $reply_id = 0, type $reply_position = 0)"><variable citdl="type" default="0" ilk="argument" line="2128" name="reply_id" /><variable citdl="type" default="0" ilk="argument" line="2128" name="reply_position" /></scope><scope doc="Get the position of a reply by querying the DB directly for the replies&#10;of a given topic.&#10;&#10;@since bbPress (r3933)&#10;&#10;@param int $reply_id&#10;@param int $topic_id" ilk="function" line="2158" lineend="2187" name="bbp_get_reply_position_raw" returns="int" signature="bbp_get_reply_position_raw(int $reply_id = 0, int $topic_id = 0)"><variable citdl="int" default="0" ilk="argument" line="2158" name="reply_id" /><variable citdl="int" default="0" ilk="argument" line="2158" name="topic_id" /><variable citdl="bbp_get_all_child_ids()" line="2173" name="topic_replies" /><variable citdl="bbp_get_topic_reply_count()" line="2169" name="reply_count" /><variable citdl="int" line="2163" name="reply_position" /></scope><scope doc="List replies&#10;&#10;@since bbPress (r4944)" ilk="function" line="2196" lineend="2220" name="bbp_list_replies" signature="bbp_list_replies($args = array())"><variable default="array()" ilk="argument" line="2196" name="args" /><variable citdl="bbp_parse_args()" line="2212" name="r" /><variable citdl="BBP_Walker_Reply" line="2215" name="walker" /></scope></scope>