wn for all files, even if&#10;they have no errors or warnings. If verbose output is disabled, we only&#10;show files that have at least one warning or error.&#10;&#10;@param array   $report      Prepared report.&#10;@param boolean $showSources Show sources?&#10;@param int     $width       Maximum allowed line width.&#10;@param boolean $toScreen    Is the report being printed to screen?&#10;&#10;@return string" ilk="function" line="108" lineend="127" name="generate" returns="string" signature="string generate(array $report, boolean $showSources = false, int $width = 80, boolean $toScreen = true)"><variable citdl="array" ilk="argument" line="108" name="report" /><variable citdl="boolean" default="false" ilk="argument" line="108" name="showSources" /><variable citdl="int" default="80" ilk="argument" line="108" name="width" /><variable citdl="boolean" default="true" ilk="argument" line="108" name="toScreen" /><variable citdl="this.generateMessage()" line="114" name="msg" /></scope><scope attributes="protected" doc="Generate the error message to show to the user.&#10;&#10;@param array $report CS report data.&#10;&#10;@return string Error message or NULL if no error/warning found." ilk="function" line="137" lineend="162" name="generateMessage" returns="string" signature="string generateMessage(array $report)"><variable citdl="array" ilk="argument" line="137" name="report" /><variable citdl="report" line="140" name="allWarnings" /><variable citdl="string" line="147" name="msg" /><variable citdl="report" line="139" name="allErrors" /></scope><scope attributes="protected" doc="Tell the user that all is fine and no error/warning has been found.&#10;&#10;@return void" ilk="function" line="170" lineend="178" name="notifyAllFine" signature="void notifyAllFine()"><variable citdl="this.getBasicCommand()" line="172" name="cmd" /></scope><scope attributes="protected" doc="Tell the user that errors/warnings have been found.&#10;&#10;@param string $msg Message to display.&#10;&#10;@re