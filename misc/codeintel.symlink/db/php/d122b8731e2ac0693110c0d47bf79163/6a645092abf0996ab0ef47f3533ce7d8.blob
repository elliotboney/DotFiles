r registered.&#10;The Event_Dispatcher will be add on first observer registration, and&#10;will be removed with the last observer.&#10;&#10;@var    integer&#10;@since  1.8.0b2&#10;@access private" line="135" name="_observerCount" /><variable citdl="string" doc="@var string Earliest version of PHP to use&#10;@since  0.7.0" line="141" name="latest_version" /><variable citdl="string" doc="@var string Last version of PHP to use" line="146" name="earliest_version" /><variable citdl="array" doc="@var array Parsing options" line="151" name="options" /><variable citdl="array" doc="@var array Data Source&#10;@since  1.8.0b2" line="157" name="dataSource" /><variable citdl="array" doc="@var array Directory list found when parsing data source&#10;@since  1.8.0b2&#10;@see    getDirlist()" line="164" name="directories" /><variable citdl="array" doc="@var array List of files ignored when parsing data source&#10;@since  1.8.0b2&#10;@see    getIgnoredFiles()" line="171" name="ignored_files" /><variable citdl="array" doc="@var array Result of the latest data source parsing&#10;@since  1.9.0b1&#10;@see    parseData()" line="178" name="latest_parse" /><scope attributes="__ctor__" doc="Class constructor (ZE1) for PHP4&#10;&#10;@access public&#10;@since  version 1.8.0b2 (2008-06-03)" ilk="function" line="186" lineend="189" name="PHP_CompatInfo_Parser" signature="PHP_CompatInfo_Parser()" /><scope attributes="__ctor__" doc="Class constructor (ZE2) for PHP5+&#10;&#10;@access public&#10;@since  version 1.8.0b2 (2008-06-03)" ilk="function" line="197" lineend="207" name="__construct" signature="__construct()" /><scope doc="Set up driver to be used&#10;&#10;Set up driver to be used, dependant on specified type.&#10;&#10;@param string $type Name the type of driver (html, text...)&#10;@param array  $conf A hash containing any additional configuration&#10;&#10;@access public&#10;@return void&#10;@since  version 1.8.0b2 (2008-06-03)" ilk="function" line="221" lineend="2