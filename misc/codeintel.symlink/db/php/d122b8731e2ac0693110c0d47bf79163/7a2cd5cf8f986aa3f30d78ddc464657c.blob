efault="'array'" ilk="argument" line="225" name="type" /><variable citdl="array" default="array()" ilk="argument" line="225" name="conf" /><variable citdl="str_replace()" line="228" name="file" /><variable line="241" name="instance" /><variable citdl="string" line="227" name="class" /></scope><scope doc="Update the current view&#10;&#10;Interface to update the view with current information.&#10;Listen events produced by Event_Dispatcher and the PHP_CompatInfo_Parser&#10;&#10;@param object &amp;$auditEvent Instance of Event_Dispatcher&#10;&#10;@return void&#10;@access public&#10;@since  version 1.8.0b2 (2008-06-03)" ilk="function" line="261" lineend="291" name="update" signature="void update(&amp; $auditEvent)"><variable ilk="argument" line="261" name="auditEvent" /><variable citdl="auditEvent.getNotificationName()" line="263" name="notifyName" /><variable citdl="auditEvent.getNotificationInfo()" line="264" name="notifyInfo" /></scope><scope doc="Initialize the wait process&#10;&#10;Initialize the wait process, with a simple message or a progress bar.&#10;&#10;@param integer $maxEntries Number of source to parse&#10;&#10;@return void&#10;@access public&#10;@since  version 1.8.0b2 (2008-06-03)" ilk="function" line="304" lineend="324" name="startWaitProgress" signature="void startWaitProgress(integer $maxEntries)"><variable citdl="integer" ilk="argument" line="304" name="maxEntries" /></scope><scope doc="Update the wait message&#10;&#10;Update the wait message, or status of the progress bar&#10;&#10;@param string $source Source (file, string) currently parsing&#10;@param string $index  Position of the $source in the data source list&#10;                      to parse&#10;&#10;@return void&#10;@access public&#10;@since  version 1.8.0b2 (2008-06-03)" ilk="function" line="339" lineend="356" name="stillWaitProgress" signature="void stillWaitProgress(string $source, string $index)"><variable citdl="string" ilk="argument" line="339" name="source" /><variable citdl="string" ilk="argument" line="339" name="index" /></scope><scope doc="Finish the wait process&#10;&#10;Finish the wait process, by erasing the progress bar&#10;&#10;@return void&#10;@access public&#10;@since  version 1.8.0b2 (2008-06-03)" ilk="function" line="367" lineend="376" name="endWaitProgress" signature="void endWaitProgress()" /><scope doc="Checks if in the include path&#10;&#10;Returns whether or not a file is in the include path&#10;&#10;@param string $file Path to filename to check if includable&#10;&#10;@static&#10;@access public&#10;@return boolean True if the file is in the include path, false otherwise&#10;@since  version 1.7.0b4 (2008-04-03)" ilk="function" line="390" lineend="400" name="isIncludable" returns="boolean" signature="boolean isIncludable(string $file)"><variable citdl="string" ilk="argument" line="390" name="file" /><variable attributes="__not_yet_defined__" line="392" name="ip" /></scope><scope doc="Utility function which wraps PHP's class_exists() function to ensure&#10;consistent behavior between PHP versions 4 and 5. Autoloading behavior&#10;is always disabled.&#10;&#10;@param string $class The name of the class whose existence should be tested.&#10;&#10;@return bool         True if the class exists, false otherwiser.&#10;&#10;@static&#10;@access private&#10;@since  version 1.8.0b2 (2008-06-03)" ilk="function" line="415" lineend="422" name="_classExists" returns="bool" signature="bool _classExists(string $class)"><variable citdl="string" ilk="argument" line="415" name="class" /></scope></scope></scope>