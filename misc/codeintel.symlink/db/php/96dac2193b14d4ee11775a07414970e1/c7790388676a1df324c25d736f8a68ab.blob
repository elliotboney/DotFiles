m string $type name of defined type&#10;@param string $ns namespace of type&#10;@return mixed&#10;@access public&#10;@deprecated" ilk="function" line="687" lineend="696" name="getPHPType" returns="mixed" signature="mixed getPHPType(string $type, string $ns)"><variable citdl="string" ilk="argument" line="687" name="type" /><variable citdl="string" ilk="argument" line="687" name="ns" /></scope><scope doc="returns an associative array of information about a given type&#10;returns false if no type exists by the given name&#10;&#10;For a complexType typeDef = array(&#10;'restrictionBase' =&gt; '',&#10;'phpType' =&gt; '',&#10;'compositor' =&gt; '(sequence|all)',&#10;'elements' =&gt; array(), // refs to elements array&#10;'attrs' =&gt; array() // refs to attributes array&#10;... and so on (see addComplexType)&#10;)&#10;&#10;  For simpleType or element, the array has different keys.&#10;&#10;@param string $type&#10;@return mixed&#10;@access public&#10;@see addComplexType&#10;@see addSimpleType&#10;@see addElement" ilk="function" line="720" lineend="789" name="getTypeDef" returns="mixed" signature="mixed getTypeDef(string $type)"><variable citdl="string" ilk="argument" line="720" name="type" /><variable citdl="this.getTypeDef()" line="739" name="etype" /><variable citdl="int" line="723" name="is_element" /><variable citdl="substr()" line="737" name="uqType" /><variable citdl="substr()" line="738" name="ns" /></scope><scope doc="returns a sample serialization of a given type, or false if no type by the given name&#10;&#10;@param string $type name of type&#10;@return mixed&#10;@access public&#10;@deprecated" ilk="function" line="799" lineend="823" name="serializeTypeDef" returns="mixed" signature="mixed serializeTypeDef(string $type)"><variable citdl="string" ilk="argument" line="799" name="type" /><variable attributes="__not_yet_defined__" line="804" name="data" /><variable attributes="__not_yet_defined__" line="811" name="eData" /><variable line="804" name="attName" /><variable line="811" name="element" /><variable line="801" name="typeDef" /></scope><scope doc="returns HTML form elements that allow a user&#10;to enter values for creating an instance of the given type.&#10;&#10;@param string $name name for type instance&#10;@param string $type name of type&#10;@return string&#10;@access public&#10;@deprecated" ilk="function" line="835" lineend="864" name="typeToForm" returns="string" signature="string typeToForm(string $name, string $type)"><variable citdl="string" ilk="argument" line="835" name="name" /><variable citdl="string" ilk="argument" line="835" name="type" /><variable line="841" name="child" /><variable line="850" name="i" /><variable line="837" name="typeDef" /><variable attributes="__not_yet_defined__" line="841" name="childDef" /></scope><scope doc="adds a complex type to the schema&#10;&#10;example: array&#10;&#10;addType(&#10;	'ArrayOfstring',&#10;	'complexType',&#10;	'array',&#10;	'',&#10;	'SOAP-ENC:Array',&#10;	array('ref'=&gt;'SOAP-ENC:arrayType','wsdl:arrayType'=&gt;'string[]'),&#10;	'xsd:string'&#10;);&#10;&#10;example: PHP associative array ( SOAP Struct )&#10;&#10;addType(&#10;	'SOAPStruct',&#10;	'complexType',&#10;	'struct',&#10;	'all',&#10;	array('myVar'=&gt; array('name'=&gt;'myVar','type'=&gt;'string')&#10;);&#10;&#10;@param name&#10;@param typeClass (complexType|simpleType|attribute)&#10;@param phpType: currently supported are array and struct (php assoc array)&#10;@param compositor (all|sequence|choice)&#10;@param restrictionBase namespace:name (http://schemas.xmlsoap.org/soap/encoding/:Array)&#10;@param elements = array ( name = array(name=&gt;'',type=&gt;'') )&#10;@param attrs = array(&#10;	array(&#10;	'ref' =&gt; &quot;http://schemas.xmlsoap.org/soap/encoding/:arrayType&quot;,&#10;	&quot;http://schemas.xmlsoap.org/wsdl/:arrayType&quot; =&gt; &quot;string[]&quot;&#10;	)&#10;)&#10;@param arrayType: namespace:name (http://www.w3.org/2001/XMLSchema:string)&#10;@access public&#10;@see getTypeDef" ilk="function" line="907" lineend="921" name="addComplexType" signature="addComplexType($name, $typeClass = 'complexType', $phpType = 'array', $compositor = '', $restrictionBase = '', $elements = array(), $attrs = array(), $arrayType = '')"><variable ilk="argument" line="907" name="name" /><variable default="'complexType'" ilk="argument" line="907" name="typeClass" /><variable default="'array'" ilk="argument" line="907" name="phpType" /><variable default="''" ilk="argument" line="907" name="compositor" /><variable default="''" ilk="argument" line="907" name="restrictionBase" /><variable default="array()" ilk="argument" line="907" name="elements" /><variable default="array()" ilk="argument" line="907" name="attrs" /><variable default="''" ilk="argument" line="907" name="arrayType" /></scope><scope doc="adds a simple type to the schema&#10;&#10;@param string $name&#10;@param string $restrictionBase namespace:name (http://schemas.xmlsoap.org/soap/encoding/:Array)&#10;@param string $typeClass (should always be simpleType)&#10;@param string $phpType (should always be scalar)&#10;@param array $enumeration array of values&#10;@access public&#10;@see nusoap_xmlschema&#10;@see getTypeDef" ilk="function" line="935" lineend="946" name="addSimpleType" signature="addSimpleType(string $name, string $restrictionBase = '', string $typeClass = 'simpleType', string $phpType = 'scalar', array $enumeration = array())"><variable citdl="string" ilk="argument" line="935" name="name" /><variable citdl="string" default="''" ilk="argument" line="935" name="restrictionBase" /><variable citdl="string" default="'simpleType'" ilk="argument" line="935" name="typeClass" /><variable citdl="string" default="'scalar'" ilk="argument" line="935" name="phpType" /><variable citdl="array" default="array()" ilk="argument" line="935" name="enumeration" /></scope><scope doc="adds an element to the schema&#10;&#10;@param array $attrs attributes that must include name and type&#10;@see nusoap_xmlschema&#10;@access public" ilk="function" line="955" lineend="964" name="addElement" signature="addElement(array $attrs)"><variable citdl="array" ilk="argument" line="955" name="attrs" /></scope></scope><scope classrefs="nusoap_xmlschema" doc="Backward compatibility" ilk="class" line="970" lineend="971" name="XMLSchema" /></scope>