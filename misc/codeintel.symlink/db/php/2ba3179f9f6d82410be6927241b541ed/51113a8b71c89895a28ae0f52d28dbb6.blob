<scope ilk="blob" lang="PHP" name="classes.php" src="/private/var/www/paperless/wp-content/plugins/bbpress/includes/common/classes.php"><scope doc="bbPress Component Class&#10;&#10;The bbPress component class is responsible for simplifying the creation&#10;of components that share similar behaviors and routines. It is used&#10;internally by bbPress to create forums, topics and replies, but can be&#10;extended to create other really neat things.&#10;&#10;@package bbPress&#10;@subpackage Classes&#10;&#10;@since bbPress (r2688)" ilk="class" line="27" lineend="172" name="BBP_Component"><variable citdl="string" doc="@var string Unique name (for internal identification)&#10;@internal" line="33" name="name" /><variable citdl="Unique" doc="@var Unique ID (normally for custom post type)" line="38" name="id" /><variable citdl="string" doc="@var string Unique slug (used in query string and permalinks)" line="43" name="slug" /><variable citdl="WP_Query" doc="@var WP_Query The loop for this component" line="48" name="query" /><variable citdl="string" doc="@var string The current ID of the queried object" line="53" name="current_id" /><scope attributes="public __ctor__" doc="bbPress Component loader&#10;&#10;@since bbPress (r2700)&#10;&#10;@param mixed $args Required. Supports these args:&#10; - name: Unique name (for internal identification)&#10; - id: Unique ID (normally for custom post type)&#10; - slug: Unique slug (used in query string and permalinks)&#10; - query: The loop for this component (WP_Query)&#10; - current_id: The current ID of the queried object&#10;@uses BBP_Component::setup_globals() Setup the globals needed&#10;@uses BBP_Component::includes() Include the required files&#10;@uses BBP_Component::setup_actions() Setup the hooks and actions" ilk="function" line="73" lineend="80" name="__construct" signature="__construct(mixed $args = '')"><variable citdl="mixed" default="''" ilk="argument" line="73" name="args" /></scope><scope attributes="private" doc="Component global variables&#10;&#10;@since bbPress (r2700)&#10;@access private&#10;&#10;@uses apply_filters() Calls 'bbp_{@link BBP_Component::name}_id'&#10;@uses apply_filters() Calls 'bbp_{@link BBP_Component::name}_slug'" ilk="function" line="91" lineend="95" name="setup_globals" signature="setup_globals($args = '')"><variable default="''" ilk="argument" line="91" name="args" /></scope><scope attributes="private" doc="Include required files&#10;&#10;@since bbPress (r2700)&#10;@access private&#10;&#10;@uses do_action() Calls 'bbp_{@link BBP_Component::name}includes'" ilk="function" line="105" lineend="107" name="includes" signature="includes()" /><scope attributes="private" doc="Setup the actions&#10;&#10;@since bbPress (r2700)&#10;@access private&#10;&#10;@uses add_action() To add various actions&#10;@uses do_action() Calls&#10;                   'bbp_{@link BBP_Component::name}setup_actions'" ilk="function" line="119" lineend="127" name="setup_actions" signature="setup_actions()" /><scope attributes="public" doc="Setup the component post types&#10;&#10;@since bbPress (r2700)&#10;&#10;@uses do_action() Calls 'bbp_{@link BBP_Component::name}_register_post_types'" ilk="function" line="136" lineend="138" name="register_post_types" signature="register_post_types()" /><scope attributes="public" doc="Register component specific taxonomies&#10;&#10;@since bbPress (r2700)&#10;&#10;@uses do_action() Calls 'bbp_{@link BBP_Component::name}_register_taxonomies'" ilk="function" line="147" lineend="149" name="register_taxonomies" signature="register_taxonomies()" /><scope attributes="public" doc="Add any additional rewrite tags&#10;&#10;@since bbPress (r2700)&#10;&#10;@uses do_action() Calls 'bbp_{@link BBP_Component::name}_add_rewrite_tags'" ilk="function" line="158" lineend="160" name="add_rewrite_tags" signature="add_rewrite_tags()" /><scope attributes="public" doc="Generate any additional rewrite rules&#10;&#10;@since bbPress (r2700)&#10;&#10;@uses do_action() Calls 'bbp_{@link BBP_Component::name}_generate_rewrite_rules'" ilk="function" line="169" lineend="171" name="generate_rewrite_rules" signature="generate_rewrite_rules($wp_rewrite)"><variable ilk="argument" line="169" name="wp_rewrite" /></scope></scope><scope classrefs="Walker" doc="Create HTML dropdown list of bbPress forums/topics.&#10;&#10;@package bbPress&#10;@subpackage Classes&#10;&#10;@since bbPress (r2746)&#10;@uses Walker" ilk="class" line="185" lineend="261" name="BBP_Walker_Dropdown"><variable citdl="string" doc="@see Walker::$tree_type&#10;&#10;@since bbPress (r2746)&#10;&#10;@var string" line="194" name="tree_type" /><variable citdl="array" doc="@see Walker::$db_fields&#10;&#10;@since bbPress (r2746)&#10;&#10;@var array" line="203" name="db_fields" /><scope attributes="public __ctor__" doc="Set the tree_type&#10;&#10;@since bbPress (r2746)" ilk="function" line="212" lineend="214" name="__construct" signature="__construct()" /><scope attributes="public" doc="@see Walker::start_el()&#10;&#10;@since bbPress (r2746)&#10;&#10;@param string $output Passed by reference. Used to append additional&#10;                       content.&#10;@param object $_post Post data object.&#10;@param int $depth Depth of post in reference to parent posts. Used&#10;                   for padding.&#10;@param array $args Uses 'selected' argument for selected post to set&#10;                    selected HTML attribute for option element.&#10;@param int $current_object_id&#10;@uses bbp_is_forum_category() To check if the forum is a category&#10;@uses current_user_can() To check if the current user can post in&#10;                          closed forums&#10;@uses bbp_is_forum_closed() To check if the forum is closed&#10;@uses apply_filters() Calls 'bbp_walker_dropdown_post_title' with the&#10;                       title, output, post, depth and args" ilk="function" line="236" lineend="260" name="start_el" signature="start_el(string &amp; $output, $object, int $depth = 0, array $args = array(), int $cur