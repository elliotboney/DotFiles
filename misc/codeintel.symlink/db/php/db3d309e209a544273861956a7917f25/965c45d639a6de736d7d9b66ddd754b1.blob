<scope ilk="blob" lang="PHP" name="XMLDocBookConverter.inc" src="/usr/local/pear/share/pear/PhpDocumentor/phpDocumentor/Converters/XML/DocBook/XMLDocBookConverter.inc"><scope classrefs="Converter" doc="XML DocBook converter.&#10;This Converter takes output from the {@link Parser} and converts it to DocBook output&#10;&#10;@package Converters&#10;@subpackage XMLDocBook&#10;@see parserDocBlock, parserInclude, parserPage, parserClass, parserDefine, parserFunction, parserMethod, parserVar&#10;@author Greg Beaver &lt;cellog@php.net&gt;&#10;@since 1.0&#10;@version $Id: XMLDocBookConverter.inc 317233 2011-09-24 04:30:11Z ashnazg $&#10;@todo indexes for other DocBook converters not based on peardoc&#10;@todo templates" ilk="class" line="43" lineend="1786" name="XMLDocBookConverter"><variable citdl="boolean" doc="XMLDocBookConverter wants elements sorted by type as well as alphabetically&#10;@see Converter::$sort_page_contents_by_type&#10;@var boolean" line="50" name="sort_page_contents_by_type" /><variable citdl="string" doc="@var string" line="52" name="outputformat" /><variable citdl="string" doc="@var string" line="54" name="name" /><variable citdl="array" doc="indexes of elements by package that need to be generated&#10;@var array" line="59" name="leftindex" /><variable citdl="boolean" doc="whether a @see is going to be in the {@link $base_dir}, or in a package/subpackage subdirectory of $base_dir&#10;@var boolean" line="64" name="local" /><variable citdl="string" doc="name of current page being converted&#10;@var string" line="70" name="page" /><variable citdl="string" doc="path of current page being converted&#10;@var string" line="76" name="path" /><variable citdl="string" doc="name of current class being converted&#10;@var string" line="82" name="class" /><variable citdl="Template" doc="template for the procedural page currently being processed&#10;@var Template" line="88" name="page_data" /><variable citdl="string" doc="output directory for the current procedural page being processed&#10;@var string" line="94" name="page_dir" /><variable citdl="string" doc="target directory passed on the command-line.&#10;{@link $targetDir} is malleable, always adding package/ and package/subpackage/ subdirectories onto it.&#10;@var string" line="101" name="base_dir" /><variable citdl="string" doc="output directory for the current class being processed&#10;@var string" line="107" name="class_dir" /><variable citdl="Template" doc="template for the class currently being processed&#10;@var Template" line="113" name="class_data" /><variable citdl="array" doc="array of converted package page names.&#10;Used to link to the package page in the left index&#10;@var array Format: array(package =&gt; 1)" line="120" name="package_pages" /><variable citdl="boolean" doc="controls formatting of parser informative output&#10;&#10;Converter prints:&#10;&quot;Converting /path/to/file.php... Procedural Page Elements... Classes...&quot;&#10;Since HTMLdefaultConverter outputs files while converting, it needs to send a \n to start a new line.  However, if there&#10;is more than one class, output is messy, with multiple \n's just between class file output.  This variable prevents that&#10;and is purely cosmetic&#10;@var boolean" line="132" name="juststarted" /><variable citdl="array" doc="contains all of the template procedural page element loop data needed for the current template&#10;@var array" line="138" name="current" /><variable citdl="array" doc="contains all of the template class element loop data needed for the current template&#10;@var array" line="144" name="currentclass" /><variable citdl="array" doc="template options.  Currently only 1 recognized option usepear&#10;&#10;usepear tells the getLink() function to return a package link to PEAR and PEAR_ERROR if possible, and to link directly&#10;to the fully-delimited link package#class.method or package#file.method in PEAR style, if possible, even if the&#10;package is not parsed.  This will allow parsing of separate PEAR packages without parsing the entire thing at once!&#10;@var array" line="153" name="template_options" /><variable citdl="array()" line="155" name="function_data" /><variable citdl="array()" line="156" name="method_data" /><variable citdl="element" line="157" name="sourceloc" /><variable citdl="string" doc="peardoc2 Category&#10;@var string" line="162" name="category" /><scope attributes="__ctor__" doc="sets {@link $base_dir} to $targetDir&#10;@see Converter()" ilk="function" line="167" lineend="170" name="XMLDocBookConverter" signature="XMLDocBookConverter(&amp; $allp, &amp; $packp, &amp; $classes, &amp; $procpages, $po, $pp, $qm, $targetDir, $templateDir, $title)"><variable ilk="argument" line="167" name="allp" /><variable ilk="argument" line="167" name="packp" /><variable ilk="argument" line="167" name="classes" /><variable ilk="argument" line="167" name="procpages" /><variable ilk="argument" line="167" name="po" /><variable ilk="argument" line="167" name="pp" /><variable ilk="argument" line="167" name="qm" /><variable ilk="argument" line="167" name="targetDir" /><variable ilk="argument" line="167" name="templateDir" /><variable ilk="argument" line="167" name="title" /></scope><scope doc="do that stuff in $template_options" ilk="function" line="175" lineend="178" name="getLink" returns="Converter.getLink()" signature="&amp;getLink($expr, $package = false, $packages = false)"><variable ilk="argument" line="175" name="expr" /><variable default="false" ilk="argument" line="175" name="package" /><variable default="false" ilk="argument" line="175" name="packages" /></scope><scope ilk="function" line="180" lineend="184" name="unmangle" returns="string" signature="unmangle($s, $sourcecode)"><variable ilk="argument" line="180" name="s" /><variable ilk="argument" line="180" name="sourcecode" /></scope><scope ilk="function" line="186" lineend="203" name="type_adjust" returns="typename" signature="type_adjust($typename)"><variable ilk="argument" line="186" n