<scope ilk="blob" lang="PHP" name="AbstractScopeSniff.php" src="/usr/local/pear/share/pear/PHP/CodeSniffer/Standards/AbstractScopeSniff.php"><scope attributes="abstract" doc="An AbstractScopeTest allows for tests that extend from this class to&#10;listen for tokens within a particular scope.&#10;&#10;Below is a test that listens to methods that exist only within classes:&#10;&lt;code&gt;&#10;class ClassScopeTest extends PHP_CodeSniffer_Standards_AbstractScopeSniff&#10;{&#10;    public function __construct()&#10;    {&#10;        parent::__construct(array(T_CLASS), array(T_FUNCTION));&#10;    }&#10;&#10;    protected function processTokenWithinScope(PHP_CodeSniffer_File $phpcsFile, $)&#10;    {&#10;        $className = $phpcsFile-&gt;getDeclarationName($currScope);&#10;        echo 'encountered a method within class '.$className;&#10;    }&#10;}&#10;&lt;/code&gt;&#10;&#10;@category  PHP&#10;@package   PHP_CodeSniffer&#10;@author    Greg Sherwood &lt;gsherwood@squiz.net&gt;&#10;@author    Marc McIntyre &lt;mmcintyre@squiz.net&gt;&#10;@copyright 2006-2012 Squiz Pty Ltd (ABN 77 084 670 600)&#10;@license   https://github.com/squizlabs/PHP_CodeSniffer/blob/master/licence.txt BSD Licence&#10;@version   Release: 1.4.6&#10;@link      http://pear.php.net/package/PHP_CodeSniffer" ilk="class" interfacerefs="PHP_CodeSniffer_Sniff" line="47" lineend="199" name="PHP_CodeSniffer_Standards_AbstractScopeSniff"><variable attributes="private" citdl="array" doc="The token types that this test wishes to listen to within the scope.&#10;&#10;@var array" line="55" name="_tokens" /><variable attributes="private" citdl="string" doc="The type of scope opener tokens that this test wishes to listen to.&#10;&#10;@var string" line="62" name="_scopeTokens" /><variable attributes="private" citdl="boolean" doc="True if this test should fire on tokens outside of the scope.&#10;&#10;@var boolean" line="69" name="_listenOutside" /><scope attributes="public __ctor__" doc="Constructs a new AbstractScopeTest.&#10;&#10;@param array   $scopeTokens   The type of scope the test wishes to listen to.&#10;@param array   $tokens        The tokens that the test wishes to listen to&#10;                              within the scope.&#10;@param boolean $listenOutside If true this test will also alert the&#10;                              extending class when a token is found outside&#10;                              the scope, by calling the&#10;                              processTokenOutsideScope method.&#10;&#10;@see PHP_CodeSniffer.getValidScopeTokeners()&#10;@throws PHP_CodeSniffer_Exception If the specified tokens array is empty." ilk="function" line="86" lineend="112" name="__construct" signature="__construct(array $scopeTokens, array $tokens, boolean $listenOutside = false)"><variable citdl="array" ilk="argument" line="86" name="scopeTokens" /><variable citdl="array" ilk="argument" line="86" name="tokens" /><variable citdl="boolean" default="false" ilk="argument" line="86" name="listenOutside" /><variable citdl="string" line="92" name="error" /><variable citdl="array_intersect()" line="101" name="invalidScopeTokens" /><variable citdl="implode()" line="103" name="invalid" /></scope><scope attributes="public final" doc="The method that is called to register the tokens this test wishes to&#10;listen to.&#10;&#10;DO NOT OVERRIDE THIS METHOD. Use the constructor of this class to register&#10;for the desired tokens and scope.&#10;&#10;@return array(int)&#10;@see __constructor()" ilk="function" line="125" lineend="129" name="register" returns="array" signature="array register()" /><scope attributes="public final" doc="Processes the tokens that this test is listening for.&#10;&#10;@param PHP_CodeSniffer_File $phpcsFile The file where this token was found.&#10;@param int                  $stackPtr  The position in the stack where this&#10;                                       token was found.&#10;&#10;@return void&#10;@see processTokenWithinScope()" ilk="function" line="142" lineend="158" name="process" signature="void process(PHP_CodeSniffer_File $phpcsFile, int $stackPtr)"><variable citdl="PHP_CodeSniffer_File" ilk="argument" line="142" name="phpcsFile" /><variable citdl="int" ilk="argument" line="142" name="stackPtr" /><variable attributes="__not_yet_defined__" line="147" name="code" /><variable citdl="phpcsFile.getTokens()" line="144" name="tokens" /><variable citdl="boolean" line="146" name="foundScope" /><variable line="147" name="scope" /></scope><scope attributes="protected abstract" doc="Processes a token that is found within the scope that this test is&#10;listening to.&#10;&#10;@param PHP_CodeSniffer_File $phpcsFile The file where this token was found.&#10;@param int                  $stackPtr  The position in the stack where this&#10;                                       token was found.&#10;@param int                  $currScope The position in the tokens array that&#10;                                       opened the scope that this test is&#10;                                       listening for.&#10;&#10;@return void" ilk="function" line="174" lineend="174" name="processTokenWithinScope" signature="void processTokenWithinScope(PHP_CodeSniffer_File $phpcsFile, int $stackPtr, int $currScope)"><variable citdl="PHP_CodeSniffer_File" ilk="argument" line="174" name="phpcsFile" /><variable citdl="int" ilk="argument" line="174" name="stackPtr" /><variable citdl="int" ilk="argument" line="174" name="currScope" /></scope><scope attributes="protected" doc="Processes a token that is found within the scope that this test is&#10;listening to.&#10;&#10;@param PHP_CodeSniffer_File $phpcsFile The file where this token was found.&#10;@param int                  $stackPtr  The position in the stack where this&#10;                                       token was found.&#10;&#10;@return void" ilk="function" line="191" lineend="196" name="processTokenOutsideScope" signature="void processTokenOutsideScope(PHP_CodeSniffer_File $phpcsFile, int 