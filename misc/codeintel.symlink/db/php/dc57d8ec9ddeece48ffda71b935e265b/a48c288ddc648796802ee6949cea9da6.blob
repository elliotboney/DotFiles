cified PHP_CodeSniffer_File.&#10;&#10;@param PHP_CodeSniffer_File $phpcsFile The PHP_CodeSniffer file where this&#10;                                       token was found.&#10;@param int                  $stackPtr  The position where the token was found.&#10;@param array                $currScope The current scope opener token.&#10;&#10;@return void" ilk="function" line="96" lineend="160" name="processTokenWithinScope" signature="void processTokenWithinScope(PHP_CodeSniffer_File $phpcsFile, int $stackPtr, array $currScope)"><variable citdl="PHP_CodeSniffer_File" ilk="argument" line="96" name="phpcsFile" /><variable citdl="int" ilk="argument" line="96" name="stackPtr" /><variable citdl="array" ilk="argument" line="96" name="currScope" /><variable citdl="string" line="129" name="error" /><variable citdl="phpcsFile.getMethodProperties()" line="118" name="methodProps" /><variable citdl="phpcsFile.getTokens()" line="107" name="tokens" /><variable citdl="string" line="142" name="pattern" /></scope><scope attributes="protected final" doc="Processes the token outside the scope in the file.&#10;&#10;@param PHP_CodeSniffer_File $phpcsFile The PHP_CodeSniffer file where this&#10;                                       token was found.&#10;@param int                  $stackPtr  The position where the token was found.&#10;&#10;@return void" ilk="function" line="172" lineend="190" name="processTokenOutsideScope" signature="void processTokenOutsideScope(PHP_CodeSniffer_File $phpcsFile, int $stackPtr)"><variable citdl="PHP_CodeSniffer_File" ilk="argument" line="172" name="phpcsFile" /><variable citdl="int" ilk="argument" line="172" name="stackPtr" /><variable citdl="phpcsFile.getTokens()" line="176" name="tokens" /><variable citdl="string" line="184" name="pattern" /></scope><scope attributes="abstract protected" doc="Called to process class member vars.&#10;&#10;@param PHP_CodeSniffer_File $phpcsFile The PHP_CodeSniffer file where this&#10;                                       token was found.&#10;@param int                  $stackPtr  The position where the token was found.&#10;&#10;@return void" ilk="function" line="202" lineend="202" name="processMemberVar" signature="void processMemberVar(PHP_CodeSniffer_File $phpcsFile, int $stackPtr)"><variable citdl="PHP_CodeSniffer_File" ilk="argument" line="202" name="phpcsFile" /><variable citdl="int" ilk="argument" line="202" name="stackPtr" /></scope><scope attributes="abstract protected" doc="Called to process normal member vars.&#10;&#10;@param PHP_CodeSniffer_File $phpcsFile The PHP_CodeSniffer file where this&#10;                                       token was found.&#10;@param int                  $stackPtr  The position where the token was found.&#10;&#10;@return void" ilk="function" line="217" lineend="217" name="processVariable" signature="void processVariable(PHP_CodeSniffer_File $phpcsFile, int $stackPtr)"><variable citdl="PHP_CodeSniffer_File" ilk="argument" line="217" name="phpcsFile" /><variable citdl="int" ilk="argument" line="217" name="stackPtr" /></scope><scope attributes="abstract protected" doc="Called to process variables found in double quoted strings or heredocs.&#10;&#10;Note that there may be more than one variable in the string, which will&#10;result only in one call for the string or one call per line for heredocs.&#10;&#10;@param PHP_CodeSniffer_File $phpcsFile The PHP_CodeSniffer file where this&#10;                                       token was found.&#10;@param int                  $stackPtr  The position where the double quoted&#10;                                       string was found.&#10;&#10;@return void" ilk="function" line="236" lineend="236" name="processVariableInString" signature="void processVariableInString(PHP_CodeSniffer_File $phpcsFile, int $stackPtr)"><variable citdl="PHP_CodeSniffer_File" ilk="argument" line="236" name="phpcsFile" /><variable citdl="int" ilk="argument" line="236" name="stackPtr" /></scope></scope></scope>