<scope ilk="blob" lang="PHP" name="LogEvent.php" src="/usr/local/pear/share/pear/PhpDocumentor/src/phpDocumentor/Parser/Event/LogEvent.php"><scope doc="phpDocumentor&#10;&#10;PHP Version 5.3&#10;&#10;@author    Mike van Riel &lt;mike.vanriel@naenius.com&gt;&#10;@copyright 2010-2012 Mike van Riel / Naenius (http://www.naenius.com)&#10;@license   http://www.opensource.org/licenses/mit-license.php MIT&#10;@link      http://phpdoc.org" ilk="namespace" line="12" name="phpDocumentor\Parser\Event"><scope classrefs="\phpDocumentor\Event\EventAbstract" doc="Event for capturing events during the parsing of a file.&#10;&#10;These events represent errors and warning found during processing of the file.&#10;&#10;@author    Mike van Riel &lt;mike.vanriel@naenius.com&gt;&#10;@copyright 2010-2012 Mike van Riel / Naenius (http://www.naenius.com)&#10;@license   http://www.opensource.org/licenses/mit-license.php MIT" ilk="class" line="23" lineend="142" name="LogEvent"><variable attributes="protected" citdl="string" doc="@var string" line="26" name="message" /><variable attributes="protected" citdl="string" doc="@var string" line="29" name="type" /><variable attributes="protected" citdl="int" doc="@var int" line="32" name="code" /><variable attributes="protected" citdl="int" doc="@var int" line="35" name="line" /><scope attributes="public" doc="Sets the numeric code for this event.&#10;&#10;Each parsing event should have a numeric code that does not overlap with&#10;other errors. These codes and their messages are commonly found in the&#10;Messages folder of your installed plugin.&#10;&#10;@param int $code&#10;&#10;@return LogEvent" ilk="function" line="48" lineend="53" name="setCode" returns="LogEvent" signature="LogEvent setCode(int $code)"><variable citdl="int" ilk="argument" line="48" name="code" /></scope><scope attributes="public" doc="Returns the numeric code associated with this event.&#10;&#10;@see setCode for a complete description.&#10;&#10;@return int" ilk="function" line="62" lineend="65" name="getCode" returns="int" signature="int getCode()" /><scope attributes="public" doc="Sets the line number where the event occurred.&#10;&#10;@param int $line&#10;&#10;@return LogEvent" ilk="function" line="74" lineend="79" name="setLine" returns="LogEvent" signature="LogEvent setLine(int $line)"><variable citdl="int" ilk="argument" line="74" name="line" /></scope><scope attributes="public" doc="Returns the line number for this event.&#10;&#10;@return int" ilk="function" line="86" lineend="89" name="getLine" returns="int" signature="int getLine()" /><scope attributes="public" doc="Sets the message text for this event.&#10;&#10;@param string $message&#10;&#10;@see setCode() for more informetion regarding event codes and messages.&#10;&#10;@return LogEvent" ilk="function" line="100" lineend="105" name="setMessage" returns="LogEvent" signature="LogEvent setMessage(string $message)"><variable citdl="string" ilk="argument" line="100" name="message" /></scope><scope attributes="public" doc="Returns the message text associated with this event.&#10;&#10;@return string" ilk="function" line="112" lineend="115" name="getMessage" returns="string" signature="string getMessage()" /><scope attributes="public" doc="Sets the type of event.&#10;&#10;@param string $type&#10;&#10;@todo find out which types are supported and expand this DocBlock.&#10;&#10;@return LogEvent" ilk="function" line="126" lineend="131" name="setType" returns="LogEvent" signature="LogEvent setType(string $type)"><variable citdl="string" ilk="argument" line="126" name="type" /></scope><scope attributes="public" doc="Returns the type for this event.&#10;&#10;@return string" ilk="function" line="138" lineend="141" name="getType" returns="string" signature="string getType()" /></scope></scope></scope>