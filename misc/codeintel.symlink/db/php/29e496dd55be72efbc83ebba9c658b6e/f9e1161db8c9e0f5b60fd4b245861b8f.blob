"501" name="serviceNow" /><variable citdl="array" ilk="argument" line="501" name="dispmap" /><variable citdl="boolean" ilk="argument" line="501" name="servicenow" /></scope><scope doc="Set debug level of server.&#10;@param integer $in debug lvl: determines info added to xmlrpc responses (as xml comments)&#10;0 = no debug info,&#10;1 = msgs set from user with debugmsg(),&#10;2 = add complete xmlrpc request (headers and body),&#10;3 = add also all processing warnings happened during method processing&#10;(NB: this involves setting a custom error handler, and might interfere&#10;with the standard processing of the php function exposed as method. In&#10;particular, triggering an USER_ERROR level error will not halt script&#10;execution anymore, but just end up logged in the xmlrpc response)&#10;Note that info added at elevel 2 and 3 will be base64 encoded&#10;@access public" ilk="function" line="547" lineend="550" name="setDebug" signature="setDebug(integer $in)"><variable citdl="integer" ilk="argument" line="547" name="in" /></scope><scope doc="Return a string with the serialized representation of all debug info&#10;@param string $charset_encoding the target charset encoding for the serialization&#10;@return string an XML comment (or two)" ilk="function" line="557" lineend="578" name="serializeDebug" returns="string" signature="string serializeDebug(string $charset_encoding = '')"><variable citdl="string" default="''" ilk="argument" line="557" name="charset_encoding" /><variable citdl="string" line="564" name="out" /><variable attributes="__not_yet_defined__" line="569" name="GLOBALS" /></scope><scope doc="Execute the xmlrpc request, printing the response&#10;@param string $data the request body. If null, the http POST request will be examined&#10;@return xmlrpcresp the response object (usually not used by caller...)&#10;@access public" ilk="function" line="586" lineend="692" name="service" returns="xmlrpcresp" signature="xmlrpcresp service(string $data = null, $return