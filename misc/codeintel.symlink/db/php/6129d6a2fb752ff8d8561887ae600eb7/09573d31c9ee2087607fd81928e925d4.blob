<scope ilk="blob" lang="PHP" name="class.soap_val.php" src="/private/var/www/kw/plugins/w3-total-cache/lib/Nusoap/class.soap_val.php"><scope classrefs="nusoap_base" doc="For creating serializable abstractions of native PHP types.  This class&#10;allows element name/namespace, XSD type, and XML attributes to be&#10;associated with a value.  This is extremely useful when WSDL is not&#10;used, but is also useful when WSDL is used with polymorphic types, including&#10;xsd:anyType and user-defined types.&#10;&#10;@author   Dietrich Ayala &lt;dietrich@ganx4.com&gt;&#10;@version  $Id: class.soap_val.php,v 1.11 2007/04/06 13:56:32 snichol Exp $&#10;@access   public" ilk="class" line="18" lineend="103" name="soapval"><variable citdl="string" doc="The XML element name&#10;&#10;@var string&#10;@access private" line="25" name="name" /><variable citdl="type" doc="The XML type name (string or false)&#10;&#10;@var mixed&#10;@access private" line="32" name="type" /><variable citdl="value" doc="The PHP value&#10;&#10;@var mixed&#10;@access private" line="39" name="value" /><variable citdl="element_ns" doc="The XML element namespace (string or false)&#10;&#10;@var mixed&#10;@access private" line="46" name="element_ns" /><variable citdl="type_ns" doc="The XML type namespace (string or false)&#10;&#10;@var mixed&#10;@access private" line="53" name="type_ns" /><variable citdl="attributes" doc="The XML element attributes (array or false)&#10;&#10;@var mixed&#10;@access private" line="60" name="attributes" /><scope attributes="__ctor__" doc="constructor&#10;&#10;@param    string $name optional name&#10;@param    mixed $type optional type name&#10;@param	mixed $value optional value&#10;@param	mixed $element_ns optional namespace of value&#10;@param	mixed $type_ns optional namespace of type&#10;@param	mixed $attributes associative array of attributes to add to element serialization&#10;@access   public" ilk="function" line="73" lineend="81" name="soapval" signature="soapval(string $name = 'soapval', mixed $type = false, mixed $value = -1, mixed $element_ns = false, mixed $type_ns = false, mixed $attributes = false)"><variable citdl="string" default="'soapval'" ilk="argument" line="73" name="name" /><variable citdl="mixed" default="false" ilk="argument" line="73" name="type" /><variable citdl="mixed" default="-1" ilk="argument" line="73" name="value" /><variable citdl="mixed" default="false" ilk="argument" line="73" name="element_ns" /><variable citdl="mixed" default="false" ilk="argument" line="73" name="type_ns" /><variable citdl="mixed" default="false" ilk="argument" line="73" name="attributes" /></scope><scope doc="return serialized value&#10;&#10;@param	string $use The WSDL use value (encoded|literal)&#10;@return	string XML data&#10;@access   public" ilk="function" line="90" lineend="92" name="serialize" returns="string" signature="string serialize(string $use = 'encoded')"><variable citdl="string" default="'encoded'" ilk="argument" line="90" name="use" /></scope><scope doc="decodes a soapval object into a PHP native type&#10;&#10;@return	mixed&#10;@access   public" ilk="function" line="100" lineend="102" name="decode" returns="mixed" signature="mixed decode()" /></scope></scope>