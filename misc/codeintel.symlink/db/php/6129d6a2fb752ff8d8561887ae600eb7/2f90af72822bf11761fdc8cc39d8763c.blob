<scope ilk="blob" lang="PHP" name="class.soapclient.php" src="/private/var/www/kw/plugins/w3-total-cache/lib/Nusoap/class.soapclient.php"><scope classrefs="nusoap_base" doc="[nu]soapclient higher level class for easy usage.&#10;&#10;usage:&#10;&#10;// instantiate client with server info&#10;$soapclient = new nusoap_client( string path [ ,mixed wsdl] );&#10;&#10;// call method, get results&#10;echo $soapclient-&gt;call( string methodname [ ,array parameters] );&#10;&#10;// bye bye client&#10;unset($soapclient);&#10;&#10;@author   Dietrich Ayala &lt;dietrich@ganx4.com&gt;&#10;@author   Scott Nichol &lt;snichol@users.sourceforge.net&gt;&#10;@version  $Id: class.soapclient.php,v 1.69 2010/04/26 20:15:08 snichol Exp $&#10;@access   public" ilk="class" line="27" lineend="983" name="nusoap_client"><variable citdl="string" line="29" name="username" /><variable citdl="string" line="30" name="password" /><variable citdl="string" line="31" name="authtype" /><variable citdl="array()" line="32" name="certRequest" /><variable citdl="headers" line="33" name="requestHeaders" /><variable citdl="string" line="34" name="responseHeaders" /><variable citdl="parser.get_soapheader()" line="35" name="responseHeader" /><variable citdl="string" line="36" name="document" /><variable citdl="endpoint" line="37" name="endpoint" /><variable citdl="string" line="38" name="forceEndpoint" /><variable citdl="proxyhost" line="39" name="proxyhost" /><variable citdl="proxyport" line="40" name="proxyport" /><variable citdl="proxyusername" line="41" name="proxyusername" /><variable citdl="proxypassword" line="42" name="proxypassword" /><variable citdl="string" line="43" name="portName" /><variable citdl="string" line="44" name="xml_encoding" /><variable citdl="boolean" line="45" name="http_encoding" /><variable citdl="int" line="46" name="timeout" /><variable citdl="int" line="47" name="response_timeout" /><variable citdl="string" line="48" name="endpointType" /><variable citdl="boolean" l