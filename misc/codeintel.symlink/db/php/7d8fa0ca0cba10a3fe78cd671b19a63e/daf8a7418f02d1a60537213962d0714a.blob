<scope ilk="blob" lang="PHP" name="Plural.php" src="/usr/local/pear/share/pear/PhpDocumentor/vendor/zendframework/zend-i18n/Zend/I18n/View/Helper/Plural.php"><scope doc="Zend Framework (http://framework.zend.com/)&#10;&#10;@link      http://github.com/zendframework/zf2 for the canonical source repository&#10;@copyright Copyright (c) 2005-2013 Zend Technologies USA Inc. (http://www.zend.com)&#10;@license   http://framework.zend.com/license/new-bsd New BSD License" ilk="namespace" line="10" name="Zend\I18n\View\Helper"><import line="12" module="Zend\I18n" symbol="Exception" /><import alias="PluralRule" line="13" module="Zend\I18n\Translator\Plural" symbol="Rule" /><import line="14" module="Zend\View\Helper" symbol="AbstractHelper" /><scope classrefs="AbstractHelper" doc="Helper for rendering text based on a count number (like the I18n plural translation helper, but when translation&#10;is not needed).&#10;&#10;Please note that we did not write any hard-coded rules for languages, as languages can evolve, we prefered to&#10;let the developer define the rules himself, instead of potentially break applications if we change rules in the&#10;future.&#10;&#10;However, you can find most of the up-to-date plural rules for most languages in those links:&#10;     - http://unicode.org/repos/cldr-tmp/trunk/diff/supplemental/language_plural_rules.html&#10;     - https://developer.mozilla.org/en-US/docs/Localization_and_Plurals" ilk="class" line="28" lineend="102" name="Plural"><variable attributes="protected" citdl="PluralRule" doc="Plural rule to use&#10;&#10;@var PluralRule" line="35" name="rule" /><scope attributes="public __ctor__" doc="@throws Exception\ExtensionNotLoadedException if ext/intl is not present" ilk="function" line="40" lineend="48" name="__construct" signature="__construct()" /><scope attributes="public" doc="Given an array of strings, a number and, if wanted, an optional locale (the default one is used&#10;otherwise), this picks the right string according to plural rules of the locale&#10;&#10;@param  array|string $strings&#10;@param  int          $number&#10;@throws Exception\InvalidArgumentException&#10;@return string" ilk="function" line="59" lineend="74" name="__invoke" returns="string" signature="string __invoke($strings, int $number)"><variable ilk="argument" line="59" name="strings" /><variable citdl="int" ilk="argument" line="59" name="number" /><variable citdl="this.getPluralRule().evaluate()" line="71" name="pluralIndex" /></scope><scope attributes="public" doc="Set the plural rule to use&#10;&#10;@param  PluralRule|string $pluralRule&#10;@return Plural" ilk="function" line="82" lineend="91" name="setPluralRule" returns="Plural" signature="Plural setPluralRule($pluralRule)"><variable ilk="argument" line="82" name="pluralRule" /></scope><scope attributes="public" doc="Get the plural rule to  use&#10;&#10;@return PluralRule" ilk="function" line="98" lineend="101" name="getPluralRule" returns="PluralRule" signature="PluralRule getPluralRule()" /></scope></scope></scope>