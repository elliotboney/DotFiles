le" ilk="argument" line="50" name="listener" /><variable citdl="integer" default="0" ilk="argument" line="50" name="priority" /></scope><scope attributes="public" doc="Adds an event subscriber.&#10;&#10;The subscriber is asked for all the events he is&#10;interested in and added as a listener for these events.&#10;&#10;@param EventSubscriberInterface $subscriber The subscriber.&#10;&#10;@api" ilk="function" line="62" lineend="62" name="addSubscriber" signature="addSubscriber(EventSubscriberInterface $subscriber)"><variable citdl="EventSubscriberInterface" ilk="argument" line="62" name="subscriber" /></scope><scope attributes="public" doc="Removes an event listener from the specified events.&#10;&#10;@param string|array $eventName The event(s) to remove a listener from&#10;@param callable     $listener  The listener to remove" ilk="function" line="70" lineend="70" name="removeListener" signature="removeListener($eventName, callable $listener)"><variable ilk="argument" line="70" name="eventName" /><variable citdl="callable" ilk="argument" line="70" name="listener" /></scope><scope attributes="public" doc="Removes an event subscriber.&#10;&#10;@param EventSubscriberInterface $subscriber The subscriber" ilk="function" line="77" lineend="77" name="removeSubscriber" signature="removeSubscriber(EventSubscriberInterface $subscriber)"><variable citdl="EventSubscriberInterface" ilk="argument" line="77" name="subscriber" /></scope><scope attributes="public" doc="Gets the listeners of a specific event or all listeners.&#10;&#10;@param string $eventName The name of the event&#10;&#10;@return array The event listeners for the specified event, or all event listeners by event name" ilk="function" line="86" lineend="86" name="getListeners" returns="array" signature="array getListeners(string $eventName = null)"><variable citdl="string" default="null" ilk="argument" line="86" name="eventName" /></scope><scope attributes="public" doc="Checks whether an event has any registered listene