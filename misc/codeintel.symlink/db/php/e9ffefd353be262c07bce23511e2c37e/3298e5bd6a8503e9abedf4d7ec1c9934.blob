<scope ilk="blob" lang="PHP" name="class-wp-xmlrpc-server.php" src="/private/var/www/wordpress.staging/wp-includes/class-wp-xmlrpc-server.php"><scope classrefs="IXR_Server" doc="WordPress XMLRPC server implementation.&#10;&#10;Implements compatibility for Blogger API, MetaWeblog API, MovableType, and&#10;pingback. Additional WordPress API for managing comments, pages, posts,&#10;options, etc.&#10;&#10;As of WordPress 3.5.0, XML-RPC is enabled by default. It can be disabled&#10;via the xmlrpc_enabled filter found in wp_xmlrpc_server::login().&#10;&#10;@package WordPress&#10;@subpackage Publishing&#10;@since 1.5.0" ilk="class" line="22" lineend="5524" name="wp_xmlrpc_server"><scope attributes="__ctor__" doc="Register all of the XMLRPC methods that XMLRPC server understands.&#10;&#10;Sets up server and method property. Passes XMLRPC&#10;methods through the 'xmlrpc_methods' filter to allow plugins to extend&#10;or replace XMLRPC methods.&#10;&#10;@since 1.5.0&#10;&#10;@return wp_xmlrpc_server" ilk="function" line="35" lineend="130" name="__construct" returns="wp_xmlrpc_server" signature="wp_xmlrpc_server __construct()" /><variable citdl="array()" line="126" name="methods" /><scope ilk="function" line="132" lineend="134" name="serve_request" signature="serve_request()" /><scope doc="Test XMLRPC API by saying, &quot;Hello!&quot; to client.&#10;&#10;@since 1.5.0&#10;&#10;@param array $args Method Parameters.&#10;@return string" ilk="function" line="144" lineend="146" name="sayHello" returns="string" signature="string sayHello(array $args)"><variable citdl="array" ilk="argument" line="144" name="args" /></scope><scope doc="Test XMLRPC API by adding two numbers for client.&#10;&#10;@since 1.5.0&#10;&#10;@param array $args Method Parameters.&#10;@return int" ilk="function" line="156" lineend="160" name="addTwoNumbers" returns="int" signature="int addTwoNumbers(array $args)"><variable citdl="array" ilk="argument" line="156" name="args" /><variable citdl="args" line="158" name=