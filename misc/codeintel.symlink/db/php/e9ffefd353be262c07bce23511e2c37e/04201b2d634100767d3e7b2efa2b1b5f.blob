__" line="3691" name="regex" /><variable citdl="fopen()" line="3673" name="fp" /><variable line="3691" name="field" /></scope><scope doc="Returns true.&#10;&#10;Useful for returning true to filters easily.&#10;&#10;@since 3.0.0&#10;@see __return_false()&#10;@return bool true" ilk="function" line="3710" lineend="3712" name="__return_true" returns="bool" signature="bool __return_true()" /><scope doc="Returns false.&#10;&#10;Useful for returning false to filters easily.&#10;&#10;@since 3.0.0&#10;@see __return_true()&#10;@return bool false" ilk="function" line="3723" lineend="3725" name="__return_false" returns="bool" signature="bool __return_false()" /><scope doc="Returns 0.&#10;&#10;Useful for returning 0 to filters easily.&#10;&#10;@since 3.0.0&#10;@return int 0" ilk="function" line="3735" lineend="3737" name="__return_zero" returns="int" signature="int __return_zero()" /><scope doc="Returns an empty array.&#10;&#10;Useful for returning an empty array to filters easily.&#10;&#10;@since 3.0.0&#10;@return array Empty array" ilk="function" line="3747" lineend="3749" name="__return_empty_array" returns="array" signature="array __return_empty_array()" /><scope doc="Returns null.&#10;&#10;Useful for returning null to filters easily.&#10;&#10;@since 3.4.0&#10;@return null" ilk="function" line="3759" lineend="3761" name="__return_null" returns="null" signature="null __return_null()" /><scope doc="Returns an empty string.&#10;&#10;Useful for returning an empty string to filters easily.&#10;&#10;@since 3.7.0&#10;@see __return_null()&#10;@return string Empty string" ilk="function" line="3772" lineend="3774" name="__return_empty_string" returns="string" signature="string __return_empty_string()" /><scope doc="Send a HTTP header to disable content type sniffing in browsers which support it.&#10;&#10;@link http://blogs.msdn.com/ie/archive/2008/07/02/ie8-security-part-v-comprehensive-protection.aspx&#10;@link http://src.chromium.org/viewvc/chrome?view=rev&amp;revision=6985&#10;&#10;@since 3.0.0&#10;@return none" ilk="function" line="3785" lineend="3787" name="send_nosniff_header" returns="none" signature="none send_nosniff_header()" /><scope doc="Returns a MySQL expression for selecting the week number based on the start_of_week option.&#10;&#10;@internal&#10;@since 3.0.0&#10;@param string $column&#10;@return string" ilk="function" line="3797" lineend="3811" name="_wp_mysql_week" returns="string" signature="string _wp_mysql_week(string $column)"><variable citdl="string" ilk="argument" line="3797" name="column" /><variable line="3798" name="start_of_week" /></scope><scope doc="Finds hierarchy loops using a callback function that maps object IDs to parent IDs.&#10;&#10;@since 3.1.0&#10;@access private&#10;&#10;@param callback $callback function that accepts ( ID, $callback_args ) and outputs parent_ID&#10;@param int $start The ID to start the loop check at&#10;@param int $start_parent the parent_ID of $start to use instead of calling $callback( $start ). Use null to always use $callback&#10;@param array $callback_args optional additional arguments to send to $callback&#10;@return array IDs of all members of loop" ilk="function" line="3825" lineend="3832" name="wp_find_hierarchy_loop" returns="array" signature="array wp_find_hierarchy_loop(callback $callback, int $start, int $start_parent, array $callback_args = array())"><variable citdl="callback" ilk="argument" line="3825" name="callback" /><variable citdl="int" ilk="argument" line="3825" name="start" /><variable citdl="int" ilk="argument" line="3825" name="start_parent" /><variable citdl="array" default="array()" ilk="argument" line="3825" name="callback_args" /><variable line="3828" name="arbitrary_loop_member" /><variable citdl="is_null()" line="3826" name="override" /></scope><scope doc="Uses the &quot;The Tortoise and the Hare&quot; algorithm to detect loops.&#10;&#10;For every step of the algorithm, the hare takes two steps and the tortoise one.&#10;If the hare ever laps the tortoise, there must be a loop.&#10;&#10;@since 3.1.0&#10;@access private&#10;&#10;@param callback $callback function that accepts ( ID, callback_arg, ... ) and outputs parent_ID&#10;@param int $start The ID to start the loop check at&#10;@param array $override an array of ( ID =&gt; parent_ID, ... ) to use instead of $callback&#10;@param array $callback_args optional additional arguments to send to $callback&#10;@param bool $_return_loop Return loop members or just detect presence of loop?&#10;            Only set to true if you already know the given $start is part of a loop&#10;            (otherwise the returned array might include branches)&#10;@return mixed scalar ID of some arbitrary member of the loop, or array of IDs of all members of loop if $_return_loop" ilk="function" line="3852" lineend="3877" name="wp_find_hierarchy_loop_tortoise_hare" returns="mixed" signature="mixed wp_find_hierarchy_loop_tortoise_hare(callback $callback, int $start, array $override = array(), array $callback_args = array(), bool $_return_loop = false)"><variable citdl="callback" ilk="argument" line="3852" name="callback" /><variable citdl="int" ilk="argument" line="3852" name="start" /><variable citdl="array" default="array()" ilk="argument" line="3852" name="override" /><variable citdl="array" default="array()" ilk="argument" line="3852" name="callback_args" /><variable citdl="bool" default="false" ilk="argument" line="3852" name="_return_loop" /><variable citdl="array()" line="3854" name="return" /><variable citdl="hare" line="3853" name="tortoise" /><variable line="3858" name="evanescent_hare" /><variable attributes="__not_yet_defined__" line="3858" name="hare" /></scope><scope doc="Send a HTTP header to limit rendering of pages to same origin iframes.&#10;&#10;@link https://developer.mozilla.org/en/the_x-frame-options_response_header&#10;&#10;@since 3.1.3&#10;@return none" ilk="function" line="3887" lineend="3889" name="send_frame_options_header" returns="none" signature="none send_frame_o