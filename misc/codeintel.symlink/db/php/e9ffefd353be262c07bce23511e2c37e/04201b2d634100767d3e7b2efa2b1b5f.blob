curity&#10;@since 2.0.4&#10;&#10;@param string $action The nonce action." ilk="function" line="2071" lineend="2083" name="wp_nonce_ays" signature="wp_nonce_ays(string $action)"><variable citdl="string" ilk="argument" line="2071" name="action" /><variable citdl="__()" line="2072" name="title" /><variable citdl="sprintf()" line="2074" name="html" /></scope><scope doc="Kill WordPress execution and display HTML message with error message.&#10;&#10;This function complements the die() PHP function. The difference is that&#10;HTML will be displayed to the user. It is recommended to use this function&#10;only, when the execution should not continue any further. It is not&#10;recommended to call this function very often and try to handle as many errors&#10;as possible silently.&#10;&#10;@since 2.0.4&#10;&#10;@param string $message Error message.&#10;@param string $title Error title.&#10;@param string|array $args Optional arguments to control behavior." ilk="function" line="2100" lineend="2109" name="wp_die" signature="wp_die(string $message = '', string $title = '', $args = array())"><variable citdl="string" default="''" ilk="argument" line="2100" name="message" /><variable citdl="string" default="''" ilk="argument" line="2100" name="title" /><variable default="array()" ilk="argument" line="2100" name="args" /><variable line="2101" name="function" /></scope><scope doc="Kill WordPress execution and display HTML message with error message.&#10;&#10;This is the default handler for wp_die if you want a custom one for your&#10;site then you can overload using the wp_die_handler filter in wp_die&#10;&#10;@since 3.0.0&#10;@access private&#10;&#10;@param string $message Error message.&#10;@param string $title Error title.&#10;@param string|array $args Optional arguments to control behavior." ilk="function" line="2124" lineend="2306" name="_default_wp_die_handler" signature="_default_wp_die_handler(string $message, string $title = '', $args = array())"><variable citdl="string" ilk="a