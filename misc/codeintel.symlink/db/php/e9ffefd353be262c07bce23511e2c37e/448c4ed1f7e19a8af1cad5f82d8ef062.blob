ributes="protected" citdl="string" doc="Database Name&#10;&#10;@since 3.1.0&#10;@access protected&#10;@var string" line="469" name="dbname" /><variable attributes="protected" citdl="string" doc="Database Host&#10;&#10;@since 3.1.0&#10;@access protected&#10;@var string" line="478" name="dbhost" /><variable attributes="protected" citdl="string" doc="Database Handle&#10;&#10;@since 0.71&#10;@access protected&#10;@var string" line="487" name="dbh" /><variable citdl="string" doc="A textual description of the last query/get_row/get_var call&#10;&#10;@since 3.0.0&#10;@access public&#10;@var string" line="496" name="func_call" /><variable attributes="public" citdl="bool" doc="Whether MySQL is used as the database engine.&#10;&#10;Set in WPDB::db_connect() to true, by default. This is used when checking&#10;against the required MySQL version for WordPress. Normally, a replacement&#10;database drop-in (db.php) will skip these checks, but setting this to true&#10;will force the checks to occur.&#10;&#10;@since 3.3.0&#10;@access public&#10;@var bool" line="510" name="is_mysql" /><scope attributes="__ctor__" doc="Connects to the database server and selects a database&#10;&#10;PHP5 style constructor for compatibility with PHP5. Does&#10;the actual setting up of the class properties and connection&#10;to the database.&#10;&#10;@link http://core.trac.wordpress.org/ticket/3354&#10;@since 2.0.8&#10;&#10;@param string $dbuser MySQL database user&#10;@param string $dbpassword MySQL database password&#10;@param string $dbname MySQL database name&#10;@param string $dbhost MySQL database host" ilk="function" line="527" lineend="541" name="__construct" signature="__construct(string $dbuser, string $dbpassword, string $dbname, string $dbhost)"><variable citdl="string" ilk="argument" line="527" name="dbuser" /><variable citdl="string" ilk="argument" line="527" name="dbpassword" /><variable citdl="string" ilk="argument" line="527" name="dbname" /><variable citdl="string" ilk="argument" line="527" name="dbhost" /></scope><scope doc="PHP5 style destructor and will run when database object is destroyed.&#10;&#10;@see wpdb::__construct()&#10;@since 2.0.8&#10;@return bool true" ilk="function" line="550" lineend="552" name="__destruct" returns="bool" signature="bool __destruct()" /><scope doc="PHP5 style magic getter, used to lazy-load expensive data.&#10;&#10;@since 3.5.0&#10;&#10;@param string $name The private member to get, and optionally process&#10;@return mixed The private member" ilk="function" line="562" lineend="567" name="__get" returns="mixed" signature="mixed __get(string $name)"><variable citdl="string" ilk="argument" line="562" name="name" /></scope><scope doc="Magic function, for backwards compatibility&#10;&#10;@since 3.5.0&#10;&#10;@param string $name  The private member to set&#10;@param mixed  $value The value to set" ilk="function" line="577" lineend="579" name="__set" signature="__set(string $name, mixed $value)"><variable citdl="string" ilk="argument" line="577" name="name" /><variable citdl="mixed" ilk="argument" line="577" name="value" /></scope><scope doc="Magic function, for backwards compatibility&#10;&#10;@since 3.5.0&#10;&#10;@param string $name  The private member to check&#10;&#10;@return bool If the member is set or not" ilk="function" line="590" lineend="592" name="__isset" returns="bool" signature="bool __isset(string $name)"><variable citdl="string" ilk="argument" line="590" name="name" /></scope><scope doc="Magic function, for backwards compatibility&#10;&#10;@since 3.5.0&#10;&#10;@param string $name  The private member to unset" ilk="function" line="601" lineend="603" name="__unset" signature="__unset(string $name)"><variable citdl="string" ilk="argument" line="601" name="name" /></scope><scope doc="Set $this-&gt;charset and $this-&gt;collate&#10;&#10;@since 3.1.0" ilk="function" line="610" lineend="623" name="init_charset" signature="init_charset()" /><scope doc="Sets the connection's character set.&#10;&#10;@since 3.1.0&#10;&#10;@param resource $dbh     The resource given by mysql_connect&#10;@param string   $charset The character set (optional)&#10;@param string   $collate The collation (optional)" ilk="function" line="634" lineend="649" name="set_charset" signature="set_charset(resource $dbh, string $charset = null, string $collate = null)"><variable citdl="resource" ilk="argument" line="634" name="dbh" /><variable citdl="string" default="null" ilk="argument" line="634" name="charset" /><variable citdl="string" default="null" ilk="argument" line="634" name="collate" /><variable citdl="this.prepare()" line="643" name="query" /></scope><scope doc="Sets the table prefix for the WordPress tables.&#10;&#10;@since 2.5.0&#10;&#10;@param string $prefix Alphanumeric name for the new prefix.&#10;@param bool $set_table_names Optional. Whether the table names, e.g. wpdb::$posts, should be updated or not.&#10;@return string|WP_Error Old prefix or WP_Error on error" ilk="function" line="660" lineend="688" name="set_prefix" returns="string" signature="string set_prefix(string $prefix, bool $set_table_names = true)"><variable citdl="string" ilk="argument" line="660" name="prefix" /><variable citdl="bool" default="true" ilk="argument" line="660" name="set_table_names" /><variable citdl="is_multisite()" line="665" name="old_prefix" /><variable attributes="__not_yet_defined__" line="673" name="prefixed_table" /><variable line="673" name="table" /></scope><variable citdl="prefix" line="670" name="base_prefix" /><scope doc="Sets blog id.&#10;&#10;@since 3.0.0&#10;@access public&#10;@param int $blog_id&#10;@param int $site_id Optional.&#10;@return string previous blog id" ilk="function" line="699" lineend="715" name="set_blog_id" returns="string" signature="string set_blog_id(int $blog_id, int $site_id = 0)"><variable citdl="int" ilk="argument" line="699" name="blog_id" /><variable citdl="int" default="0" ilk="argument" line="699" name="site_id" /><variable attributes="__not_yet_defined__" line="708" name="prefixed_table" /><variable citdl="this.blogid" line="703" name="old_blog_id" /><variable line="708" name="table" /></scope><scope doc="Gets blog prefix.&#10;&#10;@uses is_multisite()&#10;@since 3.0.0&#10;@param int $blog_id Optional.&#10;@return string Blog prefix." ilk="function" line="725" lineend="737" name="get_blog_prefix" returns="string" signature="string get_blog_prefix(int $blog_id = null)"><variable citdl="int" default="null" ilk="argument" line="725" name="blog_id" /></scope><scope doc="Returns an array of WordPress tables.&#10;&#10;Also allows for the CUSTOM_USER_TABLE and CUSTOM_USER_META_TABLE to&#10;override the WordPress users and usermeta tables that would otherwise&#10;be determined by the prefix.&#10;&#10;The scope argument can take one of the following:&#10;&#10;'all' - returns 'all' and 'global' tables. No old tables are returned.&#10;'blog' - returns the blog-level tables for the queried blog.&#10;'global' - returns the global tables for the installation, returning multisite tables only if running multisite.&#10;'ms_global' - returns the multisite global tables, regardless if current installation is multisite.&#10;'old' - returns tables which are deprecated.&#10;&#10;@since 3.0.0&#10;@uses wpdb::$tables&#10;@uses wpdb::$old_tables&#10;@uses wpdb::$global_tables&#10;@uses wpdb::$ms_global_tables&#10;@uses is_multisite()&#10;&#10;@param string $scope Optional. Can be all, global, ms_global, blog, or old tables. Defaults to all.&#10;@param bool $prefix Optional. Whether to include table prefixes. Default true. If blog&#10;	prefix is requested, then the custom users and usermeta tables will be mapped.&#10;@param int $blog_id Optional. The blog_id to prefix. Defaults to wpdb::$blogid. Used only when prefix is requested.&#10;@return array Table names. When a prefix is requested, the key is the unprefixed table name." ilk="function" line="767" lineend="815" name="tables" returns="array" signature="array tables(string $scope = 'all', bool $prefix = true, int $blog_id = 0)"><variable citdl="string" default="'all'" ilk="argument" line="767" name="scope" /><variable citdl="bool" default="true" ilk="argument" line="767" name="prefix" /><variable citdl="int" default="0" ilk="argument" line="767" name="blog_id" /><variable citdl="this.get_blog_prefix()" line="796" name="blog_prefix" /><variable citdl="array_merge()" line="770" name="tables" /><variable line="799" name="k" /><variable citdl="this.base_prefix" line="797" name="base_prefix" /><variable citdl="array_merge()" line="798" name="global_tables" /><variable attributes="__not_yet_defined__" line="799" name="table" /></scope><scope doc="Selects a database using the current database connection.&#10;&#10;The database name will be changed based on the current database&#10;connection. On failure, the execution will bail and display an DB error.&#10;&#10;@since 0.71&#10;&#10;@param string $db MySQL database name&#10;@param resource $dbh Optional link identifier.&#10;@return null Always null." ilk="function" line="829" lineend="846" name="select" returns="null" signature="null select(string $db, resource $dbh = null)"><variable citdl="string" ilk="argument" line="829" name="db" /><variable citdl="resource" default="null" ilk="argument" line="829" name="dbh" /></scope><scope doc="Do not use, deprecated.&#10;&#10;Use esc_sql() or wpdb::prepare() instead.&#10;&#10;@since 2.8.0&#10;@deprecated 3.6.0&#10;@see wpdb::prepare&#10;@see esc_sql()&#10;@access private&#10;&#10;@param string $string&#10;@return string" ilk="function" line="862" lineend="866" name="_weak_escape" returns="string" signature="string _weak_escape(string $string)"><variable citdl="string" ilk="argument" line="862" name="string" /></scope><scope doc="Real escape, using mysql_real_escape_string()&#10;&#10;@see mysql_real_escape_string()&#10;@since 2.8.0&#10;@access private&#10;&#10;@param  string $string to escape&#10;@return string escaped" ilk="function" line="878" lineend="885" name="_real_escape" returns="string" signature="string _real_escape(string $string)"><variable citdl="string" ilk="argument" line="878" name="string" /><variable citdl="get_class()" line="882" name="class" /></scope><scope doc="Escape data. Works on arrays.&#10;&#10;@uses wpdb::_real_escape()&#10;@since  2.8.0&#10;@access private&#10;&#10;@param  string|array $data&#10;@return string|array escaped" ilk="function" line="897" lineend="910" name="_escape" returns="string" signature="string _escape($data)"><variable ilk="argument" line="897" name="data" /><variable attributes="__not_yet_defined__" line="899" name="v" /><variable line="899" name="k" /></scope><scope doc="Do not use, deprecated.&#10;&#10;Use esc_sql() or wpdb::prepare() instead.&#10;&#10;@since 0.71&#10;@deprecated 3.6.0&#10;@see wpdb::prepare()&#10;@see esc_sql()&#10;&#10;@param mixed $data&#10;@return mixed" ilk="function" line="925" lineend="940" name="escape" returns="mixed" signature="mixed escape(mixed $data)"><variable citdl="mixed" ilk="argument" line="925" name="data" /><variable attributes="__not_yet_defined__" line="929" name="v" /><variable line="929" name="k" /></scope><scope doc="Escapes content by reference for insertion into the database, for security&#10;&#10;@uses wpdb::_real_escape()&#10;@since 2.3.0&#10;@param string $string to escape&#10;@return void" ilk="function" line="950" lineend="953" name="escape_by_ref" signature="void escape_by_ref(string &amp; $string)"><variable citdl="string" ilk="argument" line="950" name="string" /></scope><scope doc="Prepares a SQL query for safe execution. Uses sprintf()-like syntax.&#10;&#10;The following directives can be used in the query format string:&#10;  %d (integer)&#10;  %f (float)&#10;  %s (string)&#10;  %% (literal percentage sign - no argument needed)&#10;&#10;All of %d, %f, and %s are to be left unquoted in the query string and they need an argument passed for them.&#10;Literals (%) as parts of the query must be properly written as %%.&#10;&#10;This function only supports a small subset of the sprintf syntax; it only supports %d (integer), %f (float), and %s (string).&#10;Does not support sign, padding, alignment, width or precision specifiers.&#10;Does not support argument numbering/swapping.&#10;&#10;May be called like {@link http://php.net/sprintf sprintf()} or like {@link http://php.net/vsprintf vsprintf()}.&#10;&#10;Both %d and %s should be left unquoted in the query string.&#10;&#10;&lt;code&gt;&#10;wpdb::prepare( &quot;SELECT * FROM `table` WHERE `column` = %s AND `field` = %d&quot;, 'foo', 1337 )&#10;wpdb::prepare( &quot;SELECT DATE_FORMAT(`field`, '%%c') FROM `table` WHERE `column` = %s&quot;, 'foo' );&#10;&lt;/code&gt;&#10;&#10;@link http://php.net/sprintf Description of syntax.&#10;@since 2.3.0&#10;&#10;@param string $query Query statement with sprintf()-like placeholders&#10;@param array|mixed $args The array of variables to substitute into the query's placeholders if being called like&#10;	{@link http://php.net/vsprintf vsprintf()}, or the first variable to substitute into the query's placeholders if&#10;	being called like {@link http://php.net/sprintf sprintf()}.&#10;@param mixed $args,... further variables to substitute into the query's placeholders if being called like&#10;	{@link http://php.net/sprintf sprintf()}.&#10;@return null|false|string Sanitized query string, null if there is no query, false if there is an error and string&#10;	if there was something to prepare" ilk="function" line="992" lineend="1007" name="prepare" returns="null" signature="null prepare(string $query, mixed $args)"><variable citdl="string" ilk="argument" line="992" name="query" /><variable citdl="mixed" ilk="argument" line="992" name="args" /></scope><scope doc="Print SQL/DB error.&#10;&#10;@since 0.71&#10;@global array $EZSQL_ERROR Stores error information of query and error string&#10;&#10;@param string $str The error to display&#10;@return bool False if the showing of errors is disabled." ilk="function" line="1018" lineend="1057" name="print_error" returns="bool" signature="bool print_error(string $str = '')"><variable citdl="string" default="''" ilk="argument" line="1018" name="str" /><variable citdl="htmlspecialchars()" line="1050" name="query" /><variable attributes="__not_yet_defined__" line="1019" name="EZSQL_ERROR" /><variable citdl="string" line="1043" name="msg" /><variable line="1030" name="error_str" /><variable line="1030" name="caller" /></scope><scope doc="Enables showing of database errors.&#10;&#10;This function should be used only to enable showing of errors.&#10;wpdb::hide_errors() should be used instead for hiding of errors. However,&#10;this function can be used to enable and disable showing of database&#10;errors.&#10;&#10;@since 0.71&#10;@see wpdb::hide_errors()&#10;&#10;@param bool $show Whether to show or hide errors&#10;@return bool Old value for showing errors." ilk="function" line="1073" lineend="1077" name="show_errors" returns="bool" signature="bool show_errors(bool $show = true)"><variable citdl="bool" default="true" ilk="argument" line="1073" name="show" /><variable citdl="this.show_errors" line="1074" name="errors" /></scope><scope doc="Disables showing of database errors.&#10;&#10;By default database errors are not shown.&#10;&#10;@since 0.71&#10;@see wpdb::show_errors()&#10;&#10;@return bool Whether showing of errors was active" ilk="function" line="1089" lineend="1093" name="hide_errors" returns="bool" signature="bool hide_errors()"><variable citdl="this.show_errors" line="1090" name="show" /></scope><scope doc="Whether to suppress database errors.&#10;&#10;By default database errors are suppressed, with a simple&#10;call to this function they can be enabled.&#10;&#10;@since 2.5.0&#10;@see wpdb::hide_errors()&#10;@param bool $suppress Optional. New value. Defaults to true.&#10;@return bool Old value" ilk="function" line="1106" lineend="1110" name="suppress_errors" returns="bool" signature="bool suppress_errors(bool $suppress = true)"><variable citdl="bool" default="true" ilk="argument" line="1106" name="suppress" /><variable citdl="this.suppress_errors" line="1107" name="errors" /></scope><scope doc="Kill cached query results.&#10;&#10;@since 0.71&#10;@return void" ilk="function" line="1118" lineend="1127" name="flush" signature="void flush()" /><scope doc="Connect to and select database&#10;&#10;@since 3.0.0" ilk="function" line="1134" lineend="1168" name="db_connect" signature="db_connect()"><variable citdl="defined()" line="1138" name="new_link" /><variable citdl="defined()" line="1139" name="client_flags" /></scope><variable line="1144" name="new_link" /><scope doc="Perform a MySQL database query, using current database connection.&#10;&#10;More information can be found on the codex page.&#10;&#10;@since 0.71&#10;&#10;@param string $query Database query&#10;@return int|false Number of rows affected/selected or false on error" ilk="function" line="1180" lineend="1245" name="query" returns="int" signature="int query(string $query)"><variable citdl="string" ilk="argument" line="1180" name="query" /><variable citdl="int" line="1193" name="return_val" /><variable line="1233" name="row" /><variable citdl="int" line="1232" name="num_rows" /></scope><scope doc="Insert a row into a table.&#10;&#10;&lt;code&gt;&#10;wpdb::insert( 'table', array( 'column' =&gt; 'foo', 'field' =&gt; 'bar' ) )&#10;wpdb::insert( 'table', array( 'column' =&gt; 'foo', 'field' =&gt; 1337 ), array( '%s', '%d' ) )&#10;&lt;/code&gt;&#10;&#10;@since 2.5.0&#10;@see wpdb::prepare()&#10;@see wpdb::$field_types&#10;@see wp_set_wpdb_vars()&#10;&#10;@param string $table table name&#10;@param array $data Data to insert (in column =&gt; value pairs). Both $data columns and $data values should be &quot;raw&quot; (neither should be SQL escaped).&#10;@param array|string $format Optional. An array of formats to be mapped to each of the value in $data. If string, that format will be used for all of the values in $data.&#10;	A format is one of '%d', '%f', '