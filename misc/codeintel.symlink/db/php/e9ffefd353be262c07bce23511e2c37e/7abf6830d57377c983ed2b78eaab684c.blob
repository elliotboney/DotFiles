 Sites/[Site Name]&quot; menu and all submenus.&#10;&#10;@since 3.1.0&#10;&#10;@param WP_Admin_Bar $wp_admin_bar" ilk="function" line="334" lineend="452" name="wp_admin_bar_my_sites_menu" signature="wp_admin_bar_my_sites_menu(WP_Admin_Bar $wp_admin_bar)"><variable citdl="WP_Admin_Bar" ilk="argument" line="334" name="wp_admin_bar" /><variable citdl="string" line="406" name="blavatar" /><variable attributes="__not_yet_defined__" line="403" name="blog" /><variable citdl="string" line="409" name="menu_id" /><variable line="408" name="blogname" /></scope><scope doc="Provide a shortlink.&#10;&#10;@since 3.1.0&#10;&#10;@param WP_Admin_Bar $wp_admin_bar" ilk="function" line="461" lineend="476" name="wp_admin_bar_shortlink_menu" signature="wp_admin_bar_shortlink_menu(WP_Admin_Bar $wp_admin_bar)"><variable citdl="WP_Admin_Bar" ilk="argument" line="461" name="wp_admin_bar" /><variable citdl="string" line="463" name="id" /><variable citdl="string" line="468" name="html" /><variable citdl="wp_get_shortlink()" line="462" name="short" /></scope><scope doc="Provide an edit link for posts and terms.&#10;&#10;@since 3.1.0&#10;&#10;@param WP_Admin_Bar $wp_admin_bar" ilk="function" line="485" lineend="543" name="wp_admin_bar_edit_menu" signature="wp_admin_bar_edit_menu(WP_Admin_Bar $wp_admin_bar)"><variable citdl="WP_Admin_Bar" ilk="argument" line="485" name="wp_admin_bar" /><variable line="504" name="tax" /><variable line="492" name="post_type_object" /><variable citdl="get_current_screen()" line="489" name="current_screen" /><variable citdl="get_post()" line="490" name="post" /><variable attributes="__not_yet_defined__" line="486" name="wp_the_query" /><variable citdl="wp_the_query.get_queried_object()" line="516" name="current_object" /><variable attributes="__not_yet_defined__" line="486" name="tag" /></scope><scope doc="Add &quot;Add New&quot; menu.&#10;&#10;@since 3.1.0&#10;&#10;@param WP_Admin_Bar $wp_admin_bar" ilk="function" line="552" lineend="610" name="wp_admin_bar_new_cont