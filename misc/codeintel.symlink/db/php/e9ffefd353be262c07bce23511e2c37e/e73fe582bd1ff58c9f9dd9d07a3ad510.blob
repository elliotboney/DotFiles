<scope ilk="blob" lang="PHP" name="author-template.php" src="/private/var/www/wordpress.staging/wp-includes/author-template.php"><scope doc="Retrieve the author of the current post.&#10;&#10;@since 1.5&#10;@uses $authordata The current author's DB object.&#10;@uses apply_filters() Calls 'the_author' hook on the author display name.&#10;&#10;@param string $deprecated Deprecated.&#10;@return string The author's display name." ilk="function" line="23" lineend="37" name="get_the_author" returns="string" signature="string get_the_author(string $deprecated = '')"><variable citdl="string" default="''" ilk="argument" line="23" name="deprecated" /><variable attributes="__not_yet_defined__" line="24" name="authordata" /></scope><scope doc="Display the name of the author of the current post.&#10;&#10;The behavior of this function is based off of old functionality predating&#10;get_the_author(). This function is not deprecated, but is designed to echo&#10;the value from get_the_author() and as an result of any old theme that might&#10;still use the old behavior will also pass the value from get_the_author().&#10;&#10;The normal, expected behavior of this function is to echo the author and not&#10;return it. However, backwards compatibility has to be maintained.&#10;&#10;@since 0.71&#10;@see get_the_author()&#10;@link http://codex.wordpress.org/Template_Tags/the_author&#10;&#10;@param string $deprecated Deprecated.&#10;@param string $deprecated_echo Deprecated. Use get_the_author(). Echo the string or return it.&#10;@return string The author's display name, from get_the_author()." ilk="function" line="58" lineend="66" name="the_author" returns="string" signature="string the_author(string $deprecated = '', string $deprecated_echo = true)"><variable citdl="string" default="''" ilk="argument" line="58" name="deprecated" /><variable citdl="string" default="true" ilk="argument" line="58" name="deprecated_echo" /></scope><scope doc="Retrieve the author who last edited the current post.&#10;&#10;@since 2.8&#10;@uses $post The current post's DB object.&#10;@uses get_post_meta() Retrieves the ID of the author who last edited the current post.&#10;@uses get_userdata() Retrieves the author's DB object.&#10;@uses apply_filters() Calls 'the_modified_author' hook on the author display name.&#10;@return string The author's display name." ilk="function" line="78" lineend="91" name="get_the_modified_author" returns="string" signature="string get_the_modified_author()"><variable line="79" name="last_id" /><variable citdl="get_userdata()" line="80" name="last_user" /></scope><scope doc="Display the name of the author who last edited the current post.&#10;&#10;@since 2.8&#10;@see get_the_author()&#10;@return string The author's display name, from get_the_modified_author()." ilk="function" line="100" lineend="102" name="the_modified_author" returns="string" signature="string the_modified_author()" /><scope doc="Retrieve the requested data of the author of the current post.&#10;@link http://codex.wordpress.org/Template_Tags/the_author_meta&#10;@since 2.8.0&#10;@uses $authordata The current author's DB object (if $user_id not specified).&#10;@param string $field selects the field of the users record.&#10;@param int $user_id Optional. User ID.&#10;@return string The author's field from the current author's DB object." ilk="function" line="113" lineend="137" name="get_the_author_meta" returns="string" signature="string get_the_author_meta(string $field = '', int $user_id = false)"><variable citdl="string" default="''" ilk="argument" line="113" name="field" /><variable citdl="int" default="false" ilk="argument" line="113" name="user_id" /><variable line="124" name="value" /><variable attributes="__not_yet_defined__" citdl="get_userdata()" line="115" name="authordata" /></scope><scope doc="Retrieve the requested data of the author of the current post.&#10;@link http://codex.wordpress.org/Template_Tags/the_author_meta&#10;@since 2.8.0&#10;@param string $field selects the field of the users record.&#10;@param int $user_id Optional. User ID.&#10;@echo string The author's field from the current author's DB object." ilk="function" line="147" lineend="161" name="the_author_meta" signature="the_author_meta(string $field = '', int $user_id = false)"><variable citdl="string" default="''" ilk="argument" line="147" name="field" /><variable citdl="int" default="false" ilk="argument" line="147" name="user_id" /><variable citdl="get_the_author_meta()" line="148" name="author_meta" /></scope><scope doc="Retrieve either author's link or author's name.&#10;&#10;If the author has a home page set, return an HTML link, otherwise just return the&#10;author's name.&#10;&#10;@uses get_the_author_meta()&#10;@uses get_the_author()" ilk="function" line="172" lineend="178" name="get_the_author_link" returns="string" signature="get_the_author_link()" /><scope doc="Display either author's link or author's name.&#10;&#10;If the author has a home page set, echo an HTML link, otherwise just echo the&#10;author's name.&#10;&#10;@link http://codex.wordpress.org/Template_Tags/the_author_link&#10;@since 2.1&#10;@uses get_the_author_link()" ilk="function" line="190" lineend="192" name="the_author_link" signature="the_author_link()" /><scope doc="Retrieve the number of posts by the author of the current post.&#10;&#10;@since 1.5&#10;@uses $post The current post in the Loop's DB object.&#10;@uses count_user_posts()&#10;@return int The number of posts by the author." ilk="function" line="202" lineend="204" name="get_the_author_posts" returns="int" signature="int get_the_author_posts()" /><scope doc="Display the number of posts by the author of the current post.&#10;&#10;@link http://codex.wordpress.org/Template_Tags/the_author_posts&#10;@since 0.71&#10;@uses get_the_author_posts() Echoes returned value from function." ilk="function" line="213" lineend="215" name="the_author_posts" signature="the_author_posts()" /><scope doc="Display an HTML link to the author page of the author of the current post.&#10;&#10;Does just echo get_author_posts_url() function, like the others do. The&#10;reason for this, is that another function is used to help in printing the&#10;link to the author's posts.&#10;&#10;@link http://codex.wordpress.org/Template_Tags/the_author_posts_link&#10;@since 1.2.0&#10;@uses $authordata The current author's DB object.&#10;@uses get_author_posts_url()&#10;@uses get_the_author()&#10;@param string $deprecated Deprecated." ilk="function" line="231" lineend="253" name="the_author_posts_link" signature="the_author_posts_link(string $deprecated = '')"><variable citdl="string" default="''" ilk="argument" line="231" name="deprecated" /><variable citdl="sprintf()" line="243" name="link" /><variable attributes="__not_yet_defined__" line="235" name="authordata" /></scope><scope doc="Retrieve the URL to the author page for the user with the ID provided.&#10;&#10;@since 2.1.0&#10;@uses $wp_rewrite WP_Rewrite&#10;@return string The URL to the author's page." ilk="function" line="262" lineend="292" name="get_author_posts_url" returns="string" signature="string get_author_posts_url($author_id, $author_nicename = '')"><variable ilk="argument" line="262" name="author_id" /><variable default="''" ilk="argument" line="262" name="author_nicename" /><variable citdl="wp_rewrite.get_author_permastruct()" line="265" name="link" /><variable citdl="int" line="264" name="auth_ID" /><variable citdl="home_url()" line="268" name="file" /><variable attributes="__not_yet_defined__" line="263" name="wp_rewrite" /><variable citdl="get_userdata()" line="272" name="user" /></scope><scope doc="List all the authors of the blog, with several options available.&#10;&#10;&lt;ul&gt;&#10;&lt;li&gt;optioncount (boolean) (false): Show the count in parenthesis next to the&#10;author's name.&lt;/li&gt;&#10;&lt;li&gt;exclude_admin (boolean) (true): Exclude the 'admin' user that is&#10;installed by default.&lt;/li&gt;&#10;&lt;li&gt;show_fullname (boolean) (false): Show their full names.&lt;/li&gt;&#10;&lt;li&gt;hide_empty (boolean) (true): Don't show authors without any posts.&lt;/li&gt;&#10;&lt;li&gt;feed (string) (''): If isn't empty, show links to author's feeds.&lt;/li&gt;&#10;&lt;li&gt;feed_image (string) (''): If isn't empty, use this image to link to&#10;feeds.&lt;/li&gt;&#10;&lt;li&gt;echo (boolean) (true): Set to false to return the output, instead of&#10;echoing.&lt;/li&gt;&#10;&lt;li&gt;style (string) ('list'): Whether to display list of authors in list form&#10;or as a string.&lt;/li&gt;&#10;&lt;li&gt;html (bool) (true): Whether to list the items in html form or plaintext.&#10;&lt;/li&gt;&#10;&lt;/ul&gt;&#10;&#10;@link http://codex.wordpress.org/Template_Tags/wp_list_authors&#10;@since 1.2.0&#10;@param array $args The argument array.&#10;@return null|string The output, if echo is set to false." ilk="function" line="320" lineend="416" name="wp_list_authors" returns="null" signature="null wp_list_authors(array $args = '')"><variable citdl="array" default="''" ilk="argument" line="320" name="args" /><variable line="350" name="posts" /><variable citdl="get_userdata()" line="345" name="author" /><variable attributes="__not_yet_defined__" line="347" name="exclude_admin" /><variable attributes="__not_yet_defined__" line="403" name="optioncount" /><variable citdl="feed" line="357" name="name" /><variable attributes="__not_yet_defined__" line="412" name="echo" /><variable citdl="string" line="355" name="link" /><variable citdl="array()" line="340" name="author_count" /><variable citdl="title" line="382" name="alt" /><variable attributes="__not_yet_defined__" line="374" name="feed" /><variable attributes="__not_yet_defined__" line="368" name="style" /><variable citdl="string" line="334" name="return" /><variable citdl="get_users()" line="338" name="authors" /><variable attributes="__not_yet_defined__" line="362" name="html" /><variable attributes="__not_yet_defined__" line="352" name="hide_empty" /><variable citdl="array()" line="329" name="defaults" /><variable attributes="__not_yet_defined__" line="341" name="row" /><variable attributes="__not_yet_defined__" line="344" name="author_id" /><variable attributes="__not_yet_defined__" line="357" name="show_fullname" /><variable attributes="__not_yet_defined__" line="321" name="wpdb" /><variable attributes="__not_yet_defined__" line="374" name="feed_image" /><variable citdl="wp_array_slice_assoc()" line="336" name="query_args" /><variable citdl="string" line="384" name="title" /></scope><scope doc="Does this site have more than one author&#10;&#10;Checks to see if more than one author has published posts.&#10;&#10;@since 3.2.0&#10;@return bool Whether or not we have more than one author" ilk="function" line="426" lineend="443" name="is_multi_author" returns="bool" signature="bool is_multi_author()"><variable attributes="__not_yet_defined__" line="427" name="wpdb" /><variable citdl="int" line="429" name="is_multi_author" /><variable citdl="array()" line="430" name="rows" /></scope><scope doc="Helper function to clear the cache for number of authors.&#10;&#10;@private" ilk="function" line="450" lineend="452" name="__clear_multi_author_cache" signature="__clear_multi_author_cache()" /></scope>