y" /><variable citdl="mixed" ilk="argument" line="238" name="value" /></scope><scope attributes="public" doc="Get extra item data.&#10;&#10;Gets data associated with a registered item.&#10;&#10;@access public&#10;@since 3.3.0&#10;&#10;@param string $handle Name of the item. Should be unique.&#10;@param string $key    The data key.&#10;@return mixed Extra item data (string), false otherwise." ilk="function" line="257" lineend="265" name="get_data" returns="mixed" signature="mixed get_data(string $handle, string $key)"><variable citdl="string" ilk="argument" line="257" name="handle" /><variable citdl="string" ilk="argument" line="257" name="key" /></scope><scope attributes="public" doc="Un-register an item or items.&#10;&#10;@access public&#10;@since 2.1.0&#10;&#10;@param mixed $handles Item handle and argument (string) or item handles and arguments (array of strings).&#10;@return void" ilk="function" line="276" lineend="279" name="remove" signature="void remove(mixed $handles)"><variable citdl="mixed" ilk="argument" line="276" name="handles" /><variable attributes="__not_yet_defined__" line="277" name="handle" /></scope><scope attributes="public" doc="Queue an item or items.&#10;&#10;Decodes handles and arguments, then queues handles and stores&#10;arguments in the class property $args. For example in extending&#10;classes, $args is appended to the item url as a query string.&#10;Note $args is NOT the $args property of items in the $registered array.&#10;&#10;@access public&#10;@since 2.1.0&#10;&#10;@param mixed $handles Item handle and argument (string) or item handles and arguments (array of strings)." ilk="function" line="294" lineend="303" name="enqueue" signature="enqueue(mixed $handles)"><variable citdl="mixed" ilk="argument" line="294" name="handles" /><variable attributes="__not_yet_defined__" citdl="explode()" line="295" name="handle" /></scope><scope attributes="public" doc="Dequeue an item or items.&#10;&#10;Decodes handles and arguments, then dequeues handles&#10;and removes arguments from the class property $args.&#10;&#10;@access public&#10;@since 2.1.0&#10;&#10;@param mixed $handles Item handle and argument (string) or item handles and arguments (array of strings)." ilk="function" line="316" lineend="325" name="dequeue" signature="dequeue(mixed $handles)"><variable citdl="mixed" ilk="argument" line="316" name="handles" /><variable attributes="__not_yet_defined__" citdl="explode()" line="317" name="handle" /><variable citdl="array_search()" line="319" name="key" /></scope><scope attributes="public" doc="Query list for an item.&#10;&#10;@access public&#10;@since 2.1.0&#10;&#10;@param string $handle Name of the item. Should be unique.&#10;@param string $list   Property name of list array.&#10;@return bool Found, or object Item data." ilk="function" line="337" lineend="358" name="query" returns="bool" signature="bool query(string $handle, string $list = 'registered')"><variable citdl="string" ilk="argument" line="337" name="handle" /><variable citdl="string" default="'registered'" ilk="argument" line="337" name="list" /></scope><scope attributes="public" doc="Set item group, unless already in a lower group.&#10;&#10;@access public&#10;@since 2.8.0&#10;&#10;@param string $handle    Name of the item. Should be unique.&#10;@param bool   $recursion Internal flag that calling function was called recursively.&#10;@param mixed  $group     Group level.&#10;@return bool Not already in the group or a lower group" ilk="function" line="371" lineend="384" name="set_group" returns="bool" signature="bool set_group(string $handle, bool $recursion, mixed $group)"><variable citdl="string" ilk="argument" line="371" name="handle" /><variable citdl="bool" ilk="argument" line="371" name="recursion" /><variable citdl="mixed" ilk="argument" line="371" name="group" /></scope></scope><scope doc="Class _WP_Dependency&#10;&#10;Helper class to register a handle and associated data.&#10;&#10;@access private&#10;@since 2.6.0" ilk="class" line="396" lineend="481" name="_WP_Dependency"><variable citdl="null" doc="The handle name.&#10;&#10;@access public&#10;@since 2.6.0&#10;@var null" line="404" name="handle" /><variable citdl="null" doc="The handle source.&#10;&#10;@access public&#10;@since 2.6.0&#10;@var null" line="413" name="src" /><variable citdl="array" doc="An array of handle dependencies.&#10;&#10;@access public&#10;@since 2.6.0&#10;@var array" line="422" name="deps" /><variable citdl="bool" doc="The handle version.&#10;&#10;Used for cache-busting.&#10;&#10;@access public&#10;@since 2.6.0&#10;@var bool|string" line="433" name="ver" /><variable citdl="null" doc="Additional arguments for the handle.&#10;&#10;@access public&#10;@since 2.6.0&#10;@var null" line="442" name="args" /><variable citdl="array" doc="Extra data to supply to the handle.&#10;&#10;@access public&#10;@since 2.6.0&#10;@var array" line="451" name="extra" /><scope attributes="__ctor__" doc="Setup dependencies.&#10;&#10;@since 2.6.0" ilk="function" line="458" lineend="462" name="__construct" signature="__construct()" /><scope doc="Add handle data.&#10;&#10;@access public&#10;@since 2.6.0&#10;&#10;@param string $name The data key to add.&#10;@param mixed  $data The data value to add.&#10;@return bool False if not scalar, true otherwise." ilk="function" line="474" lineend="479" name="add_data" returns="bool" signature="bool add_data(string $name, mixed $data)"><variable citdl="string" ilk="argument" line="474" name="name" /><variable citdl="mixed" ilk="argument" line="474" name="data" /></scope></scope></scope>