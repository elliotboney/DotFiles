erpt of the current comment.&#10;&#10;@since 1.2.0&#10;&#10;@param int $comment_ID Optional. The ID of the comment for which to print the excerpt. Default current comment." ilk="function" line="513" lineend="523" name="comment_excerpt" signature="comment_excerpt(int $comment_ID = 0)"><variable citdl="int" default="0" ilk="argument" line="513" name="comment_ID" /><variable citdl="get_comment_excerpt()" line="514" name="comment_excerpt" /></scope><scope doc="Retrieve the comment id of the current comment.&#10;&#10;@since 1.5.0&#10;&#10;@return int The comment ID." ilk="function" line="532" lineend="542" name="get_comment_ID" returns="int" signature="int get_comment_ID()"><variable attributes="__not_yet_defined__" line="533" name="comment" /></scope><scope doc="Display the comment id of the current comment.&#10;&#10;@since 0.71" ilk="function" line="549" lineend="551" name="comment_ID" signature="comment_ID()" /><scope doc="Retrieve the link to a given comment.&#10;&#10;@since 1.5.0&#10;&#10;@param mixed $comment Optional. Comment to retrieve. Default current comment.&#10;@param array $args    Optional. An array of arguments to override the defaults. @see get_page_of_comment()&#10;@return string The permalink to the given comment." ilk="function" line="562" lineend="608" name="get_comment_link" returns="string" signature="string get_comment_link(mixed $comment = null, array $args = array())"><variable citdl="mixed" default="null" ilk="argument" line="562" name="comment" /><variable citdl="array" default="array()" ilk="argument" line="562" name="args" /><variable citdl="get_permalink()" line="589" name="link" /><variable citdl="args" line="569" name="page" /><variable citdl="array()" line="574" name="defaults" /><variable attributes="__not_yet_defined__" line="563" name="wp_rewrite" /><variable attributes="__not_yet_defined__" line="563" name="in_comment_loop" /></scope><scope doc="Retrieve the link to the current post comments.&#10;&#10;@since 1.5.0&#10;&#10;@param int