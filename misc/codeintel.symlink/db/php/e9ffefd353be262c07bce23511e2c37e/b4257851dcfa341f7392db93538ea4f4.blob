ld not use it as a link, is because of moving the&#10;blog across domains.&#10;&#10;@since 1.5.0&#10;&#10;@param int $id Optional. Post ID.&#10;@return string" ilk="function" line="150" lineend="154" name="get_the_guid" returns="string" signature="string get_the_guid(int $id = 0)"><variable citdl="int" default="0" ilk="argument" line="150" name="id" /><variable citdl="get_post()" line="151" name="post" /></scope><scope doc="Display the post content.&#10;&#10;@since 0.71&#10;&#10;@param string $more_link_text Optional. Content for when there is more text.&#10;@param bool $strip_teaser Optional. Strip teaser content before the more text. Default is false." ilk="function" line="164" lineend="169" name="the_content" signature="the_content(string $more_link_text = null, bool $strip_teaser = false)"><variable citdl="string" default="null" ilk="argument" line="164" name="more_link_text" /><variable citdl="bool" default="false" ilk="argument" line="164" name="strip_teaser" /><variable citdl="get_the_content()" line="165" name="content" /></scope><scope doc="Retrieve the post content.&#10;&#10;@since 0.71&#10;&#10;@param string $more_link_text Optional. Content for when there is more text.&#10;@param bool $stripteaser Optional. Strip teaser content before the more text. Default is false.&#10;@return string" ilk="function" line="180" lineend="233" name="get_the_content" returns="string" signature="string get_the_content(string $more_link_text = null, $strip_teaser = false, bool $stripteaser)"><variable citdl="string" default="null" ilk="argument" line="180" name="more_link_text" /><variable default="false" ilk="argument" line="180" name="strip_teaser" /><variable citdl="bool" ilk="argument" line="180" name="stripteaser" /><variable attributes="__not_yet_defined__" line="181" name="pages" /><variable attributes="__not_yet_defined__" line="181" name="more" /><variable citdl="pages" line="198" name="content" /><variable citdl="content" line="212" name="teaser" /><variable citdl=