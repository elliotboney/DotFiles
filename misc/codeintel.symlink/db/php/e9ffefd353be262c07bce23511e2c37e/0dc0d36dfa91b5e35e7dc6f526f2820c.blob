<scope ilk="blob" lang="PHP" name="script-loader.php" src="/private/var/www/wordpress.staging/wp-includes/script-loader.php"><import line="25" module="/class.wp-dependencies.php" /><import line="28" module="/class.wp-scripts.php" /><import line="31" module="/functions.wp-scripts.php" /><import line="34" module="/class.wp-styles.php" /><import line="37" module="/functions.wp-styles.php" /><import line="51" module="/version.php" /><import line="539" module="/version.php" /><scope doc="Register all WordPress scripts.&#10;&#10;Localizes some of them.&#10;args order: $scripts-&gt;add( 'handle', 'url', 'dependencies', 'query-string', 1 );&#10;when last arg === 1 queues the script for the footer&#10;&#10;@since 2.6.0&#10;&#10;@param object $scripts WP_Scripts object." ilk="function" line="50" lineend="521" name="wp_default_scripts" signature="wp_default_scripts(object &amp; $scripts)"><variable citdl="object" ilk="argument" line="50" name="scripts" /><variable citdl="boolean" line="57" name="guessed_url" /><variable attributes="__not_yet_defined__" line="53" name="wp_version" /><variable line="215" name="max_upload_size" /><variable citdl="SCRIPT_DEBUG" line="66" name="suffix" /><variable citdl="wp_guess_url()" line="56" name="guessurl" /><variable citdl="array()" line="244" name="uploader_l10n" /></scope><scope doc="Assign default styles to $styles object.&#10;&#10;Nothing is returned, because the $styles parameter is passed by reference.&#10;Meaning that whatever object is passed will be updated without having to&#10;reassign the variable that was passed back to the same value. This saves&#10;memory.&#10;&#10;Adding default styles is not the only task, it also assigns the base_url&#10;property, the default version, and text direction for the object.&#10;&#10;@since 2.6.0&#10;&#10;@param object $styles" ilk="function" line="538" lineend="600" name="wp_default_styles" signature="wp_default_styles(object &amp; $styles)"><variable citdl="object" ilk="argument" line="538" name="styles" /><variable citdl="SCRIPT_DEBUG" line="553" name="suffix" /><variable attributes="__not_yet_defined__" line="541" name="wp_version" /><variable attributes="__not_yet_defined__" line="594" name="rtl_style" /><variable line="544" name="guessurl" /><variable citdl="array()" line="555" name="rtl_styles" /></scope><scope doc="Reorder JavaScript scripts array to place prototype before jQuery.&#10;&#10;@since 2.3.1&#10;&#10;@param array $js_array JavaScript scripts array&#10;@return array Reordered array, if needed." ilk="function" line="610" lineend="625" name="wp_prototype_before_jquery" returns="array" signature="array wp_prototype_before_jquery(array $js_array)"><variable citdl="array" ilk="argument" line="610" name="js_array" /><variable line="614" name="jquery" /><variable line="611" name="prototype" /></scope><scope doc="Load localized data on print rather than initialization.&#10;&#10;These localizations require information that may not be loaded even by init.&#10;&#10;@since 2.5.0" ilk="function" line="634" lineend="643" name="wp_just_in_time_script_localization" signature="wp_just_in_time_script_localization()" /><scope doc="Administration Screen CSS for changing the styles.&#10;&#10;If installing the 'wp-admin/' directory will be replaced with './'.&#10;&#10;The $_wp_admin_css_colors global manages the Administration Screens CSS&#10;stylesheet that is loaded. The option that is set is 'admin_color' and is the&#10;color and key for the array. The value for the color key is an object with&#10;a 'url' parameter that has the URL path to the CSS file.&#10;&#10;The query from $src parameter will be appended to the URL that is given from&#10;the $_wp_admin_css_colors array value URL.&#10;&#10;@since 2.6.0&#10;@uses $_wp_admin_css_colors&#10;&#10;@param string $src Source URL.&#10;@param string $handle Either 'colors' or 'colors-rtl'.&#10;@return string URL path to CSS stylesheet for Administration Screens." ilk="function" line="665" lineend="692" name="wp_style_loader_src" returns="string" signature="string wp_style_loader_src(string $src, string $handle)"><variable citdl="string" ilk="argument" line="665" name="src" /><variable citdl="string" ilk="argument" line="665" name="handle" /><variable attributes="__not_yet_defined__" line="670" name="_wp_admin_css_colors" /><variable citdl="get_user_option()" line="671" name="color" /><variable citdl="color.url" line="678" name="url" /><variable citdl="parse_url()" line="677" name="parsed" /></scope><scope doc="Prints the script queue in the HTML head on admin pages.&#10;&#10;Postpones the scripts that were queued for the footer.&#10;print_footer_scripts() is called in the footer to print these scripts.&#10;&#10;@since 2.8&#10;&#10;@see wp_print_scripts()" ilk="function" line="704" lineend="724" name="print_head_scripts" returns="wp_scripts.done" signature="print_head_scripts()"><variable attributes="__not_yet_defined__" line="705" name="concatenate_scripts" /><variable attributes="__not_yet_defined__" line="705" name="wp_scripts" /></scope><scope doc="Prints the scripts that were queued for the footer or too late for the HTML head.&#10;&#10;@since 2.8" ilk="function" line="731" lineend="746" name="print_footer_scripts" returns="wp_scripts.done" signature="print_footer_scripts()"><variable attributes="__not_yet_defined__" line="732" name="concatenate_scripts" /><variable attributes="__not_yet_defined__" line="732" name="wp_scripts" /></scope><scope doc="@internal use" ilk="function" line="751" lineend="777" name="_print_scripts" signature="_print_scripts()"><variable attributes="__not_yet_defined__" line="752" name="compress_scripts" /><variable citdl="compress_scripts" line="754" name="zip" /><variable citdl="str_split()" line="758" name="concat" /><variable attributes="__not_yet_defined__" line="752" name="wp_scripts" /><variable citdl="wp_scripts.base_url" line="771" name="src" /></scope><scope doc="Prints the script queue in the HTML head on the front end.&#10;&#10;Postpones the scripts that were queued for the footer.&#10;wp_print_footer_scripts() is called in the footer to print these scripts.&#10;&#10;@since 2.8" ilk="function" line="787" lineend="799" name="wp_print_head_scripts" returns="print_head_scripts()" signature="wp_print_head_scripts()"><variable attributes="__not_yet_defined__" line="793" name="wp_scripts" /></scope><scope doc="Private, for use in *_footer_scripts hooks&#10;&#10;@since 3.3.0" ilk="function" line="806" lineend="809" name="_wp_footer_scripts" signature="_wp_footer_scripts()" /><scope doc="Hooks to print the scripts and styles in the footer.&#10;&#10;@since 2.8" ilk="function" line="816" lineend="818" name="wp_print_footer_scripts" signature="wp_print_footer_scripts()" /><scope doc="Wrapper for do_action('wp_enqueue_scripts')&#10;&#10;Allows plugins to queue scripts for the front end using wp_enqueue_script().&#10;Runs first in wp_head() where all is_home(), is_page(), etc. functions are available.&#10;&#10;@since 2.8" ilk="function" line="828" lineend="830" name="wp_enqueue_scripts" signature="wp_enqueue_scripts()" /><scope doc="Prints the styles queue in the HTML head on admin pages.&#10;&#10;@since 2.8" ilk="function" line="837" lineend="856" name="print_admin_styles" returns="wp_styles.done" signature="print_admin_styles()"><variable citdl="compress_css" line="845" name="zip" /><variable attributes="__not_yet_defined__" line="838" name="wp_styles" /><variable attributes="__not_yet_defined__" line="838" name="compress_css" /><variable attributes="__not_yet_defined__" line="838" name="concatenate_scripts" /></scope><scope doc="Prints the styles that were queued too late for the HTML head.&#10;&#10;@since 3.3.0" ilk="function" line="863" lineend="877" name="print_late_styles" returns="wp_styles.done" signature="print_late_styles()"><variable attributes="__not_yet_defined__" line="864" name="wp_styles" /><variable attributes="__not_yet_defined__" line="864" name="concatenate_scripts" /></scope><scope doc=