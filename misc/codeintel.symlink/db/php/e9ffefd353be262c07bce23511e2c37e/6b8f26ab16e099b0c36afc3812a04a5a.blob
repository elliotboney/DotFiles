e attributes="__not_yet_defined__" line="199" name="key" /><variable line="228" name="default_theme_slug" /><variable citdl="dirname()" line="248" name="parent_dir" /><variable line="251" name="directories" /></scope><scope attributes="public" doc="When converting the object to a string, the theme name is returned.&#10;&#10;@return string Theme name, ready for display (translated)" ilk="function" line="297" lineend="299" name="__toString" returns="string" signature="string __toString()" /><scope attributes="public" doc="__isset() magic method for properties formerly returned by current_theme_info()" ilk="function" line="304" lineend="311" name="__isset" returns="in_array()" signature="__isset($offset)"><variable ilk="argument" line="304" name="offset" /></scope><variable attributes="static" citdl="array()" line="308" name="properties" /><scope attributes="public" doc="__get() magic method for properties formerly returned by current_theme_info()" ilk="function" line="316" lineend="350" name="__get" returns="this.get()" signature="__get($offset)"><variable ilk="argument" line="316" name="offset" /></scope><scope attributes="public" doc="Method to implement ArrayAccess for keys formerly returned by get_themes()" ilk="function" line="355" lineend="355" name="offsetSet" signature="offsetSet($offset, $value)"><variable ilk="argument" line="355" name="offset" /><variable ilk="argument" line="355" name="value" /></scope><scope attributes="public" doc="Method to implement ArrayAccess for keys formerly returned by get_themes()" ilk="function" line="360" lineend="360" name="offsetUnset" signature="offsetUnset($offset)"><variable ilk="argument" line="360" name="offset" /></scope><scope attributes="public" doc="Method to implement ArrayAccess for keys formerly returned by get_themes()" ilk="function" line="365" lineend="373" name="offsetExists" returns="in_array()" signature="offsetExists($offset)"><variable ilk="argument" line="365" name="offset" /></scope><variable attributes="static" citdl="array()" line="370" name="keys" /><scope attributes="public" doc="Method to implement ArrayAccess for keys formerly returned by get_themes().&#10;&#10;Author, Author Name, Author URI, and Description did not previously return&#10;translated data. We are doing so now as it is safe to do. However, as&#10;Name and Title could have been used as the key for get_themes(), both remain&#10;untranslated for back compatibility. This means that ['Name'] is not ideal,&#10;and care should be taken to use $theme-&gt;display('Name') to get a properly&#10;translated header." ilk="function" line="385" lineend="428" name="offsetGet" returns="this.get()" signature="offsetGet($offset)"><variable ilk="argument" line="385" name="offset" /></scope><scope attributes="public" doc="Returns errors property.&#10;&#10;@since 3.4.0&#10;@access public&#10;&#10;@return WP_Error|bool WP_Error if there are errors, or false." ilk="function" line="438" lineend="440" name="errors" returns="WP_Error" signature="WP_Error errors()" /><scope attributes="public" doc="Whether the theme exists.&#10;&#10;A theme with errors exists. A theme with the error of 'theme_not_found',&#10;meaning that the theme's directory was not found, does not exist.&#10;&#10;@since 3.4.0&#10;@access public&#10;&#10;@return bool Whether the theme exists." ilk="function" line="453" lineend="455" name="exists" returns="bool" signature="bool exists()" /><scope attributes="private" doc="Adds theme data to cache.&#10;&#10;Cache entries keyed by the theme and the type of data.&#10;&#10;@access private&#10;@since 3.4.0&#10;&#10;@param string $key Type of data to store (theme, screenshot, headers, page_templates)&#10;@param string $data Data to store&#10;@return bool Return value from wp_cache_add()" ilk="function" line="481" lineend="483" name="cache_add" returns="bool" signature="bool cache_add(string $key, string $data)"><variable citdl="string" ilk="argument" line="481" name="key" /><variable citdl="string" ilk="argument" line="481" name="data" /></scope><scope attributes="private" doc="Gets theme data from cache.&#10;&#10;Cache entries are keyed by the theme and the type of data.&#10;&#10;@access private&#10;@since 3.4.0&#10;&#10;@param string $key Type of data to retrieve (theme, screenshot, headers, page_templates)&#10;@return mixed Retrieved data" ilk="function" line="496" lineend="498" name="cache_get" returns="mixed" signature="mixed cache_get(string $key)"><variable citdl="string" ilk="argument" line="496" name="key" /></scope><scope attributes="public" doc="Clears the cache for the theme.&#10;&#10;@access public&#10;@since 3.4.0" ilk="function" line="506" lineend="512" name="cache_delete" signature="cache_delete()"><variable attributes="__not_yet_defined__" line="507" name="key" /></scope><scope attributes="public" doc="Get a raw, unformatted theme header.&#10;&#10;The header is sanitized, but is not translated, and is not marked up for display.&#10;To get a theme header for display, use the display() method.&#10;&#10;Use the get_template() method, not the 'Template' header, for finding the template.&#10;The 'Template' header is only good for what was written in the style.css, while&#10;get_template() takes into account where WordPress actually located the theme and&#10;whether it is actually valid.&#10;&#10;@access public&#10;@since 3.4.0&#10;&#10;@param string $header Theme header. Name, Description, Author, Version, ThemeURI, AuthorURI, Status, Tags.&#10;@return string String on success, false on failure." ilk="function" line="531" lineend="554" name="get" returns="string" signature="string get(string $header)"><variable citdl="string" ilk="argument" line="531" name="header" /><variable attributes="__not_yet_defined__" line="546" name="_header" /></scope><scope attributes="public" doc="Gets a theme header, formatted and translated for display.&#10;&#10;@access public&#10;@since 3.4.0&#10;&#10;@param string $header Theme header. Name, Description, Author, Version, ThemeURI, AuthorURI, Status, Tags.&#10;@param bool $markup Optional. Whether to mark up the header. Defaults to true.&#10;@param bool $translate Optional. Whether to translate the header. Defaults to true.&#10;@return string Processed header, false on failure." ilk="function" line="567" lineend="580" name="display" returns="string" signature="string display(string $header, bool $markup = true, bool $translate = true)"><variable citdl="string" ilk="argument" line="567" name="header" /><variable citdl="bool" default="true" ilk="argument" line="567" name="markup" /><variable citdl="bool" default="true" ilk="argument" line="567" name="translate" /><variable citdl="this.get()" line="568" name="value" /></scope><scope attributes="private" doc="Sanitize a theme header.&#10;&#10;@param string $header Theme header. Name, Description, Author, Version, ThemeURI, AuthorURI, Status, Tags.&#10;@param string $value Value to sanitize." ilk="function" line="588" lineend="629" name="sanitize_header" returns="value" signature="sanitize_header(string $header, string $value)"><variable citdl="string" ilk="argument" line="588" name="header" /><variable citdl="string" ilk="argument" line="588" name="value" /></scope><variable attributes="static" citdl="array()" line="603" name="header_tags" /><variable attributes="static" citdl="array()" line="616" name="header_tags_with_a" /><scope attributes="private" doc="Mark up a theme header.&#10;&#10;@access private&#10;@since 3.4.0&#10;&#10;@param string $header Theme header. Name, Description, Author, Version, ThemeURI, AuthorURI, Status, Tags.&#10;@param string $value Value to mark up.&#10;@param string $translate Whether the header has been translated.&#10;@return string Value, marked up." ilk="function" line="642" lineend="676" name="markup_header" returns="string" signature="string markup_header(string $header, string $value, string $translate)"><variable citdl="string" ilk="argument" line="642" name="header" /><variable citdl="string" ilk="argument" line="642" name="value" /><variable citdl="string" ilk="argument" line="642" name="translate" /><variable attributes="__not_yet_defined__" citdl="__()" line="663" name="comma" /><variable attributes="__not_yet_defined__" line="654" name="attr" /></scope><variable attributes="static" line="653" name="attr" /><variable attributes="static" line="662" name="comma" /><scope attributes="private" doc="Translate a theme header.&#10;&#10;@access private&#10;@since 3.4.0&#10;&#10;@param string $header Theme header. Name, Description, Author, Version, ThemeURI, AuthorURI, Status, Tags.&#10;@param string $value Value to translate.&#10;@return string Translated value." ilk="function" line="688" lineend="719" name="translate_header" returns="string" signature="string translate_header(string $header, string $value)"><variable citdl="string" ilk="argument" line="688" name="header" /><variable citdl="string" ilk="argument" line="688" name="value" /><variable citdl="get_theme_feature_list()" line="703" name="feature_list" /><variable attributes="__not_yet_defined__" line="708" name="tag" /><variable attributes="__not_yet_defined__" line="704" name="tags" /><variable attributes="__not_yet_defined__" citdl="array()" line="701" name="tags_list" /></scope><variable attributes="static" line="700" name="tags_list" /><scope attributes="public" doc="The directory name of the theme's &quot;stylesheet&quot; files, inside the theme root.&#10;&#10;In the case of a child theme, this is directory name of the child theme.&#10;Otherwise, get_stylesheet() is the same as get_template().&#10;&#10;@since 3.4.0&#10;@access public&#10;&#10;@return string Stylesheet" ilk="function" line="732" lineend="734" name="get_stylesheet" returns="string" signature="string get_stylesheet()" /><scope attributes="public" doc="The directory name of the theme's &quot;template&quot; files, inside the theme root.&#10;&#10;In the case of a child theme, this is the directory name of the parent theme.&#10;Otherwise, the get_template() is the same as get_stylesheet().&#10;&#10;@since 3.4.0&#10;@access public&#10;&#10;@return string Template" ilk="function" line="747" lineend="749" name="get_template" returns="string" signature="string get_template()" /><scope attributes="public" doc="Returns the absolute path to the directory of a theme's &quot;stylesheet&quot; files.&#10;&#10;In the case of a child theme, this is the absolute path to the directory&#10;of the child theme's files.&#10;&#10;@since 3.4.0&#10;@access public&#10;&#10;@return string Absolute path of the stylesheet directory." ilk="function" line="762" lineend="767" name="get_stylesheet_directory" returns="string" signature="string get_stylesheet_directory()" /><scope attributes="public" doc="Returns the absolute path to the directory of a theme's &quot;template&quot; files.&#10;&#10;In the case of a child theme, this is the absolute path to the directory&#10;of the parent theme's files.&#10;&#10;@since 3.4.0&#10;@access public&#10;&#10;@return string Absolute path of the template directory." ilk="function" line="780" lineend="787" name="get_template_directory" returns="string" signature="string get_template_directory()"><variable line="781" name="theme_root" /></scope><scope attributes="public" doc="Returns the URL to the directory of a theme's &quot;stylesheet&quot; files.&#10;&#10;In the case of a child theme, this is the URL to the directory of the&#10;child theme's files.&#10;&#10;@since 3.4.0&#10;@access public&#10;&#10;@return string URL to the stylesheet directory." ilk="function" line="800" lineend="802" name="get_stylesheet_directory_uri" returns="string" signature="string get_stylesheet_directory_uri()" /><scope attributes="public" doc="Returns the URL to the directory of a theme's &quot;template&quot; files.&#10;&#10;In the case of a child theme, this is the URL to the directory of the&#10;parent theme's files.&#10;&#10;@since 3.4.0&#10;@access public&#10;&#10;@return string URL to the template directory." ilk="function" line="815" lineend="822" name="get_template_directory_uri" returns="string" signature="string get_template_directory_uri()"><variable line="816" name="theme_root_uri" /></scope><scope attributes="public" doc="The absolute path to the directory of the theme root.&#10;&#10;This is typically the absolute path to wp-content/themes.&#10;&#10;@since 3.4.0&#10;@access public&#10;&#10;@return string Theme root." ilk="function" line="834" lineend="836" name="get_theme_root" returns="string" signature="string get_theme_root()" /><scope attributes="public" doc="Returns the URL to the directory of the theme root.&#10;&#10;This is typically the absolute URL to wp-content/themes. This forms the basis&#10;for all other URLs returned by WP_Theme, so we pass it to the public function&#10;get_theme_root_uri() and allow it to run the theme_root_uri filter.&#10;&#10;@uses get_theme_root_uri()&#10;&#10;@since 3.4.0&#10;@access public&#10;&#10;@return string Theme root URI." ilk="function" line="852" lineend="856" name="get_theme_root_uri" returns="string" signature="string get_theme_root_uri()" /><scope attributes="public" doc="Returns the main screenshot file for the theme.&#10;&#10;The main screenshot is called screenshot.png. gif and jpg extensions are also allowed.&#10;&#10;Screenshots for a theme must be in the stylesheet directory. (In the case of child&#10;themes, parent theme screenshots are not inherited.)&#10;&#10;@since 3.4.0&#10;@access public&#10;&#10;@param string $uri Type of URL to return, either 'relative' or an absolute URI. Defaults to absolute URI.&#10;@return mixed Screenshot file. False if the theme does not have a screenshot." ilk="function" line="872" lineend="893" name="get_screenshot" returns="mixed" signature="mixed get_screenshot(string $uri = 'uri')"><variable citdl="string" default="'uri'" ilk="argument" line="872" name="uri" /><variable citdl="this.cache_get()" line="873" name="screenshot" /><variable attributes="__not_yet_defined__" line="882" name="ext" /></scope><scope attributes="public" doc="Return files in the theme's directory.&#10;&#10;@since 3.4.0&#10;@access public&#10;&#10;@param mixed $type Optional. Array of extensions to return. Defaults to all files (null).&#10;@param int $depth Optional. How deep to search for files. Defaults to a flat scan (0 depth). -1 depth is infinite.&#10;@param bool $search_parent Optional. Whether to return parent files. Defaults to false.&#10;@return array Array of files, keyed by the path to the file relative to the theme's directory, with the values&#10;	being absolute paths." ilk="function" line="907" lineend="914" name="get_files" returns="array" signature="array get_files(mixed $type = null, int $depth = 0, bool $search_parent = false)"><variable citdl="mixed" default="null" ilk="argument" line="907" name="type" /><variable citdl="int" default="0" ilk="argument" line="907" name="depth" /><variable citdl="bool" default="false" ilk="argument" line="907" name="search_parent" /><variable citdl="array()" line="908" name="files" /></scope><scope attributes="public" doc="Returns the theme's page templates.&#10;&#10;@since 3.4.0&#10;@access public&#10;&#10;@return array Array of page templates, keyed by filename, with the value of the translated header name." ilk="function" line="924" lineend="955" name="get_page_templates" returns="array" signature="array get_page_templates()"><variable attributes="__not_yet_defined__" line="937" name="header" /><variable line="936" name="file" /><variable attributes="__not_yet_defined__" citdl="this.translate_header()" line="946" name="page_template" /><variable citdl="array()" line="934" name="files" /><variable attributes="__not_yet_defined__" line="936" name="full_path" /><variable citdl="this.cache_get()" line="929" name="page_templates" /></scope><scope attributes="private static" doc="Scans a directory for files of a certain extension.&#10;&#10;@since 3.4.0&#10;@access private&#10;&#10;@param string $path Absolute path to search.&