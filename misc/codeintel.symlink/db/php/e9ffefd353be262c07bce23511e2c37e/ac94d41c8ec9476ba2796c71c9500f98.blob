es="__not_yet_defined__" line="103" name="wp_version" /><variable citdl="phpversion()" line="104" name="php_version" /><variable attributes="__not_yet_defined__" line="103" name="required_php_version" /></scope><scope doc="Don't load all of WordPress when handling a favicon.ico request.&#10;Instead, send the headers for a zero-length favicon and bail.&#10;&#10;@since 3.0.0" ilk="function" line="122" lineend="128" name="wp_favicon_request" signature="wp_favicon_request()"><variable attributes="__not_yet_defined__" line="123" name="_SERVER" /></scope><scope doc="Dies with a maintenance message when conditions are met.&#10;&#10;Checks for a file in the WordPress root directory named &quot;.maintenance&quot;.&#10;This file will contain the variable $upgrading, set to the time the file&#10;was created. If the file was created less than 10 minutes ago, WordPress&#10;enters maintenance mode and displays a message.&#10;&#10;The default message can be replaced by using a drop-in (maintenance.php in&#10;the wp-content directory).&#10;&#10;@access private&#10;@since 3.0.0" ilk="function" line="144" lineend="182" name="wp_maintenance" signature="wp_maintenance()"><variable attributes="__not_yet_defined__" line="148" name="upgrading" /><variable citdl="_SERVER" line="162" name="protocol" /></scope><scope doc="PHP 5 standard microtime start capture.&#10;&#10;@access private&#10;@since 0.71&#10;@global float $timestart Seconds from when function is called.&#10;@return bool Always returns true." ilk="function" line="192" lineend="196" name="timer_start" returns="bool" signature="bool timer_start()"><variable attributes="__not_yet_defined__" citdl="microtime()" line="193" name="timestart" /></scope><scope doc="Return and/or display the time from the page start to when function is called.&#10;&#10;You can get the results and print them by doing:&#10;&lt;code&gt;&#10;$nTimePageTookToExecute = timer_stop();&#10;echo $nTimePageTookToExecute;&#10;&lt;/code&gt;&#10;&#10;Or instead, you can do:&#10;&lt;code&gt;&#10;timer_stop(1);&#10;&lt;/code&gt;&#10;which will do what the above does. If you need the result, you can assign it to a variable, but&#10;in most cases, you only need to echo it.&#10;&#10;@since 0.71&#10;@global float $timestart Seconds from when timer_start() is called&#10;@global float $timeend Seconds from when function is called&#10;&#10;@param int $display Use '0' or null to not echo anything and 1 to echo the total time&#10;@param int $precision The amount of digits from the right of the decimal to display. Default is 3.&#10;@return float The &quot;second.microsecond&quot; finished time calculation" ilk="function" line="222" lineend="230" name="timer_stop" returns="float" signature="float timer_stop(int $display = 0, int $precision = 3)"><variable citdl="int" default="0" ilk="argument" line="222" name="display" /><variable citdl="int" default="3" ilk="argument" line="222" name="precision" /><variable attributes="__not_yet_defined__" citdl="microtime()" line="223" name="timeend" /><variable attributes="__not_yet_defined__" line="223" name="timestart" /><variable citdl="timeend" line="225" name="timetotal" /><variable line="226" name="r" /></scope><scope doc="Sets PHP error handling and handles WordPress debug mode.&#10;&#10;Uses three constants: WP_DEBUG, WP_DEBUG_DISPLAY, and WP_DEBUG_LOG. All three can be&#10;defined in wp-config.php. Example: &lt;code&gt; define( 'WP_DEBUG', true ); &lt;/code&gt;&#10;&#10;WP_DEBUG_DISPLAY and WP_DEBUG_LOG perform no function unless WP_DEBUG is true.&#10;WP_DEBUG defaults to false.&#10;&#10;When WP_DEBUG is true, all PHP notices are reported. WordPress will also display&#10;notices, including one when a deprecated WordPress function, function argument,&#10;or file is used. Deprecated code may be removed from a later version.&#10;&#10;It is strongly recommended that plugin and theme developers use WP_DEBUG in their&#10;development environments.&#10;&#10;When WP_DEBUG_DISPLAY is true, WordPress will force errors to be displayed.&#10;WP_DEBUG_DISPLAY defaults to true. Defining it as null prevents WordPress from&#10;changing the global configuration setting. Defining WP_DEBUG_DISPLAY as false&#10;will force errors to be hidden.&#10;&#10;When WP_DEBUG_LOG is true, errors will be logged to wp-content/debug.log.&#10;WP_DEBUG_LOG defaults to false.&#10;&#10;Errors are never displayed for XML-RPC requests.&#10;&#10;@access private&#10;@since 3.0.0" ilk="function" line="261" lineend="279" name="wp_debug_mode" signature="wp_debug_mode()" /><scope doc="Sets the location of the language directory.&#10;&#10;To set directory manually, define &lt;code&gt;WP_LANG_DIR&lt;/code&gt; in wp-config.php.&#10;&#10;If the language directory exists within WP_CONTENT_DIR, that is used.&#10;Otherwise if the language directory exists within WPINC, that's used.&#10;Finally, if neither of the preceding directories are found,&#10;WP_CONTENT_DIR/languages is used.&#10;&#10;The WP_LANG_DIR constant was introduced in 2.1.0.&#10;&#10;@access private&#10;@since 3.0.0" ilk="function" line="296" lineend="312" name="wp_set_lang_dir" signature="wp_set_lang_dir()" /><variable citdl="WP_CONTENT_DIR" ilk="constant" line="299" name="WP_LANG_DIR" /><variable citdl="string" ilk="constant" line="302" name="LANGDIR" /><scope doc="Load the correct database class file.&#10;&#10;This function is used to load the database class file either at runtime or by&#10;wp-admin/setup-config.php. We must globalize $wpdb to ensure that it is&#10;defined globally by the inline code in wp-db.php.&#10;&#10;@since 2.5.0&#10;@global $wpdb WordPress Database Object" ilk="function" line="324" lineend="335" name="require_wp_db" signature="require_wp_db()"><variable attributes="__not_yet_defined__" citdl="wpdb" line="325" name="wpdb" /></scope><scope doc="Sets the database table prefix and the format specifiers for database table columns.&#10;&#10;Columns not listed here default to %s.&#10;&#10;@see wpdb::$field_types Since 2.8.0&#10;@see wpdb::prepare()&#10;@see wpdb::insert()&#10;@see wpdb::update()&#10;@see wpdb::set_prefix()&#10;&#10;@access private&#10;@since 3.0.0" ilk="function" line="351" lineend="370" name="wp_set_wpdb_vars" signature="wp_set_wpdb_vars()"><variable attributes="__not_yet_defined__" line="352" name="wpdb" /><variable citdl="wpdb.set_prefix()" line="364" name="prefix" /><variable attributes="__not_yet_defined__" line="352" name="table_prefix" /></scope><scope doc="Access/Modify private global variable $_wp_using_ext_object_cache&#10;&#10;Toggle $_wp_using_ext_object_cache on and off without directly touching global&#10;&#10;@since 3.7.0&#10;&#10;@param bool $using Whether external object cache is being used&#10;@return bool The current 'using' setting" ilk="function" line="382" lineend="388" name="wp_using_ext_object_cache" returns="bool" signature="bool wp_using_ext_object_cache(bool $using = null)"><variable citdl="bool" default="null" ilk="argument" line="382" name="using" /><variable attributes="__not_yet_defined__" line="383" name="_wp_using_ext_object_cache" /><variable citdl="_wp_using_ext_object_cache" line="384" name="current_using" /></scope><scope doc="Starts the WordPress object cache.&#10;&#10;If an object-cache.php file exists in the wp-content directory,&#10;it uses that drop-in as an external object cache.&#10;&#10;@access private&#10;@since 3.0.0" ilk="function" line="399" lineend="433" name="wp_start_object_cache" signature="wp_start_object_cache()"><variable citdl="boolean" line="402" name="first_init" /><variable attributes="__not_yet_defined__" line="400" name="blog_id" /></scope><scope doc="Redirects to the installer if WordPress is not installed.&#10;&#10;Dies with an error message when multisite is enabled.&#10;&#10;@access private&#10;@since 3.0.0" ilk="function" line="443" lineend="457" name="wp_not_installed" signature="wp_not_installed()"><variable citdl="wp_guess_url()" line="452" name="link" /><variable attributes="__not_yet_defined__" line="447" name="_SERVER" /></scope><scope doc="Returns array of must-use plugin files to be included in global scope.&#10;&#10;The default directory is wp-content/mu-plugins. To change the default directory&#10;manually, define &lt;code&gt;WPMU_PLUGIN_DIR&lt;/code&gt; and &lt;code&gt;WPMU_PLUGIN_URL&lt;/code&gt;&#10;in wp-config.php.&#10;&#10;@access private&#10;@since 3.0.0&#10;@return array Files to include" ilk="function" line="470" lineend="484" name="wp_get_mu_plugins" returns="array" signature="array wp_get_mu_plugins()"><variable line="474" name="dh" /><variable line="476" name="plugin" /><variable citdl="array()" line="471" name="mu_plugins" /></scope><scope doc="Returns array of plugin files to be included in global scope.&#10;&#10;The default directory is wp-content/plugins. To change the default directory&#10;manually, define &lt;code&gt;WP_PLUGIN_DIR&lt;/code&gt; and &lt;code&gt;WP_PLUGIN_URL&lt;/code&gt;&#10;in wp-config.php.&#10;&#10;@access private&#10;@since 3.0.0&#10;@return array Files to include" ilk="function" line="497" lineend="522" name="wp_get_active_and_valid_plugins" returns="array" signature="array wp_get_active_and_valid_plugins()"><variable citdl="is_multisite()" line="510" name="network_plugins" /><variable citdl="array()" line="498" name="plugins" /><variable attributes="__not_yet_defined__" line="512" name="plugin" /><variable citdl="array()" line="499" name="active_plugins" /></scope><scope doc="Sets internal encoding using mb_internal_encoding().&#10;&#10;In most cases the default internal encoding is latin1, which is of no use,&#10;since we want to use the mb_ functions for utf-8 strings.&#10;&#10;@access private&#10;@since 3.0.0" ilk="function" line="533" lineend="539" name="wp_set_internal_encoding" signature="wp_set_internal_encoding()"><variable citdl="get_option()" line="535" name="charset" /></scope><scope doc="Add magic quotes to $_GET, $_POST, $_COOKIE, and $_SERVER.&#10;&#10;Also forces $_REQUEST to be $_GET + $_POST. If $_SERVER, $_COOKIE,&#10;or $_ENV are needed, use those superglobals directly.&#10;&#10;@access private&#10;@since 3.0.0" ilk="function" line="550" lineend="566" name="wp_magic_quotes" signature="wp_magic_quotes()"><variable citdl="array_merge()" line="565" name="_REQUEST" /><variable citdl="stripslashes_deep()" line="554" name="_POST" /><variable citdl="stripslashes_deep()" line="553" name="_GET" /><variable citdl="stripslashes_deep()" line="555" name="_COOKIE" /><variable citdl="add_magic_quotes()" line="562" name="_SERVER" /></scope><scope doc="Runs just before PHP shuts down execution.&#10;&#10;@access private&#10;@since 1.2.0" ilk="function" line="574" lineend="582" name="shutdown_action_hook" signature="shutdown_action_hook()" /><scope doc="Copy an object.&#10;&#10;@since 2.7.0&#10;@deprecated 3.2&#10;&#10;@param object $object The object to clone&#10;@return object The cloned object" ilk="function" line="594" lineend="597" name="wp_clone" returns="object" signature="object wp_clone(object $object)"><variable citdl="object" ilk="argument" line="594" name="object" /></scope><scope doc="Whether the current request is for a network or blog admin page&#10;&#10;Does not inform on whether the user is an admin! Use capability checks to&#10;tell if the user should be accessing a section or not.&#10;&#10;@since 1.5.1&#10;&#10;@return bool True if inside WordPress administration pages." ilk="function" line="609" lineend="616" name="is_admin" returns="bool" signature="bool is_admin()"><variable attributes="__not_yet_defined__" line="610" name="GLOBALS" /></scope><scope doc="Whether the current request is for a blog admin screen /wp-admin/&#10;&#10;Does not inform on whether the user is a blog admin! Use capability checks to&#10;tell if the user should be accessing a section or not.&#10;&#10;@since 3.1.0&#10;&#10;@return bool True if inside WordPress network administration pages." ilk="function" line="628" lineend="635" name="is_blog_admin" returns="bool" signature="bool is_blog