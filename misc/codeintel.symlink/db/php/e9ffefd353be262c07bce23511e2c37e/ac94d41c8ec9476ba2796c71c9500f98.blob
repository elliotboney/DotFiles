here is a risk that a file can be double-included.&#10;&#10;@since 3.4.0&#10;@access private" ilk="function" line="716" lineend="785" name="wp_load_translations_early" signature="wp_load_translations_early()"><variable attributes="__not_yet_defined__" line="747" name="wp_local_package" /><variable attributes="__not_yet_defined__" line="717" name="text_direction" /><variable citdl="locations" line="738" name="locales" /><variable attributes="__not_yet_defined__" citdl="WP_Locale" line="717" name="wp_locale" /><variable attributes="__not_yet_defined__" line="770" name="locale" /><variable attributes="__not_yet_defined__" citdl="array_unique()" line="753" name="locations" /><variable attributes="__not_yet_defined__" line="771" name="location" /><variable attributes="static" citdl="boolean" line="719" name="loaded" /></scope></scope>