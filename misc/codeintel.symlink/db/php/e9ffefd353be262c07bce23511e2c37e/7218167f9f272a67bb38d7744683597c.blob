line="240" name="wp_object_cache" /></scope><scope doc="WordPress Object Cache&#10;&#10;The WordPress Object Cache is used to save on trips to the database. The&#10;Object Cache stores all of the cache data to memory and makes the cache&#10;contents available by using a key, which is used to name and later retrieve&#10;the cache contents.&#10;&#10;The Object Cache can be replaced by other caching mechanisms by placing files&#10;in the wp-content folder which is looked at in wp-settings. If that file&#10;exists, then this file will not be included.&#10;&#10;@package WordPress&#10;@subpackage Cache&#10;@since 2.0" ilk="class" line="261" lineend="653" name="WP_Object_Cache"><variable citdl="array" doc="Holds the cached objects&#10;&#10;@var array&#10;@access private&#10;@since 2.0.0" line="270" name="cache" /><variable citdl="int" doc="The amount of times the cache data was already stored in the cache.&#10;&#10;@since 2.5.0&#10;@access private&#10;@var int" line="279" name="cache_hits" /><variable citdl="int" doc="Amount of times the cache did not have the request in cache&#10;&#10;@var int&#10;@access public&#10;@since 2.0.0" line="288" name="cache_misses" /><variable citdl="array" doc="List of global groups&#10;&#10;@var array&#10;@access protected&#10;@since 3.0.0" line="297" name="global_groups" /><variable citdl="int" doc="The blog prefix to prepend to keys in non-global groups.&#10;&#10;@var int&#10;@access private&#10;@since 3.5.0" line="306" name="blog_prefix" /><scope doc="Adds data to the cache if it doesn't already exist.&#10;&#10;@uses WP_Object_Cache::_exists Checks to see if the cache already has data.&#10;@uses WP_Object_Cache::set Sets the data after the checking the cache&#10;	contents existence.&#10;&#10;@since 2.0.0&#10;&#10;@param int|string $key What to call the contents in the cache&#10;@param mixed $data The contents to store in the cache&#10;@param string $group Where to group the cache contents&#10;@param int $expire When to expire the cache contents&#10;@return bool False if cache key and group already exist, true on success" ilk="function" line="323" lineend="338" name="add" returns="bool" signature="bool add($key, mixed $data, string $group = 'default', int $expire = 0)"><variable ilk="argument" line="323" name="key" /><variable citdl="mixed" ilk="argument" line="323" name="data" /><variable citdl="string" default="'default'" ilk="argument" line="323" name="group" /><variable citdl="int" default="0" ilk="argument" line="323" name="expire" /><variable citdl="key" line="330" name="id" /></scope><scope doc="Sets the list of global groups.&#10;&#10;@since 3.0.0&#10;&#10;@param array $groups List of groups that are global." ilk="function" line="347" lineend="352" name="add_global_groups" signature="add_global_groups(array $groups)"><variable citdl="array" ilk="argument" line="347" name="groups" /></scope><scope doc="Decrement numeric cache item's value&#10;&#10;@since 3.3.0&#10;&#10;@param int|string $key The cache key to increment&#10;@param int $offset The amount by which to decrement the item's value. Default is 1.&#10;@param string $group The group the key is in.&#10;@return false|int False on failure, the item's new value on success." ilk="function" line="364" lineend="385" name="decr" returns="false" signature="false decr($key, int $offset = 1, string $group = 'default')"><variable ilk="argument" line="364" name="key" /><variable citdl="int" default="1" ilk="argument" line="364" name="offset" /><variable citdl="string" default="'default'" ilk="argument" line="364" name="group" /></scope><scope doc="Remove the contents of the cache key in the group&#10;&#10;If the cache key does not exist in the group and $force parameter is set&#10;to false, then nothing will happen. The $force parameter is set to false&#10;by default.&#10;&#10;@since 2.0.0&#10;&#10;@param int|string $key What the contents in the cache are called&#10;@param string $group Where the cache contents are grouped&#10;@param bool $force Optional. Whether to force the unsetting of the cache&#10;	key in the group&#10;@return bool False if the contents weren't deleted and true on success" ilk="function" line="402" lineend="414" name="delete" returns="bool" signature="bool delete($key, string $group = 'default', bool $force = false)"><variable ilk="argument" line="402" name="key" /><variable citdl="string" default="'default'" ilk="argument" line="402" name="group" /><variable citdl="bool" default="false" ilk="argument" line="402" name="force" /></scope><scope doc="Clears the object cache of all data&#10;&#10;@since 2.0.0&#10;&#10;@return bool Always returns true" ilk="function" line="423" lineend="427" name="flush" returns="bool" signature="bool flush()" /><scope doc="Retrieves the cache contents, if it exists&#10;&#10;The contents will be first attempted to be retrieved by searching by the&#10;key in the cache group. If the cache is hit (success) then the contents&#10;are returned.&#10;&#10;On failure, the number of cache misses will be incremented.&#10;&#10;@since 2.0.0&#10;&#10;@param int|string $key What the contents in the cache are called&#10;@param string $group Where the cache contents are grouped&#10;@param string $force Whether to force a refetch rather than relying on the local cache (default is false)&#10;@return bool|mixed False on failure to retrieve contents or the cache&#10;	contents on success" ilk="function" line="446" lineend="465" name="get" returns="bool" signature="bool get($key, string $group = 'default', string $force = false, &amp; $found = null)"><variable ilk="argument" line="446" name="key" /><variable citdl="string" default="'default'" ilk="argument" line="446" name="group" /><variable citdl="string" default="false" ilk="argument" line="446" name="force" /><variable default="null" ilk="argument" line="446" name="found" /></scope><scope doc="Increment numeric cache item's value&#10;&#10;@since 3.3.0&#10;&#10;@param int|string $key The cache key to increment&#10;@param int $offset The amount by which to increment the item's value. Default is 1.&#10;@param string $group The group the key is in.&#10;@return false|int False on failure, the item's new value on success." ilk="function" line="477" lineend="498" name="incr" returns="false" signature="false incr($key, int $offset = 1, string $group = 'default')"><variable ilk="argument" line="477" name="key" /><variable citdl="int" default="1" ilk="argument" line="477" name="offset" /><variable citdl="string" default="'default'" ilk="argument" line="477" name="group" /></scope><scope doc="Replace the contents in the cache, if contents already exist&#10;&#10;@since 2.0.0&#10;@see WP_Object_Cache::set()&#10;&#10;@param int|string $key What to call the contents in the cache&#10;@param mixed $data The contents to store in the cache&#10;@param string $group Where to group the cache contents&#10;@param int $expire When to expire the cache contents&#10;@return bool False if not exists, true if contents were replaced" ilk="function" line="512" lineend="524" name="replace" returns="bool" signature="bool replace($key, mixed $data, string $group = 'default', int $expire = 0)"><variable ilk="argument" line="512" name="key" /><variable citdl="mixed" ilk="argument" line="512" name="data" /><variable citdl="string" default="'default'" ilk="argument" line="512" name="group" /><variable citdl="int" default="0" ilk="argument" line="512" name="expire" /><variable citdl="key" line="516" name="id" /></scope><scope doc="Reset keys&#10;&#10;@since 3.0.0&#10;@deprecated 3.5.0" ilk="function" line="532" lineend="540" name="reset" signature="reset()"><variable attributes="__not_yet_defined__" line="536" name="group" /></scope><scope doc="Sets the data contents into the cache&#10;&#10;The cache contents is grouped by the $group parameter followed by the&#10;$key. This allows for duplicate ids in unique groups. Therefore, naming of&#10;the group should be used with care and should follow normal function&#10;naming guidelines outside of core WordPress usage.&#10;&#10;The $expire parameter is not used, because the cache will automatically&#10;expire for each time a page is accessed and PHP finishes. The method is&#10;more for cache plugins which use files.&#10;&#10;@since 2.0.0&#10;&#10;@param int|string $key What to call the contents in the cache&#10;@param mixed $data The contents to store in the cache&#10;@param string $group Where to group the cache contents&#10;@param int $expire Not Used&#10;@return bool Always returns true" ilk="function" line="562" lineend="574" name="set" returns="bool" signature="bool set($key, mixed $data, string $group = 'default', int $expire = 0)"><variable ilk="argument" line="562" name="key" /><variable citdl="mixed" ilk="argument" line="562" name="data" /><variable citdl="string" default="'default'" ilk="argument" line="562" name="group" /><variable citdl="int" default="0" ilk="argument" line="562" name="expire" /></scope><scope doc="Echoes the stats of the caching.&#10;&#10;Gives the cache hits, and cache misses. Also prints every cached group,&#10;key and the data.&#10;&#10;@since 2.0.0" ilk="function" line="584" lineend="594" name="stats" signature="stats()"><variable line="590" name="group" /><variable attributes="__not_yet_defined__" line="590" name="cache" /></scope><scope doc="Switch the interal blog id.&#10;&#10;This changes the blog id used to create keys in blog specific groups.&#10;&#10;@since 3.5.0&#10;&#10;@param int $blog_id Blog ID" ilk="function" line="605" lineend="608" name="switch_to_blog" signature="switch_to_blog(int $blog_id)"><variable citdl="int" ilk="argument" line="605" name="blog_id" /></scope><scope attributes="protected" doc="Utility function to determine whether a key exists in the cache.&#10;&#10;@since 3.4.0&#10;&#10;@access protected" ilk="function" line="617" lineend="619" name="_exists" signature="_exists($key, $group)"><variable ilk="argument" line="617" name="key" /><variable ilk="argument" line="617" name="group" /></scope><scope attributes="__ctor__" doc="Sets up object properties; PHP 5 style constructor&#10;&#10;@since 2.0.8&#10;@return null|WP_Object_Cache If cache is disabled, returns null." ilk="function" line="627" lineend="639" name="__construct" returns="null" signature="null __construct()"><variable attributes="__not_yet_defined__" line="628" name="blog_id" /></scope><variable citdl="is_multisite()" line="630" name="multisite" /><scope doc="Will save the object cache before object is completely destroyed.&#10;&#10;Called upon object destruction, which should be when PHP ends.&#10;&#10;@since  2.0.8&#10;&#10;@return bool True value. Won't be used by PHP" ilk="function" line="650" lineend="652" name="__destruct" returns="bool" signature="bool __destruct()" /></scope></scope>