;@param string $class&#10;@return boolean" ilk="function" line="111" lineend="138" name="loadAnnotationClass" returns="boolean" signature="boolean loadAnnotationClass(string $class)"><variable citdl="string" ilk="argument" line="111" name="class" /><variable citdl="str_replace()" line="115" name="file" /><variable attributes="__not_yet_defined__" line="133" name="loader" /><variable attributes="__not_yet_defined__" line="122" name="dir" /><variable attributes="__not_yet_defined__" line="114" name="namespace" /><variable line="117" name="path" /><variable line="116" name="dirs" /></scope></scope></scope></scope>