<scope ilk="blob" lang="Ruby" name="rdoc/normal_class">
      <scope ilk="namespace" name="RDoc">
        <scope classrefs="RDoc::ClassModule" ilk="class" name="NormalClass">
          <scope doc="Appends the superclass, if any, to the included modules." ilk="function" name="ancestors" signature="ancestors()" />
          <scope doc="The definition of this class, class MyClassName" ilk="function" name="definition" signature="definition()" />
        </scope>
      </scope>
    </scope>
    