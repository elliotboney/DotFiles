<scope ilk="blob" lang="Ruby" name="rexml/formatters/transitive">
      <scope ilk="namespace" name="REXML">
        <scope ilk="namespace" name="Formatters">
          <scope classrefs="Default" ilk="class" name="Transitive">
            <scope attributes="__classmethod__ __ctor__" ilk="function" name="new" signature="new( indentation=2, ie_hack=false )" />
          </scope>
        </scope>
      </scope>
    </scope>
    