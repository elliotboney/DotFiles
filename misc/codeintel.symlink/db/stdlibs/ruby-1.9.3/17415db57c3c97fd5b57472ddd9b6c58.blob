<scope ilk="blob" lang="Ruby" name="bigdecimal/ludcmp">
      <scope ilk="namespace" name="LUSolve">
        <scope doc="Performs LU decomposition of the n by n matrix a." ilk="function" name="ludecomp" signature="ludecomp(a,n,zero=0,one=1)" />
        <scope doc="Solves a*x = b for x, using LU decomposition. &#10; a is a matrix, b is a constant vector, x is the solution vector. &#10; ps is the pivot, a vector which indicates the permutation of rows performed during LU decomposition." ilk="function" name="lusolve" signature="lusolve(a,b,ps,zero=0.0)" />
      </scope>
    </scope>
    