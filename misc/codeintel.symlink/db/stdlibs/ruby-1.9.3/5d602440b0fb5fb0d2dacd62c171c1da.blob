<scope ilk="blob" lang="Ruby" name="rake/loaders/makefile">
      <scope ilk="namespace" name="Rake">
        <scope classrefs="Object" ilk="class" name="MakefileLoader">
          <import symbol="Rake::DSL" />
          <scope doc="Load the makefile dependencies in +fn+." ilk="function" name="load" signature="load(fn)" />
          <variable attributes="__const__" citdl="Object" name="SPACE_MARK" />
        </scope>
      </scope>
    </scope>
    