        <scope doc="Computes the square root of +a+.  It makes use of Complex and Rational to have no rounding errors if possible. &#10; Math.sqrt(4/9)      # =&gt; 2/3&#10;Math.sqrt(- 4/9)    # =&gt; Complex(0, 2/3)&#10;Math.sqrt(4.0/9.0)  # =&gt; 0.666666666666667" ilk="function" name="sqrt" signature="sqrt(a)" />
