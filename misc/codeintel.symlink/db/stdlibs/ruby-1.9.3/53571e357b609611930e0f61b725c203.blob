        <scope classrefs="Struct" ilk="class" name="Tms">
          <import symbol="Enumerable" />
          <scope ilk="function" name="cstime" />
          <scope ilk="function" name="cstime=" />
          <scope ilk="function" name="cutime" />
          <scope ilk="function" name="cutime=" />
          <scope ilk="function" name="stime" />
          <scope ilk="function" name="stime=" />
