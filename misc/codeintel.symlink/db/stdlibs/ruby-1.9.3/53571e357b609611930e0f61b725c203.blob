      <scope classrefs="Object" ilk="class" name="StringScanner">
        <scope doc="Returns +true+ iff the scan pointer is at the beginning of the line. &#10; s = StringScanner.new(&quot;test\ntest\n&quot;)&#10;s.bol?           # =&gt; true&#10;s.scan(/te/)&#10;s.bol?           # =&gt; false&#10;s.scan(/st\n/)&#10;s.bol?           # =&gt; true&#10;s.terminate&#10;s.bol?           # =&gt; true" ilk="function" name="beginning_of_line?" signature="beginning_of_line?()" />
        <scope ilk="function" name="bol?" />
        <scope doc="This returns the value that #scan would return, without advancing the scan pointer.  The match register is affected, though. &#10; s = StringScanner.new(&quot;Fri Dec 12 1975 14:39&quot;)&#10;s.check /Fri/               # -&gt; &quot;Fri&quot;&#10;s.pos                       # -&gt; 0&#10;s.matched                   # -&gt; &quot;Fri&quot;&#10;s.check /12/                # -&gt; nil&#10;s.matched                   # -&gt; nil&#10; Mnemonic: it &quot;checks&quot; to see whether a #scan will return a value." ilk="function" name="check" signature="check(p1)" />
        <scope doc="This returns the value that #scan_until would return, without advancing the scan pointer.  The match register is affected, though. &#10; s = StringScanner.new(&quot;Fri Dec 12 1975 14:39&quot;)&#10;s.check_until /12/          # -&gt; &quot;Fri Dec 12&quot;&#10;s.pos                       # -&gt; 0&#10;s.matched                   # -&gt; 12&#10; Mnemonic: it &quot;checks&quot; to see whether a #scan_until will return a value." ilk="function" name="check_until" signature="check_until(p1)" />
        <scope doc="Equivalent to #terminate. This method is obsolete; use #terminate instead." ilk="function" name="clear" signature="clear()" />
        <scope doc="Appends +str+ to the string being scanned. This method does not affect scan pointer. &#10; s = StringScanner.new(&quot;Fri Dec 12 1975 14:39&quot;)&#10;s.scan(/Fri /)&#10;s &lt;&lt; &quot; +1000 GMT&quot;&#10;s.string            # -&gt; &quot;Fri Dec 12 1975 14:39 +1000 GMT&quot;&#10;s.scan(/Dec/)       # -&gt; &quot;Dec&quot;" ilk="function" name="concat" signature="concat(p1)" />
        <scope doc="Equivalent to #eos?. This method is obsolete, use #eos? instead." ilk="function" name="empty?" signature="empty?()" />
        <scope doc="Returns +true+ if the scan pointer is at the end of the string. &#10; s = StringScanner.new('test string')&#10;p s.eos?          # =&gt; false&#10;s.scan(/test/)&#10;p s.eos?          # =&gt; false&#10;s.terminate&#10;p s.eos?          # =&gt; true" ilk="function" name="eos?" signature="eos?()" />
        <scope doc="Looks _ahead_ to see if the +pattern+ exists _anywhere_ in the string, without advancing the scan pointer.  This predicates whether a #scan_until will return a value. &#10; s = StringScanner.new('test string')&#10;s.exist? /s/            # -&gt; 3&#10;s.scan /test/           # -&gt; &quot;test&quot;&#10;s.exist? /s/            # -&gt; 2&#10;s.exist? /e/            # -&gt; nil" ilk="function" name="exist?" signature="exist?(p1)" />
        <scope doc="Scans one byte and returns it. This method is not multibyte character sensitive. See also: #getch. &#10; s = StringScanner.new('ab')&#10;s.get_byte         # =&gt; &quot;a&quot;&#10;s.get_byte         # =&gt; &quot;b&quot;&#10;s.get_byte         # =&gt; nil&#10;&#10;$KCODE = 'EUC'&#10;s = StringScanner.new(&quot;\244\242&quot;)&#10;s.get_byte         # =&gt; &quot;\244&quot;&#10;s.get_byte         # =&gt; &quot;\242&quot;&#10;s.get_byte         # =&gt; nil" ilk="function" name="get_byte" signature="get_byte()" />
        <scope doc="Equivalent to #get_byte. This method is obsolete; use #get_byte instead." ilk="function" name="getbyte" signature="getbyte()" />
        <scope doc="Scans one character and returns it. This method is multibyte character sensitive. &#10; s = StringScanner.new(&quot;ab&quot;)&#10;s.getch           # =&gt; &quot;a&quot;&#10;s.getch           # =&gt; &quot;b&quot;&#10;s.getch           # =&gt; nil&#10;&#10;$KCODE = 'EUC'&#10;s = StringScanner.new(&quot;\244\242&quot;)&#10;s.getch           # =&gt; &quot;\244\242&quot;   # Japanese hira-kana &quot;A&quot; in EUC-JP&#10;s.getch           # =&gt; nil" ilk="function" name="getch" signature="getch()" />
        <scope doc="Tests whether the given +pattern+ is matched from the current scan pointer. Returns the length of the match, or +nil+.  The scan pointer is not advanced. &#10; s = StringScanner.new('test string')&#10;p s.match?(/\w+/)   # -&gt; 4&#10;p s.match?(/\w+/)   # -&gt; 4&#10;p s.match?(/\s+/)   # -&gt; nil" ilk="function" name="match?" signature="match?(p1)" />
        <scope doc="Returns the last matched string. &#10; s = StringScanner.new('test string')&#10;s.match?(/\w+/)     # -&gt; 4&#10;s.matched           # -&gt; &quot;test&quot;" ilk="function" name="matched" signature="matched()" />
        <scope doc="Returns +true+ iff the last match was successful. &#10; s = StringScanner.new('test string')&#10;s.match?(/\w+/)     # =&gt; 4&#10;s.matched?          # =&gt; true&#10;s.match?(/\d+/)     # =&gt; nil&#10;s.matched?          # =&gt; false" ilk="function" name="matched?" signature="matched?()" />
        <scope doc="Returns the size of the most recent match (see #matched), or +nil+ if there was no recent match. &#10; s = StringScanner.new('test string')&#10;s.check /\w+/           # -&gt; &quot;test&quot;&#10;s.matched_size          # -&gt; 4&#10;s.check /\d+/           # -&gt; nil&#10;s.matched_size          # -&gt; nil" ilk="function" name="matched_size" signature="matched_size()" />
        <scope doc="Extracts a string corresponding to string[pos,len], without advancing the scan pointer. &#10; s = StringScanner.new('test string')&#10;s.peek(7)          # =&gt; &quot;test st&quot;&#10;s.peek(7)          # =&gt; &quot;test st&quot;" ilk="function" name="peek" signature="peek(p1)" />
        <scope doc="Equivalent to #peek. This method is obsolete; use #peek instead." ilk="function" name="peep" signature="peep(p1)" />
        <scope doc="Returns the byte position of the scan pointer.  In the 'reset' position, this value is zero.  In the 'terminated' position (i.e. the string is exhausted), this value is the bytesize of the string. &#10; In short, it's a 0-based index into the string. &#10; s = StringScanner.new('test string')&#10;s.pos               # -&gt; 0&#10;s.scan_until /str/  # -&gt; &quot;test str&quot;&#10;s.pos               # -&gt; 8&#10;s.terminate         # -&gt; #&lt;StringScanner fin&gt;&#10;s.pos               # -&gt; 11" ilk="function" name="pointer" signature="pointer()" />
        <scope doc="Set the byte position of the scan pointer. &#10; s = StringScanner.new('test string')&#10;s.pos = 7            # -&gt; 7&#10;s.rest               # -&gt; &quot;ring&quot;" ilk="function" name="pointer=" signature="pointer=(p1)" />
        <scope doc="Returns the byte position of the scan pointer.  In the 'reset' position, this value is zero.  In the 'terminated' position (i.e. the string is exhausted), this value is the bytesize of the string. &#10; In short, it's a 0-based index into the string. &#10; s = StringScanner.new('test string')&#10;s.pos               # -&gt; 0&#10;s.scan_until /str/  # -&gt; &quot;test str&quot;&#10;s.pos               # -&gt; 8&#10;s.terminate         # -&gt; #&lt;StringScanner fin&gt;&#10;s.pos               # -&gt; 11" ilk="function" name="pos" signature="pos()" />
        <scope doc="Set the byte position of the scan pointer. &#10; s = StringScanner.new('test string')&#10;s.pos = 7            # -&gt; 7&#10;s.rest               # -&gt; &quot;ring&quot;" ilk="function" name="pos=" signature="pos=(p1)" />
        <scope doc="Return the &lt;b&gt;post&lt;/b&gt;-match (in the regular expression sense) of the last scan. &#10; s = StringScanner.new('test string')&#10;s.scan(/\w+/)           # -&gt; &quot;test&quot;&#10;s.scan(/\s+/)           # -&gt; &quot; &quot;&#10;s.pre_match             # -&gt; &quot;test&quot;&#10;s.post_match            # -&gt; &quot;string&quot;" ilk="function" name="post_match" signature="post_match()" />
        <scope doc="Return the &lt;b&gt;pre&lt;/b&gt;-match (in the regular expression sense) of the last scan. &#10; s = StringScanner.new('test string')&#10;s.scan(/\w+/)           # -&gt; &quot;test&quot;&#10;s.scan(/\s+/)           # -&gt; &quot; &quot;&#10;s.pre_match             # -&gt; &quot;test&quot;&#10;s.post_match            # -&gt; &quot;string&quot;" ilk="function" name="pre_match" signature="pre_match()" />
        <scope doc="Reset the scan pointer (index 0) and clear matching data." ilk="function" name="reset" signature="reset()" />
        <scope doc="Returns the &quot;rest&quot; of the string (i.e. everything after the scan pointer). If there is no more data (eos? = true), it returns &quot;&quot;." ilk="function" name="rest" signature="rest()" />
        <scope doc="Returns true iff there is more data in the string.  See #eos?. This method is obsolete; use #eos? instead. &#10; s = StringScanner.new('test string')&#10;s.eos?              # These two&#10;s.rest?             # are opposites." ilk="function" name="rest?" signature="rest?()" />
        <scope doc="s.rest_size is equivalent to s.rest.size." ilk="function" name="rest_size" signature="rest_size()" />
        <scope doc="s.restsize is equivalent to s.rest_size. This method is obsolete; use #rest_size instead." ilk="function" name="restsize" signature="restsize()" />
        <scope doc="Tries to match with +pattern+ at the current position. If there's a match, the scanner advances the &quot;scan pointer&quot; and returns the matched string. Otherwise, the scanner returns +nil+. &#10; s = StringScanner.new('test string')&#10;p s.scan(/\w+/)   # -&gt; &quot;test&quot;&#10;p s.scan(/\w+/)   # -&gt; nil&#10;p s.scan(/\s+/)   # -&gt; &quot; &quot;&#10;p s.scan(/\w+/)   # -&gt; &quot;string&quot;&#10;p s.scan(/./)     # -&gt; nil" ilk="function" name="scan" signature="scan(p1)" />
        <scope doc="Tests whether the given +pattern+ is matched from the current scan pointer. Advances the scan pointer if +advance_pointer_p+ is true. Returns the matched string if +return_string_p+ is true. The match register is affected. &#10; &quot;full&quot; means &quot;#scan with full parameters&quot;." ilk="function" name="scan_full" signature="scan_full(p1, p2, p3)" />
        <scope doc="Scans the string _until_ the +pattern+ is matched.  Returns the substring up to and including the end of the match, advancing the scan pointer to that location. If there is no match, +nil+ is returned. &#10; s = StringScanner.new(&quot;Fri Dec 12 1975 14:39&quot;)&#10;s.scan_until(/1/)        # -&gt; &quot;Fri Dec 1&quot;&#10;s.pre_match              # -&gt; &quot;Fri Dec &quot;&#10;s.scan_until(/XYZ/)      # -&gt; nil" ilk="function" name="scan_until" signature="scan_until(p1)" />
        <scope doc="Scans the string _until_ the +pattern+ is matched. Advances the scan pointer if +advance_pointer_p+, otherwise not. Returns the matched string if +return_string_p+ is true, otherwise returns the number of bytes advanced. This method does affect the match register." ilk="function" name="search_full" signature="search_full(p1, p2, p3)" />
        <scope doc="Attempts to skip over the given +pattern+ beginning with the scan pointer. If it matches, the scan pointer is advanced to the end of the match, and the length of the match is returned.  Otherwise, +nil+ is returned. &#10; It's similar to #scan, but without returning the matched string. &#10; s = StringScanner.new('test string')&#10;p s.skip(/\w+/)   # -&gt; 4&#10;p s.skip(/\w+/)   # -&gt; nil&#10;p s.skip(/\s+/)   # -&gt; 1&#10;p s.skip(/\w+/)   # -&gt; 6&#10;p s.skip(/./)     # -&gt; nil" ilk="function" name="skip" signature="skip(p1)" />
        <scope doc="Advances the scan pointer until +pattern+ is matched and consumed.  Returns the number of bytes advanced, or +nil+ if no match was found. &#10; Look ahead to match +pattern+, and advance the scan pointer to the _end_ of the match.  Return the number of characters advanced, or +nil+ if the match was unsuccessful. &#10; It's similar to #scan_until, but without returning the intervening string. &#10; s = StringScanner.new(&quot;Fri Dec 12 1975 14:39&quot;)&#10;s.skip_until /12/           # -&gt; 10&#10;s                           #" ilk="function" name="skip_until" signature="skip_until(p1)" />
        <scope doc="Returns the string being scanned." ilk="function" name="string" signature="string()" />
        <scope doc="Changes the string being scanned to +str+ and resets the scanner. Returns +str+." ilk="function" name="string=" signature="string=(p1)" />
        <scope doc="Set the scan pointer to the end of the string and clear matching data." ilk="function" name="terminate" signature="terminate()" />
        <scope doc="Set the scan pointer to the previous position.  Only one previous position is remembered, and it changes with each scanning operation. &#10; s = StringScanner.new('test string')&#10;s.scan(/\w+/)        # =&gt; &quot;test&quot;&#10;s.unscan&#10;s.scan(/../)         # =&gt; &quot;te&quot;&#10;s.scan(/\d/)         # =&gt; nil&#10;s.unscan             # ScanError: unscan failed: previous match record not exist" ilk="function" name="unscan" signature="unscan()" />
        <scope attributes="__classmethod__" doc="This method is defined for backward compatibility." ilk="function" name="must_C_version" signature="must_C_version()" />
        <scope attributes="__classmethod__" doc="Creates a new StringScanner object to scan over the given +string+. +dup+ argument is obsolete and not used now." ilk="function" name="new" signature="new(p1, p2 = v2)" />
        <scope classrefs="StandardError" ilk="class" name="Error">
        </scope>
        <variable attributes="__const__" citdl="String" name="Id" />
        <variable attributes="__const__" citdl="String" name="Version" />
      </scope>
      <scope classrefs="StandardError" ilk="class" name="ScanError">
      </scope>
      <scope classrefs="Object" ilk="class" name="ConditionVariable">
        <scope doc="Wakes up all threads waiting for this lock." ilk="function" name="broadcast" signature="broadcast()" />
        <scope doc="Wakes up the first thread in line waiting for this lock." ilk="function" name="signal" signature="signal()" />
        <scope doc="Releases the lock held in +mutex+ and waits; reacquires the lock on wakeup. &#10; If +timeout+ is given, this method returns after +timeout+ seconds passed, even if no other thread doesn't signal." ilk="function" name="wait" signature="wait(mutex, timeout=nil)" />
        <scope attributes="__classmethod__" doc="Creates a new ConditionVariable" ilk="function" name="new" signature="new()" />
      </scope>
      <scope classrefs="Object" ilk="class" name="Queue">
        <scope doc="Removes all objects from the queue." ilk="function" name="clear" signature="clear()" />
        <scope doc="Alias of pop" ilk="function" name="deq" signature="deq(non_block=false)" />
        <scope doc="Returns +true+ if the queue is empty." ilk="function" name="empty?" signature="empty?()" />
        <scope doc="Alias of push" ilk="function" name="enq" signature="enq(obj)" />
        <scope doc="Returns the length of the queue." ilk="function" name="length" signature="length()" />
        <scope doc="Returns the number of threads waiting on the queue." ilk="function" name="num_waiting" signature="num_waiting()" />
        <scope doc="Retrieves data from the queue.  If the queue is empty, the calling thread is suspended until data is pushed onto the queue.  If +non_block+ is true, the thread isn't suspended, and an exception is raised." ilk="function" name="pop" signature="pop(non_block=false)" />
        <scope doc="Pushes +obj+ to the queue." ilk="function" name="push" signature="push(obj)" />
        <scope doc="Alias of pop" ilk="function" name="shift" signature="shift(non_block=false)" />
        <scope doc="Alias of length." ilk="function" name="size" signature="size()" />
        <scope attributes="__classmethod__" doc="Creates a new queue." ilk="function" name="new" signature="new()" />
      </scope>
      <scope classrefs="Queue" ilk="class" name="SizedQueue">
        <scope doc="Returns the maximum size of the queue." ilk="function" name="max" signature="max()" />
        <scope doc="Sets the maximum size of the queue." ilk="function" name="max=" signature="max=(max)" />
        <scope attributes="__classmethod__" doc="Creates a fixed-length queue with a maximum size of +max+." ilk="function" name="new" signature="new(max)" />
      </scope>
      <scope ilk="namespace" name="RbConfig">
        <scope ilk="function" name="datadir" />
        <scope ilk="function" name="expand" />
        <scope ilk="function" name="ruby" />
        <variable attributes="__const__" citdl="Hash" name="CONFIG" />
        <variable attributes="__const__" citdl="String" name="DESTDIR" />
        <variable attributes="__const__" citdl="Hash" name="MAKEFILE_CONFIG" />
        <variable attributes="__const__" citdl="String" name="TOPDIR" />
      </scope>
      <scope ilk="namespace" name="Config">
        <scope ilk="function" name="datadir" />
        <scope ilk="function" name="expand" />
        <scope ilk="function" name="ruby" />
        <variable attributes="__const__" citdl="Hash" name="CONFIG" />
        <variable attributes="__const__" citdl="String" name="DESTDIR" />
        <variable attributes="__const__" citdl="Hash" name="MAKEFILE_CONFIG" />
        <variable attributes="__const__" citdl="String" name="TOPDIR" />
      </scope>
      <variable attributes="__const__" citdl="NilClass" name="CROSS_COMPILING" />
      <scope classrefs="Object" ilk="class" name="Date">
        <scope doc="Returns the astronomical Julian day number.  This is a fractional number, which is not adjusted by the offset. &#10; For example: &#10; DateTime.new(2001,2,3,4,5,6,'+7').ajd     =&gt; (11769328217/4800)&#10;DateTime.new(2001,2,2,14,5,6,'-7').ajd    =&gt; (11769328217/4800)" ilk="function" name="ajd" signature="ajd()" />
        <scope doc="Returns the astronomical modified Julian day number.  This is a fractional number, which is not adjusted by the offset. &#10; For example: &#10; DateTime.new(2001,2,3,4,5,6,'+7').amjd    =&gt; (249325817/4800)&#10;DateTime.new(2001,2,2,14,5,6,'-7').amjd   =&gt; (249325817/4800)" ilk="function" name="amjd" signature="amjd()" />
        <scope doc="Returns a string in asctime(3) format (but without &quot;\n\0&quot; at the end).  This method is equivalent to strftime('%c'). &#10; See also asctime(3) or ctime(3)." ilk="function" name="asctime" signature="asctime()" />
        <scope doc="Returns a string in asctime(3) format (but without &quot;\n\0&quot; at the end).  This method is equivalent to strftime('%c'). &#10; See also asctime(3) or ctime(3)." ilk="function" name="ctime" signature="ctime()" />
        <scope doc="Returns the day of calendar week (1-7, Monday is 1). &#10; For example: &#10; Date.new(2001,2,3).cwday          =&gt; 6" ilk="function" name="cwday" signature="cwday()" />
        <scope doc="Returns the calendar week number (1-53). &#10; For example: &#10; Date.new(2001,2,3).cweek          =&gt; 5" ilk="function" name="cweek" signature="cweek()" />
        <scope doc="Returns the calendar week based year. &#10; For example: &#10; Date.new(2001,2,3).cwyear         =&gt; 2001&#10;Date.new(2000,1,1).cwyear         =&gt; 1999" ilk="function" name="cwyear" signature="cwyear()" />
        <scope doc="Returns the day of the month (1-31). &#10; For example: &#10; Date.new(2001,2,3).mday           =&gt; 3" ilk="function" name="day" signature="day()" />
        <scope doc="Returns the fractional part of the day. &#10; For example: &#10; DateTime.new(2001,2,3,12).day_fraction    =&gt; (1/2)" ilk="function" name="day_fraction" signature="day_fraction()" />
        <scope doc="This method is equivalent to step(min, -1){|date| ...}." ilk="function" name="downto" signature="downto(p1)" />
        <scope doc="This method is equivalent to new_start(Date::ENGLAND)." ilk="function" name="england" signature="england()" />
        <scope doc="Returns true if the date is Friday." ilk="function" name="friday?" signature="friday?()" />
        <scope doc="This method is equivalent to new_start(Date::GREGORIAN)." ilk="function" name="gregorian" signature="gregorian()" />
        <scope doc="Retunrs true if the date is on or after the day of calendar reform. &#10; For example: &#10; Date.new(1582,10,15).gregorian?          =&gt; true&#10;(Date.new(1582,10,15) - 1).gregorian?    =&gt; false" ilk="function" name="gregorian?" signature="gregorian?()" />
        <scope doc="This method is equivalent to strftime('%a, %d %b %Y %T GMT'). See also RFC 2616." ilk="function" name="httpdate" signature="httpdate()" />
        <scope doc="This method is equivalent to strftime('%F')." ilk="function" name="iso8601" signature="iso8601()" />
        <scope doc="This method is equivalent to new_start(Date::ITALY)." ilk="function" name="italy" signature="italy()" />
        <scope doc="Returns the Julian day number.  This is a whole number, which is adjusted by the offset as the local time. &#10; For example: &#10; DateTime.new(2001,2,3,4,5,6,'+7').jd      =&gt; 2451944&#10;DateTime.new(2001,2,3,4,5,6,'-7').jd      =&gt; 2451944" ilk="function" name="jd" signature="jd()" />
        <scope doc="Returns a string in a JIS X 0301 format. &#10; For example: &#10; Date.new(2001,2,3).jisx0301       =&gt; &quot;H13.02.03&quot;" ilk="function" name="jisx0301" signature="jisx0301()" />
        <scope doc="This method is equivalent to new_start(Date::JULIAN)." ilk="function" name="julian" signature="julian()" />
        <scope doc="Retruns true if the date is before the day of calendar reform. &#10; For example: &#10; Date.new(1582,10,15).julian?             =&gt; false&#10;(Date.new(1582,10,15) - 1).julian?       =&gt; true" ilk="function" name="julian?" signature="julian?()" />
        <scope doc="Returns the Lilian day number.  This is a whole number, which is adjusted by the offset as the local time. &#10; For example: &#10; Date.new(2001,2,3).ld            =&gt; 152784" ilk="function" name="ld" signature="ld()" />
        <scope doc="Returns true if the year is a leap year. &#10; For example: &#10; Date.new(2000).leap?      =&gt; true&#10;Date.new(2001).leap?      =&gt; false" ilk="function" name="leap?" signature="leap?()" />
        <scope ilk="function" name="marshal_dump" />
        <scope ilk="function" name="marshal_load" />
        <scope doc="Returns the day of the month (1-31). &#10; For example: &#10; Date.new(2001,2,3).mday           =&gt; 3" ilk="function" name="mday" signature="mday()" />
        <scope doc="Returns the modified Julian day number.  This is a whole number, which is adjusted by the offset as the local time. &#10; For example: &#10; DateTime.new(2001,2,3,4,5,6,'+7').mjd     =&gt; 51943&#10;DateTime.new(2001,2,3,4,5,6,'-7').mjd     =&gt; 51943" ilk="function" name="mjd" signature="mjd()" />
        <scope doc="Returns the month (1-12). &#10; For example: &#10; Date.new(2001,2,3).mon            =&gt; 2" ilk="function" name="mon" signature="mon()" />
        <scope doc="Returns true if the date is Monday." ilk="function" name="monday?" signature="monday?()" />
        <scope doc="Returns the month (1-12). &#10; For example: &#10; Date.new(2001,2,3).mon            =&gt; 2" ilk="function" name="month" signature="month()" />
        <scope doc="Duplicates self and resets its the day of calendar reform. &#10; For example: &#10; d = Date.new(1582,10,15)&#10;d.new_start(Date::JULIAN)         =&gt; #&lt;Date: 1582-10-05 ...&gt;" ilk="function" name="new_start" signature="new_start(p1 = v1)" />
        <scope doc="Returns a date object denoting the following day." ilk="function" name="next" signature="next()" />
        <scope doc="This method is equivalent to d + n." ilk="function" name="next_day" signature="next_day(p1 = v1)" />
        <scope doc="This method is equivalent to d &gt;&gt; n" ilk="function" name="next_month" signature="next_month(p1 = v1)" />
        <scope doc="This method is equivalent to d &gt;&gt; (n * 12)" ilk="function" name="next_year" signature="next_year(p1 = v1)" />
        <scope doc="This method is equivalent to d - n." ilk="function" name="prev_day" signature="prev_day(p1 = v1)" />
        <scope doc="This method is equivalent to d &lt;&lt; n" ilk="function" name="prev_month" signature="prev_month(p1 = v1)" />
        <scope doc="This method is equivalent to d &lt;&lt; (n * 12)" ilk="function" name="prev_year" signature="prev_year(p1 = v1)" />
        <scope doc="This method is equivalent to strftime('%a, %-d %b %Y %T %z')." ilk="function" name="rfc2822" signature="rfc2822()" />
        <scope doc="This method is equivalent to strftime('%FT%T%:z')." ilk="function" name="rfc3339" signature="rfc3339()" />
        <scope doc="This method is equivalent to strftime('%a, %-d %b %Y %T %z')." ilk="function" name="rfc822" signature="rfc822()" />
        <scope doc="Returns true if the date is Saturday." ilk="function" name="saturday?" signature="saturday?()" />
        <scope doc="Returns the Julian day number denoting the day of calendar reform. &#10; For example: &#10; Date.new(2001,2,3).start                  =&gt; 2299161.0&#10;Date.new(2001,2,3,Date::GREGORIAN).start  =&gt; -Infinity" ilk="function" name="start" signature="start()" />
        <scope doc="Iterates evaluation of the given block, which takes a date object. The limit should be a date object. &#10; For example: &#10; Date.new(2001).step(Date.new(2001,-1,-1)).select{|d| d.sunday?}.size&#10;                          =&gt; 52" ilk="function" name="step" signature="step(p1, p2 = v2)" />
        <scope doc="Formats date according to the directives in the given format&#10;string.&#10;The directives begins with a percent (%) character.&#10;Any text not listed as a directive will be passed through to the&#10;output string.&#10;The directive consists of a percent (%) character,&#10;zero or more flags, optional minimum field width,&#10;optional modifier and a conversion specifier&#10;as follows.&#10;  %&lt;flags&gt;&lt;width&gt;&lt;modifier&gt;&lt;conversion&gt;&#10;Flags:&#10;  -  don't pad a numerical output.&#10;  _  use spaces for padding." ilk="function" name="strftime" signature="strftime(*args)" />
        <scope doc="Returns a date object denoting the following day." ilk="function" name="succ" signature="succ()" />
        <scope doc="Returns true if the date is Sunday." ilk="function" name="sunday?" signature="sunday?()" />
        <scope doc="Returns true if the date is Thursday." ilk="function" name="thursday?" signature="thursday?()" />
        <scope doc="Returns self;" ilk="function" name="to_date" signature="to_date()" />
        <scope doc="Returns a DateTime object which denotes self." ilk="function" name="to_datetime" signature="to_datetime()" />
        <scope doc="Returns a Time object which denotes self." ilk="function" name="to_time" signature="to_time()" />
        <scope doc="Returns true if the date is Tuesday." ilk="function" name="tuesday?" signature="tuesday?()" />
        <scope doc="This method is equivalent to step(max, 1){|date| ...}." ilk="function" name="upto" signature="upto(p1)" />
        <scope doc="Returns the day of week (0-6, Sunday is zero). &#10; For example: &#10; Date.new(2001,2,3).wday           =&gt; 6" ilk="function" name="wday" signature="wday()" />
        <scope doc="Returns true if the date is Wednesday." ilk="function" name="wednesday?" signature="wednesday?()" />
        <scope doc="This method is equivalent to strftime('%F')." ilk="function" name="xmlschema" signature="xmlschema()" />
        <scope doc="Returns the day of the year (1-366). &#10; For example: &#10; Date.new(2001,2,3).yday           =&gt; 34" ilk="function" name="yday" signature="yday()" />
        <scope doc="Returns the year. &#10; For example: &#10; Date.new(2001,2,3).year           =&gt; 2001&#10;(Date.new(1,1,1) - 1).year        =&gt; 0" ilk="function" name="year" signature="year()" />
        <scope attributes="__classmethod__" doc="Returns a hash of parsed elements." ilk="function" name="_httpdate" signature="_httpdate(p1)" />
        <scope attributes="__classmethod__" doc="Returns a hash of parsed elements." ilk="function" name="_iso8601" signature="_iso8601(p1)" />
        <scope attributes="__classmethod__" doc="Returns a hash of parsed elements." ilk="function" name="_jisx0301" signature="_jisx0301(p1)" />
        <scope attributes="__classmethod__" doc="Parses the given representation of date and time, and returns a hash of parsed elements. &#10; If the optional second argument is true and the detected year is in the range &quot;00&quot; to &quot;99&quot;, considers the year a 2-digit form and makes it full. &#10; For example: &#10; Date._parse('2001-02-03') =&gt; {:year=&gt;2001, :mon=&gt;2, :mday=&gt;3}" ilk="function" name="_parse" signature="_parse(*args)" />
        <scope attributes="__classmethod__" doc="Returns a hash of parsed elements." ilk="function" name="_rfc2822" signature="_rfc2822(p1)" />
        <scope attributes="__classmethod__" doc="Returns a hash of parsed elements." ilk="function" name="_rfc3339" signature="_rfc3339(p1)" />
        <scope attributes="__classmethod__" doc="Returns a hash of parsed elements." ilk="function" name="_rfc822" signature="_rfc822(p1)" />
        <scope attributes="__classmethod__" doc="Parses the given representation of date and time with the given template, and returns a hash of parsed elements. &#10; For example: &#10;   Date._strptime('2001-02-03', '%Y-%m-%d')&#10;                            =&gt; {:year=&gt;2001, :mon=&gt;2, :mday=&gt;3}&#10;&#10;See also strptime(3) and strftime." ilk="function" name="_strptime" signature="_strptime(*args)" />
        <scope attributes="__classmethod__" doc="Returns a hash of parsed elements." ilk="function" name="_xmlschema" signature="_xmlschema(p1)" />
        <scope attributes="__classmethod__" doc="Creates a date object denoting the given calendar date. &#10; In this class, BCE years are counted astronomically.  Thus, the year before the year 1 is the year zero, and the year preceding the year zero is the year -1.  The month and the day of month should be a negative or a positive number (as a relative month/day from the end of year/month when negative).  They should not be zero. &#10; The last argument should be a Julian day number which denotes the day of calendar reform.  Date::ITALY (2299161=1582-10-15), Date::ENGLAND (2361222=1752-09-14), Date::GREGORIAN (the proleptic Gregorian calendar) and Date::JULIAN (the proleptic Julian calendar) can be specified as a day of calendar reform. &#10; For example: &#10; Date.new(2001)            =&gt; #&lt;Date: 2001-01-01 ...&gt;&#10;Date.new(2001,2,3)        =&gt; #&lt;Date: 2001-02-03 ...&gt;&#10;Date.new(2001,2,-1)       =&gt; #&lt;Date: 2001-02-28 ...&gt;&#10; See also jd." ilk="function" name="civil" signature="civil(p1 = v1, p2 = v2, p3 = v3, p4 = v4)" />
        <scope attributes="__classmethod__" doc="Creates a date object denoting the given week date. &#10; The week and the day of week should be a negative or a positive number (as a relative week/day from the end of year/week when negative).  They should not be zero. &#10; For example: &#10; Date.commercial(2001)     =&gt; #&lt;Date: 2001-01-01 ...&gt;&#10;Date.commercial(2002)     =&gt; #&lt;Date: 2001-12-31 ...&gt;&#10;Date.commercial(2001,5,6) =&gt; #&lt;Date: 2001-02-03 ...&gt;&#10; See also jd and new." ilk="function" name="commercial" signature="commercial(p1 = v1, p2 = v2, p3 = v3, p4 = v4)" />
        <scope attributes="__classmethod__" doc="Returns true if the given year is a leap year of the proleptic Gregorian calendar. &#10; For example: &#10; Date.gregorian_leap?(1900)        =&gt; false&#10;Date.gregorian_leap?(2000)        =&gt; true" ilk="function" name="gregorian_leap?" signature="gregorian_leap?(p1)" />
        <scope attributes="__classmethod__" doc="Creates a new Date object by parsing from a string according to some RFC 2616 format. &#10; For example: &#10; Date.httpdate('Sat, 03 Feb 2001 00:00:00 GMT')&#10;                                          =&gt; #&lt;Date: 2001-02-03 ...&gt;" ilk="function" name="httpdate" signature="httpdate(p1 = v1, p2 = v2)" />
        <scope attributes="__classmethod__" doc="Creates a new Date object by parsing from a string according to some typical ISO 8601 formats. &#10; For example: &#10; Date.iso8601('2001-02-03')        =&gt; #&lt;Date: 2001-02-03 ...&gt;&#10;Date.iso8601('20010203')          =&gt; #&lt;Date: 2001-02-03 ...&gt;&#10;Date.iso8601('2001-W05-6')        =&gt; #&lt;Date: 2001-02-03 ...&gt;" ilk="function" name="iso8601" signature="iso8601(p1 = v1, p2 = v2)" />
        <scope attributes="__classmethod__" doc="Creates a date object denoting the given chronological Julian day number. &#10; For example: &#10; Date.jd(2451944)          =&gt; #&lt;Date: 2001-02-03 ...&gt;&#10;Date.jd(2451945)          =&gt; #&lt;Date: 2001-02-04 ...&gt;&#10;Date.jd(0)                =&gt; #&lt;Date: -4712-01-01 ...&gt;&#10; See also new." ilk="function" name="jd" signature="jd(p1 = v1, p2 = v2)" />
        <scope attributes="__classmethod__" doc="Creates a new Date object by parsing from a string according to some typical JIS X 0301 formats. &#10; For example: &#10; Date.jisx0301('H13.02.03')                =&gt; #&lt;Date: 2001-02-03 ...&gt;" ilk="function" name="jisx0301" signature="jisx0301(p1 = v1, p2 = v2)" />
        <scope attributes="__classmethod__" doc="Returns true if the given year is a leap year of the proleptic Julian calendar. &#10; For example: &#10; Date.julian_leap?(1900)           =&gt; true&#10;Date.julian_leap?(1901)           =&gt; false" ilk="function" name="julian_leap?" signature="julian_leap?(p1)" />
        <scope attributes="__classmethod__" doc="Returns true if the given year is a leap year of the proleptic Gregorian calendar. &#10; For example: &#10; Date.gregorian_leap?(1900)        =&gt; false&#10;Date.gregorian_leap?(2000)        =&gt; true" ilk="function" name="leap?" signature="leap?(p1)" />
        <scope attributes="__classmethod__" doc="Creates a date object denoting the given calendar date. &#10; In this class, BCE years are counted astronomically.  Thus, the year before the year 1 is the year zero, and the year preceding the year zero is the year -1.  The month and the day of month should be a negative or a positive number (as a relative month/day from the end of year/month when negative).  They should not be zero. &#10; The last argument should be a Julian day number which denotes the day of calendar reform.  Date::ITALY (2299161=1582-10-15), Date::ENGLAND (2361222=1752-09-14), Date::GREGORIAN (the proleptic Gregorian calendar) and Date::JULIAN (the proleptic Julian calendar) can be specified as a day of calendar reform. &#10; For example: &#10; Date.new(2001)            =&gt; #&lt;Date: 2001-01-01 ...&gt;&#10;Date.new(2001,2,3)        =&gt; #&lt;Date: 2001-02-03 ...&gt;&#10;Date.new(2001,2,-1)       =&gt; #&lt;Date: 2001-02-28 ...&gt;&#10; See also jd." ilk="function" name="new" signature="new(p1 = v1, p2 = v2, p3 = v3, p4 = v4)" />
        <scope attributes="__classmethod__" ilk="function" name="new!" />
        <scope attributes="__classmethod__" doc="Creates a date object denoting the given ordinal date. &#10; The day of year should be a negative or a positive number (as a relative day from the end of year when negative).  It should not be zero. &#10; For example: &#10; Date.ordinal(2001)        =&gt; #&lt;Date: 2001-01-01 ...&gt;&#10;Date.ordinal(2001,34)     =&gt; #&lt;Date: 2001-02-03 ...&gt;&#10;Date.ordinal(2001,-1)     =&gt; #&lt;Date: 2001-12-31 ...&gt;&#10; See also jd and new." ilk="function" name="ordinal" signature="ordinal(p1 = v1, p2 = v2, p3 = v3)" />
        <scope attributes="__classmethod__" doc="Parses the given representation of date and time, and creates a date object. &#10; If the optional second argument is true and the detected year is in the range &quot;00&quot; to &quot;99&quot;, considers the year a 2-digit form and makes it full. &#10; For example: &#10; Date.parse('2001-02-03')          =&gt; #&lt;Date: 2001-02-03 ...&gt;&#10;Date.parse('20010203')            =&gt; #&lt;Date: 2001-02-03 ...&gt;&#10;Date.parse('3rd Feb 2001')        =&gt; #&lt;Date: 2001-02-03 ...&gt;" ilk="function" name="parse" signature="parse(p1 = v1, p2 = v2, p3 = v3)" />
        <scope attributes="__classmethod__" doc="Creates a new Date object by parsing from a string according to some typical RFC 2822 formats. &#10; For example: &#10; Date.rfc2822('Sat, 3 Feb 2001 00:00:00 +0000')&#10;                                          =&gt; #&lt;Date: 2001-02-03 ...&gt;" ilk="function" name="rfc2822" signature="rfc2822(p1 = v1, p2 = v2)" />
        <scope attributes="__classmethod__" doc="Creates a new Date object by parsing from a string according to some typical RFC 3339 formats. &#10; For example: &#10; Date.rfc3339('2001-02-03T04:05:06+07:00') =&gt; #&lt;Date: 2001-02-03 ...&gt;" ilk="function" name="rfc3339" signature="rfc3339(p1 = v1, p2 = v2)" />
        <scope attributes="__classmethod__" doc="Creates a new Date object by parsing from a string according to some typical RFC 2822 formats. &#10; For example: &#10; Date.rfc2822('Sat, 3 Feb 2001 00:00:00 +0000')&#10;                                          =&gt; #&lt;Date: 2001-02-03 ...&gt;" ilk="function" name="rfc822" signature="rfc822(p1 = v1, p2 = v2)" />
        <scope attributes="__classmethod__" doc="Parses the given representation of date and time with the given template, and creates a date object. &#10; For example: &#10; Date.strptime('2001-02-03', '%Y-%m-%d')   =&gt; #&lt;Date: 2001-02-03 ...&gt;&#10;Date.strptime('03-02-2001', '%d-%m-%Y')   =&gt; #&lt;Date: 2001-02-03 ...&gt;&#10;Date.strptime('2001-034', '%Y-%j')        =&gt; #&lt;Date: 2001-02-03 ...&gt;&#10;Date.strptime('2001-W05-6', '%G-W%V-%u')  =&gt; #&lt;Date: 2001-02-03 ...&gt;&#10;Date.strptime('2001 04 6', '%Y %U %w')    =&gt; #&lt;Date: 2001-02-03 ...&gt;&#10;Date.strptime('2001 05 6', '%Y %W %u')    =&gt; #&lt;Date: 2001-02-03 ...&gt;&#10;Date.strptime('sat3feb01', '%a%d%b%y')    =&gt; #&lt;Date: 2001-02-03 ...&gt;&#10; See also strptime(3) and strftime." ilk="function" name="strptime" signature="strptime(p1 = v1, p2 = v2, p3 = v3)" />
        <scope attributes="__classmethod__" doc="For example: &#10; Date.today                =&gt; #&lt;Date: 2011-06-11 ..&gt;&#10; Creates a date object denoting the present day." ilk="function" name="today" signature="today(p1 = v1)" />
        <scope attributes="__classmethod__" doc="Returns true if the given calendar date is valid, and false if not. &#10; For example: &#10; Date.valid_date?(2001,2,3)        =&gt; true&#10;Date.valid_date?(2001,2,29)       =&gt; false&#10; See also jd and civil." ilk="function" name="valid_civil?" signature="valid_civil?(p1, p2, p3, p4 = v4)" />
        <scope attributes="__classmethod__" doc="Returns true if the given week date is valid, and false if not. &#10; For example: &#10; Date.valid_commercial?(2001,5,6)  =&gt; true&#10;Date.valid_commercial?(2001,5,8)  =&gt; false&#10; See also jd and commercial." ilk="function" name="valid_commercial?" signature="valid_commercial?(p1, p2, p3, p4 = v4)" />
        <scope attributes="__classmethod__" doc="Returns true if the given calendar date is valid, and false if not. &#10; For example: &#10; Date.valid_date?(2001,2,3)        =&gt; true&#10;Date.valid_date?(2001,2,29)       =&gt; false&#10; See also jd and civil." ilk="function" name="valid_date?" signature="valid_date?(p1, p2, p3, p4 = v4)" />
        <scope attributes="__classmethod__" doc="Just returns true.  It's nonsense, but is for symmetry. &#10; For example: &#10; Date.valid_jd?(2451944)           =&gt; true&#10; See also jd." ilk="function" name="valid_jd?" signature="valid_jd?(p1, p2 = v2)" />
        <scope attributes="__classmethod__" doc="Returns true if the given ordinal date is valid, and false if not. &#10; For example: &#10; Date.valid_ordinal?(2001,34)      =&gt; true&#10;Date.valid_ordinal?(2001,366)     =&gt; false&#10; See also jd and ordinal." ilk="function" name="valid_ordinal?" signature="valid_ordinal?(p1, p2, p3 = v3)" />
        <scope attributes="__classmethod__" doc="Creates a new Date object by parsing from a string according to some typical XML Schema formats. &#10; For example: &#10; Date.xmlschema('2001-02-03')      =&gt; #&lt;Date: 2001-02-03 ...&gt;" ilk="function" name="xmlschema" signature="xmlschema(p1 = v1, p2 = v2)" />
        <scope attributes="__classmethod__" doc="Creates a date object denoting the given calendar date. &#10; In this class, BCE years are counted astronomically.  Thus, the year before the year 1 is the year zero, and the year preceding the year zero is the year -1.  The month and the day of month should be a negative or a positive number (as a relative month/day from the end of year/month when negative).  They should not be zero. &#10; The last argument should be a Julian day number which denotes the day of calendar reform.  Date::ITALY (2299161=1582-10-15), Date::ENGLAND (2361222=1752-09-14), Date::GREGORIAN (the proleptic Gregorian calendar) and Date::JULIAN (the proleptic Julian calendar) can be specified as a day of calendar reform. &#10; For example: &#10; Date.new(2001)            =&gt; #&lt;Date: 2001-01-01 ...&gt;&#10;Date.new(2001,2,3)        =&gt; #&lt;Date: 2001-02-03 ...&gt;&#10;Date.new(2001,2,-1)       =&gt; #&lt;Date: 2001-02-28 ...&gt;&#10; See also jd." ilk="function" name="new" signature="new(p1 = v1, p2 = v2, p3 = v3, p4 = v4)" />
        <variable attributes="__const__" citdl="Array" name="ABBR_DAYNAMES" />
        <variable attributes="__const__" citdl="Array" name="ABBR_MONTHNAMES" />
        <variable attributes="__const__" citdl="Array" name="DAYNAMES" />
        <variable attributes="__const__" citdl="Fixnum" name="ENGLAND" />
        <scope ilk="namespace" name="Format">
          <variable attributes="__const__" citdl="Hash" name="ABBR_DAYS" />
