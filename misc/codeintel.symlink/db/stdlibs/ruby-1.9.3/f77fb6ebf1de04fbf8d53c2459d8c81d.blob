<scope ilk="blob" lang="Ruby" name="irb/inspector">
      <scope ilk="namespace" name="IRB">
        <scope classrefs="Object" ilk="class" name="Inspector">
          <scope attributes="__classmethod__ __ctor__" ilk="function" name="new" signature="new(inspect_proc, init_proc = nil)" />
          <scope ilk="function" name="init" signature="init()" />
          <scope ilk="function" name="inspect_value" signature="inspect_value(v)" />
        </scope>
      </scope>
    </scope>
    