        <scope classrefs="Object" ilk="class" name="Option">
          <scope attributes="__classmethod__" doc="Creates a new Socket::Option object which contains boolean as data. Actually 0 or 1 as int is used. &#10; p Socket::Option.bool(:INET, :SOCKET, :KEEPALIVE, true)&#10;=&gt; #&lt;Socket::Option: INET SOCKET KEEPALIVE 1&gt;&#10;&#10;p Socket::Option.bool(:INET, :SOCKET, :KEEPALIVE, false)&#10;=&gt; #&lt;Socket::Option: AF_INET SOCKET KEEPALIVE 0&gt;" ilk="function" name="bool" signature="bool(p1, p2, p3, p4)" />
          <scope attributes="__classmethod__" doc="Creates a new Socket::Option object which contains an int as data. &#10; The size and endian is dependent on the platform. &#10; p Socket::Option.int(:INET, :SOCKET, :KEEPALIVE, 1)&#10;=&gt; #&lt;Socket::Option: INET SOCKET KEEPALIVE 1&gt;" ilk="function" name="int" signature="int(p1, p2, p3, p4)" />
          <scope attributes="__classmethod__" doc="Creates a new Socket::Option object for SOL_SOCKET/SO_LINGER. &#10; _onoff_ should be an integer or a boolean. &#10; _secs_ should be the number of seconds. &#10; p Socket::Option.linger(true, 10)&#10;=&gt; #&lt;Socket::Option: UNSPEC SOCKET LINGER on 10sec&gt;" ilk="function" name="linger" signature="linger(p1, p2)" />
          <scope attributes="__classmethod__ __ctor__" doc="Returns a new Socket::Option object. &#10; sockopt = Socket::Option.new(:INET, :SOCKET, :KEEPALIVE, [1].pack(&quot;i&quot;))&#10;p sockopt =&gt; #&lt;Socket::Option: INET SOCKET KEEPALIVE 1&gt;" ilk="function" name="new" signature="new(p1, p2, p3, p4)" />
          <scope doc="Returns the data in _sockopt_ as an boolean value. &#10; sockopt = Socket::Option.int(:INET, :SOCKET, :KEEPALIVE, 1)&#10;p sockopt.bool =&gt; true" ilk="function" name="bool" signature="bool()" />
          <scope doc="returns the socket option data as a string. &#10; p Socket::Option.new(:INET6, :IPV6, :RECVPKTINFO, [1].pack(&quot;i!&quot;)).data&#10;=&gt; &quot;\x01\x00\x00\x00&quot;" ilk="function" name="data" signature="data()" />
          <scope doc="returns the socket family as an integer. &#10; p Socket::Option.new(:INET6, :IPV6, :RECVPKTINFO, [1].pack(&quot;i!&quot;)).family&#10;=&gt; 10" ilk="function" name="family" signature="family()" />
          <scope doc="Returns a string which shows sockopt in human-readable form. &#10; p Socket::Option.new(:INET, :SOCKET, :KEEPALIVE, [1].pack(&quot;i&quot;)).inspect&#10;=&gt; &quot;#&lt;Socket::Option: INET SOCKET KEEPALIVE 1&gt;&quot;" ilk="function" name="inspect" signature="inspect()" />
          <scope doc="Returns the data in _sockopt_ as an int. &#10; The size and endian is dependent on the platform. &#10; sockopt = Socket::Option.int(:INET, :SOCKET, :KEEPALIVE, 1)&#10;p sockopt.int =&gt; 1" ilk="function" name="int" signature="int()" />
          <scope doc="returns the socket level as an integer. &#10; p Socket::Option.new(:INET6, :IPV6, :RECVPKTINFO, [1].pack(&quot;i!&quot;)).level&#10;=&gt; 41" ilk="function" name="level" signature="level()" />
          <scope doc="Returns the linger data in _sockopt_ as a pair of boolean and integer. &#10; sockopt = Socket::Option.linger(true, 10)&#10;p sockopt.linger =&gt; [true, 10]" ilk="function" name="linger" signature="linger()" />
          <scope doc="returns the socket option name as an integer. &#10; p Socket::Option.new(:INET6, :IPV6, :RECVPKTINFO, [1].pack(&quot;i!&quot;)).optname&#10;=&gt; 2" ilk="function" name="optname" signature="optname()" />
          <scope doc="returns the socket option data as a string. &#10; p Socket::Option.new(:INET6, :IPV6, :RECVPKTINFO, [1].pack(&quot;i!&quot;)).data&#10;=&gt; &quot;\x01\x00\x00\x00&quot;" ilk="function" name="to_s" signature="to_s()" />
          <scope doc="Calls String#unpack on sockopt.data. &#10; sockopt = Socket::Option.new(:INET, :SOCKET, :KEEPALIVE, [1].pack(&quot;i&quot;))&#10;p sockopt.unpack(&quot;i&quot;)      =&gt; [1]&#10;p sockopt.data.unpack(&quot;i&quot;) =&gt; [1]" ilk="function" name="unpack" signature="unpack(p1)" />
        </scope>
        <scope classrefs="Object" ilk="class" name="UDPSource">
          <scope attributes="__classmethod__ __ctor__" doc="+remote_adress+ is an Addrinfo object. &#10; +local_adress+ is an Addrinfo object. &#10; +reply_proc+ is a Proc used to send reply back to the source." ilk="function" name="new" signature="new(remote_address, local_address, &amp;reply_proc)" />
          <scope doc="Sends the String +msg+ to the source" ilk="function" name="reply" signature="reply(msg)" />
          <scope ilk="function" name="local_address" />
          <scope ilk="function" name="remote_address" />
        </scope>
      </scope>
      <scope classrefs="StandardError" ilk="class" name="SocketError">
      </scope>
      <scope classrefs="TCPSocket" ilk="class" name="TCPServer">
        <scope attributes="__classmethod__ __ctor__" doc="Creates a new server socket bound to _port_. &#10; If _hostname_ is given, the socket is bound to it. &#10; serv = TCPServer.new(&quot;127.0.0.1&quot;, 28561)&#10;s = serv.accept&#10;s.puts Time.now&#10;s.close" ilk="function" name="new" signature="new(p1 = v1, p2)" />
        <scope doc="TCPServer.open(&quot;127.0.0.1&quot;, 14641) {|serv| s = serv.accept&#10;s.puts Time.now&#10;s.close&#10; }" ilk="function" name="accept" signature="accept()" />
        <scope doc="Accepts an incoming connection using accept(2) after O_NONBLOCK is set for the underlying file descriptor. It returns an accepted TCPSocket for the incoming connection. &#10; Example require 'socket'&#10;serv = TCPServer.new(2202)&#10;begin # emulate blocking accept&#10;  sock = serv.accept_nonblock&#10;rescue IO::WaitReadable, Errno::EINTR&#10;  IO.select([serv])&#10;  retry&#10;end&#10;# sock is an accepted socket.&#10; Refer to Socket#accept for the exceptions that may be thrown if the call to TCPServer#accept_nonblock fails. &#10; TCPServer#accept_nonblock may raise any error corresponding to accept(2) failure, including Errno::EWOULDBLOCK. &#10; If the exception is Errno::EWOULDBLOCK, Errno::AGAIN, Errno::ECONNABORTED, Errno::EPROTO, it is extended by IO::WaitReadable. So IO::WaitReadable can be used to rescue the exceptions for retrying accept_nonblock. " ilk="function" name="accept_nonblock" signature="accept_nonblock()" />
        <scope doc="Listens for connections, using the specified +int+ as the backlog. A call to _listen_ only applies if the +socket+ is of type SOCK_STREAM or SOCK_SEQPACKET. &#10; Parameter +backlog+ - the maximum length of the queue for pending connections. &#10; Example 1 require 'socket'&#10;include Socket::Constants&#10;socket = Socket.new( AF_INET, SOCK_STREAM, 0 )&#10;sockaddr = Socket.pack_sockaddr_in( 2200, 'localhost' )&#10;socket.bind( sockaddr )&#10;socket.listen( 5 )&#10; Example 2 (listening on an arbitrary port, unix-based systems only): require 'socket'&#10;include Socket::Constants&#10;socket = Socket.new( AF_INET, SOCK_STREAM, 0 )&#10;socket.listen( 1 )&#10; Unix-based Exceptions On unix based systems the above will work because a new +sockaddr+ struct is created on the address ADDR_ANY, for an arbitrary port number as handed off by the kernel. It will not work on Windows, because Windows requires that the +socket+ is bound by calling _bind_ before it can _listen_. " ilk="function" name="listen" signature="listen(p1)" />
        <scope doc="Returns a file descriptor of a accepted connection. &#10; TCPServer.open(&quot;127.0.0.1&quot;, 28561) {|serv|&#10;  fd = serv.sysaccept&#10;  s = IO.for_fd(fd)&#10;  s.puts Time.now&#10;  s.close&#10;}" ilk="function" name="sysaccept" signature="sysaccept()" />
      </scope>
      <scope classrefs="IPSocket" ilk="class" name="TCPSocket">
        <scope attributes="__classmethod__" doc="Lookups host information by _hostname_. &#10; TCPSocket.gethostbyname(&quot;localhost&quot;)&#10;=&gt; [&quot;localhost&quot;, [&quot;hal&quot;], 2, &quot;127.0.0.1&quot;]" ilk="function" name="gethostbyname" signature="gethostbyname(p1)" />
        <scope attributes="__classmethod__ __ctor__" doc="Opens a TCP connection to +remote_host+ on +remote_port+.  If +local_host+ and +local_port+ are specified, then those parameters are used on the local end to establish the connection." ilk="function" name="new" signature="new(p1, p2, p3 = v3, p4 = v4)" />
        <scope attributes="__classmethod__ __ctor__" doc="Opens a TCP connection to +remote_host+ on +remote_port+.  If +local_host+ and +local_port+ are specified, then those parameters are used on the local end to establish the connection." ilk="function" name="new" signature="new(p1, p2, p3 = v3, p4 = v4)" />
      </scope>
      <scope classrefs="IPSocket" ilk="class" name="UDPSocket">
        <scope attributes="__classmethod__ __ctor__" doc="Creates a new UDPSocket object. &#10; _address_family_ should be an integer, a string or a symbol: Socket::AF_INET, &quot;AF_INET&quot;, :INET, etc. &#10; UDPSocket.new                   =&gt; #&lt;UDPSocket:fd 3&gt;&#10;UDPSocket.new(Socket::AF_INET6) =&gt; #&lt;UDPSocket:fd 4&gt;" ilk="function" name="new" signature="new(p1 = v1)" />
        <scope doc="Binds _udpsocket_ to _host_:_port_. &#10; u1 = UDPSocket.new&#10;u1.bind(&quot;127.0.0.1&quot;, 4913)&#10;u1.send &quot;message-to-self&quot;, 0, &quot;127.0.0.1&quot;, 4913&#10;p u1.recvfrom(10) =&gt; [&quot;message-to&quot;, [&quot;AF_INET&quot;, 4913, &quot;localhost&quot;, &quot;127.0.0.1&quot;]]" ilk="function" name="bind" signature="bind(host, port)" />
        <scope doc="Connects _udpsocket_ to _host_:_port_. &#10; This makes possible to send without destination address. &#10; u1 = UDPSocket.new&#10;u1.bind(&quot;127.0.0.1&quot;, 4913)&#10;u2 = UDPSocket.new&#10;u2.connect(&quot;127.0.0.1&quot;, 4913)&#10;u2.send &quot;uuuu&quot;, 0&#10;p u1.recvfrom(10) =&gt; [&quot;uuuu&quot;, [&quot;AF_INET&quot;, 33230, &quot;localhost&quot;, &quot;127.0.0.1&quot;]]" ilk="function" name="connect" signature="connect(host, port)" />
        <scope doc="Receives up to _maxlen_ bytes from +udpsocket+ using recvfrom(2) after O_NONBLOCK is set for the underlying file descriptor. If _maxlen_ is omitted, its default value is 65536. _flags_ is zero or more of the +MSG_+ options. The first element of the results, _mesg_, is the data received. The second element, _sender_inet_addr_, is an array to represent the sender address. &#10; When recvfrom(2) returns 0, Socket#recvfrom_nonblock returns an empty string as data. It means an empty packet. &#10; Parameters +maxlen+ - the number of bytes to receive from the socket&#10;+flags+ - zero or more of the +MSG_+ options &#10; Example require 'socket'&#10;s1 = UDPSocket.new&#10;s1.bind(&quot;127.0.0.1&quot;, 0)&#10;s2 = UDPSocket.new&#10;s2.bind(&quot;127.0.0.1&quot;, 0)&#10;s2.connect(*s1.addr.values_at(3,1))&#10;s1.connect(*s2.addr.values_at(3,1))&#10;s1.send &quot;aaa&quot;, 0&#10;begin # emulate blocking recvfrom" ilk="function" name="recvfrom_nonblock" signature="recvfrom_nonblock(*args)" />
        <scope doc="Sends _mesg_ via _udpsocket_. &#10; _flags_ should be a bitwise OR of Socket::MSG_* constants. &#10; u1 = UDPSocket.new&#10;u1.bind(&quot;127.0.0.1&quot;, 4913)&#10;&#10;u2 = UDPSocket.new&#10;u2.send &quot;hi&quot;, 0, &quot;127.0.0.1&quot;, 4913&#10;&#10;mesg, addr = u1.recvfrom(10)&#10;u1.send mesg, 0, addr[3], addr[1]&#10;&#10;p u2.recv(100) =&gt; &quot;hi&quot;" ilk="function" name="send" signature="send(mesg, flags, *rest)" />
      </scope>
      <scope classrefs="UNIXSocket" ilk="class" name="UNIXServer">
        <scope attributes="__classmethod__ __ctor__" doc="Creates a new UNIX server socket bound to _path_. &#10; serv = UNIXServer.new(&quot;/tmp/sock&quot;)&#10;s = serv.accept&#10;p s.read" ilk="function" name="new" signature="new(p1)" />
        <scope doc="Accepts a new connection. It returns new UNIXSocket object. &#10; UNIXServer.open(&quot;/tmp/sock&quot;) {|serv|&#10;  UNIXSocket.open(&quot;/tmp/sock&quot;) {|c|&#10;    s = serv.accept&#10;    s.puts &quot;hi&quot;&#10;    s.close&#10;    p c.read =&gt; &quot;hi\n&quot;&#10;  }&#10;}" ilk="function" name="accept" signature="accept()" />
        <scope doc="Accepts an incoming connection using accept(2) after O_NONBLOCK is set for the underlying file descriptor. It returns an accepted UNIXSocket for the incoming connection. &#10; Example require 'socket'&#10;serv = UNIXServer.new(&quot;/tmp/sock&quot;)&#10;begin # emulate blocking accept&#10;  sock = serv.accept_nonblock&#10;rescue IO::WaitReadable, Errno::EINTR&#10;  IO.select([serv])&#10;  retry&#10;end&#10;# sock is an accepted socket.&#10; Refer to Socket#accept for the exceptions that may be thrown if the call to UNIXServer#accept_nonblock fails. &#10; UNIXServer#accept_nonblock may raise any error corresponding to accept(2) failure, including Errno::EWOULDBLOCK. &#10; If the exception is Errno::EWOULDBLOCK, Errno::AGAIN, Errno::ECONNABORTED or Errno::EPROTO, it is extended by IO::WaitReadable. So IO::WaitReadable can be used to rescue the exceptions for retrying accept_nonblock. " ilk="function" name="accept_nonblock" signature="accept_nonblock()" />
        <scope doc="Listens for connections, using the specified +int+ as the backlog. A call to _listen_ only applies if the +socket+ is of type SOCK_STREAM or SOCK_SEQPACKET. &#10; Parameter +backlog+ - the maximum length of the queue for pending connections. &#10; Example 1 require 'socket'&#10;include Socket::Constants&#10;socket = Socket.new( AF_INET, SOCK_STREAM, 0 )&#10;sockaddr = Socket.pack_sockaddr_in( 2200, 'localhost' )&#10;socket.bind( sockaddr )&#10;socket.listen( 5 )&#10; Example 2 (listening on an arbitrary port, unix-based systems only): require 'socket'&#10;include Socket::Constants&#10;socket = Socket.new( AF_INET, SOCK_STREAM, 0 )&#10;socket.listen( 1 )&#10; Unix-based Exceptions On unix based systems the above will work because a new +sockaddr+ struct is created on the address ADDR_ANY, for an arbitrary port number as handed off by the kernel. It will not work on Windows, because Windows requires that the +socket+ is bound by calling _bind_ before it can _listen_. " ilk="function" name="listen" signature="listen(p1)" />
        <scope doc="Accepts a new connection. It returns the new file descriptor which is an integer. &#10; UNIXServer.open(&quot;/tmp/sock&quot;) {|serv|&#10;  UNIXSocket.open(&quot;/tmp/sock&quot;) {|c|&#10;    fd = serv.sysaccept&#10;    s = IO.new(fd)&#10;    s.puts &quot;hi&quot;&#10;    s.close&#10;    p c.read =&gt; &quot;hi\n&quot;&#10;  }&#10;}" ilk="function" name="sysaccept" signature="sysaccept()" />
      </scope>
      <scope classrefs="BasicSocket" ilk="class" name="UNIXSocket">
        <scope attributes="__classmethod__ __ctor__" doc="Creates a new UNIX client socket connected to _path_. &#10; s = UNIXSocket.new(&quot;/tmp/sock&quot;)&#10;s.send &quot;hello&quot;, 0" ilk="function" name="new" signature="new(p1)" />
        <scope attributes="__classmethod__" doc="Creates a pair of sockets connected each other. &#10; _socktype_ should be a socket type such as: :STREAM, :DGRAM, :RAW, etc. &#10; _protocol_ should be a protocol defined in the domain. 0 is default protocol for the domain. &#10; s1, s2 = UNIXSocket.pair&#10;s1.send &quot;a&quot;, 0&#10;s1.send &quot;b&quot;, 0&#10;p s2.recv(10) =&gt; &quot;ab&quot;" ilk="function" name="pair" signature="pair(p1 = v1, p2 = v2)" />
        <scope attributes="__classmethod__" doc="Creates a pair of sockets connected each other. &#10; _socktype_ should be a socket type such as: :STREAM, :DGRAM, :RAW, etc. &#10; _protocol_ should be a protocol defined in the domain. 0 is default protocol for the domain. &#10; s1, s2 = UNIXSocket.pair&#10;s1.send &quot;a&quot;, 0&#10;s1.send &quot;b&quot;, 0&#10;p s2.recv(10) =&gt; &quot;ab&quot;" ilk="function" name="socketpair" signature="socketpair(p1 = v1, p2 = v2)" />
        <scope doc="Returns the local address as an array which contains address_family and unix_path. &#10; Example serv = UNIXServer.new(&quot;/tmp/sock&quot;)&#10;p serv.addr =&gt; [&quot;AF_UNIX&quot;, &quot;/tmp/sock&quot;]" ilk="function" name="addr" signature="addr()" />
        <scope doc="Returns the path of the local address of unixsocket. &#10; s = UNIXServer.new(&quot;/tmp/sock&quot;)&#10;p s.path =&gt; &quot;/tmp/sock&quot;" ilk="function" name="path" signature="path()" />
        <scope doc="Returns the remote address as an array which contains address_family and unix_path. &#10; Example serv = UNIXServer.new(&quot;/tmp/sock&quot;)&#10;c = UNIXSocket.new(&quot;/tmp/sock&quot;)&#10;p c.peeraddr =&gt; [&quot;AF_UNIX&quot;, &quot;/tmp/sock&quot;]" ilk="function" name="peeraddr" signature="peeraddr()" />
        <scope doc="UNIXServer.open(&quot;/tmp/sock&quot;) {|serv| UNIXSocket.open(&quot;/tmp/sock&quot;) {|c|&#10;  s = serv.accept&#10;&#10;  c.send_io STDOUT&#10;  stdout = s.recv_io&#10;&#10;  p STDOUT.fileno =&gt; 1&#10;  p stdout.fileno =&gt; 7&#10;&#10;  stdout.puts &quot;hello&quot; # outputs &quot;hello\n&quot; to standard output.&#10;}&#10; }" ilk="function" name="recv_io" signature="recv_io(p1 = v1, p2 = v2)" />
        <scope doc="Receives a message via _unixsocket_. &#10; _maxlen_ is the maximum number of bytes to receive. &#10; _flags_ should be a bitwise OR of Socket::MSG_* constants. &#10; s1 = Socket.new(:UNIX, :DGRAM, 0)&#10;s1_ai = Addrinfo.unix(&quot;/tmp/sock1&quot;)&#10;s1.bind(s1_ai)&#10;&#10;s2 = Socket.new(:UNIX, :DGRAM, 0)&#10;s2_ai = Addrinfo.unix(&quot;/tmp/sock2&quot;)&#10;s2.bind(s2_ai)&#10;s3 = UNIXSocket.for_fd(s2.fileno)&#10;&#10;s1.send &quot;a&quot;, 0, s2_ai&#10;p s3.recvfrom(10) =&gt; [&quot;a&quot;, [&quot;AF_UNIX&quot;, &quot;/tmp/sock1&quot;]]" ilk="function" name="recvfrom" signature="recvfrom(*args)" />
        <scope doc="Sends _io_ as file descriptor passing. &#10; s1, s2 = UNIXSocket.pair&#10;&#10;s1.send_io STDOUT&#10;stdout = s2.recv_io&#10;&#10;p STDOUT.fileno =&gt; 1&#10;p stdout.fileno =&gt; 6&#10;&#10;stdout.puts &quot;hello&quot; # outputs &quot;hello\n&quot; to standard output." ilk="function" name="send_io" signature="send_io(p1)" />
      </scope>
    </scope>
    