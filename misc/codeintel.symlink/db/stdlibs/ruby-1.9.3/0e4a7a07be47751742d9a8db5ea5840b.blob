<scope ilk="blob" lang="Ruby" name="rdoc/normal_module">
      <scope ilk="namespace" name="RDoc">
        <scope classrefs="RDoc::ClassModule" ilk="class" name="NormalModule">
          <scope doc="The definition of this module, module MyModuleName" ilk="function" name="definition" signature="definition()" />
          <scope doc="This is a module, returns true" ilk="function" name="module?" signature="module?()" />
          <scope doc="Modules don't have one, raises NoMethodError" ilk="function" name="superclass" signature="superclass()" />
        </scope>
      </scope>
    </scope>
    