<scope ilk="blob" lang="Ruby" name="rdoc/markup/paragraph">
      <scope ilk="namespace" name="RDoc">
        <scope ilk="namespace" name="Markup">
          <scope classrefs="RDoc::Markup::Raw" ilk="class" name="Paragraph">
            <scope doc="Calls #accept_paragraph on +visitor+" ilk="function" name="accept" signature="accept(visitor)" />
          </scope>
        </scope>
      </scope>
    </scope>
    