<scope ilk="blob" lang="Ruby" name="rdoc/single_class">
      <scope ilk="namespace" name="RDoc">
        <scope classrefs="RDoc::ClassModule" ilk="class" name="SingleClass">
          <scope doc="Adds the superclass to the included modules." ilk="function" name="ancestors" signature="ancestors()" />
          <scope doc="The definition of this singleton class, class &lt;&lt; MyClassName" ilk="function" name="definition" signature="definition()" />
        </scope>
      </scope>
    </scope>
    