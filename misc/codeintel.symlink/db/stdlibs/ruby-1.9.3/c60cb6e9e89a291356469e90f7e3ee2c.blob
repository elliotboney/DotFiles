<scope ilk="blob" lang="Ruby" name="rake/invocation_exception_mixin">
      <scope ilk="namespace" name="Rake">
        <scope ilk="namespace" name="InvocationExceptionMixin">
          <scope doc="Return the invocation chain (list of Rake tasks) that were in effect when this exception was detected by rake.  May be null if no tasks were active." ilk="function" name="chain" signature="chain()" />
          <scope doc="Set the invocation chain in effect when this exception was detected." ilk="function" name="chain=" signature="chain=(value)" />
        </scope>
      </scope>
    </scope>
    